{
  "name": "@almadar/shell-hono-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@almadar/server-hono": ">=0.1.0",
    "@almadar/evaluator": ">=2.9.2",
    "@almadar/core": ">=5.8.0",
    "@almadar/integrations": ">=2.6.1",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.4.0",
    "dotenv": "^16.4.7",
    "firebase-admin": "^12.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.8.0",
    "@typescript-eslint/parser": "8.56.0",
    "@types/bun": "^1.1.0",
    "@types/node": "^20.17.19",
    "eslint": "10.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
