{
  "name": "@almadar/shell",
  "version": "2.16.4",
  "private": false,
  "description": "Minimal full-stack shell template for Almadar applications",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "npx concurrently -n client,server -c blue,green \"pnpm --filter @almadar/shell-client dev\" \"pnpm --filter @almadar/shell-server dev\"",
    "build": "pnpm run -r build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.8.17"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "^3.0.1",
      "esbuild": "^0.25.0",
      "flatted": "^3.4.1",
      "protobufjs": ">=7.5.8 <8",
      "node-forge": "^1.4.0",
      "fast-xml-parser": "^5.7.0",
      "fast-xml-builder": ">=1.1.7",
      "express>path-to-regexp": "0.1.13",
      "qs": "^6.15.2",
      "lodash-es": "^4.18.0"
    }
  },
  "files": [
    "packages",
    "locales",
    "pnpm-workspace.yaml",
    "turbo.json",
    "pnpm-lock.yaml",
    ".env.example",
    ".gitignore"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-shell.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
