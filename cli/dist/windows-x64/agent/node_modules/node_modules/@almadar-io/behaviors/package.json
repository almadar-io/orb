{
  "name": "@almadar-io/behaviors",
  "version": "0.16.3",
  "description": "Almadar standard behaviors (app, game, marketing, probes, service, variations) — private companion to @almadar/std (core, agent).",
  "type": "module",
  "main": "./dist/behaviors/index.js",
  "module": "./dist/behaviors/index.js",
  "types": "./dist/behaviors/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/behaviors/index.js",
      "types": "./dist/behaviors/index.d.ts"
    },
    "./package.json": "./package.json",
    "./behaviors/*": {
      "import": "./dist/behaviors/*.js",
      "types": "./dist/behaviors/*.d.ts"
    },
    "./behaviors/functions/*": {
      "import": "./dist/behaviors/functions/*.js",
      "types": "./dist/behaviors/functions/*.d.ts"
    },
    "./behaviors/functions": {
      "import": "./dist/behaviors/functions/index.js",
      "types": "./dist/behaviors/functions/index.d.ts"
    },
    "./factory-runtime": {
      "import": "./dist/factory-runtime/index.js",
      "types": "./dist/factory-runtime/index.d.ts"
    }
  },
  "files": [
    "dist",
    "behaviors/registry",
    "behaviors/behaviors-registry.json"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@almadar/core": ">=9.6.1"
  },
  "devDependencies": {
    "@almadar/llm": ">=2.14.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/behaviors.git"
  },
  "license": "BSL-1.1",
  "keywords": [
    "almadar",
    "behaviors",
    "lolo",
    "orb"
  ],
  "scripts": {
    "build:embeddings": "tsx scripts/build-embeddings.ts",
    "build:knob-embeddings": "tsx scripts/build-knob-embeddings.ts",
    "build": "pnpm run build:embeddings && pnpm run build:knob-embeddings && tsup",
    "build:watch": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  }
}