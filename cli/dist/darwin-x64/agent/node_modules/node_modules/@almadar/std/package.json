{
  "name": "@almadar/std",
  "version": "16.25.0",
  "description": "Standard library operators for Almadar (math, string, array, etc.)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json",
    "./modules/*": {
      "import": "./dist/modules/*.js",
      "types": "./dist/modules/*.d.ts"
    },
    "./behaviors/*": {
      "import": "./dist/behaviors/*.js",
      "types": "./dist/behaviors/*.d.ts"
    },
    "./behaviors/functions/*": {
      "import": "./dist/behaviors/functions/*.js",
      "types": "./dist/behaviors/functions/*.d.ts"
    },
    "./registry": {
      "import": "./dist/registry.js",
      "types": "./dist/registry.d.ts"
    },
    "./behaviors/functions": {
      "import": "./dist/behaviors/functions/index.js",
      "types": "./dist/behaviors/functions/index.d.ts"
    },
    "./factory-runtime": {
      "import": "./dist/factory-runtime/index.js",
      "types": "./dist/factory-runtime/index.d.ts"
    }
  },
  "files": [
    "dist",
    "behaviors/registry",
    "canonical-operators.json"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@almadar/core": ">=9.6.1"
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.3.0",
    "@almadar/llm": ">=2.14.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "10.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-std.git",
    "directory": "docs/packages/std"
  },
  "license": "BSL-1.1",
  "keywords": [
    "almadar",
    "std",
    "standard-library",
    "operators"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme",
  "scripts": {
    "build:embeddings": "tsx scripts/build-embeddings.ts",
    "build:knob-embeddings": "tsx scripts/build-knob-embeddings.ts",
    "build": "pnpm run build:embeddings && pnpm run build:knob-embeddings && tsup",
    "build:watch": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  }
}