{
  "name": "std-app-layout",
  "description": "std-app-layout — dashboard-layout chrome (sidebar nav + top bar with search + topBarActions + notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data, and the consumer can add domain icons (cart / profile / help) via topBarActions. Bind once per orbital — the consumer rebinds linkedEntity via `XAppLayout = AppShell.traits.AppLayout -> XEntity` so multiple orbitals in one file each get their own chrome without colliding on a shared atom entity.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-app-layout",
    "version": "1.4.1",
    "description": "std-app-layout — dashboard-layout chrome (sidebar nav + top bar with search + topBarActions + notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data, and the consumer can add domain icons (cart / profile / help) via topBarActions. Bind once per orbital — the consumer rebinds linkedEntity via `XAppLayout = AppShell.traits.AppLayout -> XEntity` so multiple orbitals in one file each get their own chrome without colliding on a shared atom entity.",
    "orbitals": [
      {
        "name": "AppLayoutOrbital",
        "entity": {
          "name": "AppLayoutData",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "AppLayout",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "AppLayoutData",
            "emits": [
              {
                "event": "SEARCH",
                "description": "Indicates a search query has been submitted.",
                "synonyms": "query, find, lookup",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "NOTIFY_CLICK",
                "description": "A user interacted with a notification.",
                "synonyms": "click, tap, select",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "AppLayoutStateLoaded",
                "description": "Signals the layout has finished loading and is ready.",
                "synonyms": "ready, initialized, loaded",
                "tier": "domain",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AppLayoutData]"
                  }
                ]
              },
              {
                "event": "AppLayoutStateLoadFailed",
                "description": "Indicates failure to load the layout state.",
                "synonyms": "error, failure, load failed",
                "tier": "internal",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "composing",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "AppLayoutStateLoaded",
                  "name": "App layout state loaded",
                  "description": "Signals the layout has finished loading and is ready.",
                  "synonyms": "ready, initialized, loaded",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[AppLayoutData]"
                    }
                  ]
                },
                {
                  "key": "AppLayoutStateLoadFailed",
                  "name": "App layout state load failed",
                  "description": "Indicates failure to load the layout state.",
                  "synonyms": "error, failure, load failed",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SEARCH",
                  "name": "Search",
                  "description": "Indicates a search query has been submitted.",
                  "synonyms": "query, find, lookup",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "value",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "NOTIFY_CLICK",
                  "name": "Notify Click",
                  "description": "A user interacted with a notification.",
                  "synonyms": "click, tap, select",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "composing",
                  "to": "composing",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "AppLayoutData",
                      {
                        "emit": {
                          "success": "AppLayoutStateLoaded",
                          "failure": "AppLayoutStateLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "notificationClickEvent": "NOTIFY_CLICK",
                        "navItems": [],
                        "searchEvent": "SEARCH",
                        "children": [
                          {
                            "gap": "lg",
                            "direction": "vertical",
                            "type": "stack",
                            "className": "max-w-5xl mx-auto w-full",
                            "children": [
                              "@config.contentTrait"
                            ]
                          }
                        ],
                        "layoutMode": "sidebar",
                        "appName": "App",
                        "type": "dashboard-layout",
                        "notifications": [],
                        "topBarActions": []
                      }
                    ]
                  ]
                },
                {
                  "from": "composing",
                  "to": "composing",
                  "event": "AppLayoutStateLoaded"
                },
                {
                  "from": "composing",
                  "to": "composing",
                  "event": "AppLayoutStateLoadFailed"
                },
                {
                  "from": "composing",
                  "to": "composing",
                  "event": "SEARCH"
                },
                {
                  "from": "composing",
                  "to": "composing",
                  "event": "NOTIFY_CLICK"
                }
              ]
            },
            "config": {
              "notifications": {
                "type": "[NotificationSpec]",
                "default": [],
                "label": "What notifications should appear?",
                "description": "Items shown in the notifications dropdown.",
                "synonyms": "alerts, messages, notices, notification items, bell items",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": false
                    },
                    "message": {
                      "name": "message",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "appName": {
                "type": "string",
                "default": "App",
                "label": "What should this app be called?",
                "description": "Name shown in the top-left of the chrome header.",
                "synonyms": "app title, product name, brand name, application name, site name",
                "tier": "presentation"
              },
              "topBarActions": {
                "type": "[ItemAction]",
                "default": [],
                "label": "What shortcuts go in the top bar?",
                "description": "Icon buttons shown on the right side of the top bar (e.g. cart, help, profile).",
                "synonyms": "toolbar buttons, header actions, shortcut icons, quick actions",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": true
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "navItems": {
                "type": "[NavItem]",
                "default": [],
                "label": "Which sections appear in the sidebar?",
                "description": "Top-level navigation links shown on the left rail.",
                "synonyms": "nav links, menu items, sidebar sections, navigation entries, pages",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "badge": {
                      "name": "badge",
                      "type": "string",
                      "required": false
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "href": {
                      "name": "href",
                      "type": "string",
                      "required": true
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "searchEvent": {
                "type": "string",
                "default": "SEARCH",
                "label": "Search event",
                "description": "Event emitted when the user runs a global search",
                "tier": "internal"
              },
              "detailSlot": {
                "type": "slot",
                "default": "modal",
                "label": "Detail slot",
                "description": "Slot where detail/edit views render",
                "tier": "internal"
              },
              "contentTrait": {
                "type": "trait",
                "label": "Content trait",
                "description": "Trait rendered inside the app layout content area",
                "tier": "internal"
              },
              "layoutPattern": {
                "type": "pattern",
                "default": "dashboard-layout",
                "label": "Layout pattern",
                "description": "UI pattern used to render the application chrome",
                "tier": "internal"
              },
              "layoutMode": {
                "type": "string",
                "default": "sidebar",
                "label": "Where should navigation be placed?",
                "description": "sidebar = left rail; topnav = top bar; bottomnav = mobile tab bar; minimal = no nav.",
                "synonyms": "nav position, navigation style, menu placement, layout style",
                "tier": "presentation",
                "values": [
                  "sidebar",
                  "topnav",
                  "bottomnav",
                  "minimal"
                ]
              },
              "notificationClickEvent": {
                "type": "string",
                "default": "NOTIFY_CLICK",
                "label": "Notification click event",
                "description": "Event emitted when the user picks a notification",
                "tier": "internal"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "AppLayoutPage",
            "path": "/app-layout",
            "traits": [
              {
                "ref": "AppLayout"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "AppLayoutOrbital": [
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "notificationClickEvent",
            "knob": "notificationClickEvent"
          },
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "navItems",
            "knob": "navItems"
          },
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "searchEvent",
            "knob": "searchEvent"
          },
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "layoutMode",
            "knob": "layoutMode"
          },
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "appName",
            "knob": "appName"
          },
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "type",
            "knob": "layoutPattern"
          },
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "notifications",
            "knob": "notifications"
          },
          {
            "trait": "AppLayout",
            "patternPath": "root",
            "prop": "topBarActions",
            "knob": "topBarActions"
          }
        ]
      }
    }
  },
