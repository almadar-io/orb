                                        "-",
                                        "x1",
                                        "@b.radius"
                                      ],
                                      0
                                    ]
                                  ],
                                  [
                                    "hitB",
                                    [
                                      ">",
                                      [
                                        "+",
                                        "y1",
                                        "@b.radius"
                                      ],
