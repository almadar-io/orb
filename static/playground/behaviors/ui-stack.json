                        "reverse": false,
                        "tabIndex": 0,
                        "direction": "vertical",
                        "responsive": false,
                        "type": "stack",
                        "flex": false,
                        "gap": "md",
                        "actionPayload": {},
                        "justify": "start",
                        "action": "ACTION",
                        "align": "stretch",
                        "role": "Role",
                        "style": {},
                        "className": "",
                        "wrap": false
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "actionPayload": {
                "type": "json",
                "default": {},
                "label": "Action Payload",
                "description": "Payload to include with the action event",
                "tier": "presentation"
              },
              "align": {
                "type": "string",
                "default": "stretch",
                "label": "Align",
                "description": "Align items on the cross axis",
                "tier": "presentation",
                "values": [
                  "start",
                  "center",
                  "end",
                  "stretch",
                  "baseline"
                ]
              },
              "flex": {
                "type": "boolean",
                "default": false,
                "label": "Flex",
                "description": "Fill available space (flex: 1)",
                "tier": "presentation"
              },
              "gap": {
                "type": "string",
                "default": "md",
                "label": "Gap",
                "description": "Gap between children",
                "tier": "presentation",
                "values": [
                  "none",
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "2xl"
                ]
              },
              "responsive": {
                "type": "boolean",
                "default": false,
                "label": "Responsive",
                "description": "When true, horizontal stacks flip to vertical below the md breakpoint (768px)",
                "tier": "presentation"
              },
              "justify": {
                "type": "string",
                "default": "start",
                "label": "Justify",
                "description": "Justify items on the main axis",
                "tier": "presentation",
                "values": [
                  "start",
                  "center",
                  "end",
                  "between",
                  "around",
                  "evenly"
                ]
              },
              "role": {
                "type": "string",
                "default": "Role",
                "label": "Role",
                "description": "Role for accessibility",
                "tier": "presentation"
              },
              "tabIndex": {
                "type": "number",
                "default": 0,
                "label": "Tab Index",
                "description": "Tab index for focus management",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Custom class name",
                "tier": "presentation"
              },
              "style": {
                "type": "json",
                "default": {},
                "label": "Style",
                "description": "Inline styles",
                "tier": "presentation"
              },
              "wrap": {
                "type": "boolean",
                "default": false,
                "label": "Wrap",
                "description": "Allow items to wrap",
                "tier": "presentation"
              },
              "reverse": {
                "type": "boolean",
                "default": false,
                "label": "Reverse",
                "description": "Reverse the order of children",
                "tier": "presentation"
              },
              "direction": {
                "type": "string",
                "default": "vertical",
                "label": "Direction",
                "description": "Stack direction",
                "tier": "presentation",
                "values": [
                  "horizontal",
                  "vertical"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
