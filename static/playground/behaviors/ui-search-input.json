    "orbitals": [
      {
        "name": "SearchInputOrbital",
        "entity": {
          "name": "SearchInputItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "value",
              "type": "string",
              "default": "Value"
            }
          ]
        },
        "traits": [
          {
            "name": "SearchInputRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "value"
              ]
            },
            "category": "interaction",
            "linkedEntity": "SearchInputItem",
            "emits": [
              {
                "event": "SEARCH",
                "description": "Callback when search value changes",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "SEARCH",
                  "name": "Search",
                  "description": "Callback when search value changes",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "value",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "SearchInputItem",
                      {}
                    ],
                    [
                      "set",
                      "@entity.value",
                      "Value"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "isLoading": false,
                        "type": "search-input",
                        "clearable": true,
                        "onSearch": "SEARCH",
                        "event": "Event",
                        "debounceMs": 300,
                        "className": "",
                        "placeholder": "Placeholder",
                        "entity": "SearchInputItem",
                        "query": "Query",
                        "value": "@entity.value"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "SEARCH",
                  "effects": [
                    [
                      "set",
                      "@entity.value",
                      "@payload.value"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "value": "@entity.value",
                        "entity": "SearchInputItem",
                        "placeholder": "Placeholder",
                        "debounceMs": 300,
                        "isLoading": false,
                        "query": "Query",
                        "event": "Event",
                        "onSearch": "SEARCH",
                        "className": "",
                        "clearable": true,
                        "type": "search-input"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "value": {
                "type": "string",
                "default": "Value",
                "label": "Value",
                "description": "Search value (controlled mode)",
                "tier": "presentation"
              },
              "clearable": {
                "type": "boolean",
                "default": true,
                "label": "Clearable",
                "description": "Show clear button",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Show loading state",
                "tier": "presentation"
              },
              "placeholder": {
                "type": "string",
                "default": "Placeholder",
                "label": "Placeholder",
                "description": "Placeholder text",
                "tier": "presentation"
              },
              "query": {
                "type": "string",
                "default": "Query",
                "label": "Query",
                "description": "Query singleton binding for state management. When provided, syncs search state with the query singleton. Example: '@TaskQuery'",
                "tier": "presentation"
              },
              "event": {
                "type": "string",
                "default": "Event",
                "label": "Event",
                "description": "Event name to dispatch on search (schema metadata, wired by trait) This is metadata used by the trait generator, not by the component.",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "debounceMs": {
                "type": "number",
                "default": 300,
                "label": "Debounce Ms",
                "description": "Debounce delay in milliseconds",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SearchInputPage",
            "path": "/search-input",
