{
  "name": "std-selection",
  "description": "std-selection as a Function",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-selection",
    "version": "1.0.0",
    "description": "std-selection as a Function",
    "orbitals": [
      {
        "name": "SelectableItemOrbital",
        "entity": {
          "name": "SelectableItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "name",
              "type": "string",
              "required": true,
              "description": "The item's display text or identifier.",
              "synonyms": "label, title, identifier"
            },
            {
              "name": "description",
              "type": "string",
              "description": "A textual explanation of the item.",
              "synonyms": "details, explanation, notes"
            },
            {
              "name": "status",
              "type": "string",
              "default": "active",
              "values": [
                "active",
                "inactive",
                "pending"
              ],
              "description": "Indicates the current operational state of the item.",
              "synonyms": "state, condition, flag"
            },
            {
              "name": "createdAt",
              "type": "string"
            }
          ]
        },
        "traits": [
          {
            "name": "SelectableItemSelection",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "SelectableItem",
            "emits": [
              {
                "event": "SelectableItemLoaded",
                "description": "Indicates a selectable item has been successfully loaded.",
                "synonyms": "loaded, initialized, ready",
                "tier": "domain",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[SelectableItem]"
                  }
                ]
              },
              {
                "event": "SelectableItemLoadFailed",
                "description": "Indicates a selectable item failed to load.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "idle"
                },
                {
                  "name": "selecting"
                },
                {
                  "name": "selected"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "SelectableItemLoaded",
                  "name": "SelectableItem loaded",
                  "description": "Indicates a selectable item has been successfully loaded.",
                  "synonyms": "loaded, initialized, ready",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[SelectableItem]"
                    }
                  ]
                },
                {
                  "key": "SelectableItemLoadFailed",
                  "name": "SelectableItem load failed",
                  "description": "Indicates a selectable item failed to load.",
                  "synonyms": "error, failure, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SELECT",
                  "name": "Select",
                  "description": "Indicates an item has been chosen.",
                  "synonyms": "chosen, picked, highlighted",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CONFIRM_SELECTION",
                  "name": "Confirm Selection",
                  "description": "Indicates a selection has been finalized.",
                  "synonyms": "accept, finalize, submit, choose",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CLEAR",
                  "name": "Clear"
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "SelectableItem",
                      {
                        "emit": {
                          "success": "SelectableItemLoaded",
                          "failure": "SelectableItemLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "align": "center",
                        "direction": "vertical",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Loading…",
                            "type": "typography",
                            "variant": "caption",
                            "color": "muted"
                          }
                        ],
                        "gap": "md",
                        "type": "stack",
                        "className": "py-12"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "idle",
                  "event": "SelectableItemLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "gap": "lg",
                        "type": "stack",
                        "children": [
                          {
                            "children": [
                              {
                                "name": "check-square",
                                "type": "icon"
                              },
                              {
                                "content": "SelectableItems",
                                "type": "typography",
                                "variant": "h2"
                              }
                            ],
                            "type": "stack",
                            "align": "center",
                            "direction": "horizontal",
                            "gap": "sm"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "content": "Choose a selectableitem to continue.",
                            "color": "muted",
                            "variant": "caption",
                            "type": "typography"
                          },
                          {
                            "fields": [],
                            "itemActions": [
                              {
                                "event": "SELECT",
                                "label": "Select",
                                "icon": "check"
                              }
                            ],
                            "look": "dense",
                            "renderItem": [
                              "fn",
                              "item",
                              {
                                "align": "center",
                                "children": [
                                  {
                                    "type": "checkbox",
                                    "label": "@item.name"
                                  }
                                ],
                                "direction": "horizontal",
                                "gap": "sm",
                                "type": "stack"
                              }
                            ],
                            "entity": "@payload.data",
                            "type": "data-grid",
                            "className": "transition-shadow hover:shadow-md cursor-pointer"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "SelectableItemLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "align": "center",
                        "children": [
                          {
                            "color": "error",
                            "type": "icon",
                            "name": "alert-triangle"
                          },
                          {
                            "content": "Failed to load",
                            "type": "typography",
                            "variant": "h3"
                          },
                          {
                            "content": "@payload.error",
                            "variant": "body",
                            "type": "typography",
                            "color": "muted"
                          },
                          {
                            "action": "INIT",
                            "type": "button",
                            "label": "Retry",
                            "variant": "primary",
                            "icon": "rotate-ccw"
                          }
                        ],
                        "type": "stack",
                        "direction": "vertical",
                        "className": "py-12"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "selecting",
                  "event": "SELECT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "align": "center",
                            "justify": "between",
                            "children": [
                              {
                                "align": "center",
                                "gap": "md",
                                "type": "stack",
                                "children": [
                                  {
                                    "type": "icon",
                                    "name": "check-square"
                                  },
                                  {
                                    "type": "typography",
                                    "variant": "h2",
                                    "content": "SelectableItems"
                                  }
                                ],
                                "direction": "horizontal"
                              },
                              {
                                "type": "stack",
                                "direction": "horizontal",
                                "children": [
                                  {
                                    "label": "Selecting",
                                    "type": "badge"
                                  },
                                  {
                                    "action": "CLEAR",
                                    "type": "button",
                                    "variant": "ghost",
                                    "label": "Clear",
                                    "icon": "x"
                                  }
                                ],
                                "gap": "sm",
                                "align": "center"
                              }
                            ],
                            "gap": "md",
                            "type": "stack",
                            "direction": "horizontal"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "type": "alert",
                            "message": "@payload.id",
                            "variant": "info"
                          },
                          {
                            "direction": "horizontal",
                            "children": [
                              {
                                "type": "button",
                                "icon": "check",
                                "action": "CONFIRM_SELECTION",
                                "variant": "primary",
                                "label": "Confirm",
                                "actionPayload": {
                                  "id": "@payload.id"
                                }
                              }
                            ],
                            "type": "stack",
                            "gap": "sm"
                          }
                        ],
                        "gap": "lg"
                      }
                    ]
                  ]
                },
                {
                  "from": "selecting",
                  "to": "selected",
                  "event": "CONFIRM_SELECTION",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "children": [
                          {
                            "direction": "horizontal",
                            "justify": "between",
                            "type": "stack",
                            "align": "center",
                            "children": [
                              {
                                "align": "center",
                                "direction": "horizontal",
                                "children": [
                                  {
                                    "name": "check-circle",
                                    "type": "icon"
                                  },
                                  {
                                    "content": "Selection Confirmed",
                                    "type": "typography",
                                    "variant": "h2"
                                  }
                                ],
                                "gap": "md",
                                "type": "stack"
                              },
                              {
                                "type": "badge",
                                "label": "Confirmed"
                              }
                            ],
                            "gap": "md"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "type": "alert",
                            "variant": "success",
                            "message": "Selection confirmed successfully."
                          },
                          {
                            "children": [
                              {
                                "content": "Selected ID:",
                                "type": "typography",
                                "variant": "caption"
                              },
                              {
                                "content": "@payload.id",
                                "variant": "body",
                                "type": "typography"
                              }
                            ],
                            "type": "stack",
                            "align": "center",
                            "direction": "horizontal",
                            "gap": "md"
                          },
                          {
                            "icon": "rotate-ccw",
                            "action": "CLEAR",
                            "label": "Clear Selection",
                            "type": "button",
                            "variant": "ghost"
                          }
                        ],
                        "gap": "lg",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "selecting",
                  "to": "loading",
                  "event": "CLEAR",
                  "effects": [
                    [
                      "fetch",
                      "SelectableItem",
                      {
                        "emit": {
                          "failure": "SelectableItemLoadFailed",
                          "success": "SelectableItemLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "selected",
                  "to": "loading",
                  "event": "CLEAR",
                  "effects": [
                    [
                      "fetch",
                      "SelectableItem",
                      {
                        "emit": {
                          "success": "SelectableItemLoaded",
                          "failure": "SelectableItemLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "SelectableItem",
                      {
                        "emit": {
                          "failure": "SelectableItemLoadFailed",
                          "success": "SelectableItemLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "tableLook": {
                "type": "string",
                "default": "dense",
                "label": "Table look",
                "description": "Layer 2 visual treatment for the data table rendered by this atom.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              }
            },
            "scope": "collection"
          }
        ],
        "pages": [
          {
            "name": "SelectableItemSelectionPage",
            "path": "/selectableitems/selection",
            "traits": [
              {
                "ref": "SelectableItemSelection"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "SelectableItemOrbital": [
          {
            "trait": "SelectableItemSelection",
            "patternPath": "root.children.3",
            "prop": "look",
            "knob": "tableLook"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}