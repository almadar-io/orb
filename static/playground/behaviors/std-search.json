{
  "name": "std-search",
  "description": "std-search — single primitive: search-input. Owns a SearchResult runtime entity; SEARCH persists @payload.searchTerm (matching SearchInput's emit shape) so cross-trait listeners can route it into data atoms (Browse REFETCH_QUERY).",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-search",
    "version": "1.0.0",
    "description": "std-search — single primitive: search-input. Owns a SearchResult runtime entity; SEARCH persists @payload.searchTerm (matching SearchInput's emit shape) so cross-trait listeners can route it into data atoms (Browse REFETCH_QUERY).",
    "orbitals": [
      {
        "name": "SearchResultOrbital",
        "entity": {
          "name": "SearchResult",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "searchTerm",
              "type": "string",
              "description": "The text entered by the user in the search field.",
              "synonyms": "query, search term, input, text"
            }
          ]
        },
        "traits": [
          {
            "name": "SearchResultSearch",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "searchTerm"
              ]
            },
            "category": "interaction",
            "linkedEntity": "SearchResult",
            "emits": [
              {
                "event": "SEARCH",
                "description": "Initiates a search operation based on the input term.",
                "synonyms": "query, lookup, find",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "SEARCH",
                  "name": "Search",
                  "description": "Initiates a search operation based on the input term.",
                  "synonyms": "query, lookup, find",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "searchTerm",
                      "type": "string",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "search-input",
                        "placeholder": "Search…",
                        "event": "SEARCH"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "SEARCH",
                  "effects": [
                    [
                      "set",
                      "@entity.searchTerm",
                      "@payload.searchTerm"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "placeholder": "Search…",
                        "type": "search-input",
                        "event": "SEARCH"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "event": {
                "type": "string",
                "default": "SEARCH",
                "label": "Search event",
                "description": "Event emitted when the user submits a query",
                "tier": "internal"
              },
              "placeholder": {
                "type": "string",
                "default": "Search…",
                "label": "Placeholder text",
                "description": "Hint text shown inside the empty search input",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SearchResultSearchPage",
            "path": "/searchresults/search",
            "traits": [
              {
                "ref": "SearchResultSearch"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
