            "prop": "event",
            "knob": "event"
          },
          {
            "trait": "SearchResultSearch",
            "patternPath": "root",
            "prop": "placeholder",
            "knob": "placeholder"
          },
          {
            "trait": "SearchResultSearch",
            "patternPath": "root",
