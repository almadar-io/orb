                    },
                    "defaultOpen": {
                      "name": "defaultOpen",
                      "type": "boolean",
                      "required": false
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": false
                    },
                    "disabled": {
                      "name": "disabled",
                      "type": "boolean",
                      "required": false
                    },
                    "header": {
                      "name": "header",
                      "type": "string",
                      "required": false
                    },
                    "title": {
                      "name": "title",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "openItems": {
                "type": "[string]",
                "default": [],
