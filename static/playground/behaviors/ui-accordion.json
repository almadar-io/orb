          {
            "trait": "AccordionRender",
            "patternPath": "root",
            "prop": "openItems",
            "knob": "openItems"
          },
          {
            "trait": "AccordionRender",
            "patternPath": "root",
            "prop": "multiple",
            "knob": "multiple"
          },
          {
            "trait": "AccordionRender",
            "patternPath": "root",
