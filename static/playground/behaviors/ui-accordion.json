                  "payloadSchema": [
                    {
                      "name": "itemId",
                      "type": "string"
                    },
                    {
                      "name": "isOpen",
                      "type": "boolean"
                    }
                  ]
                },
                {
                  "key": "TOGGLE",
                  "name": "Toggle",
                  "description": "Declarative toggle event — emits UI:{toggleEvent} with { itemId, isOpen }",
