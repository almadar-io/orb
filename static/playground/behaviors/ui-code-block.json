{
  "name": "ui-code-block",
  "description": "CodeBlock — UI factory (1:1 with the @almadar/ui code-block pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-code-block",
    "version": "1.0.0",
    "description": "CodeBlock — UI factory (1:1 with the @almadar/ui code-block pattern).",
    "orbitals": [
      {
        "name": "CodeBlockOrbital",
        "entity": {
          "name": "CodeBlockItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "code",
              "type": "string",
              "default": "Code"
            }
          ]
        },
        "traits": [
          {
            "name": "CodeBlockRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "code"
              ]
            },
            "category": "interaction",
            "linkedEntity": "CodeBlockItem",
            "emits": [
              {
                "event": "CHANGE",
                "description": "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "CHANGE",
                  "name": "Change",
                  "description": "GAP-51: called with the new code on every keystroke when `editable === true`. Consumers should debounce + parse downstream — `CodeBlock` does not.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.code",
                      "Code"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "mode": "code",
                        "code": "@entity.code",
                        "editable": false,
                        "type": "code-block",
                        "showCopy": false,
                        "language": "text",
                        "files": [
                          {
                            "code": "Code",
                            "label": "Label",
                            "language": "text"
                          },
                          {
                            "label": "Label 2",
                            "language": "json",
                            "code": "Code 2"
                          }
                        ],
                        "showLanguageBadge": true,
                        "showLineNumbers": false,
                        "diff": [
                          {
                            "beforeLineNumber": 1,
                            "afterLineNumber": 1,
                            "content": "Content",
                            "type": "added"
                          },
                          {
                            "type": "removed",
                            "afterLineNumber": 2,
                            "beforeLineNumber": 2,
                            "content": "Content 2"
                          }
                        ],
                        "isLoading": false,
                        "foldable": false,
                        "onChange": "CHANGE",
                        "className": "",
                        "maxHeight": "60vh",
                        "showCopyButton": true,
                        "error": "@config.error",
                        "newValue": "New Value",
                        "oldValue": "Old Value",
                        "actions": [
                          {
                            "variant": "primary",
                            "navigatesTo": "Navigates To",
                            "label": "Label"
                          },
                          {
                            "label": "Label 2",
                            "navigatesTo": "Navigates To 2",
                            "variant": "secondary"
                          }
                        ],
                        "title": "Title",
                        "wordWrap": false
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "CHANGE",
                  "effects": [
                    [
                      "set",
                      "@entity.code",
                      "@payload.code"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "wordWrap": false,
                        "files": [
                          {
                            "code": "Code",
                            "label": "Label",
                            "language": "text"
                          },
                          {
                            "label": "Label 2",
                            "language": "json",
                            "code": "Code 2"
                          }
                        ],
                        "error": "@config.error",
                        "isLoading": false,
                        "actions": [
                          {
                            "variant": "primary",
                            "navigatesTo": "Navigates To",
                            "label": "Label"
                          },
                          {
                            "label": "Label 2",
                            "navigatesTo": "Navigates To 2",
                            "variant": "secondary"
                          }
                        ],
                        "language": "text",
                        "maxHeight": "60vh",
                        "onChange": "CHANGE",
                        "mode": "code",
                        "type": "code-block",
                        "foldable": false,
                        "newValue": "New Value",
                        "diff": [
                          {
                            "beforeLineNumber": 1,
                            "afterLineNumber": 1,
                            "content": "Content",
                            "type": "added"
                          },
                          {
                            "type": "removed",
                            "afterLineNumber": 2,
                            "beforeLineNumber": 2,
                            "content": "Content 2"
                          }
                        ],
                        "code": "@entity.code",
                        "showLanguageBadge": true,
                        "showCopy": false,
                        "className": "",
                        "oldValue": "Old Value",
                        "showCopyButton": true,
                        "editable": false,
                        "showLineNumbers": false,
                        "title": "Title"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "editable": {
                "type": "boolean",
                "default": false,
                "label": "Editable",
                "description": "When true, render an editable surface that composes a transparent `Textarea` over a Prism-highlighted overlay. The overlay re-tokenizes on each keystroke (driven from a local mirror of the textarea value), so users see syntax-highlighted code while still being able to type. Folding is skipped in editable mode. History: GAP-51 first-cut shipped plain (no-highlighting) editable text; GAP-77 (2026-04-12) added the Prism overlay layer. Default: false (existing read-only behavior unchanged).",
                "tier": "presentation"
              },
              "actions": {
                "type": "[CodeBlockActionsItem]",
                "default": [
                  {
                    "variant": "primary",
                    "navigatesTo": "Navigates To",
                    "label": "Label"
                  },
                  {
                    "label": "Label 2",
                    "navigatesTo": "Navigates To 2",
                    "variant": "secondary"
                  }
                ],
                "label": "Actions",
                "description": "Action badges in the toolbar",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "navigatesTo": {
                      "name": "navigatesTo",
                      "type": "string",
                      "required": false
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost"
                      ]
                    }
                  }
                }
              },
              "code": {
                "type": "string",
                "default": "Code",
                "label": "Code",
                "description": "The code content to display",
                "tier": "presentation"
              },
              "error": {
                "type": "CodeBlockError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "maxHeight": {
                "type": "string",
                "default": "60vh",
                "label": "Max Height",
                "description": "Maximum height before scrolling",
                "tier": "presentation"
              },
              "newValue": {
                "type": "string",
                "default": "New Value",
                "label": "New Value",
                "description": "New source text — generates diff when combined with oldValue",
                "tier": "presentation"
              },
              "files": {
                "type": "[CodeBlockFilesItem]",
                "default": [
                  {
                    "code": "Code",
                    "label": "Label",
                    "language": "text"
                  },
                  {
                    "label": "Label 2",
                    "language": "json",
                    "code": "Code 2"
                  }
                ],
                "label": "Files",
                "description": "Multiple files shown as tabs",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "language": {
                      "name": "language",
                      "type": "string",
                      "required": false,
                      "values": [
                        "text",
                        "json",
                        "javascript",
                        "js",
                        "typescript",
                        "ts",
                        "jsx",
                        "tsx",
                        "css",
                        "markdown",
                        "md",
                        "bash",
                        "shell",
                        "sh",
                        "yaml",
                        "yml",
                        "rust",
                        "python",
                        "py",
                        "sql",
                        "diff",
                        "toml",
                        "go",
                        "graphql",
                        "html",
                        "xml",
                        "orb",
                        "lolo"
                      ]
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "code": {
                      "name": "code",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "showCopy": {
                "type": "boolean",
                "default": false,
                "label": "Show Copy",
                "description": "Show copy button (viewer alias for showCopyButton)",
                "tier": "presentation"
              },
              "showCopyButton": {
                "type": "boolean",
                "default": true,
                "label": "Show Copy Button",
                "description": "Show the copy button",
                "tier": "presentation"
              },
              "showLanguageBadge": {
                "type": "boolean",
                "default": true,
                "label": "Show Language Badge",
                "description": "Show the language badge",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "── Viewer props (absorbed from CodeViewer / DocCodeBlock) ────────────────",
                "tier": "presentation"
              },
              "wordWrap": {
                "type": "boolean",
                "default": false,
                "label": "Word Wrap",
                "description": "Enable word-wrap in code / diff mode",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state",
                "tier": "presentation"
              },
              "showLineNumbers": {
                "type": "boolean",
                "default": false,
                "label": "Show Line Numbers",
                "description": "Show line numbers in code / diff mode",
                "tier": "presentation"
              },
              "diff": {
                "type": "[CodeBlockDiffItem]",
                "default": [
                  {
                    "beforeLineNumber": 1,
                    "afterLineNumber": 1,
                    "content": "Content",
                    "type": "added"
                  },
                  {
                    "type": "removed",
                    "afterLineNumber": 2,
                    "beforeLineNumber": 2,
                    "content": "Content 2"
                  }
                ],
                "label": "Diff",
                "description": "Pre-computed diff lines",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "content": {
                      "name": "content",
                      "type": "string",
                      "required": true
                    },
                    "type": {
                      "name": "type",
                      "type": "string",
                      "required": true,
                      "values": [
                        "added",
                        "removed",
                        "unchanged",
                        "context"
                      ]
                    },
                    "beforeLineNumber": {
                      "name": "beforeLineNumber",
                      "type": "number",
                      "required": false
                    },
                    "afterLineNumber": {
                      "name": "afterLineNumber",
                      "type": "number",
                      "required": false
                    }
                  }
                }
              },
              "language": {
                "type": "string",
                "default": "text",
                "label": "Language",
                "description": "Programming language for syntax highlighting",
                "tier": "presentation",
                "values": [
                  "text",
                  "json",
                  "javascript",
                  "js",
                  "typescript",
                  "ts",
                  "jsx",
                  "tsx",
                  "css",
                  "markdown",
                  "md",
                  "bash",
                  "shell",
                  "sh",
                  "yaml",
                  "yml",
                  "rust",
                  "python",
                  "py",
                  "sql",
                  "diff",
                  "toml",
                  "go",
                  "graphql",
                  "html",
                  "xml",
                  "orb",
                  "lolo"
                ]
              },
              "oldValue": {
                "type": "string",
                "default": "Old Value",
                "label": "Old Value",
                "description": "Old source text — generates diff when combined with newValue",
                "tier": "presentation"
              },
              "mode": {
                "type": "string",
                "default": "code",
                "label": "Mode",
                "description": "Diff or plain-code display mode",
                "tier": "presentation",
                "values": [
                  "code",
                  "diff"
                ]
              },
              "foldable": {
                "type": "boolean",
                "default": false,
                "label": "Foldable",
                "description": "Enable brace-based code folding of multi-line `{}`/`[]` blocks (default: true).",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "CodeBlockPage",
            "path": "/code-block",
            "traits": [
              {
                "ref": "CodeBlockRender"
              }
            ]
          }
        ]
