          },
          {
            "trait": "SequenceBarRender",
            "patternPath": "root",
            "prop": "slots",
            "knob": "slots"
          },
          {
            "trait": "SequenceBarRender",
            "patternPath": "root",
            "prop": "maxSlots",
            "knob": "maxSlots"
          },
          {
            "trait": "SequenceBarRender",
            "patternPath": "root",
            "prop": "slotFeedback",
            "knob": "slotFeedback"
          },
          {
            "trait": "SequenceBarRender",
            "patternPath": "root",
            "prop": "categoryColors",
            "knob": "categoryColors"
          },
          {
            "trait": "SequenceBarRender",
            "patternPath": "root",
            "prop": "currentStep",
            "knob": "currentStep"
          }
        ]
      }
    }
  },
