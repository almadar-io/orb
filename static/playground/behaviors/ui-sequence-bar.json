{
  "name": "ui-sequence-bar",
  "description": "SequenceBar — UI factory (1:1 with the @almadar/ui sequence-bar pattern).",
  "level": "organism",
  "topic": "ui/game/2d",
  "schema": {
    "name": "ui-sequence-bar",
    "version": "1.0.0",
    "description": "SequenceBar — UI factory (1:1 with the @almadar/ui sequence-bar pattern).",
    "orbitals": [
      {
        "name": "SequenceBarOrbital",
        "entity": {
          "name": "SequenceBarItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "SequenceBarRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "SequenceBarItem",
            "emits": [
              {
                "event": "SLOT_DROP",
                "description": "Called when an item is dropped into slot at index",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  },
                  {
                    "name": "item",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "category",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "iconEmoji",
                        "type": "string"
                      },
                      {
                        "name": "iconUrl",
                        "type": "asset"
                      },
                      {
                        "name": "stateMachine",
                        "type": "json"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "SLOT_REMOVE",
                "description": "Called when a slot is cleared",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "SLOT_DROP",
                  "name": "Slot Drop",
                  "description": "Called when an item is dropped into slot at index",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "index",
                      "type": "number"
                    },
                    {
                      "name": "item",
                      "type": "object",
                      "properties": [
                        {
                          "name": "id",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "category",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "type": "string"
                        },
                        {
                          "name": "iconEmoji",
                          "type": "string"
                        },
                        {
                          "name": "iconUrl",
                          "type": "asset"
                        },
                        {
                          "name": "stateMachine",
                          "type": "json"
                        }
                      ]
                    }
                  ]
                },
                {
                  "key": "SLOT_REMOVE",
                  "name": "Slot Remove",
                  "description": "Called when a slot is cleared",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "index",
                      "type": "number"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "playing": false,
                        "className": "",
                        "onSlotRemove": "SLOT_REMOVE",
                        "size": "lg",
                        "slots": [
                          {
                            "id": "Id",
                            "iconEmoji": "Icon Emoji",
                            "iconUrl": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/ui/star.png",
                            "name": "Name",
                            "description": "Description",
                            "category": "Category"
                          },
                          {
                            "iconEmoji": "Icon Emoji 2",
                            "id": "Id 2",
                            "category": "Category 2",
                            "iconUrl": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/ui/star.png",
                            "name": "Name 2",
                            "description": "Description 2"
                          }
                        ],
                        "maxSlots": 1,
                        "onSlotDrop": "SLOT_DROP",
                        "slotFeedback": [],
                        "categoryColors": {},
                        "currentStep": -1,
                        "type": "sequence-bar"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "maxSlots": {
                "type": "number",
                "default": 1,
                "label": "Max Slots",
                "description": "Max number of slots",
                "tier": "presentation"
              },
              "slots": {
                "type": "[SequenceBarSlotsItem]",
                "default": [
                  {
                    "id": "Id",
                    "iconEmoji": "Icon Emoji",
                    "iconUrl": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/ui/star.png",
                    "name": "Name",
                    "description": "Description",
                    "category": "Category"
                  },
                  {
                    "iconEmoji": "Icon Emoji 2",
                    "id": "Id 2",
                    "category": "Category 2",
                    "iconUrl": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/ui/star.png",
                    "name": "Name 2",
                    "description": "Description 2"
                  }
                ],
                "label": "Slots",
                "description": "The current sequence (sparse — undefined means empty slot)",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "stateMachine": {
                      "name": "stateMachine",
                      "type": "string",
                      "required": false
                    },
                    "description": {
                      "name": "description",
                      "type": "string",
                      "required": false
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    "category": {
                      "name": "category",
                      "type": "string",
                      "required": true
                    },
                    "iconEmoji": {
                      "name": "iconEmoji",
                      "type": "string",
                      "required": false
                    },
                    "iconUrl": {
                      "name": "iconUrl",
                      "type": "string",
                      "required": false
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "size": {
                "type": "string",
                "default": "lg",
                "label": "Size",
                "description": "Size variant",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg"
                ]
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "playing": {
                "type": "boolean",
                "default": false,
                "label": "Playing",
                "description": "Whether the sequence is currently playing (disable interaction)",
                "tier": "presentation"
              },
              "currentStep": {
                "type": "number",
                "default": -1,
                "label": "Current Step",
                "description": "Current step index during playback (-1 = not playing)",
                "tier": "presentation"
              },
              "categoryColors": {
                "type": "Map<string,SequenceBarCategoryColorsValue>",
                "default": {},
                "label": "Category Colors",
                "description": "Category → color mapping",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "bg": {
                      "name": "bg",
                      "type": "string",
                      "required": true
                    },
                    "border": {
                      "name": "border",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "slotFeedback": {
                "type": "[string]",
                "default": [],
                "label": "Slot Feedback",
                "description": "Per-slot correctness feedback shown after a failed attempt",
                "tier": "presentation",
                "items": {
                  "type": "string",
                  "values": [
                    "correct",
                    "wrong"
                  ]
                }
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SequenceBarPage",
            "path": "/sequence-bar",
            "traits": [
              {
                "ref": "SequenceBarRender"
              }
            ]
          }
        ]
      }
