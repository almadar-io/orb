                    ],
                    [
                      "set",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "completeEvent": "COMPLETE",
                        "checkEvent": "CHECK",
                        "entity": "@entity",
                        "placeEvent": "PLACE",
                        "playAgainEvent": "PLAY_AGAIN",
                        "type": "builder-board"
                      }
                    ]
                  ]
                }
              ]
