                      ]
                    ],
                    [
                      "set",
                      "@entity.title",
                      "Build a Web App"
                    ],
                    [
                      "set",
                      "@entity.description",
                      "Drag each component into its correct slot to assemble the architecture."
                    ],
                    [
                      "set",
                      "@entity.hint",
                      "Frontend goes first, then API, then Database."
                    ],
                    [
                      "set",
                      "@entity.attempts",
                      0
                    ],
                    [
                      "set",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "playAgainEvent": "PLAY_AGAIN",
                        "entity": "@entity",
                        "type": "builder-board",
                        "placeEvent": "PLACE",
                        "checkEvent": "CHECK",
                        "completeEvent": "COMPLETE"
                      }
                    ]
                  ]
                },
                {
                  "from": "playing",
                  "to": "playing",
                  "event": "PLACE",
                  "effects": [
                    [
                      "set",
                      "@entity.slots",
                      [
                        "array/map",
                        "@entity.slots",
                        [
                          "fn",
                          "s",
                          [
                            "if",
                            [
                              "==",
                              "@s.id",
                              "@payload.slotId"
                            ],
                            [
                              "object/merge",
                              "@s",
                              {
                                "placedComponentId": "@payload.componentId"
                              }
                            ],
                            "@s"
                          ]
                        ]
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "placeEvent": "PLACE",
                        "playAgainEvent": "PLAY_AGAIN",
                        "checkEvent": "CHECK",
                        "completeEvent": "COMPLETE",
                        "type": "builder-board",
                        "entity": "@entity"
                      }
                    ]
                  ]
                },
                {
                  "from": "playing",
                  "to": "complete",
                  "event": "CHECK",
                  "guard": [
                    "==",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@entity.slots",
                        [
                          "fn",
                          "s",
                          [
                            "!=",
                            [
                              "object/get",
                              "s",
                              "placedComponentId"
                            ],
                            [
                              "object/get",
                              "s",
                              "requiredComponentId"
                            ]
                          ]
                        ]
                      ]
                    ],
                    0
                  ],
                  "effects": [
                    [
                      "set",
                      "@entity.attempts",
                      [
                        "+",
                        "@entity.attempts",
                        1
                      ]
                    ],
                    [
                      "set",
                      "@entity.result",
                      "win"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "checkEvent": "CHECK",
                        "playAgainEvent": "PLAY_AGAIN",
                        "completeEvent": "COMPLETE",
                        "placeEvent": "PLACE",
                        "entity": "@entity",
                        "type": "builder-board"
                      }
                    ]
                  ]
                },
                {
                  "from": "playing",
                  "to": "playing",
                  "event": "CHECK",
                  "guard": [
                    ">",
                    [
                      "array/len",
                      [
                        "array/filter",
                        "@entity.slots",
                        [
                          "fn",
                          "s",
                          [
                            "!=",
                            [
                              "object/get",
                              "s",
                              "placedComponentId"
                            ],
                            [
                              "object/get",
                              "s",
                              "requiredComponentId"
                            ]
                          ]
                        ]
                      ]
                    ],
                    0
                  ],
                  "effects": [
                    [
                      "set",
                      "@entity.attempts",
                      [
                        "+",
                        "@entity.attempts",
                        1
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "entity": "@entity",
                        "playAgainEvent": "PLAY_AGAIN",
                        "checkEvent": "CHECK",
                        "placeEvent": "PLACE",
                        "type": "builder-board",
                        "completeEvent": "COMPLETE"
                      }
                    ]
                  ]
                },
                {
                  "from": "complete",
                  "to": "menu",
                  "event": "PLAY_AGAIN",
                  "effects": [
                    [
                      "set",
                      "@entity.slots",
                      [
                        {
                          "id": "slot-1",
                          "requiredComponentId": "comp-a"
                        },
                        {
                          "requiredComponentId": "comp-b",
                          "id": "slot-2"
                        },
                        {
                          "requiredComponentId": "comp-c",
                          "id": "slot-3"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.attempts",
