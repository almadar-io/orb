        "traits": [
          {
            "name": "BuilderBoardRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "attempts",
                "components",
                "description",
                "hint",
                "result",
                "slots",
                "title"
              ]
            },
            "category": "interaction",
            "linkedEntity": "BuilderBoardItem",
            "emits": [
              {
                "event": "COMPLETE",
                "description": "completeEvent prop",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "success",
                    "type": "boolean",
                    "required": true
                  },
                  {
                    "name": "attempts",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "event": "PLACE",
                "description": "Emits UI:{placeEvent} with { slotId, componentId } on component placement",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "slotId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "componentId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "CHECK",
                "description": "Emits UI:{checkEvent} with {} when the player checks the build",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "PLAY_AGAIN",
                "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "playing",
                  "isInitial": true
                },
                {
                  "name": "menu"
                },
                {
                  "name": "complete"
                }
              ],
              "events": [
                {
                  "key": "START",
                  "name": "Start"
                },
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "PLACE",
                  "name": "Place",
                  "description": "Emits UI:{placeEvent} with { slotId, componentId } on component placement",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "slotId",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "componentId",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CHECK",
                  "name": "Check",
                  "description": "Emits UI:{checkEvent} with {} when the player checks the build",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "PLAY_AGAIN",
                  "name": "Play Again",
                  "description": "Emits UI:{playAgainEvent} with {} on play again / reset",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "COMPLETE",
                  "name": "Complete",
                  "description": "completeEvent prop",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "success",
                      "type": "boolean",
                      "required": true
                    },
                    {
                      "name": "attempts",
                      "type": "number",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "menu",
                  "to": "playing",
                  "event": "START",
                  "effects": [
                    [
                      "set",
                      "@entity.components",
                      [
                        {
                          "label": "Frontend",
                          "id": "comp-a",
                          "description": "User-facing layer",
                          "iconEmoji": "🖥️"
                        },
                        {
                          "id": "comp-b",
                          "iconEmoji": "🔌",
                          "description": "Service boundary",
                          "label": "API"
                        },
                        {
                          "label": "Database",
                          "description": "Persistence layer",
                          "iconEmoji": "🗄️",
                          "id": "comp-c"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.slots",
                      [
                        {
                          "id": "slot-1",
                          "requiredComponentId": "comp-a"
                        },
                        {
                          "requiredComponentId": "comp-b",
                          "id": "slot-2"
                        },
                        {
                          "requiredComponentId": "comp-c",
                          "id": "slot-3"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.title",
                      "Build a Web App"
                    ],
                    [
                      "set",
                      "@entity.description",
                      "Drag each component into its correct slot to assemble the architecture."
                    ],
                    [
                      "set",
                      "@entity.hint",
                      "Frontend goes first, then API, then Database."
                    ],
                    [
                      "set",
                      "@entity.attempts",
                      0
                    ],
                    [
                      "set",
                      "@entity.result",
                      "none"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "builder-board",
                        "checkEvent": "CHECK",
                        "completeEvent": "COMPLETE",
                        "entity": "@entity",
                        "placeEvent": "PLACE",
                        "playAgainEvent": "PLAY_AGAIN"
                      }
                    ]
                  ]
                },
                {
                  "from": "playing",
                  "to": "playing",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.components",
                      [
                        {
                          "label": "Frontend",
                          "id": "comp-a",
                          "description": "User-facing layer",
                          "iconEmoji": "🖥️"
                        },
                        {
                          "id": "comp-b",
                          "iconEmoji": "🔌",
                          "description": "Service boundary",
                          "label": "API"
                        },
                        {
                          "label": "Database",
                          "description": "Persistence layer",
                          "iconEmoji": "🗄️",
                          "id": "comp-c"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.slots",
                      [
                        {
                          "id": "slot-1",
                          "requiredComponentId": "comp-a"
                        },
                        {
                          "requiredComponentId": "comp-b",
                          "id": "slot-2"
                        },
                        {
                          "requiredComponentId": "comp-c",
                          "id": "slot-3"
