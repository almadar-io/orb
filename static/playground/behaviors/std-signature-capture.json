{
  "name": "std-signature-capture",
  "description": "std-signature-capture — a drawn-signature pad. The signer draws, clears, or submits; on submit the signature persists and the atom emits SignatureSubmitted. One job: capture a signature and report when done.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-signature-capture",
    "version": "2.0.0",
    "description": "std-signature-capture — a drawn-signature pad. The signer draws, clears, or submits; on submit the signature persists and the atom emits SignatureSubmitted. One job: capture a signature and report when done.",
    "orbitals": [
      {
        "name": "SignatureCaptureOrbital",
        "entity": {
          "name": "Signature",
          "collection": "signatures",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "targetId",
              "type": "string",
              "required": true,
              "description": "Unique identifier for the target of the signature.",
              "synonyms": "referenceId, associatedId, target"
            },
            {
              "name": "targetType",
              "type": "string",
              "required": true,
              "description": "Specifies the type of target associated with the signature.",
              "synonyms": "type, kind, category"
            },
            {
              "name": "signerName",
              "type": "string",
              "required": true,
              "description": "The name of the person providing the signature.",
              "synonyms": "name, user, person"
            },
            {
              "name": "signatureDataUrl",
              "type": "string",
              "required": true,
              "description": "Encoded signature image data, typically a data URL.",
              "synonyms": "signature image, image data, signature representation"
            },
            {
              "name": "signedAt",
              "type": "string",
              "description": "Timestamp indicating when the signature was captured.",
              "synonyms": "date, time, timestamp"
            },
            {
              "name": "ipAddress",
              "type": "string",
              "description": "The client's IP address during signature capture.",
              "synonyms": "client IP, source IP, originating IP"
            }
          ]
        },
        "traits": [
          {
            "name": "SignatureCapture",
            "category": "interaction",
            "linkedEntity": "Signature",
            "emits": [
              {
                "event": "CHANGE",
                "description": "Indicates a change in the signature drawing.",
                "synonyms": "update, modify, alter",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "dataUrl",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "SUBMIT",
                "description": "Signals the signature capture process is complete.",
                "synonyms": "done, finalized, confirmed, saved",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "event": "CLEAR",
                "description": "Signals the signature pad has been cleared.",
                "synonyms": "reset, erase, remove",
                "tier": "domain"
              },
              {
                "event": "SignatureLoaded",
                "description": "Indicates the signature pad is ready for use.",
                "synonyms": "ready, initialized, available",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Signature]"
                  }
                ]
              },
              {
                "event": "SignatureLoadFailed",
                "description": "Indicates the signature data could not be loaded.",
                "synonyms": "load error, failed load, data error",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "SignatureSubmitted",
                "description": "Indicates a signature has been successfully captured and submitted.",
                "synonyms": "signed, finalized, completed",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "targetId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "targetType",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "signerName",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "signatureDataUrl",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "signedAt",
                        "type": "string"
                      },
                      {
                        "name": "ipAddress",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "SignatureSubmitFailed",
                "description": "Indicates signature submission failed.",
                "synonyms": "error, failure, rejected",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "idle"
                },
                {
                  "name": "submitting"
                },
                {
                  "name": "submitted"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "SignatureLoaded",
                  "name": "Signature loaded",
                  "description": "Indicates the signature pad is ready for use.",
                  "synonyms": "ready, initialized, available",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[Signature]"
                    }
                  ]
                },
                {
                  "key": "SignatureLoadFailed",
                  "name": "Signature load failed",
                  "description": "Indicates the signature data could not be loaded.",
                  "synonyms": "load error, failed load, data error",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CHANGE",
                  "name": "Change",
                  "description": "Indicates a change in the signature drawing.",
                  "synonyms": "update, modify, alter",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "dataUrl",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CLEAR",
                  "name": "Clear",
                  "description": "Signals the signature pad has been cleared.",
                  "synonyms": "reset, erase, remove",
                  "tier": "domain"
                },
                {
                  "key": "SUBMIT",
                  "name": "Submit",
                  "description": "Signals the signature capture process is complete.",
                  "synonyms": "done, finalized, confirmed, saved",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "object",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "SignatureSubmitted",
                  "name": "Signature submitted",
                  "description": "Indicates a signature has been successfully captured and submitted.",
                  "synonyms": "signed, finalized, completed",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "Signature"
                    }
                  ]
                },
                {
                  "key": "SignatureSubmitFailed",
                  "name": "Signature submit failed",
                  "description": "Indicates signature submission failed.",
                  "synonyms": "error, failure, rejected",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "Signature",
                      {
                        "emit": {
                          "success": "SignatureLoaded",
                          "failure": "SignatureLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Loading…",
                            "type": "typography",
                            "variant": "caption",
                            "color": "muted"
                          }
                        ],
                        "direction": "vertical",
                        "align": "center",
                        "className": "py-12",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "idle",
                  "event": "SignatureLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "children": [
                          {
                            "variant": "h3",
                            "type": "typography",
                            "content": "Sign here"
                          },
                          {
                            "type": "typography",
                            "color": "muted",
                            "content": "Use your finger or stylus to sign below",
                            "variant": "caption"
                          },
                          {
                            "onChange": "CHANGE",
                            "type": "signature-pad",
                            "value": "@entity.signatureDataUrl"
                          },
                          {
                            "type": "stack",
                            "children": [
                              {
                                "type": "button",
                                "action": "CLEAR",
                                "variant": "secondary",
                                "icon": "trash",
                                "label": "Clear"
                              },
                              {
                                "label": "Submit",
                                "type": "button",
                                "variant": "primary",
                                "action": "SUBMIT",
                                "icon": "send"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm"
                          }
                        ],
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "idle",
                  "event": "SignatureLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "children": [
                          {
                            "content": "Sign here",
                            "type": "typography",
                            "variant": "h3"
                          },
                          {
                            "color": "muted",
                            "content": "Use your finger or stylus to sign below",
                            "type": "typography",
                            "variant": "caption"
                          },
                          {
                            "type": "signature-pad",
                            "onChange": "CHANGE",
                            "value": "@entity.signatureDataUrl"
                          },
                          {
                            "children": [
                              {
                                "icon": "trash",
                                "label": "Clear",
                                "type": "button",
                                "action": "CLEAR",
                                "variant": "secondary"
                              },
                              {
                                "label": "Submit",
                                "type": "button",
                                "variant": "primary",
                                "icon": "send",
                                "action": "SUBMIT"
                              }
                            ],
                            "gap": "sm",
                            "type": "stack",
                            "direction": "horizontal"
                          }
                        ],
                        "gap": "md",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "CHANGE",
                  "effects": [
                    [
                      "set",
                      "@entity.signatureDataUrl",
                      "@payload.dataUrl"
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "CLEAR",
                  "effects": [
                    [
                      "set",
                      "@entity.signatureDataUrl",
                      ""
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "type": "typography",
                            "content": "Sign here",
                            "variant": "h3"
                          },
                          {
                            "variant": "caption",
                            "color": "muted",
                            "content": "Use your finger or stylus to sign below",
                            "type": "typography"
                          },
                          {
                            "type": "signature-pad",
                            "onChange": "CHANGE",
                            "value": "@entity.signatureDataUrl"
                          },
                          {
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack",
                            "children": [
                              {
                                "label": "Clear",
                                "variant": "secondary",
                                "type": "button",
                                "action": "CLEAR",
                                "icon": "trash"
                              },
                              {
                                "type": "button",
                                "action": "SUBMIT",
                                "icon": "send",
                                "label": "Submit",
                                "variant": "primary"
                              }
                            ]
                          }
                        ],
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "submitting",
                  "event": "SUBMIT",
                  "effects": [
                    [
                      "persist",
                      "create",
                      "Signature",
                      "@payload.data",
                      {
                        "emit": {
                          "success": "SignatureSubmitted",
                          "failure": "SignatureSubmitFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "className": "py-12",
                        "type": "stack",
                        "direction": "vertical",
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "content": "Submitting your signature…",
                            "color": "muted",
                            "type": "typography"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "submitting",
                  "to": "submitted",
                  "event": "SignatureSubmitted",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "type": "stack",
                        "children": [
                          {
                            "type": "icon",
                            "color": "success",
                            "name": "check-circle"
                          },
                          {
                            "variant": "h3",
                            "content": "Signature recorded. Thank you.",
                            "type": "typography"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "align": "center"
                      }
                    ]
                  ]
                },
                {
                  "from": "submitting",
                  "to": "idle",
                  "event": "SignatureSubmitFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "message": "@payload.error",
                        "variant": "error"
                      }
                    ]
                  ]
                },
                {
                  "from": "submitted",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.signatureDataUrl",
                      ""
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "type": "typography",
                            "variant": "h3",
                            "content": "Sign here"
                          },
                          {
                            "type": "typography",
                            "color": "muted",
                            "variant": "caption",
                            "content": "Use your finger or stylus to sign below"
                          },
                          {
                            "value": "@entity.signatureDataUrl",
                            "onChange": "CHANGE",
                            "type": "signature-pad"
                          },
                          {
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack",
                            "children": [
                              {
                                "action": "CLEAR",
                                "icon": "trash",
                                "label": "Clear",
                                "type": "button",
                                "variant": "secondary"
                              },
                              {
                                "label": "Submit",
                                "type": "button",
                                "action": "SUBMIT",
                                "variant": "primary",
                                "icon": "send"
                              }
                            ]
                          }
                        ],
                        "gap": "md",
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "instructions": {
                "type": "string",
                "default": "Use your finger or stylus to sign below",
                "label": "Instructions",
                "description": "Helper text shown to the signer above the pad",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Sign here",
                "label": "Pad title",
                "description": "Heading shown above the signature pad",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SignatureCapturePage",
            "path": "/signatures/capture",
            "traits": [
              {
                "ref": "SignatureCapture"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "SignatureCaptureOrbital": [
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.0",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.1",
            "prop": "content",
            "knob": "instructions"
          },
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.0",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.1",
            "prop": "content",
            "knob": "instructions"
          },
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.0",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.1",
            "prop": "content",
            "knob": "instructions"
          },
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.0",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "SignatureCapture",
            "patternPath": "root.children.1",
            "prop": "content",
            "knob": "instructions"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}