            "knob": "className"
          },
          {
            "trait": "FormLayoutRender",
            "patternPath": "root",
            "prop": "searchValue",
            "knob": "searchValue"
          },
          {
            "trait": "FormLayoutRender",
            "patternPath": "root",
            "prop": "selectedIds",
            "knob": "selectedIds"
          },
          {
            "trait": "FormLayoutRender",
            "patternPath": "root",
            "prop": "totalCount",
            "knob": "totalCount"
          }
        ]
