{
  "name": "std-branching-logic",
  "description": "std-branching-logic — survey skip-logic rules. Lists rules in `browsing`; opens rule detail in `viewing_single` with Edit / Delete actions.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-branching-logic",
    "version": "1.0.0",
    "description": "std-branching-logic — survey skip-logic rules. Lists rules in `browsing`; opens rule detail in `viewing_single` with Edit / Delete actions.",
    "orbitals": [
      {
        "name": "BranchingLogicOrbital",
        "entity": {
          "name": "BranchingRule",
          "collection": "branchingrules",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "surveyId",
              "type": "string",
              "required": true,
              "description": "Unique identifier for the survey this rule applies to.",
              "synonyms": "survey, questionnaire, form"
            },
            {
              "name": "sourceQuestionId",
              "type": "string",
              "required": true,
              "description": "The ID of the question triggering the branching logic.",
              "synonyms": "trigger, source, question_id"
            },
            {
              "name": "operator",
              "type": "string",
              "default": "equals",
              "values": [
                "equals",
                "not-equals",
                "contains",
                "in"
              ],
              "description": "Specifies the comparison method used in the rule.",
              "synonyms": "comparison, method, type"
            },
            {
              "name": "value",
              "type": "string",
              "description": "The data being compared against a condition.",
              "synonyms": "data, content, expression"
            },
            {
              "name": "targetQuestionId",
              "type": "string",
              "required": true,
              "description": "The ID of the question to navigate to based on the rule.",
              "synonyms": "destination, nextQuestion, target"
            },
            {
              "name": "priority",
              "type": "number",
              "default": 0,
              "description": "Specifies the order in which rules are evaluated.",
              "synonyms": "order, sequence, precedence"
            }
          ]
        },
        "traits": [
          {
            "name": "BranchingRuleManage",
            "category": "interaction",
            "linkedEntity": "BranchingRule",
            "emits": [
              {
                "event": "OPEN_RULE",
                "description": "Signals a rule detail view should be opened.",
                "synonyms": "show, display, reveal, open",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "surveyId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "sourceQuestionId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "operator",
                        "type": "string"
                      },
                      {
                        "name": "value",
                        "type": "string"
                      },
                      {
                        "name": "targetQuestionId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "priority",
                        "type": "number"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "CLOSE_VIEW",
                "description": "Indicates the detail view has been closed.",
                "synonyms": "dismiss, hide, close",
                "tier": "presentation"
              },
              {
                "event": "DELETE_RULE",
                "description": "Signals a branching rule has been removed.",
                "synonyms": "remove, discard, delete",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "BranchingRuleLoaded",
                "description": "Indicates a branching rule has been successfully retrieved.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BranchingRule]"
                  }
                ]
              },
              {
                "event": "BranchingRuleLoadFailed",
                "description": "Indicates a failure to load a branching rule.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "viewing_single"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "BranchingRuleLoaded",
                  "name": "BranchingRule loaded",
                  "description": "Indicates a branching rule has been successfully retrieved.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[BranchingRule]"
                    }
                  ]
                },
                {
                  "key": "BranchingRuleLoadFailed",
                  "name": "BranchingRule load failed",
                  "description": "Indicates a failure to load a branching rule.",
                  "synonyms": "error, failure, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "OPEN_RULE",
                  "name": "Open Rule",
                  "description": "Signals a rule detail view should be opened.",
                  "synonyms": "show, display, reveal, open",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "BranchingRule"
                    }
                  ]
                },
                {
                  "key": "DELETE_RULE",
                  "name": "Delete Rule",
                  "description": "Signals a branching rule has been removed.",
                  "synonyms": "remove, discard, delete",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CLOSE_VIEW",
                  "name": "Close View",
                  "description": "Indicates the detail view has been closed.",
                  "synonyms": "dismiss, hide, close",
                  "tier": "presentation"
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "BranchingRule",
                      {
                        "emit": {
                          "failure": "BranchingRuleLoadFailed",
                          "success": "BranchingRuleLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "direction": "vertical",
                        "type": "stack",
                        "gap": "md",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "color": "muted",
                            "type": "typography",
                            "content": "Loading branching rules…",
                            "variant": "caption"
                          }
                        ],
                        "align": "center"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "BranchingRuleLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "type": "stack",
                        "children": [
                          {
                            "direction": "horizontal",
                            "children": [
                              {
                                "type": "icon",
                                "name": "git-branch"
                              },
                              {
                                "variant": "h3",
                                "type": "typography",
                                "content": "Branching Rules"
                              }
                            ],
                            "align": "center",
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "cols": 4,
                            "type": "simple-grid",
                            "children": [
                              {
                                "look": "elevated",
                                "type": "stat-display",
                                "value": "@payload.data.length",
                                "icon": "git-branch",
                                "label": "Total rules"
                              },
                              {
                                "type": "stat-display",
                                "icon": "clipboard-list",
                                "value": "8",
                                "label": "Active surveys",
                                "look": "elevated"
                              },
                              {
                                "look": "elevated",
                                "value": "42",
                                "icon": "skip-forward",
                                "label": "Skip jumps",
                                "type": "stat-display"
                              },
                              {
                                "label": "Priority avg",
                                "icon": "trending-up",
                                "type": "stat-display",
                                "look": "elevated",
                                "value": "3"
                              }
                            ]
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "entity": "@payload.data",
                            "fields": [
                              {
                                "variant": "caption",
                                "label": "If question",
                                "name": "sourceQuestionId"
                              },
                              {
                                "name": "operator",
                                "label": "Op",
                                "variant": "badge"
                              },
                              {
                                "name": "value",
                                "variant": "caption",
                                "label": "Value"
                              },
                              {
                                "label": "Jump to",
                                "name": "targetQuestionId",
                                "variant": "caption"
                              },
                              {
                                "name": "priority",
                                "label": "Priority",
                                "variant": "badge"
                              }
                            ],
                            "gap": "sm",
                            "itemActions": [
                              {
                                "icon": "arrow-right",
                                "event": "OPEN_RULE",
                                "variant": "primary",
                                "label": "Open"
                              },
                              {
                                "event": "DELETE_RULE",
                                "icon": "trash-2",
                                "label": "Delete",
                                "variant": "danger"
                              }
                            ],
                            "type": "data-grid",
                            "cols": 1,
                            "look": "dense"
                          }
                        ],
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "BranchingRuleLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "variant": "error",
                        "message": "@payload.error"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "viewing_single",
                  "event": "OPEN_RULE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.row.id"
                    ],
                    [
                      "set",
                      "@entity.surveyId",
                      "@payload.row.surveyId"
                    ],
                    [
                      "set",
                      "@entity.sourceQuestionId",
                      "@payload.row.sourceQuestionId"
                    ],
                    [
                      "set",
                      "@entity.operator",
                      "@payload.row.operator"
                    ],
                    [
                      "set",
                      "@entity.value",
                      "@payload.row.value"
                    ],
                    [
                      "set",
                      "@entity.targetQuestionId",
                      "@payload.row.targetQuestionId"
                    ],
                    [
                      "set",
                      "@entity.priority",
                      "@payload.row.priority"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "align": "center",
                            "children": [
                              {
                                "label": "Back",
                                "variant": "ghost",
                                "type": "button",
                                "action": "CLOSE_VIEW"
                              },
                              {
                                "name": "git-branch",
                                "type": "icon"
                              },
                              {
                                "content": "@entity.sourceQuestionId",
                                "variant": "h3",
                                "type": "typography"
                              },
                              {
                                "label": "@entity.operator",
                                "variant": "default",
                                "type": "badge"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "direction": "vertical",
                            "children": [
                              {
                                "type": "stack",
                                "children": [
                                  {
                                    "variant": "caption",
                                    "type": "typography",
                                    "color": "muted",
                                    "content": "Survey"
                                  },
                                  {
                                    "content": "@entity.surveyId",
                                    "variant": "body",
                                    "type": "typography"
                                  }
                                ],
                                "direction": "horizontal",
                                "gap": "md"
                              },
                              {
                                "type": "stack",
                                "direction": "horizontal",
                                "children": [
                                  {
                                    "color": "muted",
                                    "content": "Value",
                                    "variant": "caption",
                                    "type": "typography"
                                  },
                                  {
                                    "content": "@entity.value",
                                    "type": "typography",
                                    "variant": "body"
                                  }
                                ],
                                "gap": "md"
                              }
                            ],
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "type": "simple-grid",
                            "cols": 3,
                            "children": [
                              {
                                "icon": "help-circle",
                                "look": "elevated",
                                "type": "stat-display",
                                "label": "Source",
                                "value": "@entity.sourceQuestionId"
                              },
                              {
                                "look": "elevated",
                                "label": "Target",
                                "type": "stat-display",
                                "value": "@entity.targetQuestionId",
                                "icon": "arrow-right-circle"
                              },
                              {
                                "type": "stat-display",
                                "icon": "trending-up",
                                "value": "@entity.priority",
                                "look": "elevated",
                                "label": "Priority"
                              }
                            ]
                          },
                          {
                            "children": [
                              {
                                "type": "button",
                                "label": "Delete",
                                "actionPayload": {
                                  "id": "@entity.id"
                                },
                                "variant": "danger",
                                "action": "DELETE_RULE"
                              }
                            ],
                            "align": "center",
                            "direction": "horizontal",
                            "type": "stack",
                            "gap": "sm"
                          }
                        ],
                        "type": "stack",
                        "gap": "md",
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "DELETE_RULE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "fetch",
                      "BranchingRule",
                      {
                        "emit": {
                          "success": "BranchingRuleLoaded",
                          "failure": "BranchingRuleLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "gap": "md",
                        "type": "stack",
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "color": "muted",
                            "content": "Deleting rule…",
                            "type": "typography",
                            "variant": "caption"
                          }
                        ],
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "loading",
                  "event": "CLOSE_VIEW",
                  "effects": [
                    [
                      "fetch",
                      "BranchingRule",
                      {
                        "emit": {
                          "success": "BranchingRuleLoaded",
                          "failure": "BranchingRuleLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "color": "muted",
                            "content": "Loading branching rules…",
                            "type": "typography"
                          }
                        ],
                        "align": "center",
                        "className": "py-12",
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "loading",
                  "event": "DELETE_RULE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "fetch",
                      "BranchingRule",
                      {
                        "emit": {
                          "failure": "BranchingRuleLoadFailed",
                          "success": "BranchingRuleLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Deleting rule…",
                            "type": "typography",
                            "color": "muted",
                            "variant": "caption"
                          }
                        ],
                        "gap": "md",
                        "type": "stack",
                        "className": "py-12",
                        "direction": "vertical",
                        "align": "center"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "BranchingRule",
                      {
                        "emit": {
                          "success": "BranchingRuleLoaded",
                          "failure": "BranchingRuleLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "sm"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "statLook": {
                "type": "string",
                "default": "elevated",
                "label": "Stat display look",
                "description": "Layer 2 visual treatment for stat / KPI cards.",
                "tier": "presentation",
                "values": [
                  "elevated",
                  "flat",
                  "progress-backed",
                  "gauge",
                  "sparkline"
                ]
              },
              "title": {
                "type": "string",
                "default": "Branching Rules",
                "label": "Section title",
                "description": "Heading shown above the branching-rule list",
                "tier": "presentation"
              },
              "tableLook": {
                "type": "string",
                "default": "dense",
                "label": "Table look",
                "description": "Layer 2 visual treatment for the data table rendered by this atom.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              }
            },
            "scope": "collection"
          }
        ],
        "pages": [
          {
            "name": "BranchingRuleManagePage",
            "path": "/branching-rules",
            "traits": [
              {
                "ref": "BranchingRuleManage"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "BranchingLogicOrbital": [
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.0.children.1",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.1.children.0",
            "prop": "look",
            "knob": "statLook"
          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.1.children.1",
            "prop": "look",
            "knob": "statLook"
          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.1.children.2",
            "prop": "look",
            "knob": "statLook"
          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.1.children.3",
            "prop": "look",
            "knob": "statLook"
          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.3",
            "prop": "look",
            "knob": "tableLook"
          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.4.children.0",
            "prop": "look",
