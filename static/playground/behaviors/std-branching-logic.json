          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.4.children.1",
            "prop": "look",
            "knob": "statLook"
          },
          {
            "trait": "BranchingRuleManage",
            "patternPath": "root.children.4.children.2",
