{
  "name": "ui-signature-pad",
  "description": "SignaturePad — UI factory (1:1 with the @almadar/ui signature-pad pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-signature-pad",
    "version": "1.0.0",
    "description": "SignaturePad — UI factory (1:1 with the @almadar/ui signature-pad pattern).",
    "orbitals": [
      {
        "name": "SignaturePadOrbital",
        "entity": {
          "name": "SignaturePadItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "SignaturePadRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "SignaturePadItem",
            "emits": [
              {
                "event": "CHANGE",
                "description": "Callback when signature changes",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "dataUrl",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "SIGN",
                "description": "Event to emit on sign",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "signature",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "CLEAR",
                "description": "Event to emit on clear",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "CHANGE",
                  "name": "Change",
                  "description": "Callback when signature changes",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "dataUrl",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SIGN",
                  "name": "Sign",
                  "description": "Event to emit on sign",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "signature",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CLEAR",
                  "name": "Clear",
                  "description": "Event to emit on clear",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "strokeWidth": 2,
                        "error": "@config.error",
                        "height": 200,
                        "label": "Label",
                        "onChange": "CHANGE",
                        "className": "",
                        "readOnly": false,
                        "clearEvent": "CLEAR",
                        "isLoading": false,
                        "signEvent": "SIGN",
                        "helperText": "Helper Text",
                        "strokeColor": "Stroke Color",
                        "type": "signature-pad",
                        "value": "Value"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "value": {
                "type": "string",
                "default": "Value",
                "label": "Value",
                "description": "Existing signature image URL",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state",
                "tier": "presentation"
              },
              "readOnly": {
                "type": "boolean",
                "default": false,
                "label": "Read Only",
                "description": "Whether the pad is read-only",
                "tier": "presentation"
              },
              "strokeColor": {
                "type": "string",
                "default": "Stroke Color",
                "label": "Stroke Color",
                "description": "Stroke color",
                "tier": "presentation"
              },
              "error": {
                "type": "SignaturePadError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "height": {
                "type": "number",
                "default": 200,
                "label": "Height",
                "description": "Pad height",
                "tier": "presentation"
              },
              "label": {
                "type": "string",
                "default": "Label",
                "label": "Label",
                "description": "Label above the pad",
                "tier": "presentation"
              },
              "helperText": {
                "type": "string",
                "default": "Helper Text",
                "label": "Helper Text",
                "description": "Helper text",
                "tier": "presentation"
              },
              "strokeWidth": {
                "type": "number",
                "default": 2,
                "label": "Stroke Width",
                "description": "Stroke width",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SignaturePadPage",
            "path": "/signature-pad",
            "traits": [
              {
                "ref": "SignaturePadRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "SignaturePadOrbital": [
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "strokeWidth",
            "knob": "strokeWidth"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "height",
            "knob": "height"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "label",
            "knob": "label"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "readOnly",
            "knob": "readOnly"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "helperText",
            "knob": "helperText"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "strokeColor",
            "knob": "strokeColor"
          },
          {
            "trait": "SignaturePadRender",
            "patternPath": "root",
            "prop": "value",
            "knob": "value"
          }
        ]
      }
    }
  },
