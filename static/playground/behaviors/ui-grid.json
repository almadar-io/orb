{
  "name": "ui-grid",
  "description": "Grid — UI factory (1:1 with the @almadar/ui grid pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-grid",
    "version": "1.0.0",
    "description": "Grid — UI factory (1:1 with the @almadar/ui grid pattern).",
    "orbitals": [
      {
        "name": "GridOrbital",
        "entity": {
          "name": "GridItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "GridRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "GridItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "rowGap": "none",
                        "cols": "@config.cols",
                        "colGap": "none",
                        "flow": "row",
                        "className": "",
                        "justifyItems": "start",
                        "style": {},
                        "type": "grid",
                        "alignItems": "start",
                        "rows": 0,
                        "children": [
                          {
                            "content": "Sample content",
                            "type": "typography"
                          }
                        ],
                        "gap": "md"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "alignItems": {
                "type": "string",
                "default": "start",
                "label": "Align Items",
                "description": "Align items on block axis",
                "tier": "presentation",
                "values": [
                  "start",
                  "center",
                  "end",
                  "stretch",
                  "baseline"
                ]
              },
              "justifyItems": {
                "type": "string",
                "default": "start",
                "label": "Justify Items",
                "description": "Justify items on inline axis",
                "tier": "presentation",
                "values": [
                  "start",
                  "center",
                  "end",
                  "stretch"
                ]
              },
              "rowGap": {
                "type": "string",
                "default": "none",
                "label": "Row Gap",
                "description": "Row gap (overrides gap for rows)",
                "tier": "presentation",
                "values": [
                  "none",
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "2xl"
                ]
              },
              "rows": {
                "type": "number",
                "default": 0,
                "label": "Rows",
                "description": "Number of rows",
                "tier": "presentation"
              },
              "flow": {
                "type": "string",
                "default": "row",
                "label": "Flow",
                "description": "Auto-flow direction",
                "tier": "presentation",
                "values": [
                  "row",
                  "col",
                  "row-dense",
                  "col-dense"
                ]
              },
              "style": {
                "type": "json",
                "default": {},
                "label": "Style",
                "description": "Inline styles",
                "tier": "presentation"
              },
              "colGap": {
                "type": "string",
                "default": "none",
                "label": "Col Gap",
                "description": "Column gap (overrides gap for columns)",
                "tier": "presentation",
                "values": [
                  "none",
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "2xl"
                ]
              },
              "gap": {
                "type": "string",
                "default": "md",
                "label": "Gap",
                "description": "Gap between items",
                "tier": "presentation",
                "values": [
                  "none",
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "2xl"
                ]
              },
              "cols": {
                "type": "string",
                "label": "Cols",
                "description": "Number of columns (can be responsive object)",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Custom class name",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "GridPage",
            "path": "/grid",
            "traits": [
              {
                "ref": "GridRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "GridOrbital": [
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "rowGap",
            "knob": "rowGap"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "colGap",
            "knob": "colGap"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "flow",
            "knob": "flow"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "justifyItems",
            "knob": "justifyItems"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "style",
            "knob": "style"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "alignItems",
            "knob": "alignItems"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "rows",
            "knob": "rows"
          },
          {
            "trait": "GridRender",
            "patternPath": "root",
            "prop": "gap",
            "knob": "gap"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}