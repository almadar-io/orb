{
  "name": "std-anim-tick",
  "description": "std-anim-tick — sprite/effects animation clock atom. Advances every unit's frame (mod frameCount) and ages @entity.effects (decrement ttl, drop expired) every tick. Boards compose it via `uses` + a sibling trait-ref rebound (linkedEntity) to a board entity that carries `units` + `effects`, replacing the inlined animTick that was duplicated across 8+ game boards.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-anim-tick",
    "version": "1.0.0",
    "description": "std-anim-tick — sprite/effects animation clock atom. Advances every unit's frame (mod frameCount) and ages @entity.effects (decrement ttl, drop expired) every tick. Boards compose it via `uses` + a sibling trait-ref rebound (linkedEntity) to a board entity that carries `units` + `effects`, replacing the inlined animTick that was duplicated across 8+ game boards.",
    "orbitals": [
      {
        "name": "AnimTickOrbital",
        "entity": {
          "name": "AnimTickItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "units",
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "properties": {
                  "animation": {
                    "name": "animation",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  "frame": {
                    "name": "frame",
                    "type": "number",
                    "required": false
                  }
                }
              }
            },
            {
              "name": "effects",
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "properties": {
                  "ttl": {
                    "name": "ttl",
                    "type": "number",
                    "required": true
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  },
                  "key": {
                    "name": "key",
                    "type": "string",
                    "required": true
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  }
                }
              }
            }
          ]
        },
        "traits": [
          {
            "name": "AnimTick",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "effects",
                "units"
              ]
            },
            "category": "game-core",
            "linkedEntity": "AnimTickItem",
            "stateMachine": {
              "states": [
                {
                  "name": "running",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "running",
                  "to": "running",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.units",
                      "@entity.units"
                    ],
                    [
                      "set",
                      "@entity.effects",
                      "@entity.effects"
                    ]
                  ]
                }
              ]
            },
            "ticks": [
              {
                "name": "animTick",
                "interval": 100,
                "effects": [
                  [
                    "set",
                    "@entity.units",
                    [
                      "array/map",
                      "@entity.units",
                      [
                        "fn",
                        "u",
                        [
                          "object/merge",
                          "@u",
                          {
                            "frame": [
                              "%",
                              [
                                "+",
                                [
                                  "object/get",
                                  "@u",
                                  "frame"
                                ],
                                1
                              ],
                              8
                            ]
                          }
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.effects",
                    [
                      "array/filter",
                      [
                        "array/map",
                        "@entity.effects",
                        [
                          "fn",
                          "e",
                          [
                            "object/merge",
                            "@e",
                            {
                              "ttl": [
                                "-",
                                [
                                  "object/get",
                                  "@e",
                                  "ttl"
                                ],
                                1
                              ]
                            }
                          ]
                        ]
                      ],
                      [
                        "fn",
                        "e",
                        [
                          ">",
                          [
                            "object/get",
                            "@e",
                            "ttl"
                          ],
                          0
                        ]
                      ]
                    ]
                  ]
                ]
              }
            ],
            "config": {
              "frameCount": {
                "type": "number",
                "default": 8,
                "label": "Frame count",
                "description": "Number of sprite frames a unit cycles through before the animation loops.",
                "synonyms": "frames, sheet length, animation length",
                "tier": "domain"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "AnimTickPage",
            "path": "/anim-tick",
            "traits": [
              {
                "ref": "AnimTick"
              }
            ]
          }
        ]
      }
    ]
  },
  "source": "",
  "lolo": ""
}