{
  "name": "std-rich-editor",
  "description": "std-rich-editor — wiki/CMS Notion-style block editor. Browses documents in `browsing`; opens the rich-block-editor on a selected row; persists block edits + publish status.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-rich-editor",
    "version": "1.0.0",
    "description": "std-rich-editor — wiki/CMS Notion-style block editor. Browses documents in `browsing`; opens the rich-block-editor on a selected row; persists block edits + publish status.",
    "orbitals": [
      {
        "name": "DocumentOrbital",
        "entity": {
          "name": "Document",
          "collection": "documents",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "title",
              "type": "string",
              "required": true,
              "description": "The human-readable name of the document.",
              "synonyms": "name, heading, label"
            },
            {
              "name": "blocksJson",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "content": {
                    "name": "content",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": false
                  },
                  "type": {
                    "name": "type",
                    "type": "string",
                    "required": true
                  }
                }
              },
              "description": "Serialized representation of the document's content blocks.",
              "synonyms": "content, data, structure, blocks"
            },
            {
              "name": "authorId",
              "type": "string",
              "description": "Unique identifier of the user who created the document.",
              "synonyms": "creatorId, userId, ownerId"
            },
            {
              "name": "parentId",
              "type": "string",
              "description": "Reference to the parent document or container.",
              "synonyms": "parent, container, owner"
            },
            {
              "name": "kind",
              "type": "string",
              "default": "page",
              "values": [
                "page",
                "doc",
                "post"
              ],
              "description": "Specifies the document type.",
              "synonyms": "type, documentType, category"
            },
            {
              "name": "status",
              "type": "string",
              "default": "draft",
              "values": [
                "draft",
                "published",
                "archived"
              ],
              "description": "Indicates the current state of the document.",
              "synonyms": "state, condition, lifecycle"
            },
            {
              "name": "version",
              "type": "number",
              "default": 1,
              "description": "Represents the version number of the document.",
              "synonyms": "revision, release, iteration"
            },
            {
              "name": "createdAt",
              "type": "string"
            },
            {
              "name": "updatedAt",
              "type": "string"
            }
          ]
        },
        "traits": [
          {
            "name": "DocumentEdit",
            "category": "interaction",
            "linkedEntity": "Document",
            "emits": [
              {
                "event": "OPEN",
                "description": "Signals the editor is being displayed.",
                "synonyms": "show, launch, reveal",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "title",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "blocksJson",
                        "type": "[BlockSpec]"
                      },
                      {
                        "name": "authorId",
                        "type": "string"
                      },
                      {
                        "name": "parentId",
                        "type": "string"
                      },
                      {
                        "name": "kind",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "version",
                        "type": "number"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      },
                      {
                        "name": "updatedAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "CLOSE_VIEW",
                "description": "Indicates the editor view is being closed.",
                "synonyms": "dismiss, hide, exit",
                "tier": "domain"
              },
              {
                "event": "BLOCKS_CHANGE",
                "description": "Signals that the content of a block has been modified.",
                "synonyms": "update, modify, changed, edit",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "event": "SAVE",
                "description": "Signals that changes have been saved.",
                "synonyms": "persist, update, commit",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "PUBLISH",
                "description": "Signals that content has been published.",
                "synonyms": "publish, release, finalize",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "DocumentLoaded",
                "description": "Signals that a document has been successfully loaded.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Document]"
                  }
                ]
              },
              {
                "event": "DocumentLoadFailed",
                "description": "Indicates that loading a document failed.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "DocumentSaved",
                "description": "Signals that a document has been successfully saved.",
                "synonyms": "saved, persisted, updated",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "title",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "blocksJson",
                        "type": "[BlockSpec]"
                      },
                      {
                        "name": "authorId",
                        "type": "string"
                      },
                      {
                        "name": "parentId",
                        "type": "string"
                      },
                      {
                        "name": "kind",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "version",
                        "type": "number"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      },
                      {
                        "name": "updatedAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "DocumentPublished",
                "description": "Indicates a document has been successfully published.",
                "synonyms": "published, released, finalized",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "title",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "blocksJson",
                        "type": "[BlockSpec]"
                      },
                      {
                        "name": "authorId",
                        "type": "string"
                      },
                      {
                        "name": "parentId",
                        "type": "string"
                      },
                      {
                        "name": "kind",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "version",
                        "type": "number"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      },
                      {
                        "name": "updatedAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "DocumentSaveFailed",
                "description": "Indicates that saving the document failed.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "editing"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "DocumentLoaded",
                  "name": "Document loaded",
                  "description": "Signals that a document has been successfully loaded.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[Document]"
                    }
                  ]
                },
                {
                  "key": "DocumentSaved",
                  "name": "Document saved",
                  "description": "Signals that a document has been successfully saved.",
                  "synonyms": "saved, persisted, updated",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "Document"
                    }
                  ]
                },
                {
                  "key": "DocumentPublished",
                  "name": "Document published",
                  "description": "Indicates a document has been successfully published.",
                  "synonyms": "published, released, finalized",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "Document"
                    }
                  ]
                },
                {
                  "key": "DocumentSaveFailed",
                  "name": "Document save failed",
                  "description": "Indicates that saving the document failed.",
                  "synonyms": "error, failure, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "DocumentLoadFailed",
                  "name": "Document load failed",
                  "description": "Indicates that loading a document failed.",
                  "synonyms": "error, failure, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "OPEN",
                  "name": "Open",
                  "description": "Signals the editor is being displayed.",
                  "synonyms": "show, launch, reveal",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "Document"
                    }
                  ]
                },
                {
                  "key": "PUBLISH",
                  "name": "Publish",
                  "description": "Signals that content has been published.",
                  "synonyms": "publish, release, finalize",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "BLOCKS_CHANGE",
                  "name": "Blocks Change",
                  "description": "Signals that the content of a block has been modified.",
                  "synonyms": "update, modify, changed, edit",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "blocks",
                      "type": "[ObjectSpec]"
                    }
                  ]
                },
                {
                  "key": "CLOSE_VIEW",
                  "name": "Close View",
                  "description": "Indicates the editor view is being closed.",
                  "synonyms": "dismiss, hide, exit",
                  "tier": "domain"
                },
                {
                  "key": "SAVE",
                  "name": "Save",
                  "description": "Signals that changes have been saved.",
                  "synonyms": "persist, update, commit",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "Document",
                      {
                        "emit": {
                          "success": "DocumentLoaded",
                          "failure": "DocumentLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "color": "muted",
                            "type": "typography",
                            "content": "Loading documents…",
                            "variant": "caption"
                          }
                        ],
                        "direction": "vertical",
                        "className": "py-12",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "DocumentLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "align": "center",
                            "children": [
                              {
                                "name": "file-text",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "content": "Documents",
                                "variant": "h3"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "type": "simple-grid",
                            "children": [
                              {
                                "type": "stat-display",
                                "look": "elevated",
                                "label": "Total docs",
                                "value": "@payload.data.length",
                                "icon": "file-text"
                              },
                              {
                                "value": "12",
                                "icon": "edit-3",
                                "look": "elevated",
                                "type": "stat-display",
                                "label": "Drafts"
                              },
                              {
                                "icon": "check-circle",
                                "look": "elevated",
                                "type": "stat-display",
                                "value": "84",
                                "label": "Published"
                              },
                              {
                                "value": "9",
                                "label": "Archived",
                                "type": "stat-display",
                                "icon": "archive",
                                "look": "elevated"
                              }
                            ],
                            "cols": 4
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "itemActions": [
                              {
                                "variant": "primary",
                                "event": "OPEN",
                                "icon": "edit",
                                "label": "Open"
                              },
                              {
                                "event": "PUBLISH",
                                "label": "Publish",
                                "variant": "secondary",
                                "icon": "send"
                              }
                            ],
                            "look": "dense",
                            "cols": 1,
                            "fields": [
                              {
                                "variant": "caption",
                                "label": "Title",
                                "name": "title"
                              },
                              {
                                "name": "kind",
                                "variant": "badge",
                                "label": "Kind"
                              },
                              {
                                "variant": "badge",
                                "label": "Status",
                                "name": "status"
                              },
                              {
                                "label": "v",
                                "variant": "caption",
                                "name": "version"
                              },
                              {
                                "variant": "caption",
                                "label": "Updated",
                                "name": "updatedAt"
                              }
                            ],
                            "type": "data-grid",
                            "gap": "sm",
                            "entity": "@payload.data"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "DocumentSaved",
                  "effects": [
                    [
                      "fetch",
                      "Document",
                      {
                        "emit": {
                          "failure": "DocumentLoadFailed",
                          "success": "DocumentLoaded"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "DocumentPublished",
                  "effects": [
                    [
                      "fetch",
                      "Document",
                      {
                        "emit": {
                          "failure": "DocumentLoadFailed",
                          "success": "DocumentLoaded"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "DocumentSaveFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "variant": "error",
                        "message": "@payload.error"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "DocumentLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "message": "@payload.error",
                        "variant": "error",
                        "type": "alert"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "editing",
                  "event": "OPEN",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.row.id"
                    ],
                    [
                      "set",
                      "@entity.title",
                      "@payload.row.title"
                    ],
                    [
                      "set",
                      "@entity.blocksJson",
                      "@payload.row.blocksJson"
                    ],
                    [
                      "set",
                      "@entity.authorId",
                      "@payload.row.authorId"
                    ],
                    [
                      "set",
                      "@entity.parentId",
                      "@payload.row.parentId"
                    ],
                    [
                      "set",
                      "@entity.kind",
                      "@payload.row.kind"
                    ],
                    [
                      "set",
                      "@entity.status",
                      "@payload.row.status"
                    ],
                    [
                      "set",
                      "@entity.version",
                      "@payload.row.version"
                    ],
                    [
                      "set",
                      "@entity.createdAt",
                      "@payload.row.createdAt"
                    ],
                    [
                      "set",
                      "@entity.updatedAt",
                      "@payload.row.updatedAt"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "gap": "sm",
                            "align": "center",
                            "type": "stack",
                            "children": [
                              {
                                "variant": "ghost",
                                "label": "Back",
                                "action": "CLOSE_VIEW",
                                "type": "button"
                              },
                              {
                                "name": "file-text",
                                "type": "icon"
                              },
                              {
                                "variant": "h3",
                                "content": "@entity.title",
                                "type": "typography"
                              },
                              {
                                "type": "badge",
                                "label": "@entity.status",
                                "variant": "secondary"
                              }
                            ],
                            "direction": "horizontal"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "showToolbar": true,
                            "placeholder": "Start writing…",
                            "initialBlocks": "@entity.blocksJson",
                            "changeEvent": "BLOCKS_CHANGE",
                            "type": "rich-block-editor"
                          },
                          {
                            "type": "stack",
                            "children": [
                              {
                                "actionPayload": {
                                  "id": "@entity.id"
                                },
                                "label": "Save",
                                "action": "SAVE",
                                "variant": "primary",
                                "type": "button"
                              },
                              {
                                "type": "button",
                                "variant": "secondary",
                                "action": "PUBLISH",
                                "actionPayload": {
                                  "id": "@entity.id"
                                },
                                "label": "Publish"
                              }
                            ],
                            "gap": "sm",
                            "align": "center",
                            "direction": "horizontal"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "PUBLISH",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "fetch",
                      "Document",
                      {
                        "emit": {
                          "failure": "DocumentLoadFailed",
                          "success": "DocumentLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "color": "muted",
                            "content": "Publishing document…",
                            "type": "typography"
                          }
                        ],
                        "align": "center",
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "editing",
                  "to": "editing",
                  "event": "BLOCKS_CHANGE",
                  "effects": [
                    [
                      "set",
                      "@entity.blocksJson",
                      "@payload.blocks"
                    ]
                  ]
                },
                {
                  "from": "editing",
                  "to": "loading",
                  "event": "CLOSE_VIEW",
                  "effects": [
                    [
                      "fetch",
                      "Document",
                      {
                        "emit": {
                          "success": "DocumentLoaded",
                          "failure": "DocumentLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Loading documents…",
                            "type": "typography",
                            "variant": "caption",
                            "color": "muted"
                          }
                        ],
                        "direction": "vertical",
                        "className": "py-12",
                        "gap": "md",
                        "align": "center",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "editing",
                  "to": "loading",
                  "event": "SAVE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "persist",
                      "update",
                      "Document",
                      "@entity",
                      {
                        "emit": {
                          "success": "DocumentSaved",
                          "failure": "DocumentSaveFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "gap": "md",
                        "type": "stack",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "color": "muted",
                            "type": "typography",
                            "content": "Saving document…",
                            "variant": "caption"
                          }
                        ],
                        "align": "center",
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "editing",
                  "to": "loading",
                  "event": "PUBLISH",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "set",
                      "@entity.status",
                      "published"
                    ],
                    [
                      "persist",
                      "update",
                      "Document",
                      "@entity",
                      {
                        "emit": {
                          "failure": "DocumentSaveFailed",
                          "success": "DocumentPublished"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "className": "py-12",
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "type": "typography",
