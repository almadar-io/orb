{
  "name": "ui-wizard-progress",
  "description": "WizardProgress — UI factory (1:1 with the @almadar/ui wizard-progress pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-wizard-progress",
    "version": "1.0.0",
    "description": "WizardProgress — UI factory (1:1 with the @almadar/ui wizard-progress pattern).",
    "orbitals": [
      {
        "name": "WizardProgressOrbital",
        "entity": {
          "name": "WizardProgressItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "WizardProgressRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "WizardProgressItem",
            "emits": [
              {
                "event": "STEP_CLICK",
                "description": "Callback when a completed step is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "stepIndex",
                    "type": "number"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "STEP_CLICK",
                  "name": "Step Click",
                  "description": "Callback when a completed step is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "stepIndex",
                      "type": "number"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "wizard-progress",
                        "className": "",
                        "stepClickEvent": "STEP_CLICK",
                        "onStepClick": "STEP_CLICK",
                        "allowNavigation": true,
                        "compact": false,
                        "currentStep": 1,
                        "steps": [
                          {
                            "title": "Title",
                            "description": "Description",
                            "id": "Id"
                          },
                          {
                            "id": "Id 2",
                            "description": "Description 2",
                            "title": "Title 2"
                          }
                        ]
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "currentStep": {
                "type": "number",
                "default": 1,
                "label": "Current Step",
                "description": "Current step index (0-based)",
                "tier": "presentation"
              },
              "allowNavigation": {
                "type": "boolean",
                "default": true,
                "label": "Allow Navigation",
                "description": "Allow clicking on completed steps to navigate back",
                "tier": "presentation"
              },
              "steps": {
                "type": "[WizardProgressStepsItem]",
                "default": [
                  {
                    "title": "Title",
                    "description": "Description",
                    "id": "Id"
                  },
                  {
                    "id": "Id 2",
                    "description": "Description 2",
                    "title": "Title 2"
                  }
                ],
                "label": "Steps",
                "description": "Step definitions (compatible with WizardContainer's WizardStep). A string is shorthand for `{ id: str, title: str }`.",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "description": {
                      "name": "description",
                      "type": "string",
                      "required": false
                    },
                    "title": {
                      "name": "title",
                      "type": "string",
                      "required": true
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "compact": {
                "type": "boolean",
                "default": false,
                "label": "Compact",
                "description": "Compact mode (smaller, no titles)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "WizardProgressPage",
            "path": "/wizard-progress",
            "traits": [
              {
                "ref": "WizardProgressRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "WizardProgressOrbital": [
          {
            "trait": "WizardProgressRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "WizardProgressRender",
            "patternPath": "root",
            "prop": "allowNavigation",
            "knob": "allowNavigation"
          },
          {
            "trait": "WizardProgressRender",
            "patternPath": "root",
            "prop": "compact",
            "knob": "compact"
          },
          {
            "trait": "WizardProgressRender",
            "patternPath": "root",
            "prop": "currentStep",
            "knob": "currentStep"
          },
          {
            "trait": "WizardProgressRender",
            "patternPath": "root",
            "prop": "steps",
            "knob": "steps"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}