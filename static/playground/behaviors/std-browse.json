{
  "name": "std-browse",
  "description": "std-browse as a Function — single primitive: data-grid. Owns the fetch + REFETCH (query/filter/page) state machine. Consumers configure fields/imageField/itemActions/cols/gap/variant; the atom renders the grid. Each `fields[]` entry accepts `{ name, label, variant }` plus optional `referenceEntity` + `displayField` to render a foreign-key column as the joined entity's display value (data-grid resolves @list[referenceEntity] at render time when both keys are present).",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-browse",
    "version": "2.2.0",
    "description": "std-browse as a Function — single primitive: data-grid. Owns the fetch + REFETCH (query/filter/page) state machine. Consumers configure fields/imageField/itemActions/cols/gap/variant; the atom renders the grid. Each `fields[]` entry accepts `{ name, label, variant }` plus optional `referenceEntity` + `displayField` to render a foreign-key column as the joined entity's display value (data-grid resolves @list[referenceEntity] at render time when both keys are present).",
    "orbitals": [
      {
        "name": "BrowseItemOrbital",
        "entity": {
          "name": "BrowseItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "name",
              "type": "string",
              "required": true,
              "description": "The item's identifier or title.",
              "synonyms": "title, label, itemName"
            },
            {
              "name": "description",
              "type": "string",
              "description": "A textual explanation or summary of the item.",
              "synonyms": "summary, details, notes, explanation"
            },
            {
              "name": "status",
              "type": "string",
              "default": "active",
              "values": [
                "active",
                "inactive",
                "pending"
              ],
              "description": "Indicates the current operational state of the item.",
              "synonyms": "state, condition, flag"
            },
            {
              "name": "createdAt",
              "type": "string"
            }
          ]
        },
        "traits": [
          {
            "name": "BrowseItemBrowse",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "BrowseItem",
            "emits": [
              {
                "event": "BrowseItemLoaded",
                "description": "Signals that a browse item has been successfully loaded.",
                "synonyms": "loaded, received, populated",
                "tier": "domain",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BrowseItem]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "event": "BrowseItemLoadFailed",
                "description": "Indicates a failure to load a browse item.",
                "synonyms": "error, failed, problem, unsuccessful",
                "tier": "internal",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "VIEW",
                "description": "Signals a grid view has been displayed or updated.",
                "synonyms": "display, show, update, render",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "EDIT",
                "description": "Signals a request to edit the selected item.",
                "synonyms": "modify, update, change",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "DELETE",
                "description": "Signals a request to remove an item from the dataset.",
                "synonyms": "remove, discard, delete, purge",
                "tier": "presentation",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "BrowseItemLoaded",
                  "name": "BrowseItem loaded",
                  "description": "Signals that a browse item has been successfully loaded.",
                  "synonyms": "loaded, received, populated",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[BrowseItem]"
                    },
                    {
                      "name": "totalCount",
                      "type": "number"
                    }
                  ]
                },
                {
                  "key": "BrowseItemLoadFailed",
                  "name": "BrowseItem load failed",
                  "description": "Indicates a failure to load a browse item.",
                  "synonyms": "error, failed, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "REFETCH_QUERY",
                  "name": "Refetch Query",
                  "description": "Triggers a data refresh based on the current query.",
                  "synonyms": "refresh, reload, update, re-query",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "searchTerm",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "REFETCH_FILTER",
                  "name": "Refetch Filter",
                  "description": "Triggers a data refresh based on current filter criteria.",
                  "synonyms": "refresh, filter, update, reload",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "field",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "value",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "REFETCH_PAGE",
                  "name": "Refetch Page",
                  "description": "Triggers a data grid page refresh.",
                  "synonyms": "reload, refresh, update, paginate",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "page",
                      "type": "number",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "VIEW",
                  "name": "View",
                  "description": "Signals a grid view has been displayed or updated.",
                  "synonyms": "display, show, update, render",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "object",
                      "properties": [
                        {
                          "name": "id",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "type": "string"
                        },
                        {
                          "name": "status",
                          "type": "string"
                        },
                        {
                          "name": "createdAt",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                },
                {
                  "key": "EDIT",
                  "name": "Edit",
                  "description": "Signals a request to edit the selected item.",
                  "synonyms": "modify, update, change",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "object",
                      "properties": [
                        {
                          "name": "id",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "type": "string"
                        },
                        {
                          "name": "status",
                          "type": "string"
                        },
                        {
                          "name": "createdAt",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                },
                {
                  "key": "DELETE",
                  "name": "Delete",
                  "description": "Signals a request to remove an item from the dataset.",
                  "synonyms": "remove, discard, delete, purge",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "object",
                      "properties": [
                        {
                          "name": "id",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "type": "string"
                        },
                        {
                          "name": "status",
                          "type": "string"
                        },
                        {
                          "name": "createdAt",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "BrowseItem",
                      {
                        "offset": 0,
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        },
                        "limit": 10
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "size": "sm",
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "BrowseItemLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "fields": [
                              {
                                "label": "Name",
                                "name": "name",
                                "variant": "h4"
                              },
                              {
                                "name": "description",
                                "label": "Description",
                                "variant": "caption"
                              },
                              {
                                "label": "Status",
                                "variant": "badge",
                                "name": "status"
                              }
                            ],
                            "type": "data-grid",
                            "pageSize": 10,
                            "gap": "md",
                            "imageField": "",
                            "entity": "@payload.data",
                            "cols": 1,
                            "itemActions": []
                          }
                        ],
                        "type": "stack",
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "BrowseItemLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "content": "@payload.error",
                        "type": "typography",
                        "color": "error",
                        "variant": "caption"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "BrowseItem",
                      {
                        "offset": 0,
                        "emit": {
                          "failure": "BrowseItemLoadFailed",
                          "success": "BrowseItemLoaded"
                        },
                        "limit": 10
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "size": "sm",
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REFETCH_QUERY",
                  "effects": [
                    [
                      "fetch",
                      "BrowseItem",
                      {
                        "offset": 0,
                        "filter": [
                          "or",
                          [
                            "=",
                            "@payload.searchTerm",
                            ""
                          ],
                          [
                            "str/includes",
                            [
                              "object/get",
                              "@entity",
                              "name"
                            ],
                            "@payload.searchTerm"
                          ]
                        ],
                        "limit": 10,
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REFETCH_FILTER",
                  "effects": [
                    [
                      "fetch",
                      "BrowseItem",
                      {
                        "filter": [
                          "or",
                          [
                            "=",
                            "@payload.value",
                            ""
                          ],
                          [
                            "=",
                            [
                              "object/get",
                              "@entity",
                              "@payload.field"
                            ],
                            "@payload.value"
                          ]
                        ],
                        "offset": 0,
                        "emit": {
                          "failure": "BrowseItemLoadFailed",
                          "success": "BrowseItemLoaded"
                        },
                        "limit": 10
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REFETCH_PAGE",
                  "effects": [
                    [
                      "fetch",
                      "BrowseItem",
                      {
                        "limit": 10,
                        "offset": [
                          "*",
                          [
                            "-",
                            "@payload.page",
                            1
                          ],
                          10
                        ],
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "BrowseItemLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "fields": [
                              {
                                "label": "Name",
                                "name": "name",
                                "variant": "h4"
                              },
                              {
                                "name": "description",
                                "label": "Description",
                                "variant": "caption"
                              },
                              {
                                "label": "Status",
                                "variant": "badge",
                                "name": "status"
                              }
                            ],
                            "type": "data-grid",
                            "pageSize": 10,
                            "gap": "md",
                            "imageField": "",
                            "entity": "@payload.data",
                            "cols": 1,
                            "itemActions": []
                          }
                        ],
                        "type": "stack",
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "BrowseItem",
                      {
                        "offset": 0,
                        "limit": 10,
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "sm"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "imageLabelBinding": {
                "type": "string",
                "default": "@item.thumbnailLabel",
                "label": "Image label binding",
                "description": "Binding path for the image-area label slot.",
                "tier": "internal"
              },
              "filters": {
                "type": "[FilterSpec]",
                "default": [],
                "label": "Which filters should appear above the list?",
                "description": "Dropdown filter facets by field. Each fires a refetch when the user changes the selection. Empty = no filter bar.",
                "synonyms": "filter bar, faceted filters, field filters, column filters, dropdowns",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "options": {
                      "name": "options",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    },
                    "field": {
                      "name": "field",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "gap": {
                "type": "string",
                "default": "md",
                "label": "Spacing between rows",
                "description": "Gap between grid cells: sm, md, or lg.",
                "synonyms": "row gap, cell spacing, grid gap, padding between items",
                "tier": "presentation"
              },
              "maxInlineActions": {
                "type": "number",
                "default": 99,
                "label": "How many row actions to show before collapsing?",
                "description": "Actions beyond this count collapse into a '⋯' overflow menu. Set 2–3 for dense tables.",
                "synonyms": "inline actions limit, overflow threshold, max buttons per row",
                "tier": "presentation"
              },
              "metaBinding": {
                "type": "string",
                "default": "@item.createdAt",
                "label": "Meta field binding",
                "description": "Binding path for the secondary meta slot (timestamp / category).",
                "tier": "internal"
              },
              "itemActions": {
                "type": "[ItemAction]",
                "default": [],
                "label": "What actions can users take on each row?",
                "description": "Buttons rendered on each row (e.g. Edit, Delete, View).",
                "synonyms": "row buttons, row actions, item actions, per-row buttons, table actions",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": true
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "titleBinding": {
                "type": "string",
                "default": "@item.name",
                "label": "Title field binding",
                "description": "Binding path for the card title slot (e.g. @item.dishName).",
                "tier": "internal"
              },
              "columns": {
                "type": "[ColumnSpec]",
                "default": [
                  {
                    "header": "Name",
                    "weight": "medium",
                    "key": "name",
                    "align": "left",
                    "field": "name"
                  },
                  {
                    "key": "description",
                    "header": "Detail",
                    "align": "left",
                    "field": "description"
                  },
                  {
                    "format": "badge",
                    "header": "Status",
                    "field": "status",
                    "key": "status",
                    "align": "center"
                  }
                ],
                "label": "Table columns",
                "description": "Column definitions for table-style variants (dense). Each maps an entity field to a column with optional width / align / weight / format.",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "className": {
                      "name": "className",
                      "type": "string",
                      "required": false
                    },
                    "width": {
                      "name": "width",
                      "type": "string",
                      "required": false
                    },
                    "align": {
                      "name": "align",
                      "type": "string",
                      "required": false
                    },
                    "header": {
                      "name": "header",
                      "type": "string",
                      "required": false
                    },
                    "format": {
                      "name": "format",
                      "type": "string",
                      "required": false
                    },
                    "key": {
                      "name": "key",
                      "type": "string",
                      "required": true
                    },
                    "field": {
                      "name": "field",
                      "type": "string",
                      "required": false
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "weight": {
                      "name": "weight",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "bodyContent": {
                "type": "render-ui",
                "default": {
                  "children": [
                    {
                      "fields": "@config.fields",
                      "type": "data-grid",
                      "pageSize": "@config.displayPageSize",
                      "gap": "@config.gap",
                      "imageField": "@config.imageField",
                      "entity": "@payload.data",
                      "cols": "@config.cols",
                      "itemActions": "@config.itemActions"
                    }
                  ],
                  "type": "stack",
                  "direction": "vertical"
                },
                "label": "Body content tree",
                "description": "Render-ui SExpr rendered after rows load. Default is the canonical data-grid call wrapped in a stack. Layer 3 variants override this with their own tree (composing data-list/data-grid/entity-table + custom renderItem lambdas + filter-group, kbd, card, etc.) to deliver entirely different browse UX while inheriting the same trait, state machine, emits, and listens.",
                "tier": "internal"
              },
              "categoryBinding": {
                "type": "string",
                "default": "@item.category",
                "label": "Category field binding",
                "description": "Binding path for the category/tag slot.",
                "tier": "internal"
              },
              "badgeBinding": {
                "type": "string",
                "default": "@item.status",
                "label": "Badge field binding",
                "description": "Binding path for the status/badge slot.",
                "tier": "internal"
              },
              "displayPageSize": {
                "type": "number",
                "default": 10,
                "label": "How many rows to show at once?",
                "description": "Rows visible per page before the pagination control appears.",
                "synonyms": "visible rows, items per page, display limit, show per page",
                "tier": "presentation"
              },
              "cols": {
                "type": "number",
                "default": 1,
                "label": "How many columns in the grid?",
                "description": "Number of columns in the responsive card/grid layout.",
                "synonyms": "columns, grid width, card columns, num columns",
                "tier": "presentation"
              },
              "assigneeBinding": {
                "type": "string",
                "default": "@item.assignee",
                "label": "Assignee field binding",
                "description": "Binding path for the assignee/owner slot.",
                "tier": "internal"
              },
              "descriptionBinding": {
                "type": "string",
                "default": "@item.description",
                "label": "Description field binding",
                "description": "Binding path for the card body/subtitle slot.",
                "tier": "internal"
              },
              "pageSize": {
                "type": "number",
                "default": 10,
                "label": "How many rows to fetch per page?",
                "description": "Records fetched from the server per page request.",
                "synonyms": "fetch limit, records per page, batch size, page limit",
                "tier": "presentation"
              },
              "fields": {
                "type": "[FieldSpec]",
                "default": [
                  {
                    "label": "Name",
                    "name": "name",
                    "variant": "h4"
                  },
                  {
                    "name": "description",
