{
  "name": "ui-progress-dots",
  "description": "ProgressDots — UI factory (1:1 with the @almadar/ui progress-dots pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-progress-dots",
    "version": "1.0.0",
    "description": "ProgressDots — UI factory (1:1 with the @almadar/ui progress-dots pattern).",
    "orbitals": [
      {
        "name": "ProgressDotsOrbital",
        "entity": {
          "name": "ProgressDotsItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ProgressDotsRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ProgressDotsItem",
            "emits": [
              {
                "event": "DOT_CLICK",
                "description": "Callback when a dot is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "DOT_CLICK",
                  "name": "Dot Click",
                  "description": "Callback when a dot is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "index",
                      "type": "number"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "count": 1,
                        "onDotClick": "DOT_CLICK",
                        "type": "progress-dots",
                        "currentIndex": 1,
                        "size": "md",
                        "className": ""
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "currentIndex": {
                "type": "number",
                "default": 1,
                "label": "Current Index",
                "description": "Current active index (0-based)",
                "tier": "presentation"
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Dot size",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg"
                ]
              },
              "count": {
                "type": "number",
                "default": 1,
                "label": "Count",
                "description": "Total number of dots",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ProgressDotsPage",
            "path": "/progress-dots",
            "traits": [
              {
                "ref": "ProgressDotsRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ProgressDotsOrbital": [
          {
            "trait": "ProgressDotsRender",
            "patternPath": "root",
            "prop": "count",
            "knob": "count"
          },
          {
            "trait": "ProgressDotsRender",
            "patternPath": "root",
            "prop": "currentIndex",
            "knob": "currentIndex"
          },
          {
            "trait": "ProgressDotsRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "ProgressDotsRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}