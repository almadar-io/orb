{
  "name": "ui-pull-to-refresh",
  "description": "PullToRefresh — UI factory (1:1 with the @almadar/ui pull-to-refresh pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-pull-to-refresh",
    "version": "1.0.0",
    "description": "PullToRefresh — UI factory (1:1 with the @almadar/ui pull-to-refresh pattern).",
    "orbitals": [
      {
        "name": "PullToRefreshOrbital",
        "entity": {
          "name": "PullToRefreshItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "PullToRefreshRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "PullToRefreshItem",
            "emits": [
              {
                "event": "REFRESH",
                "description": "Event name to emit on refresh (emitted as UI:{refreshEvent})",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "REFRESH",
                  "name": "Refresh",
                  "description": "Event name to emit on refresh (emitted as UI:{refreshEvent})",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "type": "typography",
                            "content": "Sample content"
                          }
                        ],
                        "refreshPayload": {},
                        "type": "pull-to-refresh",
                        "threshold": 60,
                        "className": "",
                        "refreshEvent": "REFRESH"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "refreshPayload": {
                "type": "json",
                "default": {},
                "label": "Refresh Payload",
                "description": "Payload to include with the refresh event",
                "tier": "presentation"
              },
              "threshold": {
                "type": "number",
                "default": 60,
                "label": "Threshold",
                "description": "Pull distance threshold to trigger refresh in px (default: 60)",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "PullToRefreshPage",
            "path": "/pull-to-refresh",
            "traits": [
              {
                "ref": "PullToRefreshRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "PullToRefreshOrbital": [
          {
            "trait": "PullToRefreshRender",
            "patternPath": "root",
            "prop": "refreshPayload",
            "knob": "refreshPayload"
          },
          {
            "trait": "PullToRefreshRender",
            "patternPath": "root",
            "prop": "threshold",
            "knob": "threshold"
          },
          {
            "trait": "PullToRefreshRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
