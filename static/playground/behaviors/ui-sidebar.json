{
  "name": "ui-sidebar",
  "description": "Sidebar — UI factory (1:1 with the @almadar/ui sidebar pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-sidebar",
    "version": "1.0.0",
    "description": "Sidebar — UI factory (1:1 with the @almadar/ui sidebar pattern).",
    "orbitals": [
      {
        "name": "SidebarOrbital",
        "entity": {
          "name": "SidebarItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "collapsed",
              "type": "boolean",
              "default": false
            }
          ]
        },
        "traits": [
          {
            "name": "SidebarRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "collapsed"
              ]
            },
            "category": "interaction",
            "linkedEntity": "SidebarItem",
            "emits": [
              {
                "event": "COLLAPSE_CHANGE",
                "description": "Event emitted when collapse state changes, payload: { collapsed: boolean }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "collapsed",
                    "type": "boolean",
                    "required": true
                  }
                ]
              },
              {
                "event": "CLOSE",
                "description": "Event emitted when close button is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "LOGO_CLICK",
                "description": "Event emitted when logo/brand is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "COLLAPSE_CHANGE",
                  "name": "Collapse Change",
                  "description": "Event emitted when collapse state changes, payload: { collapsed: boolean }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "collapsed",
                      "type": "boolean",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "Event emitted when close button is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "LOGO_CLICK",
                  "name": "Logo Click",
                  "description": "Event emitted when logo/brand is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.collapsed",
                      false
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "sidebar",
                        "collapsed": "@entity.collapsed",
                        "footerContent": "@config.footerContent",
                        "logoClickEvent": "LOGO_CLICK",
                        "brandName": "KFlow",
                        "collapseChangeEvent": "COLLAPSE_CHANGE",
                        "closeEvent": "CLOSE",
                        "hideCollapseButton": false,
                        "showCloseButton": false,
                        "items": [
                          {
                            "isActive": false,
                            "badge": "Badge",
                            "active": false,
                            "label": "Label",
                            "icon": "circle",
                            "id": "Id",
                            "href": "Href",
                            "subItems": []
                          },
                          {
                            "id": "Id 2",
                            "active": true,
                            "icon": "circle",
                            "isActive": true,
                            "badge": "Badge 2",
                            "label": "Label 2",
                            "href": "Href 2",
                            "subItems": []
                          }
                        ],
                        "logoSrc": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                        "userSection": "@config.userSection",
                        "className": "",
                        "defaultCollapsed": false,
                        "logo": [
                          {
                            "content": "Logo",
                            "type": "typography"
                          }
                        ],
                        "error": "@config.error",
                        "isLoading": false
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "COLLAPSE_CHANGE",
                  "effects": [
                    [
                      "set",
                      "@entity.collapsed",
                      "@payload.collapsed"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "sidebar",
                        "userSection": "@config.userSection",
                        "items": [
                          {
                            "isActive": false,
                            "badge": "Badge",
                            "active": false,
                            "label": "Label",
                            "icon": "circle",
                            "id": "Id",
                            "href": "Href",
                            "subItems": []
                          },
                          {
                            "id": "Id 2",
                            "active": true,
                            "icon": "circle",
                            "isActive": true,
                            "badge": "Badge 2",
                            "label": "Label 2",
                            "href": "Href 2",
                            "subItems": []
                          }
                        ],
                        "brandName": "KFlow",
                        "logoClickEvent": "LOGO_CLICK",
                        "footerContent": "@config.footerContent",
                        "collapsed": "@entity.collapsed",
                        "collapseChangeEvent": "COLLAPSE_CHANGE",
                        "error": "@config.error",
                        "defaultCollapsed": false,
                        "logoSrc": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                        "logo": [
                          {
                            "content": "Logo",
                            "type": "typography"
                          }
                        ],
                        "className": "",
                        "isLoading": false,
                        "hideCollapseButton": false,
                        "closeEvent": "CLOSE",
                        "showCloseButton": false
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "defaultCollapsed": {
                "type": "boolean",
                "default": false,
                "label": "Default Collapsed",
                "description": "Default collapsed state",
                "tier": "presentation"
              },
              "hideCollapseButton": {
                "type": "boolean",
                "default": false,
                "label": "Hide Collapse Button",
                "description": "Hide the collapse/expand button",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "userSection": {
                "type": "node",
                "label": "User Section",
                "description": "User section content",
                "tier": "presentation"
              },
              "items": {
                "type": "[SidebarItemsItem]",
                "default": [
                  {
                    "isActive": false,
                    "badge": "Badge",
                    "active": false,
                    "label": "Label",
                    "icon": "circle",
                    "id": "Id",
                    "href": "Href",
                    "subItems": []
                  },
                  {
                    "id": "Id 2",
                    "active": true,
                    "icon": "circle",
                    "isActive": true,
                    "badge": "Badge 2",
                    "label": "Label 2",
                    "href": "Href 2",
                    "subItems": []
                  }
                ],
                "label": "Items",
                "description": "Navigation items",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "active": {
                      "name": "active",
                      "type": "boolean",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "badge": {
                      "name": "badge",
                      "type": "string",
                      "required": false
                    },
                    "subItems": {
                      "name": "subItems",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    "isActive": {
                      "name": "isActive",
                      "type": "boolean",
                      "required": false
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "href": {
                      "name": "href",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "brandName": {
                "type": "string",
                "default": "KFlow",
                "label": "Brand Name",
                "description": "Brand/App name",
                "tier": "presentation"
              },
              "error": {
                "type": "SidebarError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "logoSrc": {
                "type": "asset",
                "default": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                "label": "Logo Src",
                "description": "Logo image source",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "showCloseButton": {
                "type": "boolean",
                "default": false,
                "label": "Show Close Button",
                "description": "Show a close button (for mobile)",
                "tier": "presentation"
              },
              "collapsed": {
                "type": "boolean",
                "default": false,
                "label": "Collapsed",
                "description": "Collapsed state (controlled)",
                "tier": "presentation"
              },
              "footerContent": {
                "type": "node",
                "label": "Footer Content",
                "description": "Footer content (e.g., theme toggle)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SidebarPage",
            "path": "/sidebar",
            "traits": [
              {
                "ref": "SidebarRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "SidebarOrbital": [
          {
            "trait": "SidebarRender",
            "patternPath": "root",
            "prop": "brandName",
            "knob": "brandName"
          },
          {
            "trait": "SidebarRender",
            "patternPath": "root",
            "prop": "hideCollapseButton",
            "knob": "hideCollapseButton"
          },
          {
            "trait": "SidebarRender",
            "patternPath": "root",
            "prop": "showCloseButton",
            "knob": "showCloseButton"
          },
          {
            "trait": "SidebarRender",
            "patternPath": "root",
            "prop": "items",
            "knob": "items"
          },
          {
            "trait": "SidebarRender",
            "patternPath": "root",
            "prop": "logoSrc",
            "knob": "logoSrc"
          },
          {
            "trait": "SidebarRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "SidebarRender",
            "patternPath": "root",
