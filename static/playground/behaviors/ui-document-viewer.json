            "knob": "totalPages"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "src",
            "knob": "src"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "actions",
            "knob": "actions"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "content",
            "knob": "content"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "showToolbar",
            "knob": "showToolbar"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "documentType",
            "knob": "documentType"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "height",
            "knob": "height"
          }
        ]
      }
    }
  },
