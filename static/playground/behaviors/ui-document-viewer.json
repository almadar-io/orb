{
  "name": "ui-document-viewer",
  "description": "DocumentViewer — UI factory (1:1 with the @almadar/ui document-viewer pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-document-viewer",
    "version": "1.0.0",
    "description": "DocumentViewer — UI factory (1:1 with the @almadar/ui document-viewer pattern).",
    "orbitals": [
      {
        "name": "DocumentViewerOrbital",
        "entity": {
          "name": "DocumentViewerItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "DocumentViewerRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "DocumentViewerItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "documents": [
                          {
                            "label": "Label",
                            "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                            "content": "Content",
                            "documentType": "pdf"
                          },
                          {
                            "content": "Content 2",
                            "label": "Label 2",
                            "documentType": "text",
                            "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                          }
                        ],
                        "showPrint": false,
                        "showDownload": false,
                        "error": "@config.error",
                        "currentPage": 0,
                        "totalPages": 0,
                        "title": "Title",
                        "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                        "actions": [
                          {
                            "navigatesTo": "Navigates To",
                            "label": "Label",
                            "variant": "primary"
                          },
                          {
                            "variant": "secondary",
                            "label": "Label 2",
                            "navigatesTo": "Navigates To 2"
                          }
                        ],
                        "className": "",
                        "isLoading": false,
                        "type": "document-viewer",
                        "content": "Content",
                        "showToolbar": true,
                        "documentType": "pdf",
                        "height": "Height"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "totalPages": {
                "type": "number",
                "default": 0,
                "label": "Total Pages",
                "description": "Total pages",
                "tier": "presentation"
              },
              "error": {
                "type": "DocumentViewerError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  }
                }
              },
              "documents": {
                "type": "[DocumentViewerDocumentsItem]",
                "default": [
                  {
                    "label": "Label",
                    "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                    "content": "Content",
                    "documentType": "pdf"
                  },
                  {
                    "content": "Content 2",
                    "label": "Label 2",
                    "documentType": "text",
                    "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  }
                ],
                "label": "Documents",
                "description": "Multiple documents (tabbed view)",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "documentType": {
                      "name": "documentType",
                      "type": "string",
                      "required": false,
                      "values": [
                        "pdf",
                        "text",
                        "html",
                        "markdown"
                      ]
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "src": {
                      "name": "src",
                      "type": "string",
                      "required": false
                    },
                    "content": {
                      "name": "content",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "showToolbar": {
                "type": "boolean",
                "default": true,
                "label": "Show Toolbar",
                "description": "Show toolbar",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Document title",
                "tier": "presentation"
              },
              "src": {
                "type": "asset",
                "default": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                "label": "Src",
                "description": "Document URL (for PDF/external documents)",
                "tier": "presentation"
              },
              "height": {
                "type": "string",
                "default": "Height",
                "label": "Height",
                "description": "Viewer height",
                "tier": "presentation"
              },
              "showPrint": {
                "type": "boolean",
                "default": false,
                "label": "Show Print",
                "description": "Show print button",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "content": {
                "type": "string",
                "default": "Content",
                "label": "Content",
                "description": "Document content (for text/html/markdown)",
                "tier": "presentation"
              },
              "currentPage": {
                "type": "number",
                "default": 0,
                "label": "Current Page",
                "description": "Current page (for multi-page documents)",
                "tier": "presentation"
              },
              "documentType": {
                "type": "string",
                "default": "pdf",
                "label": "Document Type",
                "description": "Document type",
                "tier": "presentation",
                "values": [
                  "pdf",
                  "text",
                  "html",
                  "markdown"
                ]
              },
              "actions": {
                "type": "[DocumentViewerActionsItem]",
                "default": [
                  {
                    "navigatesTo": "Navigates To",
                    "label": "Label",
                    "variant": "primary"
                  },
                  {
                    "variant": "secondary",
                    "label": "Label 2",
                    "navigatesTo": "Navigates To 2"
                  }
                ],
                "label": "Actions",
                "description": "Actions",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "navigatesTo": {
                      "name": "navigatesTo",
                      "type": "string",
                      "required": false
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": false
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost"
                      ]
                    }
                  }
                }
              },
              "showDownload": {
                "type": "boolean",
                "default": false,
                "label": "Show Download",
                "description": "Show download button",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "DocumentViewerPage",
            "path": "/document-viewer",
            "traits": [
              {
                "ref": "DocumentViewerRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "DocumentViewerOrbital": [
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "documents",
            "knob": "documents"
          },
          {
            "trait": "DocumentViewerRender",
            "patternPath": "root",
            "prop": "showPrint",
            "knob": "showPrint"
          },
          {
            "trait": "DocumentViewerRender",
