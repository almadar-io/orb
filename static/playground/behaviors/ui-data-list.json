{
  "name": "ui-data-list",
  "description": "DataList — UI factory (1:1 with the @almadar/ui data-list pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-data-list",
    "version": "1.0.0",
    "description": "DataList — UI factory (1:1 with the @almadar/ui data-list pattern).",
    "orbitals": [
      {
        "name": "DataListOrbital",
        "entity": {
          "name": "DataListItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "DataListRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "DataListItem",
            "emits": [
              {
                "event": "REORDER",
                "description": "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "ITEM_CLICK",
                "description": "When set, the whole row is clickable and emits UI:{itemClickEvent} with { id, row } (action-button clicks stopPropagation so they still win).",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "SWIPE_LEFT",
                "description": "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "SWIPE_RIGHT",
                "description": "Event emitted on right swipe: UI:{swipeRightEvent} with { row }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "LONG_PRESS",
                "description": "Event emitted on long press: UI:{longPressEvent} with { row }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "LOAD_MORE",
                "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "VIEW",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "DataListLoaded",
                "description": "DataList rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DataListItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "DataListLoaded",
                  "name": "Data list loaded",
                  "description": "DataList rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[DataListItem]"
                    }
                  ]
                },
                {
                  "key": "VIEW",
                  "name": "View",
                  "description": "User opened a record from the list.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "REORDER",
                  "name": "Reorder",
                  "description": "Event emitted on reorder: UI:{reorderEvent} with { fromIndex, toIndex }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "ITEM_CLICK",
                  "name": "Item Click",
