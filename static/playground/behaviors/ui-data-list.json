                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SWIPE_LEFT",
                  "name": "Swipe Left",
                  "description": "Event emitted on left swipe: UI:{swipeLeftEvent} with { row }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SWIPE_RIGHT",
                  "name": "Swipe Right",
                  "description": "Event emitted on right swipe: UI:{swipeRightEvent} with { row }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "LONG_PRESS",
                  "name": "Long Press",
                  "description": "Event emitted on long press: UI:{longPressEvent} with { row }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "LOAD_MORE",
                  "name": "Load More",
                  "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "DataListItem",
                      {
                        "emit": {
                          "success": "DataListLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "dndItemIdField": "Dnd Item Id Field",
                        "hasMore": false,
                        "infiniteScroll": false,
                        "itemActions": [
                          {
                            "event": "VIEW",
                            "label": "View"
                          }
                        ],
                        "isLoading": false,
                        "variant": "default",
                        "sortable": false,
                        "swipeRightActions": [
                          {
                            "icon": "circle",
                            "variant": "primary",
                            "label": "Label"
                          },
                          {
                            "icon": "circle",
                            "variant": "secondary",
                            "label": "Label 2"
                          }
                        ],
                        "fields": [
                          {
                            "variant": "h3",
                            "icon": "circle",
                            "label": "Label",
                            "name": "Name",
                            "format": "date"
                          },
                          {
                            "icon": "circle",
                            "format": "currency",
                            "name": "Name 2",
                            "label": "Label 2",
                            "variant": "h4"
                          }
                        ],
                        "loadMoreEvent": "LOAD_MORE",
                        "swipeRightEvent": "SWIPE_RIGHT",
                        "itemClickEvent": "ITEM_CLICK",
                        "maxInlineActions": 0,
                        "dndRoot": false,
                        "error": "@config.error",
                        "longPressEvent": "LONG_PRESS",
                        "positionEvent": "Position Event",
                        "dropEvent": "Drop Event",
                        "gap": "none",
                        "reorderable": false,
                        "accepts": "Accepts",
                        "look": "dense",
                        "senderField": "Sender Field",
                        "swipeLeftEvent": "SWIPE_LEFT",
                        "columns": [
                          {
                            "name": "Name",
                            "variant": "h3",
                            "icon": "circle",
                            "label": "Label",
                            "format": "date"
                          },
                          {
                            "variant": "h4",
                            "icon": "circle",
                            "label": "Label 2",
                            "format": "currency",
                            "name": "Name 2"
                          }
                        ],
                        "type": "data-list",
                        "dragGroup": "Drag Group",
                        "reorderEvent": "REORDER",
                        "pageSize": 5,
                        "swipeLeftActions": [
                          {
                            "variant": "primary",
                            "icon": "circle",
                            "label": "Label"
                          },
                          {
                            "label": "Label 2",
                            "icon": "circle",
                            "variant": "secondary"
                          }
                        ],
                        "className": "",
                        "currentUser": "Current User",
                        "groupBy": "Group By",
                        "entity": "@entity"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "DataListLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "dropEvent": "Drop Event",
                        "dndItemIdField": "Dnd Item Id Field",
                        "isLoading": false,
                        "swipeRightEvent": "SWIPE_RIGHT",
                        "longPressEvent": "LONG_PRESS",
                        "dndRoot": false,
                        "maxInlineActions": 0,
                        "senderField": "Sender Field",
                        "itemClickEvent": "ITEM_CLICK",
                        "currentUser": "Current User",
                        "error": "@config.error",
                        "variant": "default",
                        "groupBy": "Group By",
                        "sortable": false,
                        "type": "data-list",
                        "pageSize": 5,
                        "gap": "none",
                        "look": "dense",
                        "reorderEvent": "REORDER",
                        "swipeLeftActions": [
                          {
                            "variant": "primary",
                            "icon": "circle",
                            "label": "Label"
                          },
                          {
                            "label": "Label 2",
                            "icon": "circle",
                            "variant": "secondary"
                          }
                        ],
                        "fields": [
                          {
                            "variant": "h3",
                            "icon": "circle",
                            "label": "Label",
                            "name": "Name",
                            "format": "date"
                          },
                          {
                            "icon": "circle",
                            "format": "currency",
                            "name": "Name 2",
                            "label": "Label 2",
                            "variant": "h4"
                          }
                        ],
                        "accepts": "Accepts",
                        "entity": "@payload.data",
                        "infiniteScroll": false,
                        "swipeLeftEvent": "SWIPE_LEFT",
                        "reorderable": false,
                        "swipeRightActions": [
                          {
                            "icon": "circle",
                            "variant": "primary",
                            "label": "Label"
                          },
                          {
                            "icon": "circle",
                            "variant": "secondary",
                            "label": "Label 2"
                          }
                        ],
                        "columns": [
                          {
                            "name": "Name",
                            "variant": "h3",
                            "icon": "circle",
                            "label": "Label",
                            "format": "date"
                          },
                          {
                            "variant": "h4",
                            "icon": "circle",
                            "label": "Label 2",
                            "format": "currency",
                            "name": "Name 2"
                          }
                        ],
                        "itemActions": [
                          {
                            "event": "VIEW",
                            "label": "View"
                          }
                        ],
                        "dragGroup": "Drag Group",
                        "positionEvent": "Position Event",
                        "loadMoreEvent": "LOAD_MORE",
                        "className": "",
                        "hasMore": false
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "VIEW",
                  "effects": [
                    [
                      "emit",
                      "VIEW",
                      {}
                    ]
                  ]
                }
              ]
            },
            "config": {
              "swipeLeftActions": {
                "type": "[DataListSwipeLeftActionsItem]",
                "default": [
                  {
                    "variant": "primary",
                    "icon": "circle",
                    "label": "Label"
                  },
                  {
                    "label": "Label 2",
                    "icon": "circle",
                    "variant": "secondary"
                  }
                ],
                "label": "Swipe Left Actions",
                "description": "Actions revealed on left swipe",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "danger",
                        "ghost"
                      ]
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state",
                "tier": "presentation"
              },
              "swipeRightActions": {
                "type": "[DataListSwipeRightActionsItem]",
                "default": [
                  {
                    "icon": "circle",
                    "variant": "primary",
                    "label": "Label"
                  },
                  {
                    "icon": "circle",
                    "variant": "secondary",
                    "label": "Label 2"
                  }
                ],
                "label": "Swipe Right Actions",
                "description": "Actions revealed on right swipe",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "danger",
                        "ghost"
                      ]
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "reorderable": {
                "type": "boolean",
                "default": false,
                "label": "Reorderable",
                "description": "Enable drag-to-reorder with grip handles",
                "tier": "presentation"
              },
              "accepts": {
                "type": "string",
                "default": "Accepts",
                "label": "Accepts",
                "description": "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "default",
                "label": "Variant",
                "description": "Visual variant",
                "tier": "presentation",
                "values": [
                  "default",
                  "card",
                  "compact",
                  "message"
                ]
              },
              "maxInlineActions": {
                "type": "number",
                "default": 0,
                "label": "Max Inline Actions",
                "description": "Max inline action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline.",
                "tier": "presentation"
              },
              "groupBy": {
                "type": "string",
                "default": "Group By",
                "label": "Group By",
                "description": "Group items by a field value (renders section headers between groups)",
                "tier": "presentation"
              },
              "itemActions": {
                "type": "[DataListItemActionsItem]",
                "default": [],
                "label": "Item Actions",
                "description": "Per-item action buttons",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost",
                        "danger"
                      ]
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "dragGroup": {
                "type": "string",
                "default": "Drag Group",
                "label": "Drag Group",
                "description": "When set, items in this container are draggable and announce this group as their source",
                "tier": "presentation"
              },
              "columns": {
                "type": "[DataListColumnsItem]",
                "default": [
                  {
                    "name": "Name",
                    "variant": "h3",
                    "icon": "circle",
                    "label": "Label",
                    "format": "date"
                  },
                  {
                    "variant": "h4",
                    "icon": "circle",
                    "label": "Label 2",
                    "format": "currency",
                    "name": "Name 2"
                  }
                ],
                "label": "Columns",
                "description": "Alias for `fields` — the compiler emits `columns` for field defs.",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "format": {
                      "name": "format",
                      "type": "string",
                      "required": false,
                      "values": [
                        "date",
                        "currency",
                        "number",
                        "boolean",
                        "percent"
                      ]
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "h3",
                        "h4",
                        "body",
                        "caption",
                        "badge",
                        "small",
                        "progress"
                      ]
                    }
                  }
                }
              },
              "currentUser": {
                "type": "string",
                "default": "Current User",
                "label": "Current User",
                "description": "Current user identifier; messages matching this value align right (used with variant: 'message')",
                "tier": "presentation"
              },
              "fields": {
                "type": "[DataListFieldsItem]",
                "default": [
                  {
                    "variant": "h3",
                    "icon": "circle",
                    "label": "Label",
                    "name": "Name",
                    "format": "date"
                  },
                  {
                    "icon": "circle",
                    "format": "currency",
                    "name": "Name 2",
                    "label": "Label 2",
                    "variant": "h4"
                  }
                ],
                "label": "Fields",
                "description": "Field definitions for rendering each row. The pattern contract in `@almadar/patterns` documents `columns` as the wire-format alias the compiler emits — both names resolve to the same shape here. Pass either.",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "h3",
                        "h4",
                        "body",
                        "caption",
                        "badge",
                        "small",
                        "progress"
                      ]
                    },
                    "format": {
                      "name": "format",
                      "type": "string",
                      "required": false,
                      "values": [
                        "date",
                        "currency",
                        "number",
                        "boolean",
                        "percent"
                      ]
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "sortable": {
                "type": "boolean",
                "default": false,
                "label": "Sortable",
                "description": "Enable in-container reorder; items can be dragged to new positions among siblings",
                "tier": "presentation"
              },
              "dndItemIdField": {
                "type": "string",
                "default": "Dnd Item Id Field",
                "label": "Dnd Item Id Field",
                "description": "Row field used as the @dnd-kit draggable id (default 'id')",
                "tier": "presentation"
              },
              "hasMore": {
                "type": "boolean",
                "default": false,
                "label": "Has More",
                "description": "Whether more items are available for infinite scroll",
                "tier": "presentation"
              },
              "positionEvent": {
                "type": "string",
                "default": "Position Event",
                "label": "Position Event",
                "description": "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "error": {
                "type": "DataListError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "dropEvent": {
                "type": "string",
                "default": "Drop Event",
                "label": "Drop Event",
                "description": "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }",
                "tier": "presentation"
              },
              "look": {
                "type": "string",
                "default": "dense",
                "label": "Look",
                "description": "Layer 2 visual treatment — mirrors the `entity-table` look enum so data-grid / data-list / entity-table share one knob name from authors.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              },
              "senderField": {
                "type": "string",
                "default": "Sender Field",
                "label": "Sender Field",
                "description": "Field name identifying the sender (used with variant: 'message')",
                "tier": "presentation"
              },
              "dndRoot": {
                "type": "boolean",
                "default": false,
                "label": "Dnd Root",
                "description": "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable.",
                "tier": "presentation"
              },
              "infiniteScroll": {
                "type": "boolean",
                "default": false,
                "label": "Infinite Scroll",
                "description": "Enable infinite scroll loading",
                "tier": "presentation"
              },
              "pageSize": {
                "type": "number",
                "default": 5,
                "label": "Page Size",
                "description": "Max items to show before 'Show More' button. Defaults to 5. Set to 0 to disable.",
                "tier": "presentation"
              },
              "gap": {
                "type": "string",
                "default": "none",
                "label": "Gap",
                "description": "Gap between rows",
                "tier": "presentation",
                "values": [
                  "none",
                  "sm",
                  "md",
                  "lg"
                ]
              }
