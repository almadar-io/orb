            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "cols": 1,
                        "className": "",
                        "maxCols": 1,
                        "minChildWidth": "Min Child Width",
                        "type": "simple-grid",
                        "gap": "md",
                        "children": [
                          {
                            "type": "typography",
                            "content": "Sample content"
                          }
                        ]
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "minChildWidth": {
                "type": "string",
