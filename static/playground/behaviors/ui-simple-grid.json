                "description": "Minimum width of each child (e.g., 200, '200px', '15rem')",
                "tier": "presentation"
              },
              "maxCols": {
                "type": "number",
                "default": 1,
                "label": "Max Cols",
                "description": "Maximum number of columns",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Custom class name",
                "tier": "presentation"
              },
              "cols": {
                "type": "number",
                "default": 1,
                "label": "Cols",
                "description": "Exact number of columns (disables auto-fit)",
                "tier": "presentation"
              },
              "gap": {
                "type": "string",
                "default": "md",
                "label": "Gap",
                "description": "Gap between items",
