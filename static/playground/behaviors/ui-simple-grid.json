            "prop": "maxCols",
            "knob": "maxCols"
          },
          {
            "trait": "SimpleGridRender",
            "patternPath": "root",
            "prop": "minChildWidth",
            "knob": "minChildWidth"
          },
          {
            "trait": "SimpleGridRender",
            "patternPath": "root",
