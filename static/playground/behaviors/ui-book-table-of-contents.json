                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BookTableOfContentsItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
