{
  "name": "std-image-upload-multi",
  "description": "std-image-upload-multi — multi-image upload with drop zone, gallery preview, and per-batch progress.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-image-upload-multi",
    "version": "1.0.0",
    "description": "std-image-upload-multi — multi-image upload with drop zone, gallery preview, and per-batch progress.",
    "orbitals": [
      {
        "name": "UploadedImageOrbital",
        "entity": {
          "name": "UploadedImage",
          "collection": "uploadedimages",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "url",
              "type": "string",
              "required": true,
              "description": "The accessible address for retrieving the image data.",
              "synonyms": "link, path, address"
            },
            {
              "name": "name",
              "type": "string",
              "description": "The filename or identifier for the uploaded image.",
              "synonyms": "filename, originalName, identifier"
            },
            {
              "name": "sizeBytes",
              "type": "number",
              "description": "The file size in bytes.",
              "synonyms": "length, filesize, bytes"
            },
            {
              "name": "mimeType",
              "type": "string",
              "description": "The file's internet media type.",
              "synonyms": "type, format, media type"
            },
            {
              "name": "width",
              "type": "number",
              "description": "The image's width in pixels.",
              "synonyms": "imageWidth, pixelWidth"
            },
            {
              "name": "height",
              "type": "number",
              "description": "The vertical dimension of the image, in pixels.",
              "synonyms": "vertical, y, dimension"
            },
            {
              "name": "parentId",
              "type": "string",
              "description": "Identifier of the parent resource this image belongs to.",
              "synonyms": "parent, reference, source"
            },
            {
              "name": "parentType",
              "type": "string",
              "description": "Identifies the type of the parent entity.",
              "synonyms": "parent, type, category"
            },
            {
              "name": "uploadedAt",
              "type": "string",
              "description": "Timestamp indicating when the image was uploaded.",
              "synonyms": "date, timestamp, upload time"
            }
          ]
        },
        "traits": [
          {
            "name": "UploadedImageUpload",
            "category": "interaction",
            "linkedEntity": "UploadedImage",
            "emits": [
              {
                "event": "UPLOAD",
                "description": "Signals that an image upload process has begun.",
                "synonyms": "start, initiate, begin",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "files",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "event": "UploadedImageLoaded",
                "description": "Signals a single image has finished loading.",
                "synonyms": "loaded, received, parsed",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[UploadedImage]"
                  }
                ]
              },
              {
                "event": "UploadedImageLoadFailed",
                "description": "Indicates an image failed to load during the upload process.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "UploadedImageCreated",
                "description": "A new image has been successfully uploaded.",
                "synonyms": "added, new, received",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "url",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string"
                      },
                      {
                        "name": "sizeBytes",
                        "type": "number"
                      },
                      {
                        "name": "mimeType",
                        "type": "string"
                      },
                      {
                        "name": "width",
                        "type": "number"
                      },
                      {
                        "name": "height",
                        "type": "number"
                      },
                      {
                        "name": "parentId",
                        "type": "string"
                      },
                      {
                        "name": "parentType",
                        "type": "string"
                      },
                      {
                        "name": "uploadedAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "UploadedImageUploadFailed",
                "description": "Indicates a single image upload encountered an error.",
                "synonyms": "error, failure, problem, rejected",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "UploadedImageDeleted",
                "description": "Signals an image has been removed from the upload queue.",
                "synonyms": "removed, discarded, taken out",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "UploadedImageDeleteFailed",
                "description": "Indicates an image deletion operation failed.",
                "synonyms": "failed delete, deletion error",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "uploading"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "UploadedImageLoaded",
                  "name": "UploadedImage loaded",
                  "description": "Signals a single image has finished loading.",
                  "synonyms": "loaded, received, parsed",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[UploadedImage]"
                    }
                  ]
                },
                {
                  "key": "UploadedImageLoadFailed",
                  "name": "UploadedImage load failed",
                  "description": "Indicates an image failed to load during the upload process.",
                  "synonyms": "error, failure, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "UPLOAD",
                  "name": "Upload",
                  "description": "Signals that an image upload process has begun.",
                  "synonyms": "start, initiate, begin",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "files",
                      "type": "object",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "DELETE",
                  "name": "Delete",
                  "description": "Indicates a selected image has been removed.",
                  "synonyms": "remove, discard, clear",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "UploadedImageDeleted",
                  "name": "UploadedImage deleted",
                  "description": "Signals an image has been removed from the upload queue.",
                  "synonyms": "removed, discarded, taken out",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "UploadedImageDeleteFailed",
                  "name": "UploadedImage delete failed",
                  "description": "Indicates an image deletion operation failed.",
                  "synonyms": "failed delete, deletion error",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "UploadedImageCreated",
                  "name": "UploadedImage created",
                  "description": "A new image has been successfully uploaded.",
                  "synonyms": "added, new, received",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "UploadedImage"
                    }
                  ]
                },
                {
                  "key": "UploadedImageUploadFailed",
                  "name": "UploadedImage upload failed",
                  "description": "Indicates a single image upload encountered an error.",
                  "synonyms": "error, failure, problem, rejected",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "UploadedImage",
                      {
                        "emit": {
                          "success": "UploadedImageLoaded",
                          "failure": "UploadedImageLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Loading images…",
                            "type": "typography",
                            "variant": "caption",
                            "color": "muted"
                          }
                        ],
                        "className": "py-12",
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "UploadedImageLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack",
                        "children": [
                          {
                            "align": "center",
                            "type": "stack",
                            "children": [
                              {
                                "type": "icon",
                                "name": "image-plus"
                              },
                              {
                                "type": "typography",
                                "variant": "h3",
                                "content": "Upload Images"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "accept": "image/*",
                            "icon": "image-plus",
                            "maxSize": 10485760,
                            "action": "UPLOAD",
                            "label": "Drop images here",
                            "maxFiles": 10,
                            "description": "or click to browse",
                            "type": "upload-drop-zone"
                          },
                          {
                            "entity": "@payload.data",
                            "type": "media-gallery"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "UploadedImageLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "message": "@payload.error",
                        "variant": "error"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "uploading",
                  "event": "UPLOAD",
                  "effects": [
                    [
                      "persist",
                      "create",
                      "UploadedImage",
                      "@payload.files",
                      {
                        "emit": {
                          "failure": "UploadedImageUploadFailed",
                          "success": "UploadedImageCreated"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "align": "center",
                        "type": "stack",
                        "className": "py-12",
                        "direction": "vertical",
                        "children": [
                          {
                            "type": "typography",
                            "variant": "h3",
                            "content": "Uploading images…"
                          },
                          {
                            "progressType": "linear",
                            "value": 0,
                            "type": "progress-bar",
                            "max": 100
                          }
                        ],
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "DELETE",
                  "effects": [
                    [
                      "persist",
                      "delete",
                      "UploadedImage",
                      "@payload.id",
                      {
                        "emit": {
                          "success": "UploadedImageDeleted",
                          "failure": "UploadedImageDeleteFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "UploadedImageDeleted",
                  "effects": [
                    [
                      "fetch",
                      "UploadedImage",
                      {
                        "emit": {
                          "success": "UploadedImageLoaded",
                          "failure": "UploadedImageLoadFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "error",
                  "event": "UploadedImageDeleteFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "message": "@payload.error",
                        "variant": "error"
                      }
                    ]
                  ]
                },
                {
                  "from": "uploading",
                  "to": "loading",
                  "event": "UploadedImageCreated",
                  "effects": [
                    [
                      "fetch",
                      "UploadedImage",
                      {
                        "emit": {
                          "success": "UploadedImageLoaded",
                          "failure": "UploadedImageLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "className": "py-12",
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "name": "check-circle",
                            "type": "icon",
                            "color": "success"
                          },
                          {
                            "variant": "h3",
                            "content": "Upload complete",
                            "type": "typography"
                          }
                        ],
                        "align": "center"
                      }
                    ]
                  ]
                },
                {
                  "from": "uploading",
                  "to": "error",
                  "event": "UploadedImageUploadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "error",
                        "type": "alert",
                        "message": "@payload.error"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "browsing",
                  "event": "UploadedImageLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "type": "stack",
                            "align": "center",
                            "direction": "horizontal",
                            "gap": "sm",
                            "children": [
                              {
                                "name": "image-plus",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "variant": "h3",
                                "content": "Upload Images"
                              }
                            ]
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "accept": "image/*",
                            "icon": "image-plus",
                            "maxFiles": 10,
                            "label": "Drop images here",
                            "description": "or click to browse",
                            "type": "upload-drop-zone",
                            "maxSize": 10485760,
                            "action": "UPLOAD"
                          },
                          {
                            "entity": "@payload.data",
                            "type": "media-gallery"
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "title": {
                "type": "string",
                "default": "Upload Images",
                "label": "Section title",
                "description": "Heading shown above the upload zone",
                "tier": "presentation"
              },
              "maxImages": {
                "type": "number",
                "default": 10,
                "label": "Max images",
                "description": "Maximum number of images accepted per upload batch",
                "tier": "domain"
              },
              "accept": {
                "type": "string",
                "default": "image/*",
                "label": "MIME filter",
                "description": "Browser accept filter for the file picker",
                "tier": "domain"
              },
              "maxBytesPerImage": {
                "type": "number",
                "default": 10485760,
                "label": "Size limit (bytes)",
                "description": "Per-image upload size cap",
                "tier": "domain"
              }
            },
            "scope": "collection"
          }
        ],
        "pages": [
          {
            "name": "UploadedImageUploadPage",
            "path": "/uploadedimages/upload",
            "traits": [
              {
                "ref": "UploadedImageUpload"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "UploadedImageOrbital": [
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.0.children.1",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.2",
            "prop": "accept",
            "knob": "accept"
          },
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.2",
            "prop": "maxSize",
            "knob": "maxBytesPerImage"
          },
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.2",
            "prop": "maxFiles",
            "knob": "maxImages"
          },
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.0.children.1",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.2",
            "prop": "accept",
            "knob": "accept"
          },
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.2",
            "prop": "maxFiles",
            "knob": "maxImages"
          },
          {
            "trait": "UploadedImageUpload",
            "patternPath": "root.children.2",
            "prop": "maxSize",
            "knob": "maxBytesPerImage"
          }
        ]
      }
    }
  },
