{
  "name": "ui-pagination",
  "description": "Pagination — UI factory (1:1 with the @almadar/ui pagination pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-pagination",
    "version": "1.0.0",
    "description": "Pagination — UI factory (1:1 with the @almadar/ui pagination pattern).",
    "orbitals": [
      {
        "name": "PaginationOrbital",
        "entity": {
          "name": "PaginationItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "pageSize",
              "type": "number",
              "default": 0
            }
          ]
        },
        "traits": [
          {
            "name": "PaginationRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "pageSize"
              ]
            },
            "category": "interaction",
            "linkedEntity": "PaginationItem",
            "emits": [
              {
                "event": "PAGE_CHANGE",
                "description": "Callback when page changes (optional - can be a no-op if not interactive)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "page",
                    "type": "number"
                  }
                ]
              },
              {
                "event": "PAGE_SIZE_CHANGE",
                "description": "Callback when page size changes",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "size",
                    "type": "number"
                  },
                  {
                    "name": "pageSize",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "PAGE_SIZE_CHANGE",
                  "name": "Page Size Change",
                  "description": "Callback when page size changes",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "size",
                      "type": "number"
                    },
                    {
                      "name": "pageSize",
                      "type": "number",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "PAGE_CHANGE",
                  "name": "Page Change",
                  "description": "Callback when page changes (optional - can be a no-op if not interactive)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "page",
                      "type": "number"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.pageSize",
                      0
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "currentPage": 1,
                        "onPageSizeChange": "PAGE_SIZE_CHANGE",
                        "showPageSize": false,
                        "type": "pagination",
                        "totalItems": 0,
                        "className": "",
                        "showJumpToPage": false,
                        "pageChangeEvent": "PAGE_CHANGE",
                        "pageSizeChangeEvent": "PAGE_SIZE_CHANGE",
                        "maxVisiblePages": 7,
                        "pageSizeOptions": [],
                        "showTotal": false,
                        "pageSize": "@entity.pageSize",
                        "onPageChange": "PAGE_CHANGE",
                        "totalPages": 1
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "PAGE_SIZE_CHANGE",
                  "effects": [
                    [
                      "set",
                      "@entity.pageSize",
                      "@payload.pageSize"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "pageSizeChangeEvent": "PAGE_SIZE_CHANGE",
                        "className": "",
                        "pageSizeOptions": [],
                        "showTotal": false,
                        "type": "pagination",
                        "onPageChange": "PAGE_CHANGE",
                        "pageChangeEvent": "PAGE_CHANGE",
                        "showPageSize": false,
                        "totalItems": 0,
                        "pageSize": "@entity.pageSize",
                        "maxVisiblePages": 7,
                        "onPageSizeChange": "PAGE_SIZE_CHANGE",
                        "totalPages": 1,
                        "showJumpToPage": false,
                        "currentPage": 1
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "showJumpToPage": {
                "type": "boolean",
                "default": false,
                "label": "Show Jump To Page",
                "description": "Show jump to page input",
                "tier": "presentation"
              },
              "totalPages": {
                "type": "number",
                "default": 1,
                "label": "Total Pages",
                "description": "Total number of pages",
                "tier": "presentation"
              },
              "pageSize": {
                "type": "number",
                "default": 0,
                "label": "Page Size",
                "description": "Current page size",
                "tier": "presentation"
              },
              "showPageSize": {
                "type": "boolean",
                "default": false,
                "label": "Show Page Size",
                "description": "Show page size selector",
                "tier": "presentation"
              },
              "maxVisiblePages": {
                "type": "number",
                "default": 7,
                "label": "Max Visible Pages",
                "description": "Maximum number of page buttons to show",
                "tier": "presentation"
              },
              "showTotal": {
                "type": "boolean",
                "default": false,
                "label": "Show Total",
                "description": "Show total count",
                "tier": "presentation"
              },
              "pageSizeOptions": {
                "type": "[number]",
                "default": [],
                "label": "Page Size Options",
                "description": "Page size options",
                "tier": "presentation",
                "items": {
                  "type": "number"
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "currentPage": {
                "type": "number",
                "default": 1,
                "label": "Current Page",
                "description": "Current page (1-indexed)",
                "tier": "presentation"
              },
              "totalItems": {
                "type": "number",
                "default": 0,
                "label": "Total Items",
                "description": "Total items count",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "PaginationPage",
            "path": "/pagination",
            "traits": [
              {
                "ref": "PaginationRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "PaginationOrbital": [
          {
            "trait": "PaginationRender",
            "patternPath": "root",
            "prop": "currentPage",
            "knob": "currentPage"
          },
