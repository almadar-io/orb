{
  "name": "ui-file-tree",
  "description": "FileTree — UI factory (1:1 with the @almadar/ui file-tree pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-file-tree",
    "version": "1.0.0",
    "description": "FileTree — UI factory (1:1 with the @almadar/ui file-tree pattern).",
    "orbitals": [
      {
        "name": "FileTreeOrbital",
        "entity": {
          "name": "FileTreeItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "FileTreeRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "FileTreeItem",
            "emits": [
              {
                "event": "FILE_SELECT",
                "description": "Called when a file is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "path",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "FILE_SELECT",
                  "name": "File Select",
                  "description": "Called when a file is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "path",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "indent": 16,
                        "className": "",
                        "onFileSelect": "FILE_SELECT",
                        "selectedPath": "Selected Path",
                        "type": "file-tree",
                        "tree": [
                          {
                            "type": "file",
                            "children": [],
                            "size": 1,
                            "language": "Language",
                            "name": "Name",
                            "path": "Path"
                          },
                          {
                            "name": "Name 2",
                            "children": [],
                            "language": "Language 2",
                            "type": "dir",
                            "path": "Path 2",
                            "size": 2
                          }
                        ]
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "CSS class",
                "tier": "presentation"
              },
              "indent": {
                "type": "number",
                "default": 16,
                "label": "Indent",
                "description": "Indent size per level in px (default: 16)",
                "tier": "presentation"
              },
              "selectedPath": {
                "type": "string",
                "default": "Selected Path",
                "label": "Selected Path",
                "description": "Currently selected file path",
                "tier": "presentation"
              },
              "tree": {
                "type": "[FileTreeTreeItem]",
                "default": [
                  {
                    "type": "file",
                    "children": [],
                    "size": 1,
                    "language": "Language",
                    "name": "Name",
                    "path": "Path"
                  },
                  {
                    "name": "Name 2",
                    "children": [],
                    "language": "Language 2",
                    "type": "dir",
                    "path": "Path 2",
                    "size": 2
                  }
                ],
                "label": "Tree",
                "description": "The tree data",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "size": {
                      "name": "size",
                      "type": "number",
                      "required": false
                    },
                    "children": {
                      "name": "children",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    "type": {
                      "name": "type",
                      "type": "string",
                      "required": true,
                      "values": [
                        "file",
                        "dir"
                      ]
                    },
                    "language": {
                      "name": "language",
                      "type": "string",
                      "required": false
                    },
                    "path": {
                      "name": "path",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "FileTreePage",
            "path": "/file-tree",
            "traits": [
              {
                "ref": "FileTreeRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "FileTreeOrbital": [
          {
            "trait": "FileTreeRender",
            "patternPath": "root",
            "prop": "indent",
            "knob": "indent"
          },
          {
            "trait": "FileTreeRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "FileTreeRender",
            "patternPath": "root",
            "prop": "selectedPath",
            "knob": "selectedPath"
          },
          {
            "trait": "FileTreeRender",
            "patternPath": "root",
            "prop": "tree",
            "knob": "tree"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}