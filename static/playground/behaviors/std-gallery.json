{
  "name": "std-gallery",
  "description": "std-gallery — image gallery primitive. Browses GalleryItems in a media-gallery grid; opens a lightbox modal for full-size viewing.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-gallery",
    "version": "1.0.0",
    "description": "std-gallery — image gallery primitive. Browses GalleryItems in a media-gallery grid; opens a lightbox modal for full-size viewing.",
    "orbitals": [
      {
        "name": "GalleryItemOrbital",
        "entity": {
          "name": "GalleryItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "name",
              "type": "string",
              "required": true,
              "description": "A user-friendly identifier for the item.",
              "synonyms": "title, label, identifier"
            },
            {
              "name": "description",
              "type": "string",
              "description": "A brief textual summary of the item's content.",
              "synonyms": "caption, summary, details, notes"
            },
            {
              "name": "status",
              "type": "string",
              "default": "active",
              "values": [
                "active",
                "inactive",
                "pending"
              ],
              "description": "Indicates the current state of the item.",
              "synonyms": "state, condition, flag"
            },
            {
              "name": "createdAt",
              "type": "string"
            },
            {
              "name": "imageUrl",
              "type": "string",
              "default": "https://picsum.photos/seed/gallery/800/600",
              "description": "The URL pointing to the image resource.",
              "synonyms": "image, src, path"
            }
          ]
        },
        "traits": [
          {
            "name": "GalleryItemGallery",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "description",
                "imageUrl",
                "name"
              ]
            },
            "category": "interaction",
            "linkedEntity": "GalleryItem",
            "emits": [
              {
                "event": "VIEW",
                "description": "Signals an item has been selected for viewing.",
                "synonyms": "select, choose, display",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      },
                      {
                        "name": "imageUrl",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "GalleryItemLoaded",
                "description": "Indicates a GalleryItem has finished loading.",
                "synonyms": "loaded, ready, available",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GalleryItem]"
                  }
                ]
              },
              {
                "event": "GalleryItemLoadFailed",
                "description": "Indicates a GalleryItem failed to load.",
                "synonyms": "error, failure, problem, load error",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "viewing"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "GalleryItemLoaded",
                  "name": "GalleryItem loaded",
                  "description": "Indicates a GalleryItem has finished loading.",
                  "synonyms": "loaded, ready, available",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[GalleryItem]"
                    }
                  ]
                },
                {
                  "key": "GalleryItemLoadFailed",
                  "name": "GalleryItem load failed",
                  "description": "Indicates a GalleryItem failed to load.",
                  "synonyms": "error, failure, problem, load error",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "VIEW",
                  "name": "View",
                  "description": "Signals an item has been selected for viewing.",
                  "synonyms": "select, choose, display",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "GalleryItem"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "Indicates the gallery or lightbox has been dismissed.",
                  "synonyms": "dismiss, hide, close, cancel",
                  "tier": "domain"
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "GalleryItem",
                      {
                        "emit": {
                          "failure": "GalleryItemLoadFailed",
                          "success": "GalleryItemLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "color": "muted",
                            "content": "Loading gallery…",
                            "type": "typography"
                          }
                        ],
                        "className": "py-12",
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "GalleryItemLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "type": "stack",
                            "children": [
                              {
                                "name": "image",
                                "type": "icon"
                              },
                              {
                                "variant": "h3",
                                "content": "Gallery",
                                "type": "typography"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "align": "center"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "type": "media-gallery",
                            "entity": "@payload.data"
                          }
                        ],
                        "gap": "md",
                        "type": "stack",
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "GalleryItemLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "message": "@payload.error",
                        "type": "alert",
                        "variant": "error"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "viewing",
                  "event": "VIEW",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "set",
                      "@entity.name",
                      "@payload.row.name"
                    ],
                    [
                      "set",
                      "@entity.description",
                      "@payload.row.description"
                    ],
                    [
                      "set",
                      "@entity.imageUrl",
                      "@payload.row.imageUrl"
                    ],
                    [
                      "render-ui",
                      "modal",
                      {
                        "closeAction": "CLOSE",
                        "isOpen": true,
                        "type": "lightbox",
                        "showCounter": true,
                        "images": [
                          {
                            "caption": "@entity.name",
                            "alt": "@entity.name",
                            "src": "@entity.imageUrl"
                          }
                        ],
                        "currentIndex": 0
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing",
                  "to": "loading",
                  "event": "CLOSE",
                  "effects": [
                    [
                      "render-ui",
                      "modal",
                      null
                    ],
                    [
                      "fetch",
                      "GalleryItem",
                      {
                        "emit": {
                          "failure": "GalleryItemLoadFailed",
                          "success": "GalleryItemLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "content": "Loading gallery…",
                            "color": "muted",
                            "type": "typography"
                          }
                        ],
                        "gap": "md",
                        "type": "stack",
                        "align": "center",
                        "className": "py-12"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "GalleryItem",
                      {
                        "emit": {
                          "failure": "GalleryItemLoadFailed",
                          "success": "GalleryItemLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "size": "sm",
                        "type": "spinner"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "title": {
                "type": "string",
                "default": "Gallery",
                "label": "Section title",
                "description": "Heading shown above the image gallery",
                "tier": "presentation"
              }
            },
            "scope": "collection"
          }
        ],
        "pages": [
          {
            "name": "GalleryItemGalleryPage",
            "path": "/galleryitems/gallery",
            "traits": [
              {
                "ref": "GalleryItemGallery"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "GalleryItemOrbital": [
          {
            "trait": "GalleryItemGallery",
            "patternPath": "root.children.0.children.1",
            "prop": "content",
            "knob": "title"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}