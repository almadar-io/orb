{
  "name": "ui-input",
  "description": "Input — UI factory (1:1 with the @almadar/ui input pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-input",
    "version": "1.0.0",
    "description": "Input — UI factory (1:1 with the @almadar/ui input pattern).",
    "orbitals": [
      {
        "name": "InputOrbital",
        "entity": {
          "name": "InputItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "InputRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "InputItem",
            "emits": [
              {
                "event": "ACTION",
                "description": "Declarative event name for trait dispatch",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CLEAR",
                "description": "Callback or declarative event key when clear button is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CHANGE",
                "description": "onChange handler or declarative event key for trait dispatch",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "ACTION",
                  "name": "Action",
                  "description": "Declarative event name for trait dispatch",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CLEAR",
                  "name": "Clear",
                  "description": "Callback or declarative event key when clear button is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CHANGE",
                  "name": "Change",
                  "description": "onChange handler or declarative event key for trait dispatch",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "rightIcon": "@config.rightIcon",
                        "options": [
                          {
                            "value": "Value",
                            "label": "Label"
                          },
                          {
                            "label": "Label 2",
                            "value": "Value 2"
                          }
                        ],
                        "value": "Value",
                        "onClear": "CLEAR",
                        "action": "ACTION",
                        "disabled": false,
                        "placeholder": "Placeholder",
                        "error": "",
                        "label": "Label",
                        "helperText": "Helper Text",
                        "type": "input",
                        "inputType": "text",
                        "className": "",
                        "clearable": false,
                        "icon": "circle",
                        "leftIcon": "@config.leftIcon",
                        "onChange": "CHANGE",
                        "rows": 3
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "value": {
                "type": "string",
                "default": "Value",
                "label": "Value",
                "description": "Current value",
                "tier": "presentation"
              },
              "clearable": {
                "type": "boolean",
                "default": false,
                "label": "Clearable",
                "description": "Show clear button when input has value",
                "tier": "presentation"
              },
              "disabled": {
                "type": "boolean",
                "default": false,
                "label": "Disabled",
                "description": "Whether input is disabled",
                "tier": "presentation"
              },
              "helperText": {
                "type": "string",
                "default": "Helper Text",
                "label": "Helper Text",
                "description": "helperText prop",
                "tier": "presentation"
              },
              "leftIcon": {
                "type": "icon",
                "label": "Left Icon",
                "description": "leftIcon prop",
                "tier": "presentation"
              },
              "rightIcon": {
                "type": "icon",
                "label": "Right Icon",
                "description": "rightIcon prop",
                "tier": "presentation"
              },
              "error": {
                "type": "string",
                "default": "",
                "label": "Error",
                "description": "error prop",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes applied to the root element.",
                "tier": "presentation"
              },
              "icon": {
                "type": "icon",
                "default": "circle",
                "label": "Icon",
                "description": "Lucide icon component or canonical kebab-case icon name string for left side",
                "tier": "presentation"
              },
              "inputType": {
                "type": "string",
                "default": "text",
                "label": "Input Type",
                "description": "Input type - supports 'select' and 'textarea' in addition to standard types",
                "tier": "presentation",
                "values": [
                  "text",
                  "email",
                  "password",
                  "number",
                  "tel",
                  "url",
                  "search",
                  "date",
                  "datetime-local",
                  "time",
                  "checkbox",
                  "select",
                  "textarea"
                ]
              },
              "options": {
                "type": "[InputOptionsItem]",
                "default": [
                  {
                    "value": "Value",
                    "label": "Label"
                  },
                  {
                    "label": "Label 2",
                    "value": "Value 2"
                  }
                ],
                "label": "Options",
                "description": "Options for select type",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "value": {
                      "name": "value",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "label": {
                "type": "string",
                "default": "Label",
                "label": "Label",
                "description": "label prop",
                "tier": "presentation"
              },
              "placeholder": {
                "type": "string",
                "default": "Placeholder",
                "label": "Placeholder",
                "description": "Placeholder text",
                "tier": "presentation"
              },
              "rows": {
                "type": "number",
                "default": 3,
                "label": "Rows",
                "description": "Rows for textarea type",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "InputPage",
            "path": "/input",
            "traits": [
              {
                "ref": "InputRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "InputOrbital": [
