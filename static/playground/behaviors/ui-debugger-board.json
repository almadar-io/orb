                          "content": "function add(a, b) {",
                          "isBug": false,
                          "id": "l1"
                        },
                        {
                          "isFlagged": false,
                          "isBug": true,
                          "explanation": "Should be a + b for an add function.",
                          "id": "l2",
                          "content": "  return a - b;"
                        },
                        {
                          "content": "}",
                          "isBug": false,
                          "isFlagged": false,
                          "id": "l3"
                        },
                        {
                          "isBug": false,
                          "id": "l4",
                          "isFlagged": false,
                          "content": "const total = add(2, 3);"
                        },
                        {
                          "explanation": "Typo: 'totl' should be 'total'.",
                          "isBug": true,
                          "content": "console.log(totl);",
                          "id": "l5",
                          "isFlagged": false
