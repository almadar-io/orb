{
  "name": "ui-line-chart",
  "description": "LineChart — UI factory (1:1 with the @almadar/ui line-chart pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-line-chart",
    "version": "1.0.0",
    "description": "LineChart — UI factory (1:1 with the @almadar/ui line-chart pattern).",
    "orbitals": [
      {
        "name": "LineChartOrbital",
        "entity": {
          "name": "LineChartItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "LineChartRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "LineChartItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "showValues": false,
                        "data": [
                          {
                            "color": "Color",
                            "label": "Label",
                            "value": 1
                          },
                          {
                            "label": "Label 2",
                            "value": 2,
                            "color": "Color 2"
                          }
                        ],
                        "className": "",
                        "type": "line-chart",
                        "lineColor": "var(--color-primary)",
                        "areaColor": "var(--color-primary)",
                        "showGrid": true,
                        "height": 200,
                        "showArea": true,
                        "width": 400
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "data": {
                "type": "[LineChartDataItem]",
                "default": [
                  {
                    "color": "Color",
                    "label": "Label",
                    "value": 1
                  },
                  {
                    "label": "Label 2",
                    "value": 2,
                    "color": "Color 2"
                  }
                ],
                "label": "Data",
                "description": "Data points to plot",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "name": "value",
                      "type": "number",
                      "required": true
                    },
                    "color": {
                      "name": "color",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "lineColor": {
                "type": "string",
                "default": "var(--color-primary)",
                "label": "Line Color",
                "description": "Line stroke color",
                "tier": "presentation"
              },
              "showGrid": {
                "type": "boolean",
                "default": true,
                "label": "Show Grid",
                "description": "Show horizontal grid lines at 25/50/75%",
                "tier": "presentation"
              },
              "showValues": {
                "type": "boolean",
                "default": false,
                "label": "Show Values",
                "description": "Show value labels near data points",
                "tier": "presentation"
              },
              "showArea": {
                "type": "boolean",
                "default": true,
                "label": "Show Area",
                "description": "Fill area under line with gradient",
                "tier": "presentation"
              },
              "width": {
                "type": "number",
                "default": 400,
                "label": "Width",
                "description": "SVG viewBox width",
                "tier": "presentation"
              },
              "height": {
                "type": "number",
                "default": 200,
                "label": "Height",
                "description": "SVG viewBox height",
                "tier": "presentation"
              },
              "areaColor": {
                "type": "string",
                "default": "var(--color-primary)",
                "label": "Area Color",
                "description": "Area fill color (used for gradient)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "LineChartPage",
            "path": "/line-chart",
            "traits": [
              {
                "ref": "LineChartRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "LineChartOrbital": [
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "showValues",
            "knob": "showValues"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "data",
            "knob": "data"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "lineColor",
            "knob": "lineColor"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "areaColor",
            "knob": "areaColor"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "showGrid",
            "knob": "showGrid"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "height",
            "knob": "height"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "showArea",
            "knob": "showArea"
          },
          {
            "trait": "LineChartRender",
            "patternPath": "root",
            "prop": "width",
            "knob": "width"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}