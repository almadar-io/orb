{
  "name": "ui-modal",
  "description": "Modal — UI factory (1:1 with the @almadar/ui modal pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-modal",
    "version": "1.0.0",
    "description": "Modal — UI factory (1:1 with the @almadar/ui modal pattern).",
    "orbitals": [
      {
        "name": "ModalOrbital",
        "entity": {
          "name": "ModalItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ModalRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ModalItem",
            "emits": [
              {
                "event": "CLOSE",
                "description": "Callback when modal should close (injected by slot wrapper)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "OPEN",
                "description": "Open the Modal.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "closed",
                  "isInitial": true
                },
                {
                  "name": "open"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "OPEN",
                  "name": "Open",
                  "description": "Open the Modal.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "Callback when modal should close (injected by slot wrapper)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "closed",
                  "to": "closed",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "button",
                        "label": "Open Modal",
                        "action": "OPEN"
                      }
                    ]
                  ]
                },
                {
                  "from": "closed",
                  "to": "open",
                  "event": "OPEN",
                  "effects": [
                    [
                      "render-ui",
                      "modal",
                      {
                        "isOpen": true,
                        "closeOnEscape": true,
                        "swipeDownToClose": true,
                        "children": [
                          {
                            "content": "Sample content",
                            "type": "typography"
                          }
                        ],
                        "title": "Title",
                        "onClose": "CLOSE",
                        "type": "modal",
                        "showCloseButton": true,
                        "closeEvent": "CLOSE",
                        "look": "centered-card",
                        "className": "",
                        "closeOnOverlayClick": true,
                        "footer": "@config.footer",
                        "size": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "open",
                  "to": "closed",
                  "event": "CLOSE",
                  "effects": [
                    [
                      "render-ui",
                      "modal",
                      null
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "action": "OPEN",
                        "label": "Open Modal",
                        "type": "button"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "isOpen": {
                "type": "boolean",
                "default": true,
                "label": "Is Open",
                "description": "Whether the modal is open (defaults to true when rendered by slot wrapper)",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "className prop",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "title prop",
                "tier": "presentation"
              },
              "closeOnOverlayClick": {
                "type": "boolean",
                "default": true,
                "label": "Close On Overlay Click",
                "description": "closeOnOverlayClick prop",
                "tier": "presentation"
              },
              "footer": {
                "type": "node",
                "label": "Footer",
                "description": "footer prop",
                "tier": "presentation"
              },
              "closeOnEscape": {
                "type": "boolean",
                "default": true,
                "label": "Close On Escape",
                "description": "closeOnEscape prop",
                "tier": "presentation"
              },
              "look": {
                "type": "string",
                "default": "centered-card",
                "label": "Look",
                "description": "Layer 2 visual treatment — orthogonal to the semantic variant.",
                "tier": "presentation",
                "values": [
                  "centered-card",
                  "top-sheet",
                  "side-drawer",
                  "full-screen"
                ]
              },
              "swipeDownToClose": {
                "type": "boolean",
                "default": true,
                "label": "Swipe Down To Close",
                "description": "Enable swipe-down-to-close on mobile bottom sheet (default: true)",
                "tier": "presentation"
              },
              "showCloseButton": {
                "type": "boolean",
                "default": true,
                "label": "Show Close Button",
                "description": "showCloseButton prop",
                "tier": "presentation"
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "size prop",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "full"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ModalPage",
            "path": "/modal",
            "traits": [
              {
                "ref": "ModalRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ModalOrbital": [
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "isOpen",
            "knob": "isOpen"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "closeOnEscape",
            "knob": "closeOnEscape"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "swipeDownToClose",
            "knob": "swipeDownToClose"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "showCloseButton",
            "knob": "showCloseButton"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "look",
            "knob": "look"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "closeOnOverlayClick",
            "knob": "closeOnOverlayClick"
          },
          {
            "trait": "ModalRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}