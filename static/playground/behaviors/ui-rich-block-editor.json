{
  "name": "ui-rich-block-editor",
  "description": "RichBlockEditor — UI factory (1:1 with the @almadar/ui rich-block-editor pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-rich-block-editor",
    "version": "1.0.0",
    "description": "RichBlockEditor — UI factory (1:1 with the @almadar/ui rich-block-editor pattern).",
    "orbitals": [
      {
        "name": "RichBlockEditorOrbital",
        "entity": {
          "name": "RichBlockEditorItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "RichBlockEditorRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "RichBlockEditorItem",
            "emits": [
              {
                "event": "CHANGE",
                "description": "onChange prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ]
              },
              {
                "event": "RichBlockEditorLoaded",
                "description": "RichBlockEditor rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RichBlockEditorItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "RichBlockEditorLoaded",
                  "name": "Rich block editor loaded",
                  "description": "RichBlockEditor rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[RichBlockEditorItem]"
                    }
                  ]
                },
                {
                  "key": "CHANGE",
                  "name": "Change",
                  "description": "onChange prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "blocks",
                      "type": "[object]"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "RichBlockEditorItem",
                      {
                        "emit": {
                          "success": "RichBlockEditorLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "changeEvent": "CHANGE",
                        "initialBlocks": "@entity",
                        "showToolbar": true,
                        "enableBlocks": true,
                        "readOnly": false,
                        "placeholder": "Placeholder",
                        "onChange": "CHANGE",
                        "type": "rich-block-editor",
                        "className": ""
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "RichBlockEditorLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "enableBlocks": true,
                        "placeholder": "Placeholder",
                        "className": "",
                        "readOnly": false,
                        "onChange": "CHANGE",
                        "showToolbar": true,
                        "type": "rich-block-editor",
                        "changeEvent": "CHANGE",
                        "initialBlocks": "@payload.data"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "enableBlocks": {
                "type": "boolean",
                "default": true,
                "label": "Enable Blocks",
                "description": "Opt-in to the Notion-style block authoring chrome (insert toolbar, per-row +/menu gutter, turn-into menu). Off by default: the editor renders as a plain rich text surface that edits block content inline without any add-block affordances.",
                "tier": "presentation"
              },
              "readOnly": {
                "type": "boolean",
                "default": false,
                "label": "Read Only",
                "description": "readOnly prop",
                "tier": "presentation"
              },
              "showToolbar": {
                "type": "boolean",
                "default": true,
                "label": "Show Toolbar",
                "description": "showToolbar prop",
                "tier": "presentation"
              },
              "placeholder": {
                "type": "string",
                "default": "Placeholder",
                "label": "Placeholder",
                "description": "placeholder prop",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "className prop",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "RichBlockEditorPage",
            "path": "/rich-block-editor",
            "traits": [
              {
                "ref": "RichBlockEditorRender"
              }
            ]
          }
        ]
      }
    ],
