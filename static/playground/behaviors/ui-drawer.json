{
  "name": "ui-drawer",
  "description": "Drawer — UI factory (1:1 with the @almadar/ui drawer pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-drawer",
    "version": "1.0.0",
    "description": "Drawer — UI factory (1:1 with the @almadar/ui drawer pattern).",
    "orbitals": [
      {
        "name": "DrawerOrbital",
        "entity": {
          "name": "DrawerItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "DrawerRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "DrawerItem",
            "emits": [
              {
                "event": "CLOSE",
                "description": "Callback when drawer should close (injected by slot wrapper)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "OPEN",
                "description": "Open the Drawer.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "closed",
                  "isInitial": true
                },
                {
                  "name": "open"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "OPEN",
                  "name": "Open",
                  "description": "Open the Drawer.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "Callback when drawer should close (injected by slot wrapper)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "closed",
                  "to": "closed",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "action": "OPEN",
                        "label": "Open Drawer",
                        "type": "button"
                      }
                    ]
                  ]
                },
                {
                  "from": "closed",
                  "to": "open",
                  "event": "OPEN",
                  "effects": [
                    [
                      "render-ui",
                      "drawer",
                      {
                        "children": [
                          {
                            "content": "Sample content",
                            "type": "typography"
                          }
                        ],
                        "isOpen": true,
                        "title": "Title",
                        "onClose": "CLOSE",
                        "closeOnEscape": true,
                        "footer": "@config.footer",
                        "width": "md",
                        "closeEvent": "CLOSE",
                        "showCloseButton": true,
                        "type": "drawer",
                        "closeOnOverlayClick": true,
                        "className": "",
                        "position": "right"
                      }
                    ]
                  ]
                },
                {
                  "from": "open",
                  "to": "closed",
                  "event": "CLOSE",
                  "effects": [
                    [
                      "render-ui",
                      "drawer",
                      null
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "action": "OPEN",
                        "type": "button",
                        "label": "Open Drawer"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "closeOnEscape": {
                "type": "boolean",
                "default": true,
                "label": "Close On Escape",
                "description": "Close on escape key",
                "tier": "presentation"
              },
              "position": {
                "type": "string",
                "default": "right",
                "label": "Position",
                "description": "Position (left or right)",
                "tier": "presentation",
                "values": [
                  "left",
                  "right"
                ]
              },
              "showCloseButton": {
                "type": "boolean",
                "default": true,
                "label": "Show Close Button",
                "description": "Show close button",
                "tier": "presentation"
              },
              "width": {
                "type": "string",
                "default": "md",
                "label": "Width",
                "description": "Width (CSS value or preset size)",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "full"
                ]
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional class name",
                "tier": "presentation"
              },
              "footer": {
                "type": "node",
                "label": "Footer",
                "description": "Footer content",
                "tier": "presentation"
              },
              "isOpen": {
                "type": "boolean",
                "default": true,
                "label": "Is Open",
                "description": "Whether the drawer is open (defaults to true when rendered by slot wrapper)",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Drawer title",
                "tier": "presentation"
              },
              "closeOnOverlayClick": {
                "type": "boolean",
                "default": true,
                "label": "Close On Overlay Click",
                "description": "Close on overlay click",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "DrawerPage",
            "path": "/drawer",
            "traits": [
              {
                "ref": "DrawerRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "DrawerOrbital": [
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "isOpen",
            "knob": "isOpen"
          },
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "closeOnEscape",
            "knob": "closeOnEscape"
          },
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "width",
            "knob": "width"
          },
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "showCloseButton",
            "knob": "showCloseButton"
          },
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "closeOnOverlayClick",
            "knob": "closeOnOverlayClick"
          },
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "DrawerRender",
            "patternPath": "root",
            "prop": "position",
            "knob": "position"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}