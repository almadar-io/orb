{
  "name": "std-cross-reference",
  "description": "std-cross-reference — join-table primitive for N:M relationships. Listens for LinkRequested/UnlinkRequested/FETCH_LINKS_FOR and manages the junction collection (default CrossRefLink [persistent: cross_ref_links]). Rebind via linkedEntity to your consumer junction. Emits LinkCreated, LinkRemoved, LinksLoaded as external broadcasts for downstream consumers.",
  "level": "atom",
  "topic": "infra",
  "schema": {
    "name": "std-cross-reference",
    "version": "1.0.0",
    "description": "std-cross-reference — join-table primitive for N:M relationships. Listens for LinkRequested/UnlinkRequested/FETCH_LINKS_FOR and manages the junction collection (default CrossRefLink [persistent: cross_ref_links]). Rebind via linkedEntity to your consumer junction. Emits LinkCreated, LinkRemoved, LinksLoaded as external broadcasts for downstream consumers.",
    "orbitals": [
      {
        "name": "CrossReferenceOrbital",
        "entity": {
          "name": "CrossRefLink",
          "collection": "cross_ref_links",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "leftId",
              "type": "string",
              "default": "",
              "description": "Identifier for the related entity on the left side.",
              "synonyms": "sourceId, originId, parentId"
            },
            {
              "name": "rightId",
              "type": "string",
              "default": "",
              "description": "Identifier for the related entity on the right side.",
              "synonyms": "targetId, relatedId, counterpartId"
            },
            {
              "name": "createdAt",
              "type": "string",
              "default": ""
            },
            {
              "name": "filteredLinks",
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "properties": {
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "href": {
                    "name": "href",
                    "type": "string",
                    "required": true
                  }
                }
              },
              "description": "A list of filtered link specifications.",
              "synonyms": "links, references, connections"
            }
          ]
        },
        "traits": [
          {
            "name": "CrossReferenceGate",
            "category": "lifecycle",
            "linkedEntity": "CrossRefLink",
            "emits": [
              {
                "event": "LinkCreated",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object"
                  }
                ]
              },
              {
                "event": "LinkRemoved",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "rightId",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "LinksLoaded",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "leftId",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "event": "LinksFetched",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ObjectSpec]"
                  }
                ]
              },
              {
                "event": "LinkOpFailed",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "LinkRequested",
                  "name": "Link requested",
                  "payloadSchema": [
                    {
                      "name": "leftId",
                      "type": "string"
                    },
                    {
                      "name": "rightId",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "UnlinkRequested",
                  "name": "Unlink requested",
                  "payloadSchema": [
                    {
                      "name": "leftId",
                      "type": "string"
                    },
                    {
                      "name": "rightId",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "FETCH_LINKS_FOR",
                  "name": "Fetch Links For",
                  "payloadSchema": [
                    {
                      "name": "leftId",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "LinksFetched",
                  "name": "Links fetched",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[ObjectSpec]"
                    }
                  ]
                },
                {
                  "key": "LinkCreated",
                  "name": "Link created",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "object"
                    }
                  ]
                },
                {
                  "key": "LinkRemoved",
                  "name": "Link removed",
                  "payloadSchema": [
                    {
                      "name": "leftId",
                      "type": "string"
                    },
                    {
                      "name": "rightId",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "LinksLoaded",
                  "name": "Links loaded",
                  "payloadSchema": [
                    {
                      "name": "leftId",
                      "type": "string"
                    },
                    {
                      "name": "data",
                      "type": "[ObjectSpec]"
                    }
                  ]
                },
                {
                  "key": "LinkOpFailed",
                  "name": "Link op failed",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "LinkRequested",
                  "effects": [
                    [
                      "persist",
                      "create",
                      "CrossRefLink",
                      {
                        "leftId": "@payload.leftId",
                        "rightId": "@payload.rightId"
                      },
                      {
                        "emit": {
                          "success": "LinkCreated",
                          "failure": "LinkOpFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "UnlinkRequested",
                  "effects": [
                    [
                      "persist",
                      "delete",
                      "CrossRefLink",
                      "@payload",
                      {
                        "emit": {
                          "success": "LinkRemoved",
                          "failure": "LinkOpFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "FETCH_LINKS_FOR",
                  "effects": [
                    [
                      "set",
                      "@entity.leftId",
                      "@payload.leftId"
                    ],
                    [
                      "fetch",
                      "CrossRefLink",
                      {
                        "emit": {
                          "failure": "LinkOpFailed",
                          "success": "LinksFetched"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "LinksFetched",
                  "effects": [
                    [
                      "set",
                      "@entity.filteredLinks",
                      [
                        "array/filter",
                        "@payload.data",
                        [
                          "fn",
                          "row",
                          [
                            "=",
                            [
                              "object/get",
                              "@row",
                              "leftId"
                            ],
                            "@entity.leftId"
                          ]
                        ]
                      ]
                    ],
                    [
                      "emit",
                      "LinksLoaded",
                      {
                        "leftId": "@entity.leftId",
                        "data": "@entity.filteredLinks"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "leftEntity": {
                "type": "string",
                "default": "",
                "label": "Left entity",
                "description": "Entity type on the left side of the N:M relationship",
                "synonyms": "left side, source entity, from entity, parent entity",
                "tier": "internal"
              },
              "rightIdField": {
                "type": "string",
                "default": "",
                "label": "Right FK field",
                "description": "Junction column holding the right entity's id",
                "synonyms": "right foreign key, right FK, target key, child key",
                "tier": "internal"
              },
              "leftIdField": {
                "type": "string",
                "default": "",
                "label": "Left FK field",
                "description": "Junction column holding the left entity's id",
                "synonyms": "left foreign key, left FK, source key, parent key",
                "tier": "internal"
              },
              "rightEntity": {
                "type": "string",
                "default": "",
                "label": "Right entity",
                "description": "Entity type on the right side of the N:M relationship",
                "synonyms": "right side, target entity, to entity, child entity, related entity",
                "tier": "internal"
              },
              "junctionEntity": {
                "type": "string",
                "default": "",
                "label": "Junction entity",
                "description": "Persistent entity used as the join table",
                "synonyms": "join table, link table, bridge table, junction table, mapping table",
                "tier": "internal"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "CrossReferencePage",
            "path": "/cross-reference",
            "traits": [
              {
                "ref": "CrossReferenceGate"
              }
            ]
          }
        ]
      }
    ]
  },
  "source": "",
  "lolo": ""
}