{
  "name": "ui-navigation",
  "description": "Navigation — UI factory (1:1 with the @almadar/ui navigation pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-navigation",
    "version": "1.0.0",
    "description": "Navigation — UI factory (1:1 with the @almadar/ui navigation pattern).",
    "orbitals": [
      {
        "name": "NavigationOrbital",
        "entity": {
          "name": "NavigationItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "NavigationRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "NavigationItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "isLoading": false,
                        "type": "navigation",
                        "className": "",
                        "orientation": "horizontal",
                        "items": [
                          {
                            "subMenu": [],
                            "disabled": false,
                            "icon": "circle",
                            "href": "Href",
                            "isActive": false,
                            "id": "Id",
                            "badge": "Badge",
                            "label": "Label"
                          },
                          {
                            "icon": "circle",
                            "id": "Id 2",
                            "label": "Label 2",
                            "isActive": true,
                            "badge": "Badge 2",
                            "subMenu": [],
                            "href": "Href 2",
                            "disabled": true
                          }
                        ],
                        "error": "@config.error"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "error": {
                "type": "NavigationError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "items": {
                "type": "[NavigationItemsItem]",
                "default": [
                  {
                    "subMenu": [],
                    "disabled": false,
                    "icon": "circle",
                    "href": "Href",
                    "isActive": false,
                    "id": "Id",
                    "badge": "Badge",
                    "label": "Label"
                  },
                  {
                    "icon": "circle",
                    "id": "Id 2",
                    "label": "Label 2",
                    "isActive": true,
                    "badge": "Badge 2",
                    "subMenu": [],
                    "href": "Href 2",
                    "disabled": true
                  }
                ],
                "label": "Items",
                "description": "Navigation items",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "href": {
                      "name": "href",
                      "type": "string",
                      "required": false
                    },
                    "disabled": {
                      "name": "disabled",
                      "type": "boolean",
                      "required": false
                    },
                    "isActive": {
                      "name": "isActive",
                      "type": "boolean",
                      "required": false
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "badge": {
                      "name": "badge",
                      "type": "string",
                      "required": false
                    },
                    "subMenu": {
                      "name": "subMenu",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "orientation": {
                "type": "string",
                "default": "horizontal",
                "label": "Orientation",
                "description": "Navigation orientation",
                "tier": "presentation",
                "values": [
                  "horizontal",
                  "vertical"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "NavigationPage",
            "path": "/navigation",
            "traits": [
              {
                "ref": "NavigationRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "NavigationOrbital": [
          {
            "trait": "NavigationRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "NavigationRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "NavigationRender",
            "patternPath": "root",
            "prop": "orientation",
            "knob": "orientation"
          },
          {
            "trait": "NavigationRender",
            "patternPath": "root",
            "prop": "items",
            "knob": "items"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}