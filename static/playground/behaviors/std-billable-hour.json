              "synonyms": "duration, time, amount"
            },
            {
              "name": "rate",
              "type": "number",
              "default": 0,
              "description": "The hourly charge for the work performed.",
              "synonyms": "price, cost, amount"
            },
            {
              "name": "description",
              "type": "string",
              "default": "",
