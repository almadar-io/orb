{
  "name": "ui-icon",
  "description": "Icon — UI factory (1:1 with the @almadar/ui icon pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-icon",
    "version": "1.0.0",
    "description": "Icon — UI factory (1:1 with the @almadar/ui icon pattern).",
    "orbitals": [
      {
        "name": "IconOrbital",
        "entity": {
          "name": "IconItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "IconRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "IconItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "name": "Name",
                        "size": "md",
                        "style": {},
                        "type": "icon",
                        "icon": "circle",
                        "strokeWidth": 0,
                        "animation": "none",
                        "color": "primary",
                        "className": ""
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "color": {
                "type": "string",
                "default": "primary",
                "label": "Color",
                "description": "Semantic palette token or an arbitrary Tailwind color class.",
                "tier": "presentation",
                "values": [
                  "primary",
                  "secondary",
                  "success",
                  "warning",
                  "error",
                  "muted"
                ]
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Size of the icon",
                "tier": "presentation",
                "values": [
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl"
                ]
              },
              "icon": {
                "type": "icon",
                "default": "circle",
                "label": "Icon",
                "description": "Lucide icon component (preferred for type-safe usage), OR a canonical kebab-case icon name string — a string is treated exactly like `name` so trait/factory authors can pass an icon by name through the `icon` prop.",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "style": {
                "type": "json",
                "default": {},
                "label": "Style",
                "description": "Inline style",
                "tier": "presentation"
              },
              "name": {
                "type": "string",
                "default": "Name",
                "label": "Name",
                "description": "Icon name as string (resolved from iconMap)",
                "tier": "presentation"
              },
              "strokeWidth": {
                "type": "number",
                "default": 0,
                "label": "Stroke Width",
                "description": "Icon stroke width - uses theme default if not specified",
                "tier": "presentation"
              },
              "animation": {
                "type": "string",
                "default": "none",
                "label": "Animation",
                "description": "Animation type",
                "tier": "presentation",
                "values": [
                  "spin",
                  "pulse",
                  "none"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "IconPage",
            "path": "/icon",
            "traits": [
              {
                "ref": "IconRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "IconOrbital": [
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "name",
            "knob": "name"
          },
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "style",
            "knob": "style"
          },
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "icon",
            "knob": "icon"
          },
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "strokeWidth",
            "knob": "strokeWidth"
          },
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "animation",
            "knob": "animation"
          },
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "color",
            "knob": "color"
          },
          {
            "trait": "IconRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}