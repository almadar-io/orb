                          "id": "paramB",
                          "label": "Multiplier (B)",
                          "max": 5,
                          "min": 0,
                          "step": 1
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.title",
                      "Tune the Formula"
                    ],
                    [
                      "set",
                      "@entity.description",
