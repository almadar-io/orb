{
  "name": "std-version-history",
  "description": "std-version-history — wiki/CMS revision history with diff + rollback. Browses revisions; opens detail in `viewing_single`; compares two revisions in `comparing` with intrinsic version-diff; persists rollback.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-version-history",
    "version": "1.0.0",
    "description": "std-version-history — wiki/CMS revision history with diff + rollback. Browses revisions; opens detail in `viewing_single`; compares two revisions in `comparing` with intrinsic version-diff; persists rollback.",
    "orbitals": [
      {
        "name": "RevisionOrbital",
        "entity": {
          "name": "Revision",
          "collection": "revisions",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "documentId",
              "type": "string",
              "required": true,
              "description": "Unique identifier for the associated document.",
              "synonyms": "reference, identifier, source"
            },
            {
              "name": "documentType",
              "type": "string",
              "required": true,
              "description": "Specifies the kind of document this revision belongs to.",
              "synonyms": "type, kind, category"
            },
            {
              "name": "versionNumber",
              "type": "number",
              "required": true,
              "description": "A sequential identifier representing the revision's order.",
              "synonyms": "sequence, order, iteration"
            },
            {
              "name": "authorId",
              "type": "string",
              "description": "Unique identifier for the user who made the change.",
              "synonyms": "user identifier, creator, contributor"
            },
            {
              "name": "authorName",
              "type": "string",
              "description": "The name of the user who made the change.",
              "synonyms": "user, contributor, owner"
            },
            {
              "name": "content",
              "type": "string",
              "description": "The textual data of the revision.",
              "synonyms": "text, body, data, value"
            },
            {
              "name": "summary",
              "type": "string",
              "description": "A brief explanation of the revision's changes.",
              "synonyms": "description, note, comment, explanation"
            },
            {
              "name": "createdAt",
              "type": "string"
            }
          ]
        },
        "traits": [
          {
            "name": "RevisionManage",
            "category": "interaction",
            "linkedEntity": "Revision",
            "emits": [
              {
                "event": "OPEN_REVISION",
                "description": "Signals a revision has been selected for viewing.",
                "synonyms": "select, choose, display",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "documentId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "documentType",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "versionNumber",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "authorId",
                        "type": "string"
                      },
                      {
                        "name": "authorName",
                        "type": "string"
                      },
                      {
                        "name": "content",
                        "type": "string"
                      },
                      {
                        "name": "summary",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "CLOSE_VIEW",
                "description": "Indicates the view has been closed or dismissed.",
                "synonyms": "dismiss, hide, close",
                "tier": "domain"
              },
              {
                "event": "COMPARE",
                "description": "Signals a request to compare two versions.",
                "synonyms": "compare, diff, contrast",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "beforeId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "afterId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "revisions",
                    "type": "[Revision]"
                  }
                ]
              },
              {
                "event": "ROLLBACK",
                "description": "Indicates a revision has been successfully reverted.",
                "synonyms": "reverted, undone, restored",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "RevisionLoaded",
                "description": "Signals a revision has been successfully retrieved and is ready.",
                "synonyms": "loaded, fetched, retrieved, available",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Revision]"
                  }
                ]
              },
              {
                "event": "RevisionLoadFailed",
                "description": "Indicates a failure to load revision data.",
                "synonyms": "error, fail, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "RevisionRolledBack",
                "description": "Indicates a revision has been successfully restored to a previous state.",
                "synonyms": "restored, reverted, undone",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "documentId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "documentType",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "versionNumber",
                        "type": "number",
                        "required": true
                      },
                      {
                        "name": "authorId",
                        "type": "string"
                      },
                      {
                        "name": "authorName",
                        "type": "string"
                      },
                      {
                        "name": "content",
                        "type": "string"
                      },
                      {
                        "name": "summary",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "RevisionRollbackFailed",
                "description": "Indicates that a revision rollback operation was unsuccessful.",
                "synonyms": "rollback failed, revert error, undo failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "viewing_single"
                },
                {
                  "name": "comparing"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "RevisionLoaded",
                  "name": "Revision loaded",
                  "description": "Signals a revision has been successfully retrieved and is ready.",
                  "synonyms": "loaded, fetched, retrieved, available",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[Revision]"
                    }
                  ]
                },
                {
                  "key": "RevisionRolledBack",
                  "name": "Revision rolled back",
                  "description": "Indicates a revision has been successfully restored to a previous state.",
                  "synonyms": "restored, reverted, undone",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "Revision"
                    }
                  ]
                },
                {
                  "key": "RevisionRollbackFailed",
                  "name": "Revision rollback failed",
                  "description": "Indicates that a revision rollback operation was unsuccessful.",
                  "synonyms": "rollback failed, revert error, undo failure",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "RevisionLoadFailed",
                  "name": "Revision load failed",
                  "description": "Indicates a failure to load revision data.",
                  "synonyms": "error, fail, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "OPEN_REVISION",
                  "name": "Open Revision",
                  "description": "Signals a revision has been selected for viewing.",
                  "synonyms": "select, choose, display",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "Revision"
                    }
                  ]
                },
                {
                  "key": "ROLLBACK",
                  "name": "Rollback",
                  "description": "Indicates a revision has been successfully reverted.",
                  "synonyms": "reverted, undone, restored",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CLOSE_VIEW",
                  "name": "Close View",
                  "description": "Indicates the view has been closed or dismissed.",
                  "synonyms": "dismiss, hide, close",
                  "tier": "domain"
                },
                {
                  "key": "COMPARE",
                  "name": "Compare",
                  "description": "Signals a request to compare two versions.",
                  "synonyms": "compare, diff, contrast",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "beforeId",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "afterId",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "revisions",
                      "type": "[Revision]"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "Revision",
                      {
                        "emit": {
                          "failure": "RevisionLoadFailed",
                          "success": "RevisionLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "align": "center",
                        "className": "py-12",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "color": "muted",
                            "type": "typography",
                            "variant": "caption",
                            "content": "Loading version history…"
                          }
                        ],
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "RevisionLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "align": "center",
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack",
                            "children": [
                              {
                                "name": "history",
                                "type": "icon"
                              },
                              {
                                "variant": "h3",
                                "content": "Version History",
                                "type": "typography"
                              }
                            ]
                          },
                          {
                            "cols": 4,
                            "children": [
                              {
                                "look": "elevated",
                                "icon": "history",
                                "label": "Total revisions",
                                "type": "stat-display",
                                "value": "@payload.data.length"
                              },
                              {
                                "label": "Authors",
                                "look": "elevated",
                                "type": "stat-display",
                                "value": "6",
                                "icon": "users"
                              },
                              {
                                "value": "14",
                                "label": "Saves this week",
                                "type": "stat-display",
                                "look": "elevated",
                                "icon": "save"
                              },
                              {
                                "label": "Rollbacks",
                                "value": "2",
                                "type": "stat-display",
                                "look": "elevated",
                                "icon": "rotate-ccw"
                              }
                            ],
                            "type": "simple-grid"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "fields": [
                              {
                                "label": "Version",
                                "variant": "badge",
                                "name": "versionNumber"
                              },
                              {
                                "name": "authorName",
                                "label": "Author",
                                "variant": "caption"
                              },
                              {
                                "label": "Summary",
                                "variant": "caption",
                                "name": "summary"
                              },
                              {
                                "name": "createdAt",
                                "label": "Saved",
                                "variant": "caption"
                              }
                            ],
                            "itemActions": [
                              {
                                "event": "OPEN_REVISION",
                                "label": "Open",
                                "variant": "primary",
                                "icon": "arrow-right"
                              },
                              {
                                "variant": "danger",
                                "event": "ROLLBACK",
                                "label": "Rollback",
                                "icon": "rotate-ccw"
                              }
                            ],
                            "type": "data-grid",
                            "gap": "sm",
                            "look": "dense",
                            "cols": 1,
                            "entity": "@payload.data"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "RevisionRolledBack",
                  "effects": [
                    [
                      "fetch",
                      "Revision",
                      {
                        "emit": {
                          "failure": "RevisionLoadFailed",
                          "success": "RevisionLoaded"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "RevisionRollbackFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "message": "@payload.error",
                        "type": "alert",
                        "variant": "error"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "RevisionLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "message": "@payload.error",
                        "type": "alert",
                        "variant": "error"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "viewing_single",
                  "event": "OPEN_REVISION",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.row.id"
                    ],
                    [
                      "set",
                      "@entity.documentId",
                      "@payload.row.documentId"
                    ],
                    [
                      "set",
                      "@entity.documentType",
                      "@payload.row.documentType"
                    ],
                    [
                      "set",
                      "@entity.versionNumber",
                      "@payload.row.versionNumber"
                    ],
                    [
                      "set",
                      "@entity.authorId",
                      "@payload.row.authorId"
                    ],
                    [
                      "set",
                      "@entity.authorName",
                      "@payload.row.authorName"
                    ],
                    [
                      "set",
                      "@entity.content",
                      "@payload.row.content"
                    ],
                    [
                      "set",
                      "@entity.summary",
                      "@payload.row.summary"
                    ],
                    [
                      "set",
                      "@entity.createdAt",
                      "@payload.row.createdAt"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "align": "center",
                            "children": [
                              {
                                "action": "CLOSE_VIEW",
                                "variant": "ghost",
                                "type": "button",
                                "label": "Back"
                              },
                              {
                                "type": "icon",
                                "name": "file-text"
                              },
                              {
                                "content": "@entity.summary",
                                "variant": "h3",
                                "type": "typography"
                              },
                              {
                                "variant": "default",
                                "type": "badge",
                                "label": "@entity.versionNumber"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "gap": "sm",
                            "direction": "vertical",
                            "children": [
                              {
                                "direction": "horizontal",
                                "children": [
                                  {
                                    "variant": "caption",
                                    "color": "muted",
                                    "type": "typography",
                                    "content": "Author"
                                  },
                                  {
                                    "type": "typography",
                                    "content": "@entity.authorName",
                                    "variant": "body"
                                  }
                                ],
                                "type": "stack",
                                "gap": "md"
                              },
                              {
                                "gap": "md",
                                "direction": "horizontal",
                                "type": "stack",
                                "children": [
                                  {
                                    "content": "Saved",
                                    "color": "muted",
                                    "type": "typography",
                                    "variant": "caption"
                                  },
                                  {
                                    "type": "typography",
                                    "variant": "body",
                                    "content": "@entity.createdAt"
                                  }
                                ]
                              },
                              {
                                "children": [
                                  {
                                    "color": "muted",
                                    "content": "Content",
                                    "variant": "caption",
                                    "type": "typography"
                                  },
                                  {
                                    "content": "@entity.content",
                                    "type": "typography",
                                    "variant": "body"
                                  }
                                ],
                                "direction": "horizontal",
                                "gap": "md",
                                "type": "stack"
                              }
                            ],
                            "type": "stack"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "type": "simple-grid",
                            "cols": 3,
                            "children": [
                              {
                                "icon": "tag",
                                "label": "Version",
                                "type": "stat-display",
                                "look": "elevated",
                                "value": "@entity.versionNumber"
                              },
                              {
                                "value": "@entity.documentId",
                                "look": "elevated",
                                "type": "stat-display",
                                "icon": "file",
                                "label": "Document"
                              },
                              {
                                "label": "Type",
                                "value": "@entity.documentType",
                                "look": "elevated",
                                "icon": "layers",
                                "type": "stat-display"
                              }
                            ]
                          },
                          {
                            "children": [
                              {
                                "type": "button",
                                "actionPayload": {
                                  "id": "@entity.id"
                                },
                                "label": "Compare",
                                "action": "COMPARE",
                                "variant": "secondary"
                              },
                              {
                                "actionPayload": {
                                  "id": "@entity.id"
                                },
                                "variant": "danger",
                                "action": "ROLLBACK",
                                "label": "Rollback",
                                "type": "button"
                              }
                            ],
                            "direction": "horizontal",
                            "align": "center",
                            "gap": "sm",
                            "type": "stack"
                          }
                        ],
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "ROLLBACK",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "persist",
                      "update",
                      "Revision",
                      "@entity",
                      {
                        "emit": {
                          "success": "RevisionRolledBack",
                          "failure": "RevisionRollbackFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "type": "typography",
                            "variant": "caption",
                            "color": "muted",
                            "content": "Rolling back…"
                          }
                        ],
                        "gap": "md",
                        "direction": "vertical",
                        "align": "center",
                        "className": "py-12",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "loading",
                  "event": "CLOSE_VIEW",
                  "effects": [
                    [
                      "fetch",
                      "Revision",
                      {
                        "emit": {
                          "failure": "RevisionLoadFailed",
                          "success": "RevisionLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "align": "center",
                        "gap": "md",
                        "type": "stack",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "color": "muted",
                            "type": "typography",
                            "content": "Loading version history…"
                          }
                        ],
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "comparing",
                  "event": "COMPARE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "children": [
                          {
                            "align": "center",
                            "children": [
                              {
                                "type": "button",
                                "action": "CLOSE_VIEW",
                                "label": "Back",
                                "variant": "ghost"
                              },
                              {
                                "name": "git-compare",
                                "type": "icon"
                              },
                              {
                                "variant": "h3",
                                "type": "typography",
                                "content": "Compare versions"
                              }
                            ],
                            "gap": "sm",
                            "type": "stack",
                            "direction": "horizontal"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "onRevert": "ROLLBACK",
                            "afterId": "@payload.afterId",
                            "revisions": "@payload.revisions",
                            "type": "version-diff",
                            "beforeId": "@payload.beforeId",
                            "view": "side-by-side"
                          },
                          {
                            "gap": "sm",
                            "type": "stack",
                            "children": [
                              {
                                "variant": "danger",
                                "action": "ROLLBACK",
                                "actionPayload": {
                                  "id": "@entity.id"
                                },
                                "label": "Rollback",
                                "type": "button"
                              }
                            ],
                            "align": "center",
                            "direction": "horizontal"
                          }
                        ],
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "loading",
                  "event": "ROLLBACK",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "persist",
                      "update",
                      "Revision",
                      "@entity",
                      {
                        "emit": {
                          "success": "RevisionRolledBack",
                          "failure": "RevisionRollbackFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "className": "py-12",
                        "type": "stack",
                        "direction": "vertical",
                        "align": "center",
