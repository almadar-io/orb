{
  "name": "ui-timeline",
  "description": "Timeline — UI factory (1:1 with the @almadar/ui timeline pattern).",
  "level": "organism",
  "topic": "ui/core",
  "schema": {
    "name": "ui-timeline",
    "version": "1.0.0",
    "description": "Timeline — UI factory (1:1 with the @almadar/ui timeline pattern).",
    "orbitals": [
      {
        "name": "TimelineOrbital",
        "entity": {
          "name": "TimelineItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "TimelineRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "TimelineItem",
            "emits": [
              {
                "event": "VIEW",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "TimelineLoaded",
                "description": "Timeline rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TimelineItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "TimelineLoaded",
                  "name": "Timeline loaded",
                  "description": "Timeline rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[TimelineItem]"
                    }
                  ]
                },
                {
                  "key": "VIEW",
                  "name": "View",
                  "description": "User opened a record from the list.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "TimelineItem",
                      {
                        "emit": {
                          "success": "TimelineLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "fields": [
                          "list",
                          "Item",
                          "Item 2"
                        ],
                        "look": "vertical-spacious",
                        "error": "@config.error",
                        "className": "",
                        "entity": "@entity",
                        "title": "Title",
                        "type": "timeline",
                        "isLoading": false,
                        "itemActions": [
                          {
                            "label": "View",
                            "event": "VIEW"
                          }
                        ],
                        "items": [
                          {
                            "date": "Date",
                            "id": "Id",
                            "icon": "circle",
                            "tags": [
                              "Item",
                              "Item 2"
                            ],
                            "title": "Title",
                            "status": "complete",
                            "description": "Description"
                          },
                          {
                            "tags": [
                              "Item",
                              "Item 2"
                            ],
                            "title": "Title 2",
                            "description": "Description 2",
                            "icon": "circle",
                            "date": "Date 2",
                            "id": "Id 2",
                            "status": "active"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "TimelineLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "",
                        "itemActions": [
                          {
                            "event": "VIEW",
                            "label": "View"
                          }
                        ],
                        "error": "@config.error",
                        "look": "vertical-spacious",
                        "fields": [
                          "list",
                          "Item",
                          "Item 2"
                        ],
                        "type": "timeline",
                        "items": [
                          {
                            "date": "Date",
                            "id": "Id",
                            "icon": "circle",
                            "tags": [
                              "Item",
                              "Item 2"
                            ],
                            "title": "Title",
                            "status": "complete",
                            "description": "Description"
                          },
                          {
                            "tags": [
                              "Item",
                              "Item 2"
                            ],
                            "title": "Title 2",
                            "description": "Description 2",
                            "icon": "circle",
                            "date": "Date 2",
                            "id": "Id 2",
                            "status": "active"
                          }
                        ],
                        "isLoading": false,
                        "entity": "@payload.data",
                        "title": "Title"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "VIEW",
                  "effects": [
                    [
                      "emit",
                      "VIEW",
                      {}
                    ]
                  ]
                }
              ]
            },
            "config": {
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Timeline title",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "look": {
                "type": "string",
                "default": "vertical-spacious",
                "label": "Look",
                "description": "Layer 2 visual treatment.",
                "tier": "presentation",
                "values": [
                  "vertical-compact",
                  "vertical-spacious",
                  "horizontal",
                  "swimlane"
                ]
              },
              "fields": {
                "type": "[string]",
                "default": [
                  "Item",
                  "Item 2"
                ],
                "label": "Fields",
                "description": "Fields to display",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "items": {
                "type": "[TimelineItemsItem]",
                "default": [
                  {
                    "date": "Date",
                    "id": "Id",
                    "icon": "circle",
                    "tags": [
                      "Item",
                      "Item 2"
                    ],
                    "title": "Title",
                    "status": "complete",
                    "description": "Description"
                  },
                  {
                    "tags": [
                      "Item",
                      "Item 2"
                    ],
                    "title": "Title 2",
                    "description": "Description 2",
                    "icon": "circle",
                    "date": "Date 2",
                    "id": "Id 2",
                    "status": "active"
                  }
                ],
                "label": "Items",
                "description": "Timeline items",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    "title": {
                      "name": "title",
                      "type": "string",
                      "required": true
                    },
                    "tags": {
                      "name": "tags",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "date": {
                      "name": "date",
                      "type": "string",
                      "required": false
                    },
                    "description": {
                      "name": "description",
                      "type": "string",
                      "required": false
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "status": {
                      "name": "status",
                      "type": "string",
                      "required": false,
                      "values": [
                        "complete",
                        "active",
                        "pending",
                        "error"
                      ]
                    }
                  }
                }
              },
              "error": {
                "type": "TimelineError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "itemActions": {
                "type": "[TimelineItemActionsItem]",
                "default": [
                  {
                    "label": "Label",
                    "variant": "primary",
                    "navigatesTo": "Navigates To"
                  },
                  {
                    "navigatesTo": "Navigates To 2",
                    "variant": "secondary",
                    "label": "Label 2"
                  }
                ],
                "label": "Item Actions",
                "description": "Actions per item",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": false
                    },
                    "navigatesTo": {
                      "name": "navigatesTo",
                      "type": "string",
                      "required": false
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost"
                      ]
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "TimelinePage",
            "path": "/timeline",
            "traits": [
              {
                "ref": "TimelineRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "TimelineOrbital": [
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "fields",
            "knob": "fields"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "look",
            "knob": "look"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "items",
            "knob": "items"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "look",
            "knob": "look"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "fields",
            "knob": "fields"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "items",
            "knob": "items"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "TimelineRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          }
        ]
      }
    }
  },
