    "version": "1.0.0",
    "description": "StatCard — UI factory (1:1 with the @almadar/ui stat-card pattern).",
    "orbitals": [
      {
        "name": "StatCardOrbital",
        "entity": {
          "name": "StatCardItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
