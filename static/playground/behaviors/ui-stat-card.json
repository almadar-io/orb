        "traits": [
          {
            "name": "StatCardRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "StatCardItem",
            "emits": [
              {
                "event": "StatCardLoaded",
                "description": "StatCard rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StatCardItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "StatCardLoaded",
                  "name": "Stat card loaded",
                  "description": "StatCard rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[StatCardItem]"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "StatCardItem",
                      {
                        "emit": {
                          "success": "StatCardLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "isLoading": false,
                        "iconBg": "bg-muted",
                        "currentValue": 0,
                        "action": {
