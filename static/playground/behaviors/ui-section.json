{
  "name": "ui-section",
  "description": "Section — UI factory (1:1 with the @almadar/ui section pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-section",
    "version": "1.0.0",
    "description": "Section — UI factory (1:1 with the @almadar/ui section pattern).",
    "orbitals": [
      {
        "name": "SectionOrbital",
        "entity": {
          "name": "SectionItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "SectionRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "SectionItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "default",
                        "error": "@config.error",
                        "headerClassName": "Header Class Name",
                        "action": "@config.action",
                        "contentClassName": "Content Class Name",
                        "divider": false,
                        "isLoading": false,
                        "title": "Title",
                        "className": "",
                        "children": [
                          {
                            "content": "Sample content",
                            "type": "typography"
                          }
                        ],
                        "description": "Description",
                        "padding": "md",
                        "type": "section"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "description": {
                "type": "string",
                "default": "Description",
                "label": "Description",
                "description": "Section subtitle/description",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Custom class name",
                "tier": "presentation"
              },
              "contentClassName": {
                "type": "string",
                "default": "Content Class Name",
                "label": "Content Class Name",
                "description": "Content custom class name",
                "tier": "presentation"
              },
              "divider": {
                "type": "boolean",
                "default": false,
                "label": "Divider",
                "description": "Show divider below header",
                "tier": "presentation"
              },
              "headerClassName": {
                "type": "string",
                "default": "Header Class Name",
                "label": "Header Class Name",
                "description": "Header custom class name",
                "tier": "presentation"
              },
              "error": {
                "type": "SectionError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Section title",
                "tier": "presentation"
              },
              "action": {
                "type": "node",
                "label": "Action",
                "description": "Action element (e.g., button, link)",
                "tier": "presentation"
              },
              "padding": {
                "type": "string",
                "default": "md",
                "label": "Padding",
                "description": "Padding amount",
                "tier": "presentation",
                "values": [
                  "none",
                  "sm",
                  "md",
                  "lg",
                  "xl"
                ]
              },
              "variant": {
                "type": "string",
                "default": "default",
                "label": "Variant",
                "description": "Visual variant",
                "tier": "presentation",
                "values": [
                  "default",
                  "card",
                  "bordered",
                  "filled"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SectionPage",
            "path": "/section",
            "traits": [
              {
                "ref": "SectionRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "SectionOrbital": [
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "headerClassName",
            "knob": "headerClassName"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "contentClassName",
            "knob": "contentClassName"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "divider",
            "knob": "divider"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "description",
            "knob": "description"
          },
          {
            "trait": "SectionRender",
            "patternPath": "root",
            "prop": "padding",
            "knob": "padding"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}