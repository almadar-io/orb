{
  "name": "ui-split",
  "description": "Split — UI factory (1:1 with the @almadar/ui split pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-split",
    "version": "1.0.0",
    "description": "Split — UI factory (1:1 with the @almadar/ui split pattern).",
    "orbitals": [
      {
        "name": "SplitOrbital",
        "entity": {
          "name": "SplitItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "SplitRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "SplitItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "stackBreakpoint": "md",
                        "leftClassName": "Left Class Name",
                        "stackOnMobile": true,
                        "children": [
                          {
                            "content": "Panel A",
                            "type": "typography"
                          },
                          {
                            "content": "Panel B",
                            "type": "typography"
                          }
                        ],
                        "rightClassName": "Right Class Name",
                        "type": "split",
                        "align": "stretch",
                        "isLoading": false,
                        "gap": "md",
                        "ratio": "1:1",
                        "error": "@config.error",
                        "className": "",
                        "reverse": false
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "gap": {
                "type": "string",
                "default": "md",
                "label": "Gap",
                "description": "Gap between panels",
                "tier": "presentation",
                "values": [
                  "none",
                  "sm",
                  "md",
                  "lg",
                  "xl"
                ]
              },
              "stackBreakpoint": {
                "type": "string",
                "default": "md",
                "label": "Stack Breakpoint",
                "description": "Breakpoint to switch from stacked to side-by-side",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg",
                  "xl"
                ]
              },
              "rightClassName": {
                "type": "string",
                "default": "Right Class Name",
                "label": "Right Class Name",
                "description": "Right/second panel class name",
                "tier": "presentation"
              },
              "align": {
                "type": "string",
                "default": "stretch",
                "label": "Align",
                "description": "Align items vertically",
                "tier": "presentation",
                "values": [
                  "start",
                  "center",
                  "end",
                  "stretch"
                ]
              },
              "error": {
                "type": "SplitError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "leftClassName": {
                "type": "string",
                "default": "Left Class Name",
                "label": "Left Class Name",
                "description": "Left/first panel class name",
                "tier": "presentation"
              },
              "ratio": {
                "type": "string",
                "default": "1:1",
                "label": "Ratio",
                "description": "Size ratio between left and right panels",
                "tier": "presentation",
                "values": [
                  "1:1",
                  "1:2",
                  "2:1",
                  "1:3",
                  "3:1",
                  "1:4",
                  "4:1",
                  "2:3",
                  "3:2"
                ]
              },
              "reverse": {
                "type": "boolean",
                "default": false,
                "label": "Reverse",
                "description": "Reverse the order (right first)",
                "tier": "presentation"
              },
              "stackOnMobile": {
                "type": "boolean",
                "default": true,
                "label": "Stack On Mobile",
                "description": "Stack vertically on mobile",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Custom class name",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "SplitPage",
            "path": "/split",
            "traits": [
              {
                "ref": "SplitRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "SplitOrbital": [
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "stackBreakpoint",
            "knob": "stackBreakpoint"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "leftClassName",
            "knob": "leftClassName"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "stackOnMobile",
            "knob": "stackOnMobile"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "rightClassName",
            "knob": "rightClassName"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "align",
            "knob": "align"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "gap",
            "knob": "gap"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "ratio",
            "knob": "ratio"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "SplitRender",
            "patternPath": "root",
            "prop": "reverse",
            "knob": "reverse"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}