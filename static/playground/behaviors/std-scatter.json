{
  "name": "std-scatter",
  "description": "std-scatter — embeddable scatter / bubble chart atom. ITEMS_LOADED maps @payload.data into {x,y,label,size,color} points using configured fields (no aggregation step — distinct from std-graphs). Drop into a dashboard alongside std-stats / std-graphs for two-numeric correlation views.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-scatter",
    "version": "1.0.0",
    "description": "std-scatter — embeddable scatter / bubble chart atom. ITEMS_LOADED maps @payload.data into {x,y,label,size,color} points using configured fields (no aggregation step — distinct from std-graphs). Drop into a dashboard alongside std-stats / std-graphs for two-numeric correlation views.",
    "orbitals": [
      {
        "name": "ScatterItemOrbital",
        "entity": {
          "name": "ScatterItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "points",
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "properties": {
                  "size": {
                    "name": "size",
                    "type": "number",
                    "required": false
                  },
                  "x": {
                    "name": "x",
                    "type": "number",
                    "required": true
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": false
                  },
                  "color": {
                    "name": "color",
                    "type": "string",
                    "required": false
                  },
                  "y": {
                    "name": "y",
                    "type": "number",
                    "required": true
                  }
                }
              },
              "description": "An array of data points for the scatter chart.",
              "synonyms": "data, values, records"
            }
          ]
        },
        "traits": [
          {
            "name": "ScatterItemPlot",
            "category": "interaction",
            "linkedEntity": "ScatterItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "ITEMS_LOADED",
                  "name": "Items Loaded",
                  "description": "Data has been received and is ready for visualization.",
                  "synonyms": "data-ready, data-available, loaded",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[ObjectSpec]"
                    },
                    {
                      "name": "totalCount",
                      "type": "number"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.points",
                      [
                        {
                          "size": 8,
                          "color": "",
                          "y": 24,
                          "label": "A",
                          "x": 12
                        },
                        {
                          "color": "",
                          "size": 6,
                          "y": 42,
                          "x": 28,
                          "label": "B"
                        },
                        {
                          "x": 45,
                          "y": 18,
                          "size": 10,
                          "label": "C",
                          "color": ""
                        },
                        {
                          "x": 60,
                          "color": "",
                          "label": "D",
                          "y": 55,
                          "size": 7
                        },
                        {
                          "label": "E",
                          "x": 78,
                          "y": 38,
                          "size": 9,
                          "color": ""
                        }
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "subtitle": "x vs y",
                        "type": "chart",
                        "chartType": "scatter",
                        "drillEvent": "",
                        "height": 280,
                        "scatterData": "@entity.points",
                        "title": "Correlation"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "ITEMS_LOADED",
                  "effects": [
                    [
                      "set",
                      "@entity.points",
                      [
                        "array/map",
                        "@payload.data",
                        [
                          "fn",
                          "row",
                          {
                            "label": [
                              "object/get",
                              "@row",
                              "",
                              ""
                            ],
                            "size": [
                              "object/get",
                              "@row",
                              "",
                              5
                            ],
                            "x": [
                              "object/get",
                              "@row",
                              "x",
                              0
                            ],
                            "y": [
                              "object/get",
                              "@row",
                              "y",
                              0
                            ],
                            "color": [
                              "object/get",
                              "@row",
                              "",
                              ""
                            ]
                          }
                        ]
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "chart",
                        "title": "Correlation",
                        "subtitle": "x vs y",
                        "drillEvent": "",
                        "chartType": "scatter",
                        "height": 280,
                        "scatterData": "@entity.points"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "labelField": {
                "type": "string",
                "default": "",
                "label": "Label field",
                "description": "Field used as the point label tooltip (blank = none)",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Correlation",
                "label": "Title",
                "description": "Heading shown above the chart",
                "tier": "presentation"
              },
              "height": {
                "type": "number",
                "default": 280,
                "label": "Chart height",
                "description": "Pixel height of the rendered scatter plot",
                "tier": "presentation"
              },
              "xField": {
                "type": "string",
                "default": "x",
                "label": "X-axis field",
                "description": "Entity field mapped to the horizontal axis",
                "tier": "presentation"
              },
              "colorField": {
                "type": "string",
                "default": "",
                "label": "Color field",
                "description": "Field used to color-code points (blank = single color)",
                "tier": "presentation"
              },
              "drillEvent": {
                "type": "string",
                "default": "",
                "label": "Drill event",
                "description": "Event emitted when the user clicks a data point",
                "tier": "internal"
              },
              "sizeField": {
                "type": "string",
                "default": "",
                "label": "Size field",
                "description": "Numeric field that scales bubble size (blank = uniform)",
                "tier": "presentation"
              },
              "subtitle": {
                "type": "string",
                "default": "x vs y",
                "label": "Subtitle",
                "description": "Secondary line below the title",
                "tier": "presentation"
              },
              "yField": {
                "type": "string",
                "default": "y",
                "label": "Y-axis field",
                "description": "Entity field mapped to the vertical axis",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ScatterItemPlotPage",
            "path": "/scatteritems",
            "traits": [
              {
                "ref": "ScatterItemPlot"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ScatterItemOrbital": [
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "subtitle",
            "knob": "subtitle"
          },
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "drillEvent",
            "knob": "drillEvent"
          },
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "height",
            "knob": "height"
          },
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "subtitle",
            "knob": "subtitle"
          },
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "drillEvent",
            "knob": "drillEvent"
          },
          {
            "trait": "ScatterItemPlot",
            "patternPath": "root",
            "prop": "height",
            "knob": "height"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}