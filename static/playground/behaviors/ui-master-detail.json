{
  "name": "ui-master-detail",
  "description": "MasterDetail — UI factory (1:1 with the @almadar/ui master-detail pattern).",
  "level": "organism",
  "topic": "ui/core",
  "schema": {
    "name": "ui-master-detail",
    "version": "1.0.0",
    "description": "MasterDetail — UI factory (1:1 with the @almadar/ui master-detail pattern).",
    "orbitals": [
      {
        "name": "MasterDetailOrbital",
        "entity": {
          "name": "MasterDetailItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "MasterDetailRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "MasterDetailItem",
            "emits": [
              {
                "event": "MasterDetailLoaded",
                "description": "MasterDetail rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MasterDetailItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "MasterDetailLoaded",
                  "name": "Master detail loaded",
                  "description": "MasterDetail rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[MasterDetailItem]"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "MasterDetailItem",
                      {
                        "emit": {
                          "success": "MasterDetailLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "detailFields": [],
                        "activeFilters": {},
                        "isLoading": false,
                        "masterFields": [
                          "list",
                          "Item",
                          "Item 2"
                        ],
                        "loading": false,
                        "error": "@config.error",
                        "page": 0,
                        "className": "",
                        "entity": "@entity",
                        "pageSize": 0,
                        "searchValue": "Search Value",
                        "type": "master-detail",
                        "totalCount": 0,
                        "selectedIds": [],
                        "sortDirection": "asc",
                        "sortBy": "Sort By"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "MasterDetailLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "pageSize": 0,
                        "className": "",
                        "error": "@config.error",
                        "totalCount": 0,
                        "entity": "@payload.data",
                        "sortBy": "Sort By",
                        "sortDirection": "asc",
                        "masterFields": [
                          "list",
                          "Item",
                          "Item 2"
                        ],
                        "searchValue": "Search Value",
                        "selectedIds": [],
                        "type": "master-detail",
                        "isLoading": false,
                        "detailFields": [],
                        "page": 0,
                        "loading": false,
                        "activeFilters": {}
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "error": {
                "type": "MasterDetailError",
                "label": "Error",
                "description": "Error state (UiError)",
                "tier": "presentation",
                "properties": {
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "searchValue": {
                "type": "string",
                "default": "Search Value",
                "label": "Search Value",
                "description": "Current search query value",
                "tier": "presentation"
              },
              "loading": {
                "type": "boolean",
                "default": false,
                "label": "Loading",
                "description": "Loading state (alias for isLoading)",
                "tier": "presentation"
              },
              "sortBy": {
                "type": "string",
                "default": "Sort By",
                "label": "Sort By",
                "description": "Current sort field",
                "tier": "presentation"
              },
              "pageProp": {
                "type": "number",
                "default": 0,
                "label": "Page",
                "description": "Current page number",
                "synonyms": "page",
                "tier": "presentation"
              },
              "selectedIds": {
                "type": "[string]",
                "default": [],
                "label": "Selected Ids",
                "description": "Currently selected item IDs",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "sortDirection": {
                "type": "string",
                "default": "asc",
                "label": "Sort Direction",
                "description": "Current sort direction",
                "tier": "presentation",
                "values": [
                  "asc",
                  "desc"
                ]
              },
              "totalCount": {
                "type": "number",
                "default": 0,
                "label": "Total Count",
                "description": "Total number of items",
                "tier": "presentation"
              },
              "pageSize": {
                "type": "number",
                "default": 0,
                "label": "Page Size",
                "description": "Number of items per page",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "detailFields": {
                "type": "[string]",
                "default": [],
                "label": "Detail Fields",
                "description": "Fields for detail view (passed through but typically handled by separate render_ui)",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "masterFields": {
                "type": "[string]",
                "default": [
                  "Item",
                  "Item 2"
                ],
                "label": "Master Fields",
                "description": "Fields to show in the master list (maps to DataTable columns)",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "activeFilters": {
                "type": "json",
                "default": {},
                "label": "Active Filters",
                "description": "Active filters",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "MasterDetailPage",
            "path": "/master-detail",
            "traits": [
              {
                "ref": "MasterDetailRender"
              }
            ]
          }
        ]
      }
    ],
