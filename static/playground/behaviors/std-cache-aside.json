{
  "name": "std-cache-aside",
  "description": "std-cache-aside as a Function",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-cache-aside",
    "version": "1.0.0",
    "description": "std-cache-aside as a Function",
    "orbitals": [
      {
        "name": "CacheEntryOrbital",
        "entity": {
          "name": "CacheEntry",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "name",
              "type": "string",
              "required": true,
              "description": "A user-defined identifier for the cache entry.",
              "synonyms": "key, identifier, alias"
            },
            {
              "name": "description",
              "type": "string",
              "description": "A human-readable explanation of the entry's content.",
              "synonyms": "explanation, details, notes, summary"
            },
            {
              "name": "status",
              "type": "string",
              "default": "active",
              "values": [
                "active",
                "inactive",
                "pending"
              ],
              "description": "Current operational state of the entry.",
              "synonyms": "state, condition, operationalStatus"
            },
            {
              "name": "createdAt",
              "type": "string"
            },
            {
              "name": "hitCount",
              "type": "number",
              "default": 0,
              "description": "The number of times this entry has been retrieved.",
              "synonyms": "count, occurrences, retrievals"
            },
            {
              "name": "cacheAge",
              "type": "number",
              "default": 0,
              "description": "Duration since the cache entry was last updated.",
              "synonyms": "age, duration, expiry"
            }
          ]
        },
        "traits": [
          {
            "name": "CacheEntryCacheManager",
            "category": "interaction",
            "linkedEntity": "CacheEntry",
            "emits": [
              {
                "event": "CacheEntryLoaded",
                "description": "Indicates a cache entry has been successfully retrieved.",
                "synonyms": "loaded, retrieved, fetched",
                "tier": "domain",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CacheEntry]"
                  }
                ]
              },
              {
                "event": "CacheEntryLoadFailed",
                "description": "Indicates a failure to load a cache entry.",
                "synonyms": "error, failure, miss, not found",
                "tier": "internal",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CacheEntryUpdated",
                "description": "Signals that a cached entry's data has been modified.",
                "synonyms": "modified, refreshed, changed, updated",
                "tier": "presentation",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CacheEntryUpdateFailed",
                "description": "Indicates a failure to update a cached entry.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "empty",
                  "isInitial": true
                },
                {
                  "name": "loading"
                },
                {
                  "name": "cached"
                },
                {
                  "name": "stale"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "FETCH",
                  "name": "Fetch"
                },
                {
                  "key": "CacheEntryLoaded",
                  "name": "CacheEntry loaded",
                  "description": "Indicates a cache entry has been successfully retrieved.",
                  "synonyms": "loaded, retrieved, fetched",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[CacheEntry]"
                    }
                  ]
                },
                {
                  "key": "CacheEntryLoadFailed",
                  "name": "CacheEntry load failed",
                  "description": "Indicates a failure to load a cache entry.",
                  "synonyms": "error, failure, miss, not found",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "INVALIDATE",
                  "name": "Invalidate"
                },
                {
                  "key": "CACHED",
                  "name": "Cached",
                  "description": "Data retrieved successfully from the cache.",
                  "synonyms": "hit, found, retrieved",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "CacheEntry"
                    }
                  ]
                },
                {
                  "key": "REFRESH",
                  "name": "Refresh"
                },
                {
                  "key": "CacheEntryUpdated",
                  "name": "CacheEntry updated",
                  "description": "Signals that a cached entry's data has been modified.",
                  "synonyms": "modified, refreshed, changed, updated",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CacheEntryUpdateFailed",
                  "name": "CacheEntry update failed",
                  "description": "Indicates a failure to update a cached entry.",
                  "synonyms": "error, failure, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "empty",
                  "to": "empty",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "gap": "lg",
                        "children": [
                          {
                            "gap": "md",
                            "direction": "horizontal",
                            "justify": "between",
                            "type": "stack",
                            "children": [
                              {
                                "gap": "md",
                                "children": [
                                  {
                                    "type": "icon",
                                    "name": "database"
                                  },
                                  {
                                    "content": "Cache (empty)",
                                    "variant": "h2",
                                    "type": "typography"
                                  }
                                ],
                                "direction": "horizontal",
                                "type": "stack"
                              },
                              {
                                "action": "FETCH",
                                "type": "button",
                                "icon": "download",
                                "label": "Fetch",
                                "variant": "primary"
                              }
                            ]
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "look": "icon-only",
                            "title": "Cache is empty",
                            "description": "Fetch data to populate the cache.",
                            "icon": "inbox",
                            "type": "empty-state"
                          }
                        ],
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "empty",
                  "to": "loading",
                  "event": "FETCH",
                  "effects": [
                    [
                      "fetch",
                      "CacheEntry",
                      {
                        "emit": {
                          "success": "CacheEntryLoaded",
                          "failure": "CacheEntryLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "direction": "vertical",
                        "type": "stack",
                        "align": "center",
                        "gap": "md",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Fetching cache…",
                            "variant": "caption",
                            "color": "muted",
                            "type": "typography"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "cached",
                  "event": "CacheEntryLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "justify": "between",
                            "direction": "horizontal",
                            "type": "stack",
                            "gap": "md",
                            "children": [
                              {
                                "direction": "horizontal",
                                "gap": "md",
                                "children": [
                                  {
                                    "name": "database",
                                    "type": "icon"
                                  },
                                  {
                                    "content": "Cache (hot)",
                                    "variant": "h2",
                                    "type": "typography"
                                  }
                                ],
                                "type": "stack"
                              },
                              {
                                "align": "center",
                                "type": "stack",
                                "direction": "horizontal",
                                "children": [
                                  {
                                    "pulse": false,
                                    "status": "online",
                                    "type": "status-dot",
                                    "label": "Cached"
                                  },
                                  {
                                    "type": "button",
                                    "action": "INVALIDATE",
                                    "icon": "trash",
                                    "variant": "ghost",
                                    "label": "Invalidate"
                                  }
                                ],
                                "gap": "sm"
                              }
                            ]
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "fields": [],
                            "entity": "@payload.data",
                            "look": "dense",
                            "type": "data-grid",
                            "renderItem": [
                              "fn",
                              "item",
                              {
                                "type": "stack",
                                "direction": "vertical",
                                "children": [
                                  {
                                    "children": [
                                      {
                                        "children": [
                                          {
                                            "name": "database",
                                            "type": "icon"
                                          },
                                          {
                                            "type": "typography",
                                            "variant": "h4",
                                            "content": "@item.name"
                                          }
                                        ],
                                        "align": "center",
                                        "direction": "horizontal",
                                        "type": "stack",
                                        "gap": "sm"
                                      },
                                      {
                                        "label": "@item.description",
                                        "type": "badge"
                                      }
                                    ],
                                    "direction": "horizontal",
                                    "align": "center",
                                    "type": "stack",
                                    "justify": "between"
                                  },
                                  {
                                    "type": "typography",
                                    "content": "@item.status",
                                    "variant": "caption"
                                  }
                                ],
                                "gap": "sm"
                              }
                            ]
                          }
                        ],
                        "direction": "vertical",
                        "type": "stack",
                        "gap": "lg"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "CacheEntryLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "align": "center",
                        "children": [
                          {
                            "type": "icon",
                            "color": "error",
                            "name": "alert-triangle"
                          },
                          {
                            "type": "typography",
                            "variant": "h3",
                            "content": "Failed to load"
                          },
                          {
                            "color": "muted",
                            "content": "@payload.error",
                            "variant": "body",
                            "type": "typography"
                          },
                          {
                            "action": "FETCH",
                            "label": "Retry",
                            "type": "button",
                            "variant": "primary",
                            "icon": "rotate-ccw"
                          }
                        ],
                        "gap": "md",
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "cached",
                  "to": "stale",
                  "event": "INVALIDATE",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "children": [
                          {
                            "type": "stack",
                            "gap": "md",
                            "justify": "between",
                            "direction": "horizontal",
                            "children": [
                              {
                                "gap": "md",
                                "direction": "horizontal",
                                "type": "stack",
                                "children": [
                                  {
                                    "type": "icon",
                                    "name": "database"
                                  },
                                  {
                                    "variant": "h2",
                                    "content": "Cache (stale)",
                                    "type": "typography"
                                  }
                                ]
                              },
                              {
                                "align": "center",
                                "gap": "sm",
                                "direction": "horizontal",
                                "children": [
                                  {
                                    "type": "status-dot",
                                    "status": "warning",
                                    "label": "Stale",
                                    "pulse": true
                                  },
                                  {
                                    "label": "Refresh",
                                    "icon": "refresh-cw",
                                    "action": "REFRESH",
                                    "type": "button",
                                    "variant": "primary"
                                  }
                                ],
                                "type": "stack"
                              }
                            ]
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "type": "alert",
                            "variant": "warning",
                            "message": "Cache data is stale. Refresh to get the latest data."
                          }
                        ],
                        "gap": "lg",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "cached",
                  "to": "loading",
                  "event": "CACHED",
                  "effects": [
                    [
                      "persist",
                      "update",
                      "CacheEntry",
                      "@payload.data",
                      {
                        "emit": {
                          "failure": "CacheEntryUpdateFailed",
                          "success": "CacheEntryUpdated"
                        }
                      }
                    ],
                    [
                      "fetch",
                      "CacheEntry",
                      {
                        "emit": {
                          "failure": "CacheEntryLoadFailed",
                          "success": "CacheEntryLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "stale",
                  "to": "loading",
                  "event": "REFRESH",
                  "effects": [
                    [
                      "fetch",
                      "CacheEntry",
                      {
                        "emit": {
                          "failure": "CacheEntryLoadFailed",
                          "success": "CacheEntryLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "stale",
                  "to": "loading",
                  "event": "FETCH",
                  "effects": [
                    [
                      "fetch",
                      "CacheEntry",
                      {
                        "emit": {
                          "failure": "CacheEntryLoadFailed",
                          "success": "CacheEntryLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "empty",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "description": "Fetch data to populate the cache.",
                        "type": "empty-state",
                        "look": "icon-only",
                        "title": "Cache is empty",
                        "icon": "inbox"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "FETCH",
                  "effects": [
                    [
                      "fetch",
                      "CacheEntry",
                      {
                        "emit": {
                          "success": "CacheEntryLoaded",
                          "failure": "CacheEntryLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "emptyLook": {
                "type": "string",
                "default": "icon-only",
                "label": "Empty-state look",
                "description": "Layer 2 visual treatment for the empty-state placeholder.",
                "tier": "presentation",
                "values": [
                  "illustrated",
                  "icon-only",
                  "text-only",
                  "mascot"
                ]
              },
              "maxCacheSize": {
                "type": "number",
                "default": 1000,
                "label": "Max cache entries",
                "description": "Hard cap on cached entries before eviction. 0 = unlimited.",
                "synonyms": "cache capacity, max entries",
                "tier": "domain"
              },
              "staleWhileRevalidate": {
                "type": "boolean",
                "default": true,
                "label": "Serve stale while revalidating",
                "description": "When true, serve stale entries to consumers while a background refresh fetches fresh data. Reduces latency at the cost of brief staleness.",
                "synonyms": "SWR, stale serving",
                "tier": "domain"
              },
              "evictionPolicy": {
                "type": "string",
                "default": "lru",
                "label": "Eviction policy",
                "description": "How entries are evicted when the cache fills: least-recently-used, least-frequently-used, first-in-first-out, or TTL-only (never evict early).",
                "synonyms": "cache replacement, eviction strategy",
                "tier": "domain",
                "values": [
                  "lru",
                  "lfu",
                  "fifo",
                  "ttl-only"
                ]
              },
              "tableLook": {
                "type": "string",
                "default": "dense",
                "label": "Table look",
                "description": "Layer 2 visual treatment for the data table rendered by this atom.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              },
              "ttlSeconds": {
                "type": "number",
                "default": 300,
                "label": "TTL (seconds)",
                "description": "Cache entry time-to-live before it goes stale. Default 5 minutes. Shorter = fresher/real-time data; longer = stable/long-lived caching.",
                "synonyms": "expiration, time to live, cache duration, freshness, real-time (short) vs long-lived (long)",
                "tier": "domain"
              }
            },
            "scope": "collection"
          }
        ],
        "pages": [
          {
            "name": "CacheEntryPage",
            "path": "/cacheentrys",
            "traits": [
              {
                "ref": "CacheEntryCacheManager"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "CacheEntryOrbital": [
          {
            "trait": "CacheEntryCacheManager",
            "patternPath": "root.children.2",
            "prop": "look",
            "knob": "emptyLook"
          },
          {
            "trait": "CacheEntryCacheManager",
            "patternPath": "root.children.2",
            "prop": "look",
            "knob": "tableLook"
          },
          {
            "trait": "CacheEntryCacheManager",
            "patternPath": "root",
            "prop": "look",
            "knob": "emptyLook"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}