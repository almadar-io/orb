                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "name",
                      "type": "string"
                    },
                    {
                      "name": "description",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close"
