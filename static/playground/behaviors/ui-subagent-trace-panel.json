                        "subagents": []
                      }
                    ]
                  ]
                },
                {
                  "from": "open",
                  "to": "closed",
                  "event": "CLOSE",
                  "effects": [
                    [
                      "render-ui",
                      "overlay",
                      null
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "action": "OPEN",
                        "label": "Open Subagent-trace-panel",
                        "type": "button"
                      }
                    ]
                  ]
                }
              ]
            },
