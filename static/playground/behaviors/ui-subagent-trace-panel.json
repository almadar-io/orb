                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "closed",
                  "to": "closed",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "action": "OPEN",
                        "label": "Open Subagent-trace-panel",
                        "type": "button"
                      }
                    ]
                  ]
                },
                {
                  "from": "closed",
                  "to": "open",
                  "event": "OPEN",
                  "effects": [
                    [
                      "render-ui",
                      "overlay",
                      {
                        "error": "@config.error",
                        "sortDirection": "asc",
                        "open": false,
                        "disclosureLevel": 1,
                        "mode": "overlay",
                        "page": 0,
                        "className": "",
