            "emits": [
              {
                "event": "CLOSE",
                "description": "Optional dismiss handler.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "OPEN",
                "description": "Open the Subagent-trace-panel.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "closed",
                  "isInitial": true
                },
                {
                  "name": "open"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "OPEN",
                  "name": "Open",
