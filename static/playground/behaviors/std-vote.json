{
  "name": "std-vote",
  "description": "std-vote — forum-style up/down vote tally with single-vote-per-user constraint. Owns a Vote entity; VOTE persists the new direction (toggling to none when re-clicking the active arrow) and emits VoteCasted so cross-trait listeners can recompute aggregates.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-vote",
    "version": "1.0.0",
    "description": "std-vote — forum-style up/down vote tally with single-vote-per-user constraint. Owns a Vote entity; VOTE persists the new direction (toggling to none when re-clicking the active arrow) and emits VoteCasted so cross-trait listeners can recompute aggregates.",
    "orbitals": [
      {
        "name": "VoteOrbital",
        "entity": {
          "name": "Vote",
          "collection": "votes",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "targetId",
              "type": "string",
              "required": true,
              "description": "Identifier for the item being voted on.",
              "synonyms": "reference, item, subject"
            },
            {
              "name": "voterId",
              "type": "string",
              "required": true,
              "description": "Unique identifier of the user casting the vote.",
              "synonyms": "user, author, participant"
            },
            {
              "name": "direction",
              "type": "string",
              "default": "none",
              "values": [
                "up",
                "down",
                "none"
              ],
              "description": "Indicates the vote's direction.",
              "synonyms": "vote, sentiment, choice"
            },
            {
              "name": "createdAt",
              "type": "string"
            }
          ]
        },
        "traits": [
          {
            "name": "VoteCast",
            "category": "interaction",
            "linkedEntity": "Vote",
            "emits": [
              {
                "event": "VOTE",
                "description": "Signals a vote has been successfully recorded.",
                "synonyms": "voted, submitted, confirmed",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "next",
                    "type": "string"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "event": "VoteLoaded",
                "description": "Indicates a vote has been successfully retrieved.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Vote]"
                  }
                ]
              },
              {
                "event": "VoteLoadFailed",
                "description": "Indicates that loading a vote failed.",
                "synonyms": "load error, failed load, fetch failure",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "VoteCasted",
                "description": "Indicates a vote has been successfully recorded.",
                "synonyms": "voted, vote-submitted, vote-changed",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "targetId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "voterId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "direction",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "VoteCastFailed",
                "description": "Indicates a vote submission failed, likely due to a constraint.",
                "synonyms": "failed, rejected, error",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "idle"
                },
                {
                  "name": "voting"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "VoteLoaded",
                  "name": "Vote loaded",
                  "description": "Indicates a vote has been successfully retrieved.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[Vote]"
                    }
                  ]
                },
                {
                  "key": "VoteLoadFailed",
                  "name": "Vote load failed",
                  "description": "Indicates that loading a vote failed.",
                  "synonyms": "load error, failed load, fetch failure",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "VOTE",
                  "name": "Vote",
                  "description": "Signals a vote has been successfully recorded.",
                  "synonyms": "voted, submitted, confirmed",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "next",
                      "type": "string"
                    },
                    {
                      "name": "data",
                      "type": "object",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "VoteCasted",
                  "name": "Vote casted",
                  "description": "Indicates a vote has been successfully recorded.",
                  "synonyms": "voted, vote-submitted, vote-changed",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "Vote"
                    }
                  ]
                },
                {
                  "key": "VoteCastFailed",
                  "name": "Vote cast failed",
                  "description": "Indicates a vote submission failed, likely due to a constraint.",
                  "synonyms": "failed, rejected, error",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "Vote",
                      {
                        "emit": {
                          "success": "VoteLoaded",
                          "failure": "VoteLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "color": "muted",
                            "type": "typography",
                            "variant": "caption",
                            "content": "Loading votes…"
                          }
                        ],
                        "direction": "vertical",
                        "align": "center",
                        "gap": "md",
                        "className": "py-12"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "idle",
                  "event": "VoteLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "vote-stack",
                        "onVote": "VOTE",
                        "count": 0,
                        "userVote": "@entity.direction",
                        "label": "Vote",
                        "variant": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "idle",
                  "event": "VoteLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "message": "@payload.error",
                        "variant": "error",
                        "type": "alert"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "voting",
                  "event": "VOTE",
                  "guard": [
                    "not",
                    [
                      "=",
                      "@payload.next",
                      "@entity.direction"
                    ]
                  ],
                  "effects": [
                    [
                      "set",
                      "@entity.direction",
                      "@payload.next"
                    ],
                    [
                      "persist",
                      "update",
                      "Vote",
                      "@payload.data",
                      {
                        "emit": {
                          "success": "VoteCasted",
                          "failure": "VoteCastFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack",
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "type": "typography",
                            "variant": "caption",
                            "color": "muted",
                            "content": "Recording your vote…"
                          }
                        ],
                        "className": "py-12"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "voting",
                  "event": "VOTE",
                  "guard": [
                    "=",
                    "@payload.next",
                    "@entity.direction"
                  ],
                  "effects": [
                    [
                      "set",
                      "@entity.direction",
                      "none"
                    ],
                    [
                      "persist",
                      "update",
                      "Vote",
                      "@payload.data",
                      {
                        "emit": {
                          "success": "VoteCasted",
                          "failure": "VoteCastFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "py-12",
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Clearing your vote…",
                            "color": "muted",
                            "type": "typography",
                            "variant": "caption"
                          }
                        ],
                        "gap": "md",
                        "align": "center"
                      }
                    ]
                  ]
                },
                {
                  "from": "voting",
                  "to": "idle",
                  "event": "VoteCasted",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "userVote": "@entity.direction",
                        "count": 0,
                        "onVote": "VOTE",
                        "type": "vote-stack",
                        "variant": "vertical",
                        "label": "Vote"
                      }
                    ]
                  ]
                },
                {
                  "from": "voting",
                  "to": "error",
                  "event": "VoteCastFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "error",
                        "message": "@payload.error",
                        "type": "alert"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "Vote",
                      {
                        "emit": {
                          "success": "VoteLoaded",
                          "failure": "VoteLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "gap": "md",
                        "type": "stack",
                        "className": "py-12",
                        "align": "center",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "type": "typography",
                            "variant": "caption",
                            "content": "Loading votes…",
                            "color": "muted"
                          }
                        ],
                        "direction": "vertical"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "allowDown": {
                "type": "boolean",
                "default": true,
                "label": "Allow downvotes",
                "description": "Show the downvote arrow alongside the upvote",
                "tier": "domain"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "VoteCastPage",
            "path": "/votes/cast",
            "traits": [
              {
                "ref": "VoteCast"
              }
            ]
          }
        ]
      }
    ]
  },
  "source": "",
  "lolo": ""
}