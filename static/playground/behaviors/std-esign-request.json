{
  "name": "std-esign-request",
  "description": "std-esign-request — specialized e-signature request tracker: send a document out for signing and track its status (draft/sent/viewed/signed/declined/expired). Just the request list + send/revoke; signature capture is std-signature-capture's job.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-esign-request",
    "version": "1.1.0",
    "description": "std-esign-request — specialized e-signature request tracker: send a document out for signing and track its status (draft/sent/viewed/signed/declined/expired). Just the request list + send/revoke; signature capture is std-signature-capture's job.",
    "orbitals": [
      {
        "name": "ESignRequestOrbital",
        "entity": {
          "name": "ESignRequest",
          "collection": "esignrequests",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "documentId",
              "type": "string",
              "required": true,
              "description": "Unique identifier for the associated document.",
              "synonyms": "document reference, file ID"
            },
            {
              "name": "documentName",
              "type": "string",
              "default": "",
              "description": "The name of the document being requested for signature.",
              "synonyms": "filename, document title, file name"
            },
            {
              "name": "recipientName",
              "type": "string",
              "required": true,
              "description": "The name of the recipient for the e-signature request.",
              "synonyms": "recipient, name, user"
            },
            {
              "name": "recipientEmail",
              "type": "string",
              "required": true,
              "description": "The email address of the recipient.",
              "synonyms": "email, address, contact"
            },
            {
              "name": "status",
              "type": "string",
              "default": "draft",
              "values": [
                "draft",
                "sent",
                "viewed",
                "signed",
                "declined",
                "expired"
              ],
              "description": "The current stage of the request lifecycle.",
              "synonyms": "state, condition, phase"
            },
            {
              "name": "sentAt",
              "type": "string",
              "default": "",
              "description": "Timestamp indicating when the request was sent.",
              "synonyms": "sent date, send time, dispatched at"
            },
            {
              "name": "signedAt",
              "type": "string",
              "default": "",
              "description": "Timestamp indicating when the request was signed.",
              "synonyms": "signed date, signature date, completion date"
            },
            {
              "name": "expiresAt",
              "type": "string",
              "default": "",
              "description": "The date and time when the request is no longer valid.",
              "synonyms": "expiration, expiry, due date"
            },
            {
              "name": "notes",
              "type": "string",
              "default": "",
              "description": "Free-text comments or additional information.",
              "synonyms": "comment, remark, description, details"
            }
          ]
        },
        "traits": [
          {
            "name": "ESignRequestSigning",
            "category": "interaction",
            "linkedEntity": "ESignRequest",
            "emits": [
              {
                "event": "SEND_REQUEST",
                "description": "Signals a request has been sent for signature.",
                "synonyms": "dispatch, submit, transmit",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "REVOKE_REQUEST",
                "description": "Indicates a signature request has been cancelled.",
                "synonyms": "cancel, void, retract",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "ESignRequestLoaded",
                "description": "Signals that the request list has been successfully populated.",
                "synonyms": "loaded, refreshed, populated, initialized",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ESignRequest]"
                  }
                ]
              },
              {
                "event": "ESignRequestLoadFailed",
                "description": "Indicates a failure to load e-signature request data.",
                "synonyms": "error, failure, load error",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "ESignRequestLoaded",
                  "name": "ESignRequest loaded",
                  "description": "Signals that the request list has been successfully populated.",
                  "synonyms": "loaded, refreshed, populated, initialized",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[ESignRequest]"
                    }
                  ]
                },
                {
                  "key": "ESignRequestLoadFailed",
                  "name": "ESignRequest load failed",
                  "description": "Indicates a failure to load e-signature request data.",
                  "synonyms": "error, failure, load error",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SEND_REQUEST",
                  "name": "Send Request",
                  "description": "Signals a request has been sent for signature.",
                  "synonyms": "dispatch, submit, transmit",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "REVOKE_REQUEST",
                  "name": "Revoke Request",
                  "description": "Indicates a signature request has been cancelled.",
                  "synonyms": "cancel, void, retract",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "ESignRequest",
                      {
                        "emit": {
                          "failure": "ESignRequestLoadFailed",
                          "success": "ESignRequestLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "ESignRequestLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "direction": "vertical",
                        "children": [
                          {
                            "content": "Signature Requests",
                            "variant": "h3",
                            "type": "typography"
                          },
                          {
                            "entity": "@payload.data",
                            "look": "dense",
                            "type": "data-grid",
                            "itemActions": [
                              {
                                "label": "Send",
                                "variant": "primary",
                                "event": "SEND_REQUEST"
                              },
                              {
                                "label": "Revoke",
                                "event": "REVOKE_REQUEST",
                                "variant": "danger"
                              }
                            ],
                            "fields": [
                              {
                                "variant": "h4",
                                "name": "documentName",
                                "label": "Document"
                              },
                              {
                                "name": "recipientName",
                                "variant": "body",
                                "label": "Recipient"
                              },
                              {
                                "variant": "caption",
                                "label": "Email",
                                "name": "recipientEmail"
                              },
                              {
                                "name": "status",
                                "variant": "badge",
                                "label": "Status"
                              },
                              {
                                "variant": "caption",
                                "label": "Sent",
                                "name": "sentAt"
                              }
                            ]
                          }
                        ],
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "ESignRequestLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "variant": "error",
                        "message": "@payload.error",
                        "title": "Failed to load signature requests"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "SEND_REQUEST",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "notify",
                      "Signature request sent",
                      "success"
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REVOKE_REQUEST",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "notify",
                      "Signature request revoked",
                      "info"
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "ESignRequest",
                      {
                        "emit": {
                          "failure": "ESignRequestLoadFailed",
                          "success": "ESignRequestLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "md"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "tableLook": {
                "type": "string",
                "default": "dense",
                "label": "Table look",
                "description": "Layer 2 visual treatment for the data table rendered by this atom.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              },
              "title": {
                "type": "string",
                "default": "Signature Requests",
                "label": "Section title",
                "description": "Heading shown above the signature-request list",
                "tier": "presentation"
              }
            },
            "scope": "collection"
          }
        ],
        "pages": [
          {
            "name": "ESignRequestPage",
            "path": "/esign",
            "traits": [
              {
                "ref": "ESignRequestSigning"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ESignRequestOrbital": [
          {
            "trait": "ESignRequestSigning",
            "patternPath": "root.children.0",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "ESignRequestSigning",
            "patternPath": "root.children.1",
            "prop": "look",
            "knob": "tableLook"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}