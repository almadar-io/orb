{
  "name": "ui-notification",
  "description": "Notification — UI factory (1:1 with the @almadar/ui notification pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-notification",
    "version": "1.0.0",
    "description": "Notification — UI factory (1:1 with the @almadar/ui notification pattern).",
    "orbitals": [
      {
        "name": "NotificationOrbital",
        "entity": {
          "name": "NotificationItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "NotificationRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "NotificationItem",
            "emits": [
              {
                "event": "DISMISS",
                "description": "Callback when toast is dismissed",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "ACTION",
                "description": "Action button click handler",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "DISMISS",
                  "name": "Dismiss",
                  "description": "Callback when toast is dismissed",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "ACTION",
                  "name": "Action",
                  "description": "Action button click handler",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "actionLabel": "Action Label",
                        "variant": "info",
                        "onDismiss": "DISMISS",
                        "badge": "Badge",
                        "dismissible": true,
                        "title": "Title",
                        "className": "",
                        "actionEvent": "ACTION",
                        "duration": 5000,
                        "message": "Message",
                        "type": "notification",
                        "onAction": "ACTION",
                        "dismissEvent": "DISMISS"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "message": {
                "type": "string",
                "default": "Message",
                "label": "Message",
                "description": "Toast message",
                "tier": "presentation"
              },
              "actionLabel": {
                "type": "string",
                "default": "Action Label",
                "label": "Action Label",
                "description": "Action button label",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "badge": {
                "type": "string",
                "default": "Badge",
                "label": "Badge",
                "description": "Badge count (optional)",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "info",
                "label": "Variant",
                "description": "Toast variant",
                "tier": "presentation",
                "values": [
                  "success",
                  "error",
                  "info",
                  "warning"
                ]
              },
              "dismissible": {
                "type": "boolean",
                "default": true,
                "label": "Dismissible",
                "description": "Show dismiss button",
                "tier": "presentation"
              },
              "duration": {
                "type": "number",
                "default": 5000,
                "label": "Duration",
                "description": "Auto-dismiss duration in milliseconds (0 = no auto-dismiss)",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Toast title (optional)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "NotificationPage",
            "path": "/notification",
            "traits": [
              {
                "ref": "NotificationRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "NotificationOrbital": [
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "actionLabel",
            "knob": "actionLabel"
          },
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "badge",
            "knob": "badge"
          },
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "dismissible",
            "knob": "dismissible"
          },
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "duration",
            "knob": "duration"
          },
          {
            "trait": "NotificationRender",
            "patternPath": "root",
            "prop": "message",
            "knob": "message"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}