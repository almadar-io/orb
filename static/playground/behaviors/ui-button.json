{
  "name": "ui-button",
  "description": "Button — UI factory (1:1 with the @almadar/ui button pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-button",
    "version": "1.0.0",
    "description": "Button — UI factory (1:1 with the @almadar/ui button pattern).",
    "orbitals": [
      {
        "name": "ButtonOrbital",
        "entity": {
          "name": "ButtonItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ButtonRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ButtonItem",
            "emits": [
              {
                "event": "ACTION",
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "ACTION",
                  "name": "Action",
                  "description": "Declarative event name — emits UI:{action} via eventBus on click",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "rightIcon": "@config.rightIcon",
                        "size": "md",
                        "icon": "circle",
                        "leftIcon": "@config.leftIcon",
                        "isLoading": false,
                        "actionPayload": {},
                        "label": "Label",
                        "variant": "primary",
                        "className": "",
                        "type": "button",
                        "disabled": false,
                        "iconRight": "@config.iconRight",
                        "action": "ACTION"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "size prop",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg"
                ]
              },
              "label": {
                "type": "string",
                "default": "Label",
                "label": "Label",
                "description": "Button label text (alternative to children for schema-driven rendering)",
                "tier": "presentation"
              },
              "iconRight": {
                "type": "icon",
                "label": "Icon Right",
                "description": "Alias for rightIcon",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "isLoading prop",
                "tier": "presentation"
              },
              "leftIcon": {
                "type": "icon",
                "label": "Left Icon",
                "description": "Left icon: a Lucide component or a canonical icon name string (e.g. 'plus', 'trash').",
                "tier": "presentation"
              },
              "actionPayload": {
                "type": "json",
                "default": {},
                "label": "Action Payload",
                "description": "Payload to include with the action event",
                "tier": "presentation"
              },
              "icon": {
                "type": "icon",
                "default": "circle",
                "label": "Icon",
                "description": "Alias for leftIcon",
                "tier": "presentation"
              },
              "rightIcon": {
                "type": "icon",
                "label": "Right Icon",
                "description": "Right icon: a Lucide component or a canonical icon name string.",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "primary",
                "label": "Variant",
                "description": "variant prop",
                "tier": "presentation",
                "values": [
                  "primary",
                  "secondary",
                  "ghost",
                  "danger",
                  "success",
                  "warning",
                  "default"
                ]
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes applied to the root element.",
                "tier": "presentation"
              },
              "disabled": {
                "type": "boolean",
                "default": false,
                "label": "Disabled",
                "description": "Disable the button (greys out, blocks click events)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ButtonPage",
            "path": "/button",
            "traits": [
              {
                "ref": "ButtonRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ButtonOrbital": [
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "icon",
            "knob": "icon"
          },
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "actionPayload",
            "knob": "actionPayload"
          },
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "label",
            "knob": "label"
          },
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "ButtonRender",
            "patternPath": "root",
            "prop": "disabled",
            "knob": "disabled"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}