{
  "name": "ui-confirm-dialog",
  "description": "ConfirmDialog — UI factory (1:1 with the @almadar/ui confirm-dialog pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-confirm-dialog",
    "version": "1.0.0",
    "description": "ConfirmDialog — UI factory (1:1 with the @almadar/ui confirm-dialog pattern).",
    "orbitals": [
      {
        "name": "ConfirmDialogOrbital",
        "entity": {
          "name": "ConfirmDialogItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ConfirmDialogRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ConfirmDialogItem",
            "emits": [
              {
                "event": "CLOSE",
                "description": "Callback when dialog is closed (injected by slot wrapper)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CONFIRM",
                "description": "Callback when action is confirmed (injected by slot wrapper)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "OPEN",
                "description": "Open the Confirm-dialog.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "closed",
                  "isInitial": true
                },
                {
                  "name": "open"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "OPEN",
                  "name": "Open",
                  "description": "Open the Confirm-dialog.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "Callback when dialog is closed (injected by slot wrapper)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CONFIRM",
                  "name": "Confirm",
                  "description": "Callback when action is confirmed (injected by slot wrapper)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "closed",
                  "to": "closed",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "button",
                        "action": "OPEN",
                        "label": "Open Confirm-dialog"
                      }
                    ]
                  ]
                },
                {
                  "from": "closed",
                  "to": "open",
                  "event": "OPEN",
                  "effects": [
                    [
                      "render-ui",
                      "modal",
                      {
                        "variant": "danger",
                        "isLoading": false,
                        "cancelLabel": "Cancel Label",
                        "confirmLabel": "Confirm Label",
                        "className": "",
                        "confirmText": "Confirm Text",
                        "error": "@config.error",
                        "message": "@config.message",
                        "title": "Title",
                        "isOpen": true,
                        "onClose": "CLOSE",
                        "type": "confirm-dialog",
                        "size": "sm",
                        "description": "@config.description",
                        "cancelText": "Cancel Text",
                        "onConfirm": "CONFIRM"
                      }
                    ]
                  ]
                },
                {
                  "from": "open",
                  "to": "closed",
                  "event": "CLOSE",
                  "effects": [
                    [
                      "render-ui",
                      "modal",
                      null
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "action": "OPEN",
                        "type": "button",
                        "label": "Open Confirm-dialog"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state for confirm button",
                "tier": "presentation"
              },
              "confirmLabel": {
                "type": "string",
                "default": "Confirm Label",
                "label": "Confirm Label",
                "description": "Alias for confirmText (schema compatibility)",
                "tier": "presentation"
              },
              "error": {
                "type": "ConfirmDialogError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "size": {
                "type": "string",
                "default": "sm",
                "label": "Size",
                "description": "Dialog size",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "full"
                ]
              },
              "variant": {
                "type": "string",
                "default": "danger",
                "label": "Variant",
                "description": "Dialog variant",
                "tier": "presentation",
                "values": [
                  "danger",
                  "warning",
                  "info",
                  "default"
                ]
              },
              "cancelText": {
                "type": "string",
                "default": "Cancel Text",
                "label": "Cancel Text",
                "description": "Cancel button text",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Dialog title",
                "tier": "presentation"
              },
              "cancelLabel": {
                "type": "string",
                "default": "Cancel Label",
                "label": "Cancel Label",
                "description": "Alias for cancelText (schema compatibility)",
                "tier": "presentation"
              },
              "confirmText": {
                "type": "string",
                "default": "Confirm Text",
                "label": "Confirm Text",
                "description": "Confirm button text",
                "tier": "presentation"
              },
              "message": {
                "type": "node",
                "label": "Message",
                "description": "Dialog message/description",
                "tier": "presentation"
              },
              "isOpen": {
                "type": "boolean",
                "default": true,
                "label": "Is Open",
                "description": "Whether the dialog is open (defaults to true when rendered by slot wrapper)",
                "tier": "presentation"
              },
              "description": {
                "type": "node",
                "label": "Description",
                "description": "Alias for message (schema compatibility)",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ConfirmDialogPage",
            "path": "/confirm-dialog",
            "traits": [
              {
                "ref": "ConfirmDialogRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ConfirmDialogOrbital": [
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "cancelLabel",
            "knob": "cancelLabel"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "confirmLabel",
            "knob": "confirmLabel"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "confirmText",
            "knob": "confirmText"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "isOpen",
            "knob": "isOpen"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "ConfirmDialogRender",
            "patternPath": "root",
            "prop": "cancelText",
            "knob": "cancelText"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}