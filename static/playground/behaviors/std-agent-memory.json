                  "from": "active",
                  "to": "active",
                  "event": "PIN",
                  "guard": [
                    "not",
                    [
                      "agent/is-pinned",
                      "@payload.id"
                    ]
                  ],
                  "effects": [
                    [
                      "agent/pin",
                      "@payload.id"
                    ],
                    [
                      "emit",
                      "PINNED",
                      {
                        "id": "@payload.id"
                      }
                    ]
                  ]
                },
                {
                  "from": "active",
                  "to": "idle",
                  "event": "FORGET",
                  "effects": [
                    [
                      "agent/forget",
                      "@payload.id"
                    ],
                    [
                      "emit",
                      "FORGOT",
                      {
                        "id": "@payload.id"
                      }
                    ]
                  ]
                },
                {
                  "from": "active",
                  "to": "active",
                  "event": "REINFORCE",
                  "effects": [
                    [
                      "agent/reinforce",
                      "@payload.id"
                    ],
                    [
                      "emit",
                      "REINFORCED",
                      {
