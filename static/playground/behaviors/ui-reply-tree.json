{
  "name": "ui-reply-tree",
  "description": "ReplyTree — UI factory (1:1 with the @almadar/ui reply-tree pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-reply-tree",
    "version": "1.0.0",
    "description": "ReplyTree — UI factory (1:1 with the @almadar/ui reply-tree pattern).",
    "orbitals": [
      {
        "name": "ReplyTreeOrbital",
        "entity": {
          "name": "ReplyTreeItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "authorName",
              "type": "string",
              "default": "Author Name"
            },
            {
              "name": "content",
              "type": "string",
              "default": "Content"
            },
            {
              "name": "authorAvatarUrl",
              "type": "string",
              "default": "Author Avatar Url"
            },
            {
              "name": "postedAt",
              "type": "string",
              "default": "Posted At"
            },
            {
              "name": "voteCount",
              "type": "number",
              "default": 1
            },
            {
              "name": "userVote",
              "type": "string",
              "default": "up",
              "values": [
                "up",
                "down",
                "none"
              ]
            },
            {
              "name": "collapsed",
              "type": "boolean",
              "default": false
            },
            {
              "name": "replies",
              "type": "string",
              "default": {}
            }
          ]
        },
        "traits": [
          {
            "name": "ReplyTreeRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ReplyTreeItem",
            "emits": [
              {
                "event": "VOTE",
                "description": "onVote prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  },
                  {
                    "name": "vote",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "REPLY",
                "description": "onReply prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "parentNodeId",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "FLAG",
                "description": "onFlag prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CONTINUE_THREAD",
                "description": "onContinueThread prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "nodeId",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "ReplyTreeLoaded",
                "description": "ReplyTree rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ReplyTreeItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "ReplyTreeLoaded",
                  "name": "Reply tree loaded",
                  "description": "ReplyTree rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[ReplyTreeItem]"
                    }
                  ]
                },
                {
                  "key": "VOTE",
                  "name": "Vote",
                  "description": "onVote prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "nodeId",
                      "type": "string"
                    },
                    {
                      "name": "vote",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "REPLY",
                  "name": "Reply",
                  "description": "onReply prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "parentNodeId",
                      "type": "string"
                    },
                    {
                      "name": "content",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "FLAG",
                  "name": "Flag",
                  "description": "onFlag prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "nodeId",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CONTINUE_THREAD",
                  "name": "Continue Thread",
                  "description": "onContinueThread prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "nodeId",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "ReplyTreeItem",
                      {
                        "emit": {
                          "success": "ReplyTreeLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "voteEvent": "VOTE",
                        "maxDepth": 6,
                        "continueThreadEvent": "CONTINUE_THREAD",
                        "flagEvent": "FLAG",
                        "onVote": "VOTE",
                        "replyEvent": "REPLY",
                        "type": "reply-tree",
                        "nodes": "@entity",
                        "onContinueThread": "CONTINUE_THREAD",
                        "onFlag": "FLAG",
                        "showActions": true,
                        "onReply": "REPLY",
                        "className": ""
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "ReplyTreeLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "continueThreadEvent": "CONTINUE_THREAD",
                        "onContinueThread": "CONTINUE_THREAD",
                        "onFlag": "FLAG",
                        "nodes": "@payload.data",
                        "type": "reply-tree",
                        "onReply": "REPLY",
                        "flagEvent": "FLAG",
                        "onVote": "VOTE",
                        "voteEvent": "VOTE",
                        "replyEvent": "REPLY",
                        "className": "",
                        "showActions": true,
                        "maxDepth": 6
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "maxDepth": {
                "type": "number",
                "default": 6,
                "label": "Max Depth",
                "description": "maxDepth prop",
                "tier": "presentation"
              },
              "showActions": {
                "type": "boolean",
                "default": true,
                "label": "Show Actions",
                "description": "showActions prop",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "className prop",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ReplyTreePage",
            "path": "/reply-tree",
            "traits": [
              {
                "ref": "ReplyTreeRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ReplyTreeOrbital": [
          {
            "trait": "ReplyTreeRender",
            "patternPath": "root",
            "prop": "maxDepth",
            "knob": "maxDepth"
          },
          {
            "trait": "ReplyTreeRender",
            "patternPath": "root",
            "prop": "showActions",
            "knob": "showActions"
          },
          {
            "trait": "ReplyTreeRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "ReplyTreeRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "ReplyTreeRender",
            "patternPath": "root",
            "prop": "showActions",
            "knob": "showActions"
          },
          {
            "trait": "ReplyTreeRender",
            "patternPath": "root",
            "prop": "maxDepth",
            "knob": "maxDepth"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}