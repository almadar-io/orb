{
  "name": "ui-avatar",
  "description": "Avatar — UI factory (1:1 with the @almadar/ui avatar pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-avatar",
    "version": "1.0.0",
    "description": "Avatar — UI factory (1:1 with the @almadar/ui avatar pattern).",
    "orbitals": [
      {
        "name": "AvatarOrbital",
        "entity": {
          "name": "AvatarItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "AvatarRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "AvatarItem",
            "emits": [
              {
                "event": "CLICK",
                "description": "Click handler",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "ACTION",
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "CLICK",
                  "name": "Click",
                  "description": "Click handler",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "ACTION",
                  "name": "Action",
                  "description": "Declarative event name — emits UI:{action} via eventBus on click",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "initials": "Initials",
                        "action": "ACTION",
                        "actionPayload": {},
                        "badge": "Badge",
                        "size": "md",
                        "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                        "alt": "Alt",
                        "icon": "circle",
                        "onClick": "CLICK",
                        "status": "online",
                        "name": "Name",
                        "type": "avatar",
                        "className": ""
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "actionPayload": {
                "type": "json",
                "default": {},
                "label": "Action Payload",
                "description": "Payload to include with the action event",
                "tier": "presentation"
              },
              "src": {
                "type": "asset",
                "default": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                "label": "Src",
                "description": "Image source URL",
                "tier": "presentation"
              },
              "icon": {
                "type": "icon",
                "default": "circle",
                "label": "Icon",
                "description": "Icon to display when no image or initials. Accepts a Lucide component directly, or a canonical kebab-case icon name string (resolved via `resolveIcon`) so trait/factory authors can pass an icon by name.",
                "tier": "presentation"
              },
              "alt": {
                "type": "string",
                "default": "Alt",
                "label": "Alt",
                "description": "Alt text for the image",
                "tier": "presentation"
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Size of the avatar",
                "tier": "presentation",
                "values": [
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl"
                ]
              },
              "name": {
                "type": "string",
                "default": "Name",
                "label": "Name",
                "description": "Full name - initials will be generated automatically",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "status": {
                "type": "string",
                "default": "online",
                "label": "Status",
                "description": "Status indicator",
                "tier": "presentation",
                "values": [
                  "online",
                  "offline",
                  "away",
                  "busy"
                ]
              },
              "initials": {
                "type": "string",
                "default": "Initials",
                "label": "Initials",
                "description": "Initials to display (e.g., 'JD' for John Doe) If not provided but name is, initials will be auto-generated",
                "tier": "presentation"
              },
              "badge": {
                "type": "string",
                "default": "Badge",
                "label": "Badge",
                "description": "Badge content (e.g., notification count)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "AvatarPage",
            "path": "/avatar",
            "traits": [
              {
                "ref": "AvatarRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "AvatarOrbital": [
          {
