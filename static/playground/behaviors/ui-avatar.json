            "knob": "size"
          },
          {
            "trait": "AvatarRender",
            "patternPath": "root",
            "prop": "src",
            "knob": "src"
          },
          {
            "trait": "AvatarRender",
            "patternPath": "root",
            "prop": "alt",
            "knob": "alt"
          },
          {
            "trait": "AvatarRender",
            "patternPath": "root",
            "prop": "icon",
            "knob": "icon"
          },
          {
            "trait": "AvatarRender",
            "patternPath": "root",
            "prop": "status",
            "knob": "status"
          },
          {
            "trait": "AvatarRender",
            "patternPath": "root",
            "prop": "name",
            "knob": "name"
          },
          {
            "trait": "AvatarRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          }
        ]
      }
    }
  },
