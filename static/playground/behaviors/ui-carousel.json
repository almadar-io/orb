{
  "name": "ui-carousel",
  "description": "Carousel — UI factory (1:1 with the @almadar/ui carousel pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-carousel",
    "version": "1.0.0",
    "description": "Carousel — UI factory (1:1 with the @almadar/ui carousel pattern).",
    "orbitals": [
      {
        "name": "CarouselOrbital",
        "entity": {
          "name": "CarouselItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "CarouselRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "CarouselItem",
            "emits": [
              {
                "event": "SLIDE_CHANGE",
                "description": "Declarative event name for slide change",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "SLIDE_CHANGE",
                  "name": "Slide Change",
                  "description": "Declarative event name for slide change",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "index",
                      "type": "number",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "autoPlayInterval": 5000,
                        "items": [],
                        "autoPlay": false,
                        "loop": false,
                        "showArrows": true,
                        "slideChangePayload": {},
                        "slideChangeEvent": "SLIDE_CHANGE",
                        "className": "",
                        "type": "carousel",
                        "showDots": true
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "showArrows": {
                "type": "boolean",
                "default": true,
                "label": "Show Arrows",
                "description": "Show prev/next arrow buttons",
                "tier": "presentation"
              },
              "slideChangePayload": {
                "type": "json",
                "default": {},
                "label": "Slide Change Payload",
                "description": "Payload to include with the slide change event",
                "tier": "presentation"
              },
              "loop": {
                "type": "boolean",
                "default": false,
                "label": "Loop",
                "description": "Enable infinite loop",
                "tier": "presentation"
              },
              "autoPlay": {
                "type": "boolean",
                "default": false,
                "label": "Auto Play",
                "description": "Enable auto-play rotation",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "items": {
                "type": "[json]",
                "default": [],
                "label": "Items",
                "description": "Array of items to display as slides",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "autoPlayInterval": {
                "type": "number",
                "default": 5000,
                "label": "Auto Play Interval",
                "description": "Auto-play interval in milliseconds (default: 5000)",
                "tier": "presentation"
              },
              "showDots": {
                "type": "boolean",
                "default": true,
                "label": "Show Dots",
                "description": "Show dot indicators",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "CarouselPage",
            "path": "/carousel",
            "traits": [
              {
                "ref": "CarouselRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "CarouselOrbital": [
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "autoPlayInterval",
            "knob": "autoPlayInterval"
          },
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "items",
            "knob": "items"
          },
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "autoPlay",
            "knob": "autoPlay"
          },
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "loop",
            "knob": "loop"
          },
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "showArrows",
            "knob": "showArrows"
          },
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "slideChangePayload",
            "knob": "slideChangePayload"
          },
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "CarouselRender",
            "patternPath": "root",
            "prop": "showDots",
            "knob": "showDots"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}