                      "render-ui",
                      "main",
                      {
                        "isValid": true,
                        "compact": false,
                        "completeLabel": "Complete Label",
                        "currentStep": "@entity.currentStep",
                        "type": "wizard-navigation",
                        "onBackClick": "BACK_CLICK",
                        "onNextClick": "NEXT_CLICK",
                        "onNext": "NEXT",
                        "showBack": true,
                        "totalSteps": "@entity.totalSteps",
                        "showComplete": true,
                        "onBack": "BACK",
                        "onComplete": "COMPLETE",
                        "showNext": true,
                        "className": "",
                        "backLabel": "Back Label",
                        "nextLabel": "Next Label",
                        "onCompleteClick": "COMPLETE_CLICK"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "showBack": {
                "type": "boolean",
                "default": true,
                "label": "Show Back",
                "description": "Show the Back button",
                "tier": "presentation"
              },
              "totalSteps": {
                "type": "number",
                "default": 1,
                "label": "Total Steps",
                "description": "Total number of steps",
                "tier": "presentation"
              },
              "compact": {
                "type": "boolean",
                "default": false,
                "label": "Compact",
                "description": "Compact mode (smaller padding)",
                "tier": "presentation"
              },
              "nextLabel": {
                "type": "string",
