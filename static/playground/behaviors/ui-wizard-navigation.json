{
  "name": "ui-wizard-navigation",
  "description": "WizardNavigation — UI factory (1:1 with the @almadar/ui wizard-navigation pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-wizard-navigation",
    "version": "1.0.0",
    "description": "WizardNavigation — UI factory (1:1 with the @almadar/ui wizard-navigation pattern).",
    "orbitals": [
      {
        "name": "WizardNavigationOrbital",
        "entity": {
          "name": "WizardNavigationItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "currentStep",
              "type": "number",
              "default": 1
            },
            {
              "name": "totalSteps",
              "type": "number",
              "default": 1
            }
          ]
        },
        "traits": [
          {
            "name": "WizardNavigationRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "currentStep",
                "totalSteps"
              ]
            },
            "category": "interaction",
            "linkedEntity": "WizardNavigationItem",
            "emits": [
              {
                "event": "BACK",
                "description": "Event to emit on Back click — emits UI:{onBack} with { currentStep, totalSteps }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "totalSteps",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "event": "NEXT",
                "description": "Event to emit on Next click — emits UI:{onNext} with { currentStep, totalSteps }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "totalSteps",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "event": "COMPLETE",
                "description": "Event to emit on Complete click — emits UI:{onComplete} with { currentStep, totalSteps }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "currentStep",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "totalSteps",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "event": "BACK_CLICK",
                "description": "Direct callback for Back (alternative to event)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "NEXT_CLICK",
                "description": "Direct callback for Next (alternative to event)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "COMPLETE_CLICK",
                "description": "Direct callback for Complete (alternative to event)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "BACK",
                  "name": "Back",
                  "description": "Event to emit on Back click — emits UI:{onBack} with { currentStep, totalSteps }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "currentStep",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "totalSteps",
                      "type": "number",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "NEXT",
                  "name": "Next",
                  "description": "Event to emit on Next click — emits UI:{onNext} with { currentStep, totalSteps }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "currentStep",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "totalSteps",
                      "type": "number",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "COMPLETE",
                  "name": "Complete",
                  "description": "Event to emit on Complete click — emits UI:{onComplete} with { currentStep, totalSteps }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "currentStep",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "totalSteps",
                      "type": "number",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "BACK_CLICK",
                  "name": "Back Click",
                  "description": "Direct callback for Back (alternative to event)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "NEXT_CLICK",
                  "name": "Next Click",
                  "description": "Direct callback for Next (alternative to event)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "COMPLETE_CLICK",
                  "name": "Complete Click",
                  "description": "Direct callback for Complete (alternative to event)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.currentStep",
                      1
                    ],
                    [
                      "set",
                      "@entity.totalSteps",
                      1
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "compact": false,
                        "isValid": true,
                        "onBack": "BACK",
                        "currentStep": "@entity.currentStep",
                        "onNextClick": "NEXT_CLICK",
                        "onBackClick": "BACK_CLICK",
                        "onComplete": "COMPLETE",
                        "showNext": true,
                        "showBack": true,
                        "className": "",
                        "completeLabel": "Complete Label",
                        "nextLabel": "Next Label",
                        "showComplete": true,
                        "onCompleteClick": "COMPLETE_CLICK",
                        "totalSteps": "@entity.totalSteps",
                        "backLabel": "Back Label",
                        "type": "wizard-navigation",
                        "onNext": "NEXT"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "BACK",
                  "effects": [
                    [
                      "set",
                      "@entity.currentStep",
                      "@payload.currentStep"
                    ],
                    [
                      "set",
                      "@entity.totalSteps",
                      "@payload.totalSteps"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "",
                        "showComplete": true,
                        "completeLabel": "Complete Label",
                        "isValid": true,
                        "onNext": "NEXT",
                        "showBack": true,
                        "totalSteps": "@entity.totalSteps",
                        "currentStep": "@entity.currentStep",
                        "onBackClick": "BACK_CLICK",
                        "backLabel": "Back Label",
                        "onNextClick": "NEXT_CLICK",
                        "onBack": "BACK",
                        "type": "wizard-navigation",
                        "onCompleteClick": "COMPLETE_CLICK",
                        "showNext": true,
                        "compact": false,
                        "nextLabel": "Next Label",
                        "onComplete": "COMPLETE"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "NEXT",
                  "effects": [
                    [
                      "set",
                      "@entity.currentStep",
                      "@payload.currentStep"
                    ],
                    [
                      "set",
                      "@entity.totalSteps",
                      "@payload.totalSteps"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "isValid": true,
                        "showBack": true,
                        "onComplete": "COMPLETE",
                        "onCompleteClick": "COMPLETE_CLICK",
                        "totalSteps": "@entity.totalSteps",
                        "compact": false,
                        "showComplete": true,
                        "completeLabel": "Complete Label",
                        "onBackClick": "BACK_CLICK",
                        "showNext": true,
                        "currentStep": "@entity.currentStep",
                        "onBack": "BACK",
                        "backLabel": "Back Label",
                        "onNext": "NEXT",
                        "onNextClick": "NEXT_CLICK",
                        "type": "wizard-navigation",
                        "nextLabel": "Next Label",
                        "className": ""
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "COMPLETE",
                  "effects": [
                    [
                      "set",
                      "@entity.currentStep",
                      "@payload.currentStep"
                    ],
                    [
                      "set",
                      "@entity.totalSteps",
                      "@payload.totalSteps"
                    ],
