                "description": "Custom label for Back button",
                "tier": "presentation"
              },
              "currentStep": {
                "type": "number",
                "default": 1,
                "label": "Current Step",
                "description": "Current step index (0-based)",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "completeLabel": {
                "type": "string",
                "default": "Complete Label",
                "label": "Complete Label",
                "description": "Custom label for Complete button",
                "tier": "presentation"
              },
              "isValid": {
                "type": "boolean",
                "default": true,
                "label": "Is Valid",
                "description": "Whether the current step is valid (enables Next/Complete)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
