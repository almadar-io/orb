{
  "name": "std-thread-comments-linear",
  "description": "Nested threaded comments — Disqus/Hacker News style: indented reply tree, inline reply composer on every comment card, and a visible replies group per parent. For forum discussions, blog comments, document review threads, project-manager issue comments.",
  "level": "atom",
  "topic": "core-variations",
  "schema": {
    "name": "std-thread-comments-linear",
    "version": "1.2.0",
    "description": "Nested threaded comments — Disqus/Hacker News style: indented reply tree, inline reply composer on every comment card, and a visible replies group per parent. For forum discussions, blog comments, document review threads, project-manager issue comments.",
    "orbitals": [
      {
        "name": "CommentsLinearOrbital",
        "uses": [
          {
            "from": "std/behaviors/std-thread",
            "as": "Thread"
          }
        ],
        "entity": {
          "name": "CommentsLinearPost",
          "collection": "commentslinearposts",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "parentId",
              "type": "string",
              "description": "Identifier of the comment this comment replies to.",
              "synonyms": "parent, replyTo, source"
            },
            {
              "name": "threadRootId",
              "type": "string",
              "required": true,
              "description": "Identifier of the top-level comment in the thread.",
              "synonyms": "rootId, topLevelId, originId"
            },
            {
              "name": "authorId",
              "type": "string",
              "required": true,
              "description": "Unique identifier for the comment's author.",
              "synonyms": "user identifier, author reference, contributor ID"
            },
            {
              "name": "authorName",
              "type": "string",
              "required": true,
              "description": "The name of the comment's author.",
              "synonyms": "author, user, contributor"
            },
            {
              "name": "content",
              "type": "string",
              "required": true,
              "description": "The text of the comment or post.",
              "synonyms": "text, body, message, postContent"
            },
            {
              "name": "createdAt",
              "type": "string"
            },
            {
              "name": "voteCount",
              "type": "number",
              "default": 0,
              "description": "The number of votes or ratings associated with the comment.",
              "synonyms": "rating, score, likes, upvotes"
            },
            {
              "name": "replyCount",
              "type": "number",
              "default": 0,
              "description": "The number of replies to this comment.",
              "synonyms": "child comments, responses, sub-comments"
            },
            {
              "name": "replies",
              "type": "relation",
              "relation": {
                "entity": "CommentsLinearPost",
                "cardinality": "many"
              },
              "description": "A list of child comments in the thread.",
              "synonyms": "replies, children, descendants"
            },
            {
              "name": "focusedRow",
              "type": "object",
              "default": {},
              "description": "The currently selected comment within the comment thread.",
              "synonyms": "selected, active, highlighted"
            }
          ]
        },
        "traits": [
          {
            "name": "CommentsLinear",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "content",
                "focusedRow",
                "parentId"
              ]
            },
            "category": "interaction",
            "linkedEntity": "CommentsLinearPost",
            "emits": [
              {
                "event": "SELECT",
                "description": "Indicates a post or reply has been chosen for interaction.",
                "synonyms": "choose, highlight, focus, activate",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "event": "REPLY",
                "description": "Indicates a new reply has been created and added to the thread.",
                "synonyms": "add, post, respond, submit",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "parentId",
                    "type": "string"
                  },
                  {
                    "name": "parentNodeId",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "EDIT_REPLY",
                "description": "Indicates a reply has been modified.",
                "synonyms": "update, change, modify",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "SUBMIT_REPLY",
                "description": "Signals a new reply has been successfully submitted.",
                "synonyms": "post, send, add, publish",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "event": "CANCEL_REPLY",
                "description": "Indicates a reply creation was aborted by the user.",
                "synonyms": "abort, dismiss, undo, cancel",
                "tier": "presentation"
              },
              {
                "event": "ThreadPostLoaded",
                "description": "Signals a thread post has been successfully retrieved.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CommentsLinearPost]"
                  }
                ]
              },
              {
                "event": "ThreadPostLoadFailed",
                "description": "Indicates a failure to load a thread post.",
                "synonyms": "load error, fetch failed, retrieval failed",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "ThreadPostCreated",
                "description": "A new post has been added to the thread.",
                "synonyms": "new post, added, created",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "parentId",
                        "type": "string"
                      },
                      {
                        "name": "threadRootId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "authorId",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "authorName",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "content",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      },
                      {
                        "name": "voteCount",
                        "type": "number"
                      },
                      {
                        "name": "replyCount",
                        "type": "number"
                      },
                      {
                        "name": "replies",
                        "type": "[ThreadPost]"
                      },
                      {
                        "name": "focusedRow",
                        "type": "object"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "ThreadPostCreateFailed",
                "description": "Indicates a failure to create a new thread post.",
                "synonyms": "error, failed, creation failed",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "replying"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "ThreadPostLoaded",
                  "name": "ThreadPost loaded",
                  "description": "Signals a thread post has been successfully retrieved.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[CommentsLinearPost]"
                    }
                  ]
                },
                {
                  "key": "ThreadPostLoadFailed",
                  "name": "ThreadPost load failed",
                  "description": "Indicates a failure to load a thread post.",
                  "synonyms": "load error, fetch failed, retrieval failed",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "REPLY",
                  "name": "Reply",
                  "description": "Indicates a new reply has been created and added to the thread.",
                  "synonyms": "add, post, respond, submit",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "parentId",
                      "type": "string"
                    },
                    {
                      "name": "parentNodeId",
                      "type": "string"
                    },
                    {
                      "name": "content",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "ThreadPostCreated",
                  "name": "ThreadPost created",
                  "description": "A new post has been added to the thread.",
                  "synonyms": "new post, added, created",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "row",
                      "type": "CommentsLinearPost"
                    }
                  ]
                },
                {
                  "key": "SELECT",
                  "name": "Select",
                  "description": "Indicates a post or reply has been chosen for interaction.",
                  "synonyms": "choose, highlight, focus, activate",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "row",
                      "type": "object",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "EDIT_REPLY",
                  "name": "Edit Reply",
                  "description": "Indicates a reply has been modified.",
                  "synonyms": "update, change, modify",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "value",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "SUBMIT_REPLY",
                  "name": "Submit Reply",
                  "description": "Signals a new reply has been successfully submitted.",
                  "synonyms": "post, send, add, publish",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "object",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CANCEL_REPLY",
                  "name": "Cancel Reply",
                  "description": "Indicates a reply creation was aborted by the user.",
                  "synonyms": "abort, dismiss, undo, cancel",
                  "tier": "presentation"
                },
                {
                  "key": "ThreadPostCreateFailed",
                  "name": "ThreadPost create failed",
                  "description": "Indicates a failure to create a new thread post.",
                  "synonyms": "error, failed, creation failed",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "CommentsLinearPost",
                      {
                        "emit": {
                          "failure": "ThreadPostLoadFailed",
                          "success": "ThreadPostLoaded"
                        },
                        "include": [
                          "replies"
                        ]
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "sm"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "ThreadPostLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "w-full px-card-md py-section",
                        "type": "stack",
                        "gap": "lg",
                        "children": [
                          {
                            "children": [
                              {
                                "size": "md",
                                "name": "message-square",
                                "type": "icon"
                              },
                              {
                                "variant": "h3",
                                "type": "typography",
                                "content": "Discussion"
                              }
                            ],
                            "gap": "sm",
                            "direction": "horizontal",
                            "align": "center",
                            "type": "stack"
                          },
                          {
                            "look": "flat-bordered",
                            "children": {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Add a comment",
                                  "variant": "label"
                                },
                                {
                                  "inputType": "textarea",
                                  "placeholder": "Share your thoughts…",
                                  "rows": 3,
                                  "type": "input",
                                  "action": "EDIT_REPLY"
                                },
                                {
                                  "justify": "end",
                                  "children": [
                                    {
                                      "action": "CANCEL_REPLY",
                                      "type": "button",
                                      "variant": "ghost",
                                      "label": "Cancel",
                                      "size": "sm"
                                    },
                                    {
                                      "type": "button",
                                      "icon": "send",
                                      "variant": "primary",
                                      "action": "SUBMIT_REPLY",
                                      "label": "Comment",
                                      "size": "sm"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm"
                            },
                            "padding": "md",
                            "type": "card"
                          },
                          {
                            "showActions": true,
                            "nodes": "@payload.data",
                            "replyEvent": "REPLY",
                            "type": "reply-tree"
                          }
                        ],
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "ThreadPostLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "message": "@payload.error",
                        "variant": "error"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "CommentsLinearPost",
                      {
                        "emit": {
                          "success": "ThreadPostLoaded",
                          "failure": "ThreadPostLoadFailed"
                        },
                        "include": [
                          "replies"
                        ]
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "sm"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "ThreadPostLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "w-full px-card-md py-section",
                        "type": "stack",
                        "gap": "lg",
                        "children": [
                          {
                            "children": [
                              {
                                "size": "md",
                                "name": "message-square",
                                "type": "icon"
                              },
                              {
                                "variant": "h3",
                                "type": "typography",
                                "content": "Discussion"
                              }
                            ],
                            "gap": "sm",
                            "direction": "horizontal",
                            "align": "center",
                            "type": "stack"
                          },
                          {
                            "look": "flat-bordered",
                            "children": {
                              "children": [
                                {
                                  "type": "typography",
                                  "content": "Add a comment",
                                  "variant": "label"
                                },
                                {
                                  "inputType": "textarea",
                                  "placeholder": "Share your thoughts…",
                                  "rows": 3,
                                  "type": "input",
                                  "action": "EDIT_REPLY"
                                },
                                {
                                  "justify": "end",
                                  "children": [
                                    {
                                      "action": "CANCEL_REPLY",
                                      "type": "button",
                                      "variant": "ghost",
                                      "label": "Cancel",
                                      "size": "sm"
                                    },
                                    {
                                      "type": "button",
                                      "icon": "send",
                                      "variant": "primary",
                                      "action": "SUBMIT_REPLY",
                                      "label": "Comment",
                                      "size": "sm"
                                    }
                                  ],
                                  "type": "stack",
                                  "direction": "horizontal",
                                  "gap": "sm"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical",
                              "gap": "sm"
                            },
                            "padding": "md",
                            "type": "card"
                          },
                          {
                            "showActions": true,
                            "nodes": "@payload.data",
                            "replyEvent": "REPLY",
                            "type": "reply-tree"
                          }
                        ],
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REPLY",
                  "guard": [
                    "not",
                    [
                      "=",
                      [
                        "str/default",
                        "@payload.content",
                        ""
                      ],
                      ""
                    ]
                  ],
                  "effects": [
                    [
                      "persist",
                      "create",
                      "CommentsLinearPost",
                      {
                        "authorName": "You",
                        "content": "@payload.content",
                        "authorId": "me",
                        "parentId": [
                          "str/default",
                          "@payload.parentNodeId",
                          "@payload.parentId"
                        ],
                        "threadRootId": [
                          "str/default",
                          "@payload.parentNodeId",
                          "root"
                        ]
                      },
                      {
                        "emit": {
                          "failure": "ThreadPostCreateFailed",
                          "success": "ThreadPostCreated"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "replying",
                  "event": "REPLY",
                  "guard": [
                    "=",
                    [
                      "str/default",
                      "@payload.content",
                      ""
                    ],
                    ""
                  ],
                  "effects": [
                    [
                      "set",
                      "@entity.parentId",
                      [
                        "str/default",
                        "@payload.parentNodeId",
                        "@payload.parentId"
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "content": "Write a reply",
                            "variant": "h4",
                            "type": "typography"
                          },
                          {
                            "placeholder": "Your reply…",
                            "action": "EDIT_REPLY",
                            "type": "textarea"
                          },
                          {
                            "gap": "sm",
                            "type": "stack",
                            "direction": "horizontal",
                            "children": [
                              {
                                "variant": "primary",
                                "label": "Submit",
                                "icon": "send",
                                "action": "SUBMIT_REPLY",
                                "type": "button"
                              },
                              {
                                "label": "Cancel",
                                "variant": "secondary",
                                "type": "button",
                                "action": "CANCEL_REPLY"
                              }
                            ]
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "ThreadPostCreated",
                  "effects": [
                    [
                      "fetch",
                      "CommentsLinearPost",
                      {
                        "include": [
                          "replies"
                        ],
                        "emit": {
                          "success": "ThreadPostLoaded",
                          "failure": "ThreadPostLoadFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "SELECT",
                  "effects": [
                    [
                      "set",
                      "@entity.focusedRow",
                      "@payload.row"
                    ],
                    [
                      "fetch",
                      "CommentsLinearPost",
                      {
                        "emit": {
                          "failure": "ThreadPostLoadFailed",
                          "success": "ThreadPostLoaded"
                        },
                        "include": [
                          "replies"
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "replying",
                  "to": "replying",
                  "event": "EDIT_REPLY",
                  "effects": [
                    [
                      "set",
                      "@entity.content",
                      "@payload.value"
                    ]
                  ]
                },
                {
                  "from": "replying",
                  "to": "browsing",
                  "event": "SUBMIT_REPLY",
                  "effects": [
                    [
                      "persist",
                      "create",
                      "CommentsLinearPost",
                      "@payload.data",
                      {
                        "emit": {
                          "failure": "ThreadPostCreateFailed",
                          "success": "ThreadPostCreated"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "replying",
                  "to": "browsing",
                  "event": "CANCEL_REPLY",
                  "effects": [
                    [
                      "set",
                      "@entity.content",
                      ""
                    ],
                    [
                      "set",
                      "@entity.parentId",
                      ""
                    ]
                  ]
                },
                {
                  "from": "replying",
                  "to": "browsing",
                  "event": "ThreadPostCreated",
                  "effects": [
                    [
                      "set",
                      "@entity.content",
                      ""
                    ],
                    [
                      "set",
                      "@entity.parentId",
                      ""
                    ],
                    [
                      "fetch",
                      "CommentsLinearPost",
                      {
                        "emit": {
                          "success": "ThreadPostLoaded",
                          "failure": "ThreadPostLoadFailed"
                        },
                        "include": [
                          "replies"
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "replying",
                  "to": "replying",
                  "event": "ThreadPostCreateFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "variant": "error",
                        "message": "@payload.error"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "CommentsLinearPost",
                      {
                        "emit": {
                          "success": "ThreadPostLoaded",
                          "failure": "ThreadPostLoadFailed"
                        },
                        "include": [
                          "replies"
                        ]
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "sm"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "threadRootId": {
                "type": "string",
                "default": "",
                "label": "Root post id",
                "description": "Top-level post whose descendants are loaded (blank = all roots)",
                "tier": "domain"
              },
              "detailAuthorBinding": {
                "type": "string",
                "default": "@entity.focusedRow.authorName",
                "label": "detailAuthorBinding",
                "description": "Detail-pane binding for the focused message author.",
                "tier": "presentation"
              },
              "replyAuthorBinding": {
                "type": "string",
                "default": "@reply.authorName",
                "label": "replyAuthorBinding",
                "description": "Reply binding for the reply author.",
                "tier": "presentation"
              },
              "tableLook": {
                "type": "string",
                "default": "dense",
                "label": "Table look",
                "description": "Layer 2 visual treatment for the data table rendered by this atom.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              },
              "emailSubjectBinding": {
                "type": "string",
                "default": "@item.subject",
                "label": "emailSubjectBinding",
                "description": "List-pane binding for the message subject.",
                "tier": "presentation"
              },
              "detailContentBinding": {
                "type": "string",
                "default": "@entity.focusedRow.content",
                "label": "detailContentBinding",
                "description": "Detail-pane binding for the message body.",
                "tier": "presentation"
              },
              "detailFromBinding": {
                "type": "string",
