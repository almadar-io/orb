{
  "name": "std-tabs-layout",
  "description": "std-tabs-layout — chrome with std-tabs strip; consumer overrides config.tabs[].content with @trait.X references.",
  "level": "molecule",
  "topic": "core",
  "schema": {
    "name": "std-tabs-layout",
    "version": "2.0.0",
    "description": "std-tabs-layout — chrome with std-tabs strip; consumer overrides config.tabs[].content with @trait.X references.",
    "orbitals": [
      {
        "name": "TabsLayoutOrbital",
        "uses": [
          {
            "from": "std/behaviors/std-tabs",
            "as": "Tabs"
          }
        ],
        "entity": {
          "name": "TabsLayoutData",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "auxiliaryEntities": [
          {
            "name": "TabsItem",
            "persistence": "runtime",
            "fields": [
              {
                "name": "id",
                "type": "string",
                "required": true
              },
              {
                "name": "activeTab",
                "type": "string",
                "default": "",
                "description": "The currently selected tab's identifier.",
                "synonyms": "selection, currentTab, highlightedTab"
              },
              {
                "name": "items",
                "type": "array",
                "default": [],
                "items": {
                  "type": "object",
                  "properties": {
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    "content": {
                      "name": "content",
                      "type": "trait",
                      "required": false
                    },
                    "badge": {
                      "name": "badge",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                },
                "description": "A collection of tab specifications defining the tab structure.",
                "synonyms": "tabs, tab list, tab definitions"
              }
            ]
          }
        ],
        "traits": [
          {
            "name": "TabsLayoutTabs",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "activeTab",
                "items"
              ]
            },
            "category": "interaction",
            "linkedEntity": "TabsItem",
            "emits": [
              {
                "event": "TAB_CHANGED",
                "description": "Signals a tab selection has occurred.",
                "synonyms": "selected, activated, switched",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "TAB_CHANGED",
                  "name": "Tab Changed",
                  "description": "Signals a tab selection has occurred.",
                  "synonyms": "selected, activated, switched",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "tabId",
                      "type": "string",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.items",
                      [
                        {
                          "id": "overview",
                          "label": "Overview",
                          "icon": "info"
                        },
                        {
                          "label": "Details",
                          "icon": "list",
                          "id": "details"
                        },
                        {
                          "label": "Settings",
                          "id": "settings",
                          "icon": "settings"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.activeTab",
                      "overview"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "default",
                        "activeTab": "@entity.activeTab",
                        "items": "@entity.items",
                        "tabChangeEvent": "TAB_CHANGED",
                        "orientation": "horizontal",
                        "type": "tabs"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "TAB_CHANGED",
                  "effects": [
                    [
                      "set",
                      "@entity.items",
                      [
                        {
                          "id": "overview",
                          "label": "Overview",
                          "icon": "info"
                        },
                        {
                          "label": "Details",
                          "icon": "list",
                          "id": "details"
                        },
                        {
                          "label": "Settings",
                          "id": "settings",
                          "icon": "settings"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.activeTab",
                      "@payload.tabId"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "default",
                        "activeTab": "@entity.activeTab",
                        "items": "@entity.items",
                        "tabChangeEvent": "TAB_CHANGED",
                        "orientation": "horizontal",
                        "type": "tabs"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "bodyContent": {
                "type": "render-ui",
                "default": {
                  "variant": "@config.variant",
                  "activeTab": "@entity.activeTab",
                  "items": "@entity.items",
                  "tabChangeEvent": "TAB_CHANGED",
                  "orientation": "@config.orientation",
                  "type": "tabs"
                },
                "label": "Body content tree",
                "description": "Render-ui SExpr rendered for the tabs surface. Default is the canonical tabs pattern bound to @entity.items / @entity.activeTab. Layer 3 variants override this with their own tree (segmented-pill bar, vertical sidebar rail, etc.) while inheriting the same trait, state machine, emits, and listens.",
                "tier": "internal"
              },
              "defaultTab": {
                "type": "string",
                "default": "overview",
                "label": "Default tab",
                "description": "Tab id selected on first render",
                "tier": "presentation"
              },
              "tabs": {
                "type": "[TabSpec]",
                "default": [
                  {
                    "id": "overview",
                    "label": "Overview",
                    "icon": "info"
                  },
                  {
                    "label": "Details",
                    "icon": "list",
                    "id": "details"
                  },
                  {
                    "label": "Settings",
                    "id": "settings",
                    "icon": "settings"
                  }
                ],
                "label": "Tabs",
                "description": "Tab entries with id, label, icon, badge, and optional content trait",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "content": {
                      "name": "content",
                      "type": "trait",
                      "required": false
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "badge": {
                      "name": "badge",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "variant": {
                "type": "string",
                "default": "default",
                "label": "Tab style",
                "description": "Visual style of the tab strip",
                "tier": "presentation",
                "values": [
                  "default",
                  "pills",
                  "underline"
                ]
              },
              "orientation": {
                "type": "string",
                "default": "horizontal",
                "label": "Orientation",
                "description": "Horizontal strip or vertical rail layout",
                "tier": "presentation",
                "values": [
                  "horizontal",
                  "vertical"
                ]
              }
            },
            "scope": "instance",
            "sourceBehavior": {
              "behavior": "std/behaviors/std-tabs",
              "alias": "Tabs",
              "originalName": "TabsItemTabs"
            },
            "sourceEntityDefinition": {
              "name": "TabsItem",
              "persistence": "runtime",
              "fields": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "activeTab",
                  "type": "string",
                  "default": "",
                  "description": "The currently selected tab's identifier.",
                  "synonyms": "selection, currentTab, highlightedTab"
                },
                {
                  "name": "items",
                  "type": "array",
                  "default": [],
                  "items": {
                    "type": "object",
                    "properties": {
                      "icon": {
                        "name": "icon",
                        "type": "string",
                        "required": false
                      },
                      "id": {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      "content": {
                        "name": "content",
                        "type": "trait",
                        "required": false
                      },
                      "badge": {
                        "name": "badge",
                        "type": "string",
                        "required": false
                      },
                      "label": {
                        "name": "label",
                        "type": "string",
                        "required": true
                      }
                    }
                  },
                  "description": "A collection of tab specifications defining the tab structure.",
                  "synonyms": "tabs, tab list, tab definitions"
                }
              ]
            }
          },
          {
            "name": "TabsLayout",
            "category": "interaction",
            "stateMachine": {
              "states": [
                {
                  "name": "composing",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "composing",
                  "to": "composing",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "max-w-6xl mx-auto w-full",
                        "gap": "md",
                        "children": [
                          {
                            "children": [
                              {
                                "name": "layout",
                                "type": "icon"
                              },
                              {
                                "variant": "h2",
                                "content": "Tabbed View",
                                "type": "typography"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "align": "center",
                            "type": "stack"
                          },
                          {
                            "type": "divider"
                          },
                          "@trait.TabsLayoutTabs"
                        ],
                        "direction": "vertical",
                        "type": "stack"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "title": {
                "type": "string",
                "default": "Tabbed View",
                "label": "Page title",
                "description": "Heading shown above the tab strip",
                "tier": "presentation"
              },
              "icon": {
                "type": "string",
                "default": "layout",
                "label": "Header icon",
                "description": "Icon name displayed next to the title",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "TabsLayoutPage",
            "path": "/tabs-layout",
            "traits": [
              {
                "ref": "TabsLayout"
              },
              {
                "ref": "TabsLayoutTabs"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "TabsLayoutOrbital": [
          {
            "trait": "TabsLayout",
            "patternPath": "root.children.0.children.0",
            "prop": "name",
            "knob": "icon"
          },
          {
            "trait": "TabsLayout",
            "patternPath": "root.children.0.children.1",
            "prop": "content",
            "knob": "title"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}