{
  "name": "ui-badge",
  "description": "Badge — UI factory (1:1 with the @almadar/ui badge pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-badge",
    "version": "1.0.0",
    "description": "Badge — UI factory (1:1 with the @almadar/ui badge pattern).",
    "orbitals": [
      {
        "name": "BadgeOrbital",
        "entity": {
          "name": "BadgeItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "BadgeRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "BadgeItem",
            "emits": [
              {
                "event": "REMOVE",
                "description": "When set, renders a small X button on the right of the badge that invokes this handler — turns the badge into a removable chip. Used by the TagInput molecule and other 'list of removable values' surfaces.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "REMOVE",
                  "name": "Remove",
                  "description": "When set, renders a small X button on the right of the badge that invokes this handler — turns the badge into a removable chip. Used by the TagInput molecule and other 'list of removable values' surfaces.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "size": "sm",
                        "type": "badge",
                        "amount": 0,
                        "className": "",
                        "icon": "circle",
                        "variant": "default",
                        "label": "Label",
                        "onRemove": "REMOVE",
                        "removeLabel": "Remove Label"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "label": {
                "type": "string",
                "default": "Label",
                "label": "Label",
                "description": "Badge label text (alternative to children for schema-driven rendering). Numeric values are auto-coerced to string for rendering — common case is unread counts, error counts, status codes, etc.",
                "tier": "presentation"
              },
              "size": {
                "type": "string",
                "default": "sm",
                "label": "Size",
                "description": "size prop",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg"
                ]
              },
              "removeLabel": {
                "type": "string",
                "default": "Remove Label",
                "label": "Remove Label",
                "description": "Accessible label for the remove button. Defaults to 'Remove'.",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "default",
                "label": "Variant",
                "description": "variant prop",
                "tier": "presentation",
                "values": [
                  "default",
                  "primary",
                  "secondary",
                  "success",
                  "warning",
                  "danger",
                  "error",
                  "info",
                  "neutral"
                ]
              },
              "icon": {
                "type": "icon",
                "default": "circle",
                "label": "Icon",
                "description": "Lucide icon component or canonical kebab-case icon name string",
                "tier": "presentation"
              },
              "amount": {
                "type": "number",
                "default": 0,
                "label": "Amount",
                "description": "Numeric count or amount to display in badge",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes applied to the root element.",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "BadgePage",
            "path": "/badge",
            "traits": [
              {
                "ref": "BadgeRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "BadgeOrbital": [
          {
            "trait": "BadgeRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "BadgeRender",
            "patternPath": "root",
            "prop": "amount",
            "knob": "amount"
          },
          {
            "trait": "BadgeRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "BadgeRender",
            "patternPath": "root",
            "prop": "icon",
            "knob": "icon"
          },
          {
            "trait": "BadgeRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "BadgeRender",
            "patternPath": "root",
            "prop": "label",
            "knob": "label"
          },
          {
            "trait": "BadgeRender",
            "patternPath": "root",
            "prop": "removeLabel",
            "knob": "removeLabel"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}