{
  "name": "ui-trait-frame",
  "description": "TraitFrame — UI factory (1:1 with the @almadar/ui trait-frame pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-trait-frame",
    "version": "1.0.0",
    "description": "TraitFrame — UI factory (1:1 with the @almadar/ui trait-frame pattern).",
    "orbitals": [
      {
        "name": "TraitFrameOrbital",
        "entity": {
          "name": "TraitFrameItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "TraitFrameRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "TraitFrameItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "fallback": [
                          {
                            "content": "Fallback",
                            "type": "typography"
                          }
                        ],
                        "type": "trait-frame",
                        "traitName": "Trait Name"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "traitName": {
                "type": "string",
                "default": "Trait Name",
                "label": "Trait Name",
                "description": "Name of the trait whose current frame to embed. Must match a trait declared in the current orbital. Compiler validates that the name exists at build time (see `ORB_BINDING_TRAIT_UNKNOWN`).",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "TraitFramePage",
            "path": "/trait-frame",
            "traits": [
              {
                "ref": "TraitFrameRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "TraitFrameOrbital": [
          {
            "trait": "TraitFrameRender",
            "patternPath": "root",
            "prop": "traitName",
            "knob": "traitName"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}