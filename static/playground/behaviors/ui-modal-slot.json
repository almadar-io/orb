{
  "name": "ui-modal-slot",
  "description": "ModalSlot — UI factory (1:1 with the @almadar/ui modal-slot pattern).",
  "level": "organism",
  "topic": "ui/core",
  "schema": {
    "name": "ui-modal-slot",
    "version": "1.0.0",
    "description": "ModalSlot — UI factory (1:1 with the @almadar/ui modal-slot pattern).",
    "orbitals": [
      {
        "name": "ModalSlotOrbital",
        "entity": {
          "name": "ModalSlotItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ModalSlotRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ModalSlotItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "ModalSlotItem",
                      {}
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "",
                        "error": "@config.error",
                        "title": "Title",
                        "isLoading": false,
                        "children": [
                          {
                            "content": "Sample content",
                            "type": "typography"
                          }
                        ],
                        "entity": "ModalSlotItem",
                        "size": "md",
                        "type": "modal-slot"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Override modal title (extracted from children if not provided)",
                "tier": "presentation"
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Modal size",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "full"
                ]
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Custom class name",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "error": {
                "type": "ModalSlotError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  }
                }
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ModalSlotPage",
            "path": "/modal-slot",
            "traits": [
              {
                "ref": "ModalSlotRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "ModalSlotOrbital": [
          {
            "trait": "ModalSlotRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "ModalSlotRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "ModalSlotRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "ModalSlotRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          }
        ]
      }
