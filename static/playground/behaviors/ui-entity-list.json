              },
              "emptyMessage": {
                "type": "string",
                "default": "Empty Message",
                "label": "Empty Message",
                "description": "emptyMessage prop",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "default",
                "label": "Variant",
                "description": "variant prop",
                "tier": "presentation",
                "values": [
                  "default",
                  "card"
                ]
              }
            },
            "scope": "instance"
          }
