{
  "name": "ui-entity-list",
  "description": "EntityList — UI factory (1:1 with the @almadar/ui entity-list pattern).",
  "level": "organism",
  "topic": "ui/core",
  "schema": {
    "name": "ui-entity-list",
    "version": "1.0.0",
    "description": "EntityList — UI factory (1:1 with the @almadar/ui entity-list pattern).",
    "orbitals": [
      {
        "name": "EntityListOrbital",
        "entity": {
          "name": "EntityListItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "EntityListRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "EntityListItem",
            "emits": [
              {
                "event": "ITEM_ACTIONS",
                "description": "Item actions - schema-driven or function-based",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "VIEW",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "EntityListLoaded",
                "description": "EntityList rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[EntityListItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "EntityListLoaded",
                  "name": "Entity list loaded",
                  "description": "EntityList rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[EntityListItem]"
                    }
                  ]
                },
                {
                  "key": "VIEW",
                  "name": "View",
                  "description": "User opened a record from the list.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "ITEM_ACTIONS",
                  "name": "Item Actions",
                  "description": "Item actions - schema-driven or function-based",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "EntityListItem",
                      {
                        "emit": {
                          "success": "EntityListLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "emptyMessage": "Empty Message",
                        "selectedIds": [],
                        "children": [
                          {
                            "type": "typography",
                            "content": "Sample content"
                          }
                        ],
                        "entityType": "Entity Type",
                        "sortDirection": "asc",
                        "searchValue": "Search Value",
                        "activeFilters": {},
                        "type": "entity-list",
                        "className": "",
                        "itemActions": [
                          {
                            "event": "VIEW",
                            "label": "View"
                          }
                        ],
                        "isLoading": false,
                        "selectable": false,
                        "showDividers": false,
                        "fields": [
                          {
                            "name": "Name",
                            "header": "Header",
                            "key": "Key",
                            "label": "Label"
                          },
                          {
                            "header": "Header 2",
                            "key": "Key 2",
                            "label": "Label 2",
                            "name": "Name 2"
                          }
                        ],
                        "entity": "@entity",
                        "error": "@config.error",
                        "pageSize": 0,
                        "sortBy": "Sort By",
                        "totalCount": 0,
                        "variant": "default",
                        "page": 0,
                        "fieldNames": []
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "EntityListLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "totalCount": 0,
                        "isLoading": false,
                        "fields": [
                          {
                            "name": "Name",
                            "header": "Header",
                            "key": "Key",
                            "label": "Label"
                          },
                          {
                            "header": "Header 2",
                            "key": "Key 2",
                            "label": "Label 2",
                            "name": "Name 2"
