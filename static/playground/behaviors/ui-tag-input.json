{
  "name": "ui-tag-input",
  "description": "TagInput — UI factory (1:1 with the @almadar/ui tag-input pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-tag-input",
    "version": "1.0.0",
    "description": "TagInput — UI factory (1:1 with the @almadar/ui tag-input pattern).",
    "orbitals": [
      {
        "name": "TagInputOrbital",
        "entity": {
          "name": "TagInputItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "TagInputRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "TagInputItem",
            "emits": [
              {
                "event": "CHANGE",
                "description": "Direct callback emitted on every change. Stays as the Storybook / non-trait contract; trait-driven schemas should prefer the bus events below.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "next",
                    "type": "[object]"
                  }
                ]
              },
              {
                "event": "ADD",
                "description": "Event emitted when a tag is added: `UI:{addEvent}` with payload `{ tag: string, value: string[] }`.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "REMOVE",
                "description": "Event emitted when a tag is removed: `UI:{removeEvent}` with payload `{ tag: string, index: number, value: string[] }`.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "CHANGE",
                  "name": "Change",
                  "description": "Direct callback emitted on every change. Stays as the Storybook / non-trait contract; trait-driven schemas should prefer the bus events below.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "next",
                      "type": "[object]"
                    }
                  ]
                },
                {
                  "key": "ADD",
                  "name": "Add",
                  "description": "Event emitted when a tag is added: `UI:{addEvent}` with payload `{ tag: string, value: string[] }`.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "REMOVE",
                  "name": "Remove",
                  "description": "Event emitted when a tag is removed: `UI:{removeEvent}` with payload `{ tag: string, index: number, value: string[] }`.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "addEvent": "ADD",
                        "onChange": "CHANGE",
                        "type": "tag-input",
                        "helperText": "Helper Text",
                        "className": "",
                        "removeEvent": "REMOVE",
                        "placeholder": "Placeholder",
                        "unique": true,
                        "value": [
                          "list",
                          "Item",
                          "Item 2"
                        ],
                        "variant": "default",
                        "disabled": false
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "placeholder": {
                "type": "string",
                "default": "Placeholder",
                "label": "Placeholder",
                "description": "Placeholder for the entry input. Default: `'Type and press Enter…'`.",
                "tier": "presentation"
              },
              "value": {
                "type": "[string]",
                "default": [
                  "Item",
                  "Item 2"
                ],
                "label": "Value",
                "description": "Current list of tags.",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "variant": {
                "type": "string",
                "default": "default",
                "label": "Variant",
                "description": "Variant applied to each chip Badge. Default: `'default'`.",
                "tier": "presentation",
                "values": [
                  "default",
                  "primary",
                  "secondary",
                  "success",
                  "warning",
                  "danger",
                  "error",
                  "info",
                  "neutral"
                ]
              },
              "helperText": {
                "type": "string",
                "default": "Helper Text",
                "label": "Helper Text",
                "description": "Helper text rendered under the input.",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes applied to the outer container.",
                "tier": "presentation"
              },
              "unique": {
                "type": "boolean",
                "default": true,
                "label": "Unique",
                "description": "Suppress duplicate entries. Default: `true`.",
                "tier": "presentation"
              },
              "disabled": {
                "type": "boolean",
                "default": false,
                "label": "Disabled",
                "description": "Disable add + remove interactions.",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "TagInputPage",
            "path": "/tag-input",
            "traits": [
              {
                "ref": "TagInputRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "TagInputOrbital": [
          {
            "trait": "TagInputRender",
            "patternPath": "root",
            "prop": "helperText",
            "knob": "helperText"
          },
          {
            "trait": "TagInputRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "TagInputRender",
            "patternPath": "root",
            "prop": "placeholder",
            "knob": "placeholder"
          },
          {
            "trait": "TagInputRender",
            "patternPath": "root",
            "prop": "unique",
            "knob": "unique"
          },
          {
            "trait": "TagInputRender",
            "patternPath": "root",
            "prop": "value",
            "knob": "value"
          },
          {
            "trait": "TagInputRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "TagInputRender",
            "patternPath": "root",
            "prop": "disabled",
            "knob": "disabled"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}