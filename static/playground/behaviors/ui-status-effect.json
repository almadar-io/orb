{
  "name": "ui-status-effect",
  "description": "StatusEffect — counts down duration every second; re-renders on each tick.",
  "level": "atom",
  "topic": "ui/game/2d",
  "schema": {
    "name": "ui-status-effect",
    "version": "1.0.0",
    "description": "StatusEffect — counts down duration every second; re-renders on each tick.",
    "orbitals": [
      {
        "name": "StatusEffectOrbital",
        "entity": {
          "name": "StatusEffectItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "duration",
              "type": "number",
              "default": 30
            }
          ]
        },
        "traits": [
          {
            "name": "StatusEffectRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "duration"
              ]
            },
            "category": "interaction",
            "linkedEntity": "StatusEffectItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.duration",
                      30
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "buff",
                        "label": "Shield",
                        "className": "",
                        "assetUrl": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/magic_02.png",
                        "duration": "@entity.duration",
                        "icon": "shield",
                        "type": "status-effect",
                        "size": "md",
                        "stacks": 0
                      }
                    ]
                  ]
                }
              ]
            },
            "ticks": [
              {
                "name": "durationTick",
                "interval": 1000,
                "guard": [
                  ">",
                  "@entity.duration",
                  0
                ],
                "effects": [
                  [
                    "set",
                    "@entity.duration",
                    [
                      "-",
                      "@entity.duration",
                      1
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "shield",
                      "stacks": 0,
                      "size": "md",
                      "type": "status-effect",
                      "assetUrl": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/magic_02.png",
                      "variant": "buff",
                      "className": "",
                      "label": "Shield",
                      "duration": "@entity.duration"
                    }
                  ]
                ]
              }
            ],
            "config": {
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "duration": {
                "type": "number",
                "default": 30,
                "label": "Duration",
                "description": "Remaining duration in seconds",
                "tier": "presentation"
              },
              "assetUrl": {
                "type": "asset",
                "default": "https://almadar-kflow-assets.web.app/shared/ui-battle-board/default/effects/magic_02.png",
                "label": "Asset Url",
                "description": "Sprite image URL — takes precedence over icon when provided",
                "tier": "presentation"
              },
              "icon": {
                "type": "icon",
                "default": "shield",
