{
  "name": "std-tabs",
  "description": "std-tabs — embeddable tab-navigation atom. Renders a tabs strip from @config.tabs ([{id, label, icon?, badge?, content?}]); clicking a tab updates @entity.activeTab so only the matching @trait.X content shows. Events remap at the call site for routing, persistence, analytics.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-tabs",
    "version": "2.1.0",
    "description": "std-tabs — embeddable tab-navigation atom. Renders a tabs strip from @config.tabs ([{id, label, icon?, badge?, content?}]); clicking a tab updates @entity.activeTab so only the matching @trait.X content shows. Events remap at the call site for routing, persistence, analytics.",
    "orbitals": [
      {
        "name": "TabsItemOrbital",
        "entity": {
          "name": "TabsItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "activeTab",
              "type": "string",
              "default": "",
              "description": "The currently selected tab's identifier.",
              "synonyms": "selection, currentTab, highlightedTab"
            },
            {
              "name": "items",
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string",
                    "required": false
                  },
                  "content": {
                    "name": "content",
                    "type": "trait",
                    "required": false
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string",
                    "required": false
                  },
                  "id": {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                }
              },
              "description": "A collection of tab specifications defining the tab structure.",
              "synonyms": "tabs, tab list, tab definitions"
            }
          ]
        },
        "traits": [
          {
            "name": "TabsItemTabs",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "activeTab",
                "items"
              ]
            },
            "category": "interaction",
            "linkedEntity": "TabsItem",
            "emits": [
              {
                "event": "TAB_CHANGED",
                "description": "Signals a tab selection has occurred.",
                "synonyms": "selected, activated, switched",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "TAB_CHANGED",
                  "name": "Tab Changed",
                  "description": "Signals a tab selection has occurred.",
                  "synonyms": "selected, activated, switched",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "tabId",
                      "type": "string",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.items",
                      [
                        {
                          "id": "overview",
                          "label": "Overview",
                          "icon": "info"
                        },
                        {
                          "label": "Details",
                          "icon": "list",
                          "id": "details"
                        },
                        {
                          "icon": "settings",
                          "id": "settings",
                          "label": "Settings"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.activeTab",
                      "overview"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "default",
                        "items": "@entity.items",
                        "orientation": "horizontal",
                        "tabChangeEvent": "TAB_CHANGED",
                        "activeTab": "@entity.activeTab",
                        "type": "tabs"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "TAB_CHANGED",
                  "effects": [
                    [
                      "set",
                      "@entity.items",
                      [
                        {
                          "id": "overview",
                          "label": "Overview",
                          "icon": "info"
                        },
                        {
                          "label": "Details",
                          "icon": "list",
                          "id": "details"
                        },
                        {
                          "icon": "settings",
                          "id": "settings",
                          "label": "Settings"
                        }
                      ]
                    ],
                    [
                      "set",
                      "@entity.activeTab",
                      "@payload.tabId"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "variant": "default",
                        "items": "@entity.items",
                        "orientation": "horizontal",
                        "tabChangeEvent": "TAB_CHANGED",
                        "activeTab": "@entity.activeTab",
                        "type": "tabs"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "tabs": {
                "type": "[TabSpec]",
                "default": [
                  {
                    "id": "overview",
                    "label": "Overview",
                    "icon": "info"
                  },
                  {
                    "label": "Details",
                    "icon": "list",
                    "id": "details"
                  },
                  {
                    "icon": "settings",
                    "id": "settings",
                    "label": "Settings"
                  }
                ],
                "label": "Tabs",
                "description": "Tab entries with id, label, icon, badge, and optional content trait",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    "badge": {
                      "name": "badge",
                      "type": "string",
                      "required": false
                    },
                    "content": {
                      "name": "content",
                      "type": "trait",
                      "required": false
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "bodyContent": {
                "type": "render-ui",
                "default": {
                  "variant": "@config.variant",
                  "items": "@entity.items",
                  "orientation": "@config.orientation",
                  "tabChangeEvent": "TAB_CHANGED",
                  "activeTab": "@entity.activeTab",
                  "type": "tabs"
                },
                "label": "Body content tree",
                "description": "Render-ui SExpr rendered for the tabs surface. Default is the canonical tabs pattern bound to @entity.items / @entity.activeTab. Layer 3 variants override this with their own tree (segmented-pill bar, vertical sidebar rail, etc.) while inheriting the same trait, state machine, emits, and listens.",
                "tier": "internal"
              },
              "defaultTab": {
                "type": "string",
                "default": "overview",
                "label": "Default tab",
                "description": "Tab id selected on first render",
                "tier": "presentation"
              },
              "orientation": {
                "type": "string",
                "default": "horizontal",
                "label": "Orientation",
                "description": "Horizontal strip or vertical rail layout",
                "tier": "presentation",
                "values": [
                  "horizontal",
                  "vertical"
                ]
              },
              "variant": {
                "type": "string",
                "default": "default",
                "label": "Tab style",
                "description": "Visual style of the tab strip",
                "tier": "presentation",
                "values": [
                  "default",
                  "pills",
                  "underline"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "TabsItemTabsPage",
            "path": "/tabsitems",
            "traits": [
              {
                "ref": "TabsItemTabs"
              }
            ]
          }
        ]
      }
    ]
  },
  "source": "",
  "lolo": ""
}