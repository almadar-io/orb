{
  "name": "ui-matrix-question",
  "description": "MatrixQuestion — UI factory (1:1 with the @almadar/ui matrix-question pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-matrix-question",
    "version": "1.0.0",
    "description": "MatrixQuestion — UI factory (1:1 with the @almadar/ui matrix-question pattern).",
    "orbitals": [
      {
        "name": "MatrixQuestionOrbital",
        "entity": {
          "name": "MatrixQuestionItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "MatrixQuestionRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "MatrixQuestionItem",
            "emits": [
              {
                "event": "CHANGE",
                "description": "Change handler invoked with rowId and selected column value",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "rowId",
                    "type": "string"
                  },
                  {
                    "name": "value",
                    "type": "number"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "CHANGE",
                  "name": "Change",
                  "description": "Change handler invoked with rowId and selected column value",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "rowId",
                      "type": "string"
                    },
                    {
                      "name": "value",
                      "type": "number"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "className": "",
                        "values": {},
                        "type": "matrix-question",
                        "size": "md",
                        "title": "Title",
                        "disabled": false,
                        "onChange": "CHANGE",
                        "rows": [
                          {
                            "id": "Id",
                            "label": "Label"
                          },
                          {
                            "id": "Id 2",
                            "label": "Label 2"
                          }
                        ],
                        "columns": [
                          {
                            "value": "Value",
                            "label": "Label"
                          },
                          {
                            "value": "Value 2",
                            "label": "Label 2"
                          }
                        ],
                        "changeEvent": "CHANGE"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Optional title rendered above the matrix",
                "tier": "presentation"
              },
              "values": {
                "type": "Map<string,string>",
                "default": {},
                "label": "Values",
                "description": "Selected value per row, keyed by rowId",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "rows": {
                "type": "[MatrixQuestionRowsItem]",
                "default": [
                  {
                    "id": "Id",
                    "label": "Label"
                  },
                  {
                    "id": "Id 2",
                    "label": "Label 2"
                  }
                ],
                "label": "Rows",
                "description": "Question rows",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "disabled": {
                "type": "boolean",
                "default": false,
                "label": "Disabled",
                "description": "Disable all inputs",
                "tier": "presentation"
              },
              "columns": {
                "type": "[MatrixQuestionColumnsItem]",
                "default": [
                  {
                    "value": "Value",
                    "label": "Label"
                  },
                  {
                    "value": "Value 2",
                    "label": "Label 2"
                  }
                ],
                "label": "Columns",
                "description": "Column definitions; defaults to 5-point Likert",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "value": {
                      "name": "value",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Visual size",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "MatrixQuestionPage",
            "path": "/matrix-question",
            "traits": [
              {
                "ref": "MatrixQuestionRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "MatrixQuestionOrbital": [
          {
            "trait": "MatrixQuestionRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "MatrixQuestionRender",
            "patternPath": "root",
            "prop": "values",
            "knob": "values"
          },
          {
            "trait": "MatrixQuestionRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "MatrixQuestionRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "MatrixQuestionRender",
            "patternPath": "root",
            "prop": "disabled",
            "knob": "disabled"
          },
          {
            "trait": "MatrixQuestionRender",
            "patternPath": "root",
            "prop": "rows",
            "knob": "rows"
          },
          {
            "trait": "MatrixQuestionRender",
            "patternPath": "root",
            "prop": "columns",
            "knob": "columns"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
