{
  "name": "std-file-store",
  "description": "std-file-store — the generic file/page tree primitive. A file-tree + config-driven data table over a hierarchical collection; opens a row in `viewing_single` with config-driven detail actions. Rebindable: pass `fields`/`itemActions`/`detailActions`/`tree` to retarget it at any hierarchical entity (files, wiki pages, note trees). Folds in the former std-page-tree via `reorderable` + a page field/action set.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-file-store",
    "version": "2.0.0",
    "description": "std-file-store — the generic file/page tree primitive. A file-tree + config-driven data table over a hierarchical collection; opens a row in `viewing_single` with config-driven detail actions. Rebindable: pass `fields`/`itemActions`/`detailActions`/`tree` to retarget it at any hierarchical entity (files, wiki pages, note trees). Folds in the former std-page-tree via `reorderable` + a page field/action set.",
    "orbitals": [
      {
        "name": "StoredFileOrbital",
        "entity": {
          "name": "StoredFile",
          "collection": "storedfiles",
          "persistence": "persistent",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "name",
              "type": "string",
              "required": true,
              "description": "The file's display name or title.",
              "synonyms": "title, label, filename"
            },
            {
              "name": "path",
              "type": "string",
              "default": "",
              "description": "The location of the file within the storage system.",
              "synonyms": "location, filepath, address"
            },
            {
              "name": "mimeType",
              "type": "string",
              "default": "",
              "description": "The file's content type, indicating its format.",
              "synonyms": "type, format, media type"
            },
            {
              "name": "sizeBytes",
              "type": "number",
              "default": 0,
              "description": "The file's size in bytes.",
              "synonyms": "length, filesize, byteCount"
            },
            {
              "name": "uploaderId",
              "type": "string",
              "default": "",
              "description": "Identifier of the user who uploaded the file.",
              "synonyms": "user, owner, creator"
            },
            {
              "name": "uploaderName",
              "type": "string",
              "default": "",
              "description": "The name of the user who uploaded the file.",
              "synonyms": "owner, user, author"
            },
            {
              "name": "folder",
              "type": "string",
              "default": "",
              "description": "The path to the containing directory.",
              "synonyms": "parent, directory, location"
            },
            {
              "name": "uploadedAt",
              "type": "string",
              "default": "",
              "description": "Timestamp indicating when the file was uploaded.",
              "synonyms": "upload date, date uploaded, upload time"
            },
            {
              "name": "isArchived",
              "type": "boolean",
              "default": false,
              "description": "Indicates whether the file is archived.",
              "synonyms": "archived, status, state"
            }
          ]
        },
        "traits": [
          {
            "name": "StoredFileStore",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "folder",
                "name",
                "path"
              ]
            },
            "category": "interaction",
            "linkedEntity": "StoredFile",
            "emits": [
              {
                "event": "OPEN_FILE",
                "description": "Indicates a file has been selected for viewing.",
                "synonyms": "select, choose, activate",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "path",
                        "type": "string"
                      },
                      {
                        "name": "mimeType",
                        "type": "string"
                      },
                      {
                        "name": "sizeBytes",
                        "type": "number"
                      },
                      {
                        "name": "uploaderId",
                        "type": "string"
                      },
                      {
                        "name": "uploaderName",
                        "type": "string"
                      },
                      {
                        "name": "folder",
                        "type": "string"
                      },
                      {
                        "name": "uploadedAt",
                        "type": "string"
                      },
                      {
                        "name": "isArchived",
                        "type": "boolean"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "CLOSE_VIEW",
                "description": "Signals the view has been closed or dismissed.",
                "synonyms": "dismiss, hide, close",
                "tier": "domain"
              },
              {
                "event": "DOWNLOAD_FILE",
                "description": "Initiates a file download process.",
                "synonyms": "export, save, retrieve",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "ARCHIVE_FILE",
                "description": "Signals a file is being moved to archive storage.",
                "synonyms": "archive, move to archive, delete permanently",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "event": "REORDER",
                "description": "Indicates the order of items in the tree has changed.",
                "synonyms": "sort, rearrange, move, change order",
                "tier": "presentation",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "path",
                        "type": "string"
                      },
                      {
                        "name": "mimeType",
                        "type": "string"
                      },
                      {
                        "name": "sizeBytes",
                        "type": "number"
                      },
                      {
                        "name": "uploaderId",
                        "type": "string"
                      },
                      {
                        "name": "uploaderName",
                        "type": "string"
                      },
                      {
                        "name": "folder",
                        "type": "string"
                      },
                      {
                        "name": "uploadedAt",
                        "type": "string"
                      },
                      {
                        "name": "isArchived",
                        "type": "boolean"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "StoredFileLoaded",
                "description": "Indicates a file has been successfully retrieved and is ready.",
                "synonyms": "loaded, fetched, retrieved, ready",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StoredFile]"
                  }
                ]
              },
              {
                "event": "StoredFileLoadFailed",
                "description": "Indicates a failure to load a stored file.",
                "synonyms": "error, failed, problem, unsuccessful",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "viewing_single"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "StoredFileLoaded",
                  "name": "StoredFile loaded",
                  "description": "Indicates a file has been successfully retrieved and is ready.",
                  "synonyms": "loaded, fetched, retrieved, ready",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[StoredFile]"
                    }
                  ]
                },
                {
                  "key": "StoredFileLoadFailed",
                  "name": "StoredFile load failed",
                  "description": "Indicates a failure to load a stored file.",
                  "synonyms": "error, failed, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "OPEN_FILE",
                  "name": "Open File",
                  "description": "Indicates a file has been selected for viewing.",
                  "synonyms": "select, choose, activate",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "StoredFile"
                    }
                  ]
                },
                {
                  "key": "REORDER",
                  "name": "Reorder",
                  "description": "Indicates the order of items in the tree has changed.",
                  "synonyms": "sort, rearrange, move, change order",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "StoredFile"
                    }
                  ]
                },
                {
                  "key": "ARCHIVE_FILE",
                  "name": "Archive File",
                  "description": "Signals a file is being moved to archive storage.",
                  "synonyms": "archive, move to archive, delete permanently",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "CLOSE_VIEW",
                  "name": "Close View",
                  "description": "Signals the view has been closed or dismissed.",
                  "synonyms": "dismiss, hide, close",
                  "tier": "domain"
                },
                {
                  "key": "DOWNLOAD_FILE",
                  "name": "Download File",
                  "description": "Initiates a file download process.",
                  "synonyms": "export, save, retrieve",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "StoredFile",
                      {
                        "emit": {
                          "failure": "StoredFileLoadFailed",
                          "success": "StoredFileLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Loading…",
                            "color": "muted",
                            "type": "typography",
                            "variant": "caption"
                          }
                        ],
                        "align": "center",
                        "type": "stack",
                        "className": "py-12",
                        "direction": "vertical",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "StoredFileLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "direction": "horizontal",
                            "align": "center",
                            "children": [
                              {
                                "name": "folder",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "variant": "h3",
                                "content": "Files"
                              },
                              {
                                "type": "badge",
                                "variant": "neutral",
                                "size": "sm",
                                "label": "@payload.data.length"
                              }
                            ],
                            "gap": "sm",
                            "type": "stack"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "type": "file-tree",
                            "tree": [
                              {
                                "children": [
                                  {
                                    "name": "Active.pdf",
                                    "type": "file",
                                    "path": "Active.pdf"
                                  },
                                  {
                                    "path": "Archived.pdf",
                                    "name": "Archived.pdf",
                                    "type": "file"
                                  }
                                ],
                                "path": "Contracts",
                                "type": "dir",
                                "name": "Contracts"
                              },
                              {
                                "children": [
                                  {
                                    "type": "file",
                                    "name": "HR.docx",
                                    "path": "Policies/HR.docx"
                                  },
                                  {
                                    "type": "file",
                                    "path": "Policies/Security.md",
                                    "name": "Security.md"
                                  }
                                ],
                                "path": "Policies",
                                "name": "Policies",
                                "type": "dir"
                              },
                              {
                                "children": [
                                  {
                                    "type": "file",
                                    "name": "Invoice.docx",
                                    "path": "Templates/Invoice.docx"
                                  },
                                  {
                                    "type": "file",
                                    "name": "NDA.pdf",
                                    "path": "Templates/NDA.pdf"
                                  }
                                ],
                                "path": "Templates",
                                "name": "Templates",
                                "type": "dir"
                              }
                            ]
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "gap": "sm",
                            "itemActions": [
                              {
                                "icon": "arrow-right",
                                "label": "Open",
                                "variant": "primary",
                                "event": "OPEN_FILE"
                              },
                              {
                                "event": "ARCHIVE_FILE",
                                "label": "Archive",
                                "variant": "danger"
                              }
                            ],
                            "reorderEvent": "REORDER",
                            "fields": [
                              {
                                "variant": "caption",
                                "label": "Name",
                                "name": "name"
                              },
                              {
                                "variant": "caption",
                                "name": "folder",
                                "label": "Folder"
                              },
                              {
                                "label": "Type",
                                "variant": "badge",
                                "name": "mimeType"
                              },
                              {
                                "variant": "caption",
                                "label": "Size",
                                "name": "sizeBytes"
                              },
                              {
                                "name": "uploadedAt",
                                "variant": "caption",
                                "label": "Uploaded"
                              }
                            ],
                            "look": "dense",
                            "entity": "@payload.data",
                            "type": "data-list",
                            "reorderable": false
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "StoredFileLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "alert",
                        "variant": "error",
                        "message": "@payload.error"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "viewing_single",
                  "event": "OPEN_FILE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.row.id"
                    ],
                    [
                      "set",
                      "@entity.name",
                      "@payload.row.name"
                    ],
                    [
                      "set",
                      "@entity.path",
                      "@payload.row.path"
                    ],
                    [
                      "set",
                      "@entity.folder",
                      "@payload.row.folder"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "type": "stack",
                        "children": [
                          {
                            "children": [
                              {
                                "type": "button",
                                "action": "CLOSE_VIEW",
                                "label": "Back",
                                "variant": "ghost"
                              },
                              {
                                "type": "icon",
                                "name": "folder"
                              },
                              {
                                "variant": "h3",
                                "type": "typography",
                                "content": "@entity.name"
                              }
                            ],
                            "direction": "horizontal",
                            "gap": "sm",
                            "type": "stack",
                            "align": "center"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "gap": "sm",
                            "direction": "vertical",
                            "type": "stack",
                            "children": [
                              {
                                "direction": "horizontal",
                                "type": "stack",
                                "children": [
                                  {
                                    "type": "typography",
                                    "color": "muted",
                                    "variant": "caption",
                                    "content": "Folder"
                                  },
                                  {
                                    "content": "@entity.folder",
                                    "type": "typography",
                                    "variant": "body"
                                  }
                                ],
                                "gap": "md"
                              },
                              {
                                "gap": "md",
                                "type": "stack",
                                "children": [
                                  {
                                    "content": "Path",
                                    "variant": "caption",
                                    "type": "typography",
                                    "color": "muted"
                                  },
                                  {
                                    "variant": "body",
                                    "content": "@entity.path",
                                    "type": "typography"
                                  }
                                ],
                                "direction": "horizontal"
                              }
                            ]
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "renderItem": [
                              "fn",
                              "a",
                              {
                                "actionPayload": {
                                  "id": "@entity.id"
                                },
                                "variant": "@a.variant",
                                "label": "@a.label",
                                "type": "button",
                                "action": "@a.event"
                              }
                            ],
                            "variant": "default",
                            "fields": [],
                            "type": "data-list",
                            "entity": [
                              {
                                "label": "Download",
                                "variant": "primary",
                                "event": "DOWNLOAD_FILE"
                              },
                              {
                                "label": "Archive",
                                "event": "ARCHIVE_FILE",
                                "variant": "danger"
                              }
                            ],
                            "gap": "sm"
                          }
                        ],
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "REORDER",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.row.id"
                    ],
                    [
                      "fetch",
                      "StoredFile",
                      {
                        "emit": {
                          "failure": "StoredFileLoadFailed",
                          "success": "StoredFileLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "align": "center",
                        "className": "py-12",
                        "type": "stack",
                        "gap": "md",
                        "direction": "vertical",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "color": "muted",
                            "content": "Reordering…",
                            "variant": "caption",
                            "type": "typography"
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "ARCHIVE_FILE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "fetch",
                      "StoredFile",
                      {
                        "emit": {
                          "success": "StoredFileLoaded",
                          "failure": "StoredFileLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "type": "typography",
                            "color": "muted",
                            "content": "Archiving…"
                          }
                        ],
                        "type": "stack",
                        "align": "center",
                        "className": "py-12",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "loading",
                  "event": "CLOSE_VIEW",
                  "effects": [
                    [
                      "fetch",
                      "StoredFile",
                      {
                        "emit": {
                          "failure": "StoredFileLoadFailed",
                          "success": "StoredFileLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Loading…",
                            "color": "muted",
                            "variant": "caption",
                            "type": "typography"
                          }
                        ],
                        "align": "center",
                        "direction": "vertical",
                        "className": "py-12",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "loading",
                  "event": "DOWNLOAD_FILE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "fetch",
                      "StoredFile",
                      {
                        "emit": {
                          "failure": "StoredFileLoadFailed",
                          "success": "StoredFileLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "gap": "md",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "variant": "caption",
                            "color": "muted",
                            "type": "typography",
                            "content": "Preparing…"
                          }
                        ],
                        "className": "py-12",
                        "align": "center",
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "viewing_single",
                  "to": "loading",
                  "event": "ARCHIVE_FILE",
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "fetch",
                      "StoredFile",
                      {
                        "emit": {
                          "failure": "StoredFileLoadFailed",
                          "success": "StoredFileLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "direction": "vertical",
                        "children": [
                          {
                            "type": "spinner"
                          },
                          {
                            "content": "Archiving…",
                            "variant": "caption",
                            "color": "muted",
                            "type": "typography"
                          }
                        ],
                        "className": "py-12",
                        "gap": "md",
                        "align": "center",
                        "type": "stack"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "StoredFile",
                      {
                        "emit": {
                          "success": "StoredFileLoaded",
                          "failure": "StoredFileLoadFailed"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "sm"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "tableLook": {
                "type": "string",
                "default": "dense",
                "label": "Table look",
                "description": "Layer 2 visual treatment for the data table rendered by this atom.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              },
              "headerIcon": {
                "type": "string",
                "default": "folder",
                "label": "Header icon",
                "description": "Icon shown beside the section title and in the detail header",
                "tier": "presentation"
              },
              "itemActions": {
                "type": "[ItemAction]",
                "default": [
                  {
                    "icon": "arrow-right",
                    "label": "Open",
                    "variant": "primary",
