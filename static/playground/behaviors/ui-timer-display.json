{
  "name": "ui-timer-display",
  "description": "TimerDisplay — counts down every second while running; re-renders on each tick.",
  "level": "atom",
  "topic": "ui/game/2d",
  "schema": {
    "name": "ui-timer-display",
    "version": "1.0.0",
    "description": "TimerDisplay — counts down every second while running; re-renders on each tick.",
    "orbitals": [
      {
        "name": "TimerDisplayOrbital",
        "entity": {
          "name": "TimerDisplayItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "seconds",
              "type": "number",
              "default": 90
            },
            {
              "name": "running",
              "type": "boolean",
              "default": true
            }
          ]
        },
        "traits": [
          {
            "name": "TimerDisplayRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": [
                "running",
                "seconds"
              ]
            },
            "category": "interaction",
            "linkedEntity": "TimerDisplayItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "set",
                      "@entity.seconds",
                      90
                    ],
                    [
                      "set",
                      "@entity.running",
                      true
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "timer-display",
                        "running": "@entity.running",
                        "size": "md",
                        "format": "mm:ss",
                        "lowThreshold": 0,
                        "seconds": "@entity.seconds",
                        "className": ""
                      }
                    ]
                  ]
                }
              ]
            },
            "ticks": [
              {
                "name": "timerTick",
                "interval": 1000,
                "guard": [
                  "and",
                  [
                    "==",
                    "@entity.running",
                    true
                  ],
                  [
                    ">",
                    "@entity.seconds",
                    0
                  ]
                ],
                "effects": [
                  [
                    "set",
                    "@entity.seconds",
                    [
                      "-",
                      "@entity.seconds",
                      1
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "md",
                      "type": "timer-display",
                      "format": "mm:ss",
                      "lowThreshold": 0,
                      "className": "",
                      "running": "@entity.running",
                      "seconds": "@entity.seconds"
                    }
                  ]
                ]
              }
            ],
            "config": {
              "lowThreshold": {
                "type": "number",
                "default": 0,
                "label": "Low Threshold",
                "description": "Seconds below which to pulse red",
                "tier": "presentation"
              },
              "running": {
                "type": "boolean",
                "default": true,
                "label": "Running",
                "description": "Whether the timer is running",
                "tier": "presentation"
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Size variant",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg"
                ]
              },
              "seconds": {
                "type": "number",
                "default": 90,
                "label": "Seconds",
                "description": "Time in seconds",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "format": {
                "type": "string",
                "default": "mm:ss",
                "label": "Format",
                "description": "Display format",
                "tier": "presentation",
                "values": [
                  "mm:ss",
                  "ss",
                  "countdown"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "TimerDisplayPage",
            "path": "/timer-display",
            "traits": [
              {
                "ref": "TimerDisplayRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "TimerDisplayOrbital": [
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "format",
            "knob": "format"
          },
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "lowThreshold",
            "knob": "lowThreshold"
          },
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "format",
            "knob": "format"
          },
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "lowThreshold",
            "knob": "lowThreshold"
          },
          {
            "trait": "TimerDisplayRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}