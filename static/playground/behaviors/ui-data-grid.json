{
  "name": "ui-data-grid",
  "description": "DataGrid — UI factory (1:1 with the @almadar/ui data-grid pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-data-grid",
    "version": "1.0.0",
    "description": "DataGrid — UI factory (1:1 with the @almadar/ui data-grid pattern).",
    "orbitals": [
      {
        "name": "DataGridOrbital",
        "entity": {
          "name": "DataGridItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "DataGridRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "DataGridItem",
            "emits": [
              {
                "event": "SELECTION",
                "description": "Selection change event name (emits UI:{selectionEvent} with { selectedIds: string[] })",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "LOAD_MORE",
                "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "VIEW",
                "description": "User opened a record from the list.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "DataGridLoaded",
                "description": "DataGrid rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DataGridItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "DataGridLoaded",
                  "name": "Data grid loaded",
                  "description": "DataGrid rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[DataGridItem]"
                    }
                  ]
                },
                {
                  "key": "VIEW",
                  "name": "View",
                  "description": "User opened a record from the list.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SELECTION",
                  "name": "Selection",
                  "description": "Selection change event name (emits UI:{selectionEvent} with { selectedIds: string[] })",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "LOAD_MORE",
                  "name": "Load More",
                  "description": "Event emitted when more items needed: UI:{loadMoreEvent}",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "DataGridItem",
                      {
                        "emit": {
                          "success": "DataGridLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "dragGroup": "Drag Group",
                        "error": "@config.error",
                        "type": "data-grid",
                        "className": "",
                        "positionEvent": "Position Event",
                        "pageSize": 0,
                        "entity": "@entity",
                        "imageField": "Image Field",
                        "selectable": false,
                        "itemActions": [
                          {
                            "label": "View",
                            "event": "VIEW"
                          }
                        ],
                        "fields": [
                          {
                            "icon": "circle",
                            "format": "date",
                            "label": "Label",
                            "name": "Name",
                            "variant": "h3"
                          },
                          {
                            "icon": "circle",
                            "variant": "h4",
                            "format": "currency",
                            "name": "Name 2",
                            "label": "Label 2"
                          }
                        ],
                        "accepts": "Accepts",
                        "maxInlineActions": 0,
                        "infiniteScroll": false,
                        "minCardWidth": 280,
                        "sortable": false,
                        "dndItemIdField": "Dnd Item Id Field",
                        "cols": 1,
                        "loadMoreEvent": "LOAD_MORE",
                        "selectionEvent": "SELECTION",
                        "hasMore": false,
                        "gap": "md",
                        "reorderEvent": "Reorder Event",
                        "columns": [
                          {
                            "icon": "circle",
                            "name": "Name",
                            "format": "date",
                            "label": "Label",
                            "variant": "h3"
                          },
                          {
                            "variant": "h4",
                            "label": "Label 2",
                            "icon": "circle",
                            "format": "currency",
                            "name": "Name 2"
                          }
                        ],
                        "dndRoot": false,
                        "dropEvent": "Drop Event",
                        "isLoading": false,
                        "look": "dense",
                        "scrollX": false
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "DataGridLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "error": "@config.error",
                        "cols": 1,
                        "infiniteScroll": false,
                        "reorderEvent": "Reorder Event",
                        "isLoading": false,
                        "dropEvent": "Drop Event",
                        "dragGroup": "Drag Group",
                        "className": "",
                        "gap": "md",
                        "imageField": "Image Field",
                        "itemActions": [
                          {
                            "label": "View",
                            "event": "VIEW"
                          }
                        ],
                        "loadMoreEvent": "LOAD_MORE",
                        "pageSize": 0,
                        "dndItemIdField": "Dnd Item Id Field",
                        "type": "data-grid",
                        "selectionEvent": "SELECTION",
                        "sortable": false,
                        "columns": [
                          {
                            "icon": "circle",
                            "name": "Name",
                            "format": "date",
                            "label": "Label",
                            "variant": "h3"
                          },
                          {
                            "variant": "h4",
                            "label": "Label 2",
                            "icon": "circle",
                            "format": "currency",
                            "name": "Name 2"
                          }
                        ],
                        "hasMore": false,
                        "maxInlineActions": 0,
                        "positionEvent": "Position Event",
                        "dndRoot": false,
                        "minCardWidth": 280,
                        "fields": [
                          {
                            "icon": "circle",
                            "format": "date",
                            "label": "Label",
                            "name": "Name",
                            "variant": "h3"
                          },
                          {
                            "icon": "circle",
                            "variant": "h4",
                            "format": "currency",
                            "name": "Name 2",
                            "label": "Label 2"
                          }
                        ],
                        "entity": "@payload.data",
                        "selectable": false,
                        "scrollX": false,
                        "look": "dense",
                        "accepts": "Accepts"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "VIEW",
                  "effects": [
                    [
                      "emit",
                      "VIEW",
                      {}
                    ]
                  ]
                }
              ]
            },
            "config": {
              "hasMore": {
                "type": "boolean",
                "default": false,
                "label": "Has More",
                "description": "Whether more items are available for infinite scroll",
                "tier": "presentation"
              },
              "infiniteScroll": {
                "type": "boolean",
                "default": false,
                "label": "Infinite Scroll",
                "description": "Enable infinite scroll loading",
                "tier": "presentation"
              },
              "maxInlineActions": {
                "type": "number",
                "default": 0,
                "label": "Max Inline Actions",
                "description": "Max inline primary action buttons before the rest collapse into a '⋯' overflow menu. Omit = all inline.",
                "tier": "presentation"
              },
              "dropEvent": {
                "type": "string",
                "default": "Drop Event",
                "label": "Drop Event",
                "description": "Bus event fired on cross-container drop. Payload: { id, sourceGroup, targetGroup, newIndex }",
                "tier": "presentation"
              },
              "error": {
                "type": "DataGridError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  }
                }
              },
              "accepts": {
                "type": "string",
                "default": "Accepts",
                "label": "Accepts",
                "description": "When set, the container accepts drops whose dragGroup matches this value (or '*' for any group)",
                "tier": "presentation"
              },
              "imageField": {
                "type": "string",
                "default": "Image Field",
                "label": "Image Field",
                "description": "Entity field name containing an image URL for card thumbnails",
                "tier": "presentation"
              },
              "reorderEvent": {
                "type": "string",
                "default": "Reorder Event",
                "label": "Reorder Event",
                "description": "Bus event fired on in-container reorder. Payload: { id, oldIndex, newIndex }",
                "tier": "presentation"
              },
              "selectable": {
                "type": "boolean",
                "default": false,
                "label": "Selectable",
                "description": "Enable multi-select with checkboxes",
                "tier": "presentation"
              },
              "dndRoot": {
                "type": "boolean",
                "default": false,
                "label": "Dnd Root",
                "description": "Mark this container as the DnD root for its subtree — descendant zones share one DndContext (cross-container drag). Use on an outer container whose own items are not draggable.",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state",
                "tier": "presentation"
              },
              "columns": {
                "type": "[DataGridColumnsItem]",
                "default": [
                  {
                    "icon": "circle",
                    "name": "Name",
                    "format": "date",
                    "label": "Label",
                    "variant": "h3"
                  },
                  {
                    "variant": "h4",
                    "label": "Label 2",
                    "icon": "circle",
                    "format": "currency",
                    "name": "Name 2"
                  }
                ],
                "label": "Columns",
                "description": "Alias for `fields` — the compiler emits `columns` for field defs.",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    },
                    "colorMap": {
                      "name": "colorMap",
                      "type": "object",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "format": {
                      "name": "format",
                      "type": "string",
                      "required": false,
                      "values": [
                        "date",
                        "currency",
                        "number",
                        "boolean",
                        "percent"
                      ]
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "h3",
                        "h4",
                        "body",
                        "caption",
                        "badge",
                        "small",
                        "progress"
                      ]
                    }
                  }
                }
              },
              "dragGroup": {
                "type": "string",
                "default": "Drag Group",
                "label": "Drag Group",
                "description": "When set, items in this container are draggable and announce this group as their source",
                "tier": "presentation"
              },
              "gap": {
                "type": "string",
                "default": "md",
                "label": "Gap",
                "description": "Gap between cards",
                "tier": "presentation",
                "values": [
                  "none",
                  "sm",
                  "md",
                  "lg",
                  "xl"
                ]
              },
              "minCardWidth": {
                "type": "number",
                "default": 280,
                "label": "Min Card Width",
                "description": "Minimum card width in pixels (used when cols is not set, default 280)",
                "tier": "presentation"
              },
              "fields": {
                "type": "[DataGridFieldsItem]",
                "default": [
                  {
                    "icon": "circle",
                    "format": "date",
                    "label": "Label",
                    "name": "Name",
                    "variant": "h3"
                  },
                  {
                    "icon": "circle",
                    "variant": "h4",
                    "format": "currency",
                    "name": "Name 2",
                    "label": "Label 2"
                  }
                ],
                "label": "Fields",
                "description": "Field definitions for rendering each card. The pattern contract in `@almadar/patterns` documents `columns` as the wire-format alias the compiler emits — both names resolve to the same shape here. Pass either.",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "format": {
                      "name": "format",
                      "type": "string",
                      "required": false,
                      "values": [
                        "date",
                        "currency",
                        "number",
                        "boolean",
                        "percent"
                      ]
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "colorMap": {
                      "name": "colorMap",
                      "type": "object",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "h3",
                        "h4",
                        "body",
                        "caption",
                        "badge",
                        "small",
                        "progress"
                      ]
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "sortable": {
                "type": "boolean",
                "default": false,
                "label": "Sortable",
                "description": "Enable in-container reorder; items can be dragged to new positions among siblings",
                "tier": "presentation"
              },
              "look": {
                "type": "string",
                "default": "dense",
                "label": "Look",
                "description": "Layer 2 visual treatment — mirrors the `entity-table` look enum so data-grid / data-list / entity-table share one knob name from authors.",
                "tier": "presentation",
                "values": [
                  "dense",
                  "spacious",
                  "striped",
                  "borderless",
                  "card-rows"
                ]
              },
              "itemActions": {
                "type": "[DataGridItemActionsItem]",
                "default": [],
                "label": "Item Actions",
                "description": "Per-item action buttons",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost",
                        "danger"
                      ]
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": true
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "positionEvent": {
                "type": "string",
                "default": "Position Event",
                "label": "Position Event",
                "description": "Bus event fired N times per drop (one per item in affected zones) so the trait can persist new positions for the WHOLE zone, not just the moved item. Payload: { id, position }",
                "tier": "presentation"
              },
              "scrollX": {
                "type": "boolean",
                "default": false,
                "label": "Scroll X",
                "description": "Lay items in a single horizontally-scrolling row (kanban columns) sized to `minCardWidth` instead of a wrapping grid.",
                "tier": "presentation"
              },
              "pageSize": {
                "type": "number",
                "default": 0,
                "label": "Page Size",
                "description": "Max items to show before 'Show More' button. Defaults to 0 (disabled).",
                "tier": "presentation"
              },
              "cols": {
                "type": "number",
                "default": 1,
                "label": "Cols",
                "description": "Number of columns (uses auto-fit if omitted)",
                "tier": "presentation"
              },
              "dndItemIdField": {
                "type": "string",
                "default": "Dnd Item Id Field",
                "label": "Dnd Item Id Field",
                "description": "Row field used as the @dnd-kit draggable id (default 'id')",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "DataGridPage",
            "path": "/data-grid",
            "traits": [
              {
                "ref": "DataGridRender"
              }
            ]
          }
        ]
      }
    ],
