{
  "name": "ui-progress-bar",
  "description": "ProgressBar — UI factory (1:1 with the @almadar/ui progress-bar pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-progress-bar",
    "version": "1.0.0",
    "description": "ProgressBar — UI factory (1:1 with the @almadar/ui progress-bar pattern).",
    "orbitals": [
      {
        "name": "ProgressBarOrbital",
        "entity": {
          "name": "ProgressBarItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ProgressBarRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ProgressBarItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "color": "default",
                        "progressType": "linear",
                        "type": "progress-bar",
                        "showLabel": false,
                        "showPercentage": false,
                        "steps": 5,
                        "value": 1,
                        "label": "Label",
                        "max": 100,
                        "size": "md",
                        "className": "",
                        "variant": "primary"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Size (for circular variant)",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg"
                ]
              },
              "label": {
                "type": "string",
                "default": "Label",
                "label": "Label",
                "description": "Label text",
                "tier": "presentation"
              },
              "max": {
                "type": "number",
                "default": 100,
                "label": "Max",
                "description": "Maximum value (for calculating percentage)",
                "tier": "presentation"
              },
              "showLabel": {
                "type": "boolean",
                "default": false,
                "label": "Show Label",
                "description": "Alias for showPercentage (pattern compatibility)",
                "tier": "presentation"
              },
              "showPercentage": {
                "type": "boolean",
                "default": false,
                "label": "Show Percentage",
                "description": "Show percentage text",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "primary",
                "label": "Variant",
                "description": "Variant/color of the progress bar",
                "tier": "presentation",
                "values": [
                  "default",
                  "primary",
                  "success",
                  "warning",
                  "error",
                  "danger"
                ]
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "color": {
                "type": "string",
                "default": "default",
                "label": "Color",
                "description": "Color variant (alias for variant)",
                "tier": "presentation",
                "values": [
                  "default",
                  "primary",
                  "success",
                  "warning",
                  "error",
                  "danger"
                ]
              },
              "progressType": {
                "type": "string",
                "default": "linear",
                "label": "Progress Type",
                "description": "Type of the progress bar (linear, circular, stepped)",
                "tier": "presentation",
                "values": [
                  "linear",
                  "circular",
                  "stepped"
                ]
              },
              "steps": {
                "type": "number",
                "default": 5,
                "label": "Steps",
                "description": "Number of steps (for stepped variant)",
                "tier": "presentation"
              },
              "value": {
                "type": "number",
                "default": 1,
                "label": "Value",
                "description": "Progress value (0-100)",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ProgressBarPage",
            "path": "/progress-bar",
            "traits": [
              {
                "ref": "ProgressBarRender"
              }
            ]
          }
        ]
      }
