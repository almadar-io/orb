{
  "name": "std-hero-banner",
  "description": "Hero marquee — eyebrow + headline + lead + primary CTA, centered in an elevated card. Above-the-fold landing surface. Standalone atom; fetches one HeroPromo record and renders inline.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-hero-banner",
    "version": "1.0.0",
    "description": "Hero marquee — eyebrow + headline + lead + primary CTA, centered in an elevated card. Above-the-fold landing surface. Standalone atom; fetches one HeroPromo record and renders inline.",
    "orbitals": [
      {
        "name": "HeroBannerOrbital",
        "entity": {
          "name": "HeroPromo",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "eyebrow",
              "type": "string",
              "default": "Announcing",
              "description": "A short introductory text or tagline.",
              "synonyms": "subtitle, teaser, prefix"
            },
            {
              "name": "headline",
              "type": "string",
              "required": true,
              "default": "Headline",
              "description": "The main title or heading for a promotional message.",
              "synonyms": "title, heading, main text"
            },
            {
              "name": "lead",
              "type": "string",
              "default": "",
              "description": "The main descriptive text for the component.",
              "synonyms": "body, content, text"
            },
            {
              "name": "ctaLabel",
              "type": "string",
              "default": "Get started",
              "description": "Text for the call to action button.",
              "synonyms": "button text, action label, call to action"
            },
            {
              "name": "ctaEvent",
              "type": "string",
              "default": "PRIMARY_CTA",
              "description": "The event triggered when the call to action is activated.",
              "synonyms": "event, action, trigger"
            },
            {
              "name": "errorMessage",
              "type": "string",
              "default": "",
              "description": "Error message to display if data retrieval fails.",
              "synonyms": "error, alert, message"
            }
          ]
        },
        "traits": [
          {
            "name": "HeroBanner",
            "category": "interaction",
            "linkedEntity": "HeroPromo",
            "emits": [
              {
                "event": "PRIMARY_CTA",
                "description": "Signals that the primary call to action has been triggered.",
                "synonyms": "click, activate, submit, trigger",
                "tier": "domain"
              },
              {
                "event": "HeroPromoLoaded",
                "description": "Signals successful loading of the hero promotion data.",
                "synonyms": "loaded, fetched, received, ready",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  }
                ]
              },
              {
                "event": "HeroPromoLoadFailed",
                "description": "Indicates failure to load the hero promotion data.",
                "synonyms": "error, failed, load error",
                "tier": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "ready"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "HeroPromoLoaded",
                  "name": "HeroPromo loaded",
                  "description": "Signals successful loading of the hero promotion data.",
                  "synonyms": "loaded, fetched, received, ready",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[object]"
                    }
                  ]
                },
                {
                  "key": "HeroPromoLoadFailed",
                  "name": "HeroPromo load failed",
                  "description": "Indicates failure to load the hero promotion data.",
                  "synonyms": "error, failed, load error",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "PRIMARY_CTA",
                  "name": "Primary Cta",
                  "description": "Signals that the primary call to action has been triggered.",
                  "synonyms": "click, activate, submit, trigger",
                  "tier": "domain"
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "HeroPromo",
                      {
                        "emit": {
                          "failure": "HeroPromoLoadFailed",
                          "success": "HeroPromoLoaded"
                        },
                        "limit": 1
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "title": "Loading…",
                        "type": "loading-state"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "ready",
                  "event": "HeroPromoLoaded",
                  "effects": [
                    [
                      "set",
                      "@entity.eyebrow",
                      [
                        "object/get",
                        [
                          "array/first",
                          "@payload.data"
                        ],
                        "eyebrow"
                      ]
                    ],
                    [
                      "set",
                      "@entity.headline",
                      [
                        "object/get",
                        [
                          "array/first",
                          "@payload.data"
                        ],
                        "headline"
                      ]
                    ],
                    [
                      "set",
                      "@entity.lead",
                      [
                        "object/get",
                        [
                          "array/first",
                          "@payload.data"
                        ],
                        "lead"
                      ]
                    ],
                    [
                      "set",
                      "@entity.ctaLabel",
                      [
                        "object/get",
                        [
                          "array/first",
                          "@payload.data"
                        ],
                        "ctaLabel"
                      ]
                    ],
                    [
                      "set",
                      "@entity.ctaEvent",
                      [
                        "object/get",
                        [
                          "array/first",
                          "@payload.data"
                        ],
                        "ctaEvent"
                      ]
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "padding": "lg",
                        "type": "card",
                        "children": [
                          {
                            "type": "stack",
                            "direction": "vertical",
                            "align": "center",
                            "children": [
                              {
                                "variant": "neutral",
                                "label": "@entity.eyebrow",
                                "type": "badge",
                                "size": "sm"
                              },
                              {
                                "content": "@entity.headline",
                                "type": "typography",
                                "variant": "h1",
                                "weight": "bold"
                              },
                              {
                                "color": "muted",
                                "type": "typography",
                                "content": "@entity.lead",
                                "variant": "body"
                              },
                              {
                                "action": "@entity.ctaEvent",
                                "label": "@entity.ctaLabel",
                                "size": "lg",
                                "variant": "primary",
                                "type": "button"
                              }
                            ],
                            "gap": "lg"
                          }
                        ],
                        "look": "elevated"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "HeroPromoLoadFailed",
                  "effects": [
                    [
                      "set",
                      "@entity.errorMessage",
                      "@payload.error"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "message": "@entity.errorMessage",
                        "title": "Failed to load hero",
                        "type": "error-state"
                      }
                    ]
                  ]
                },
                {
                  "from": "ready",
                  "to": "ready",
                  "event": "PRIMARY_CTA"
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "title": "Retrying…",
                        "type": "loading-state"
                      }
                    ]
                  ]
                }
              ]
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "HeroBannerPage",
            "path": "/hero-banner",
            "traits": [
              {
                "ref": "HeroBanner"
              }
            ]
          }
        ]
      }
    ]
  },
  "source": "",
  "lolo": ""
}