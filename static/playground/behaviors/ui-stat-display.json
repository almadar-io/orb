            "knob": "iconBg"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "trendPolarity",
            "knob": "trendPolarity"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "iconColor",
            "knob": "iconColor"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
