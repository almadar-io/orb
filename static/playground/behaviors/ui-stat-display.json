            "knob": "format"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "max",
            "knob": "max"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "suffix",
            "knob": "suffix"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "sparklineData",
            "knob": "sparklineData"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "prefix",
            "knob": "prefix"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "icon",
            "knob": "icon"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "target",
            "knob": "target"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "look",
            "knob": "look"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "trend",
            "knob": "trend"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "label",
            "knob": "label"
          },
          {
            "trait": "StatDisplayRender",
            "patternPath": "root",
            "prop": "size",
            "knob": "size"
          },
          {
            "trait": "StatDisplayRender",
