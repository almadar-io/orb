{
  "name": "ui-lightbox",
  "description": "Lightbox — UI factory (1:1 with the @almadar/ui lightbox pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-lightbox",
    "version": "1.0.0",
    "description": "Lightbox — UI factory (1:1 with the @almadar/ui lightbox pattern).",
    "orbitals": [
      {
        "name": "LightboxOrbital",
        "entity": {
          "name": "LightboxItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "LightboxRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "LightboxItem",
            "emits": [
              {
                "event": "CLOSE",
                "description": "Direct onClose callback",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "INDEX_CHANGE",
                "description": "Direct onIndexChange callback",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "index",
                    "type": "number"
                  }
                ]
              },
              {
                "event": "OPEN",
                "description": "Open the Lightbox.",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "closed",
                  "isInitial": true
                },
                {
                  "name": "open"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "OPEN",
                  "name": "Open",
                  "description": "Open the Lightbox.",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "Direct onClose callback",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "INDEX_CHANGE",
                  "name": "Index Change",
                  "description": "Direct onIndexChange callback",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "index",
                      "type": "number"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "closed",
                  "to": "closed",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "button",
                        "label": "Open Lightbox",
                        "action": "OPEN"
                      }
                    ]
                  ]
                },
                {
                  "from": "closed",
                  "to": "open",
                  "event": "OPEN",
                  "effects": [
                    [
                      "render-ui",
                      "overlay",
                      {
                        "className": "",
                        "currentIndex": 0,
                        "showCounter": true,
                        "type": "lightbox",
                        "closeAction": "Close Action",
                        "isOpen": false,
                        "images": [
                          {
                            "caption": "Caption",
                            "alt": "Alt",
                            "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                          },
                          {
                            "alt": "Alt 2",
                            "caption": "Caption 2",
                            "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                          }
                        ],
                        "onClose": "CLOSE",
                        "onIndexChange": "INDEX_CHANGE"
                      }
                    ]
                  ]
                },
                {
                  "from": "open",
                  "to": "closed",
                  "event": "CLOSE",
                  "effects": [
                    [
                      "render-ui",
                      "overlay",
                      null
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "button",
                        "action": "OPEN",
                        "label": "Open Lightbox"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "currentIndex": {
                "type": "number",
                "default": 0,
                "label": "Current Index",
                "description": "Current image index",
                "tier": "presentation"
              },
              "showCounter": {
                "type": "boolean",
                "default": true,
                "label": "Show Counter",
                "description": "Show image counter (e.g., '3 of 12')",
                "tier": "presentation"
              },
              "isOpen": {
                "type": "boolean",
                "default": false,
                "label": "Is Open",
                "description": "Whether the lightbox is open",
                "tier": "presentation"
              },
              "images": {
                "type": "[LightboxImagesItem]",
                "default": [
                  {
                    "caption": "Caption",
                    "alt": "Alt",
                    "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  },
                  {
                    "alt": "Alt 2",
                    "caption": "Caption 2",
                    "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png"
                  }
                ],
                "label": "Images",
                "description": "Array of images to display",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "src": {
                      "name": "src",
                      "type": "string",
                      "required": false
                    },
                    "alt": {
                      "name": "alt",
                      "type": "string",
                      "required": false
                    },
                    "caption": {
                      "name": "caption",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "closeAction": {
                "type": "string",
                "default": "Close Action",
                "label": "Close Action",
                "description": "Declarative close event name",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "LightboxPage",
            "path": "/lightbox",
            "traits": [
              {
                "ref": "LightboxRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "LightboxOrbital": [
          {
            "trait": "LightboxRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "LightboxRender",
            "patternPath": "root",
            "prop": "currentIndex",
            "knob": "currentIndex"
          },
          {
            "trait": "LightboxRender",
            "patternPath": "root",
            "prop": "showCounter",
            "knob": "showCounter"
          },
          {
            "trait": "LightboxRender",
            "patternPath": "root",
            "prop": "closeAction",
            "knob": "closeAction"
          },
          {
            "trait": "LightboxRender",
            "patternPath": "root",
            "prop": "isOpen",
            "knob": "isOpen"
          },
          {
            "trait": "LightboxRender",
            "patternPath": "root",
            "prop": "images",
            "knob": "images"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}