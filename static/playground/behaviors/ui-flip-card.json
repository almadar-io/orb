{
  "name": "ui-flip-card",
  "description": "FlipCard — UI factory (1:1 with the @almadar/ui flip-card pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-flip-card",
    "version": "1.0.0",
    "description": "FlipCard — UI factory (1:1 with the @almadar/ui flip-card pattern).",
    "orbitals": [
      {
        "name": "FlipCardOrbital",
        "entity": {
          "name": "FlipCardItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "FlipCardRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "FlipCardItem",
            "emits": [
              {
                "event": "FLIP",
                "description": "Callback when the card is clicked to flip",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "FLIP",
                  "name": "Flip",
                  "description": "Callback when the card is clicked to flip",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "height": "h-64",
                        "type": "flip-card",
                        "flipped": false,
                        "onFlip": "FLIP",
                        "back": [
                          {
                            "content": "Back",
                            "type": "typography"
                          }
                        ],
                        "className": "",
                        "front": [
                          {
                            "content": "Front",
                            "type": "typography"
                          }
                        ]
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "flipped": {
                "type": "boolean",
                "default": false,
                "label": "Flipped",
                "description": "Controlled flip state",
                "tier": "presentation"
              },
              "height": {
                "type": "string",
                "default": "h-64",
                "label": "Height",
                "description": "Card height as a Tailwind class (default: 'h-64')",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Optional className for the outer container",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "FlipCardPage",
            "path": "/flip-card",
            "traits": [
              {
                "ref": "FlipCardRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "FlipCardOrbital": [
          {
            "trait": "FlipCardRender",
            "patternPath": "root",
            "prop": "height",
            "knob": "height"
          },
          {
            "trait": "FlipCardRender",
            "patternPath": "root",
            "prop": "flipped",
            "knob": "flipped"
          },
          {
            "trait": "FlipCardRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}