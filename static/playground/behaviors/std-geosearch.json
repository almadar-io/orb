{
  "name": "std-geosearch",
  "description": "std-geosearch — location-aware search variant: search-input + map-view + range-slider for radius. Owns a GeoSearchResult runtime entity; GEO_SEARCH persists @payload.searchTerm/lat/lng/radiusKm so cross-trait listeners can route them into geo-aware data atoms.",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-geosearch",
    "version": "1.0.0",
    "description": "std-geosearch — location-aware search variant: search-input + map-view + range-slider for radius. Owns a GeoSearchResult runtime entity; GEO_SEARCH persists @payload.searchTerm/lat/lng/radiusKm so cross-trait listeners can route them into geo-aware data atoms.",
    "orbitals": [
      {
        "name": "GeoSearchResultOrbital",
        "entity": {
          "name": "GeoSearchResult",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "searchTerm",
              "type": "string",
              "description": "The user's search query string.",
              "synonyms": "query, text, input"
            },
            {
              "name": "centerLat",
              "type": "number",
              "description": "Latitude coordinate of the search center.",
              "synonyms": "lat, y, north"
            },
            {
              "name": "centerLng",
              "type": "number",
              "description": "The longitude coordinate of the search center.",
              "synonyms": "longitude, lng"
            },
            {
              "name": "radiusKm",
              "type": "number",
              "default": 10,
              "description": "The search radius in kilometers.",
              "synonyms": "range, distance, extent"
            },
            {
              "name": "boundsNorth",
              "type": "number",
              "description": "Northern boundary coordinate of the search area.",
              "synonyms": "north, upper, top"
            },
            {
              "name": "boundsSouth",
              "type": "number",
              "description": "Southern boundary coordinate of the search area.",
              "synonyms": "south, bottom, lowerBoundary"
            },
            {
              "name": "boundsEast",
              "type": "number",
              "description": "The eastern boundary coordinate of the search area.",
              "synonyms": "east, right, longitude"
            },
            {
              "name": "boundsWest",
              "type": "number",
              "description": "Western boundary coordinate of the search area.",
              "synonyms": "west, longitude, x"
            }
          ]
        },
        "traits": [
          {
            "name": "GeoSearchResultSearch",
            "category": "interaction",
            "linkedEntity": "GeoSearchResult",
            "emits": [
              {
                "event": "GEO_SEARCH",
                "description": "Indicates a search request with location parameters.",
                "synonyms": "search, locate, find, query",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "lat",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "lng",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "radiusKm",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "GEO_SEARCH",
                  "name": "Geo Search",
                  "description": "Indicates a search request with location parameters.",
                  "synonyms": "search, locate, find, query",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "searchTerm",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "lat",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "lng",
                      "type": "number",
                      "required": true
                    },
                    {
                      "name": "radiusKm",
                      "type": "number",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "event": "GEO_SEARCH",
                            "placeholder": "Search nearby…",
                            "type": "search-input"
                          },
                          {
                            "zoom": 12,
                            "type": "map-view",
                            "height": "240px",
                            "centerLat": "@entity.centerLat",
                            "centerLng": "@entity.centerLng",
                            "markers": []
                          },
                          {
                            "showTooltip": true,
                            "type": "range-slider",
                            "value": "@entity.radiusKm",
                            "action": "GEO_SEARCH",
                            "max": 100,
                            "min": 1,
                            "step": 1
                          }
                        ],
                        "gap": "md",
                        "type": "stack",
                        "direction": "vertical"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "GEO_SEARCH",
                  "effects": [
                    [
                      "set",
                      "@entity.searchTerm",
                      "@payload.searchTerm"
                    ],
                    [
                      "set",
                      "@entity.centerLat",
                      "@payload.lat"
                    ],
                    [
                      "set",
                      "@entity.centerLng",
                      "@payload.lng"
                    ],
                    [
                      "set",
                      "@entity.radiusKm",
                      "@payload.radiusKm"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "children": [
                          {
                            "event": "GEO_SEARCH",
                            "type": "search-input",
                            "placeholder": "Search nearby…"
                          },
                          {
                            "centerLng": "@entity.centerLng",
                            "zoom": 12,
                            "markers": [],
                            "height": "240px",
                            "type": "map-view",
                            "centerLat": "@entity.centerLat"
                          },
                          {
                            "min": 1,
                            "action": "GEO_SEARCH",
                            "max": 100,
                            "showTooltip": true,
                            "step": 1,
                            "type": "range-slider",
                            "value": "@entity.radiusKm"
                          }
                        ],
                        "type": "stack",
                        "direction": "vertical",
                        "gap": "md"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "defaultRadiusKm": {
                "type": "number",
                "default": 10,
                "label": "Default radius (km)",
                "description": "Initial search radius around the chosen center",
                "tier": "presentation"
              },
              "event": {
                "type": "string",
                "default": "GEO_SEARCH",
                "label": "Search event",
                "description": "Event emitted when the user runs a geo search",
                "tier": "internal"
              },
              "placeholder": {
                "type": "string",
                "default": "Search nearby…",
                "label": "Search placeholder",
                "description": "Hint text in the location search input",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "GeoSearchResultSearchPage",
            "path": "/geosearchresults/search",
            "traits": [
              {
                "ref": "GeoSearchResultSearch"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "GeoSearchResultOrbital": [
          {
            "trait": "GeoSearchResultSearch",
            "patternPath": "root.children.0",
            "prop": "event",
            "knob": "event"
          },
          {
            "trait": "GeoSearchResultSearch",
            "patternPath": "root.children.0",
            "prop": "placeholder",
            "knob": "placeholder"
          },
          {
            "trait": "GeoSearchResultSearch",
            "patternPath": "root.children.0",
            "prop": "event",
            "knob": "event"
          },
          {
            "trait": "GeoSearchResultSearch",
            "patternPath": "root.children.0",
            "prop": "placeholder",
            "knob": "placeholder"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}