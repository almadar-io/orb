{
  "name": "ui-header",
  "description": "Header — UI factory (1:1 with the @almadar/ui header pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-header",
    "version": "1.0.0",
    "description": "Header — UI factory (1:1 with the @almadar/ui header pattern).",
    "orbitals": [
      {
        "name": "HeaderOrbital",
        "entity": {
          "name": "HeaderItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "HeaderRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "HeaderItem",
            "emits": [
              {
                "event": "MENU_TOGGLE",
                "description": "Menu toggle callback",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "SEARCH",
                "description": "Search callback",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "USER_CLICK",
                "description": "Callback when user avatar is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "LOGO_CLICK",
                "description": "Callback when logo/brand is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "MENU_TOGGLE",
                  "name": "Menu Toggle",
                  "description": "Menu toggle callback",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SEARCH",
                  "name": "Search",
                  "description": "Search callback",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "value",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "USER_CLICK",
                  "name": "User Click",
                  "description": "Callback when user avatar is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "LOGO_CLICK",
                  "name": "Logo Click",
                  "description": "Callback when logo/brand is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "showMenuToggle": true,
                        "logo": [
                          {
                            "type": "typography",
                            "content": "Logo"
                          }
                        ],
                        "className": "",
                        "navigationItems": [
                          {
                            "label": "Label",
                            "href": "Href",
                            "icon": "circle",
                            "active": false,
                            "badge": "Badge"
                          },
                          {
                            "label": "Label 2",
                            "href": "Href 2",
                            "icon": "circle",
                            "badge": "Badge 2",
                            "active": true
                          }
                        ],
                        "onSearch": "SEARCH",
                        "userAvatar": {
                          "initials": "Initials",
                          "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                          "alt": "Alt"
                        },
                        "error": "@config.error",
                        "showSearch": false,
                        "onMenuToggle": "MENU_TOGGLE",
                        "isLoading": false,
                        "actions": "@config.actions",
                        "brandName": "KFlow",
                        "type": "header",
                        "look": "compact-bar",
                        "onLogoClick": "LOGO_CLICK",
                        "logoSrc": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                        "searchPlaceholder": "Search Placeholder",
                        "isMenuOpen": false,
                        "userName": "User Name",
                        "sticky": true,
                        "variant": "mobile",
                        "onUserClick": "USER_CLICK"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "userAvatar": {
                "type": "HeaderUserAvatar",
                "default": {
                  "initials": "Initials",
                  "src": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                  "alt": "Alt"
                },
                "label": "User Avatar",
                "description": "User avatar configuration",
                "tier": "presentation",
                "properties": {
                  "alt": {
                    "name": "alt",
                    "type": "string",
                    "required": false
                  },
                  "initials": {
                    "name": "initials",
                    "type": "string",
                    "required": false
                  },
                  "src": {
                    "name": "src",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "showMenuToggle": {
                "type": "boolean",
                "default": true,
                "label": "Show Menu Toggle",
                "description": "Show menu toggle button",
                "tier": "presentation"
              },
              "logoSrc": {
                "type": "asset",
                "default": "https://almadar-kflow-assets.web.app/shared/ui-roguelike-board/default/units/player.png",
                "label": "Logo Src",
                "description": "Logo image source",
                "tier": "presentation"
              },
              "brandName": {
                "type": "string",
                "default": "KFlow",
                "label": "Brand Name",
                "description": "Brand/App name",
                "tier": "presentation"
              },
              "look": {
                "type": "string",
                "default": "compact-bar",
                "label": "Look",
                "description": "Layer 2 visual treatment — orthogonal to the structural variant (which currently flips mobile vs desktop).",
                "tier": "presentation",
                "values": [
                  "hero",
                  "compact-bar",
                  "breadcrumb",
                  "contextual",
                  "editorial-banner"
                ]
              },
              "showSearch": {
                "type": "boolean",
                "default": false,
                "label": "Show Search",
                "description": "Show search input",
                "tier": "presentation"
              },
              "searchPlaceholder": {
                "type": "string",
                "default": "Search Placeholder",
                "label": "Search Placeholder",
                "description": "Search placeholder",
                "tier": "presentation"
              },
              "sticky": {
                "type": "boolean",
                "default": true,
                "label": "Sticky",
                "description": "Sticky header",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator (closed circuit)",
                "tier": "presentation"
              },
              "isMenuOpen": {
                "type": "boolean",
                "default": false,
                "label": "Is Menu Open",
                "description": "Is menu open (for toggle icon)",
                "tier": "presentation"
              },
              "actions": {
                "type": "node",
                "label": "Actions",
                "description": "Action buttons (right side)",
                "tier": "presentation"
              },
              "error": {
                "type": "HeaderError",
                "label": "Error",
                "description": "Error state (closed circuit)",
                "tier": "presentation",
                "properties": {
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "navigationItems": {
                "type": "[HeaderNavigationItemsItem]",
                "default": [
                  {
                    "label": "Label",
                    "href": "Href",
                    "icon": "circle",
                    "active": false,
                    "badge": "Badge"
                  },
                  {
                    "label": "Label 2",
                    "href": "Href 2",
                    "icon": "circle",
                    "badge": "Badge 2",
                    "active": true
                  }
                ],
                "label": "Navigation Items",
                "description": "Navigation items (for desktop header variant)",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "badge": {
                      "name": "badge",
                      "type": "string",
                      "required": false
                    },
                    "href": {
                      "name": "href",
                      "type": "string",
                      "required": false
                    },
                    "active": {
                      "name": "active",
                      "type": "boolean",
                      "required": false
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "userName": {
                "type": "string",
                "default": "User Name",
                "label": "User Name",
                "description": "User name (display name or email)",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "mobile",
                "label": "Variant",
                "description": "Variant - mobile shows menu toggle, desktop shows full nav",
                "tier": "presentation",
                "values": [
                  "mobile",
                  "desktop"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "HeaderPage",
            "path": "/header",
            "traits": [
              {
                "ref": "HeaderRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "HeaderOrbital": [
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "showMenuToggle",
            "knob": "showMenuToggle"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "navigationItems",
            "knob": "navigationItems"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "userAvatar",
            "knob": "userAvatar"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "showSearch",
            "knob": "showSearch"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "brandName",
            "knob": "brandName"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "look",
            "knob": "look"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "logoSrc",
            "knob": "logoSrc"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "searchPlaceholder",
            "knob": "searchPlaceholder"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "isMenuOpen",
            "knob": "isMenuOpen"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "userName",
            "knob": "userName"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "sticky",
            "knob": "sticky"
          },
          {
            "trait": "HeaderRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}