{
  "name": "ui-flex",
  "description": "Flex — UI factory (1:1 with the @almadar/ui flex pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-flex",
    "version": "1.0.0",
    "description": "Flex — UI factory (1:1 with the @almadar/ui flex pattern).",
    "orbitals": [
      {
        "name": "FlexOrbital",
        "entity": {
          "name": "FlexItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "FlexRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "FlexItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "inline": false,
                        "gap": "none",
                        "className": "",
                        "align": "stretch",
                        "grow": 0,
                        "type": "flex",
                        "wrap": "nowrap",
                        "basis": "Basis",
                        "children": [
                          {
                            "type": "typography",
                            "content": "Sample content"
                          }
                        ],
                        "justify": "start",
                        "shrink": 0,
                        "direction": "row"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "wrap": {
                "type": "string",
                "default": "nowrap",
                "label": "Wrap",
                "description": "Flex wrap",
                "tier": "presentation",
                "values": [
                  "nowrap",
                  "wrap",
                  "wrap-reverse"
                ]
              },
              "justify": {
                "type": "string",
                "default": "start",
                "label": "Justify",
                "description": "Justify content",
                "tier": "presentation",
                "values": [
                  "start",
                  "center",
                  "end",
                  "between",
                  "around",
                  "evenly"
                ]
              },
              "align": {
                "type": "string",
                "default": "stretch",
                "label": "Align",
                "description": "Align items",
                "tier": "presentation",
                "values": [
                  "start",
                  "center",
                  "end",
                  "stretch",
                  "baseline"
                ]
              },
              "direction": {
                "type": "string",
                "default": "row",
                "label": "Direction",
                "description": "Flex direction",
                "tier": "presentation",
                "values": [
                  "row",
                  "row-reverse",
                  "col",
                  "col-reverse"
                ]
              },
              "gap": {
                "type": "string",
                "default": "none",
                "label": "Gap",
                "description": "Gap between items",
                "tier": "presentation",
                "values": [
                  "none",
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                  "2xl"
                ]
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Custom class name",
                "tier": "presentation"
              },
              "grow": {
                "type": "number",
                "default": 0,
                "label": "Grow",
                "description": "Flex grow",
                "tier": "presentation"
              },
              "inline": {
                "type": "boolean",
                "default": false,
                "label": "Inline",
                "description": "Inline flex",
                "tier": "presentation"
              },
              "shrink": {
                "type": "number",
                "default": 0,
                "label": "Shrink",
                "description": "Flex shrink",
                "tier": "presentation"
              },
              "basis": {
                "type": "string",
                "default": "Basis",
                "label": "Basis",
                "description": "Flex basis",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "FlexPage",
            "path": "/flex",
            "traits": [
              {
                "ref": "FlexRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "FlexOrbital": [
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "inline",
            "knob": "inline"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "gap",
            "knob": "gap"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "align",
            "knob": "align"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "grow",
            "knob": "grow"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "wrap",
            "knob": "wrap"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "basis",
            "knob": "basis"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "justify",
            "knob": "justify"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "shrink",
            "knob": "shrink"
          },
          {
            "trait": "FlexRender",
            "patternPath": "root",
            "prop": "direction",
            "knob": "direction"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}