{
  "name": "std-browse-map",
  "description": "Map browse — geo pin map: rows with lat/lng render as markers on a map-view, with a compact list beneath. For fleet vehicles, field technicians, store locations, delivery routes — anything with coordinates. Same BrowseItemBrowse trait + state machine as std-browse; only the bodyContent differs (a map instead of a grid).",
  "level": "atom",
  "topic": "core-variations",
  "schema": {
    "name": "std-browse-map",
    "version": "1.0.0",
    "description": "Map browse — geo pin map: rows with lat/lng render as markers on a map-view, with a compact list beneath. For fleet vehicles, field technicians, store locations, delivery routes — anything with coordinates. Same BrowseItemBrowse trait + state machine as std-browse; only the bodyContent differs (a map instead of a grid).",
    "orbitals": [
      {
        "name": "MapBrowseOrbital",
        "uses": [
          {
            "from": "std/behaviors/std-browse",
            "as": "Browse"
          }
        ],
        "entity": {
          "name": "MapRow",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "name",
              "type": "string",
              "required": true,
              "description": "A descriptive label for the row.",
              "synonyms": "title, label, identifier"
            },
            {
              "name": "status",
              "type": "string",
              "default": "active",
              "values": [
                "active",
                "inactive",
                "pending"
              ],
              "description": "Indicates the current operational state of the row.",
              "synonyms": "state, condition, enabled, disabled"
            },
            {
              "name": "lat",
              "type": "number",
              "default": 0,
              "description": "Represents the latitude coordinate.",
              "synonyms": "latitude, y-coordinate, north-south position"
            },
            {
              "name": "lng",
              "type": "number",
              "default": 0,
              "description": "The longitude coordinate of a location.",
              "synonyms": "longitude, x, horizontal position"
            },
            {
              "name": "address",
              "type": "string",
              "default": "",
              "description": "The textual location associated with the coordinate data.",
              "synonyms": "location, place, addressString"
            },
            {
              "name": "createdAt",
              "type": "string",
              "default": ""
            },
            {
              "name": "description",
              "type": "string",
              "description": "A textual explanation or summary of the item.",
              "synonyms": "summary, details, notes, explanation"
            }
          ]
        },
        "traits": [
          {
            "name": "MapBrowse",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "MapRow",
            "emits": [
              {
                "event": "BrowseItemLoaded",
                "description": "Signals that a browse item has been successfully loaded.",
                "synonyms": "loaded, received, populated",
                "tier": "domain",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MapRow]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "event": "BrowseItemLoadFailed",
                "description": "Indicates a failure to load a browse item.",
                "synonyms": "error, failed, problem, unsuccessful",
                "tier": "internal",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "VIEW",
                "description": "Signals a grid view has been displayed or updated.",
                "synonyms": "display, show, update, render",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "EDIT",
                "description": "Signals a request to edit the selected item.",
                "synonyms": "modify, update, change",
                "tier": "domain",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              },
              {
                "event": "DELETE",
                "description": "Signals a request to remove an item from the dataset.",
                "synonyms": "remove, discard, delete, purge",
                "tier": "presentation",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "object",
                    "properties": [
                      {
                        "name": "id",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "name",
                        "type": "string",
                        "required": true
                      },
                      {
                        "name": "description",
                        "type": "string"
                      },
                      {
                        "name": "status",
                        "type": "string"
                      },
                      {
                        "name": "createdAt",
                        "type": "string"
                      }
                    ]
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "loading",
                  "isInitial": true
                },
                {
                  "name": "browsing"
                },
                {
                  "name": "error"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "BrowseItemLoaded",
                  "name": "BrowseItem loaded",
                  "description": "Signals that a browse item has been successfully loaded.",
                  "synonyms": "loaded, received, populated",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[MapRow]"
                    },
                    {
                      "name": "totalCount",
                      "type": "number"
                    }
                  ]
                },
                {
                  "key": "BrowseItemLoadFailed",
                  "name": "BrowseItem load failed",
                  "description": "Indicates a failure to load a browse item.",
                  "synonyms": "error, failed, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "REFETCH_QUERY",
                  "name": "Refetch Query",
                  "description": "Triggers a data refresh based on the current query.",
                  "synonyms": "refresh, reload, update, re-query",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "searchTerm",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "REFETCH_FILTER",
                  "name": "Refetch Filter",
                  "description": "Triggers a data refresh based on current filter criteria.",
                  "synonyms": "refresh, filter, update, reload",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "field",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "value",
                      "type": "string",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "REFETCH_PAGE",
                  "name": "Refetch Page",
                  "description": "Triggers a data grid page refresh.",
                  "synonyms": "reload, refresh, update, paginate",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "page",
                      "type": "number",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "VIEW",
                  "name": "View",
                  "description": "Signals a grid view has been displayed or updated.",
                  "synonyms": "display, show, update, render",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "object",
                      "properties": [
                        {
                          "name": "id",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "type": "string"
                        },
                        {
                          "name": "status",
                          "type": "string"
                        },
                        {
                          "name": "createdAt",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                },
                {
                  "key": "EDIT",
                  "name": "Edit",
                  "description": "Signals a request to edit the selected item.",
                  "synonyms": "modify, update, change",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "object",
                      "properties": [
                        {
                          "name": "id",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "type": "string"
                        },
                        {
                          "name": "status",
                          "type": "string"
                        },
                        {
                          "name": "createdAt",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                },
                {
                  "key": "DELETE",
                  "name": "Delete",
                  "description": "Signals a request to remove an item from the dataset.",
                  "synonyms": "remove, discard, delete, purge",
                  "tier": "presentation",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "row",
                      "type": "object",
                      "properties": [
                        {
                          "name": "id",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "name",
                          "type": "string",
                          "required": true
                        },
                        {
                          "name": "description",
                          "type": "string"
                        },
                        {
                          "name": "status",
                          "type": "string"
                        },
                        {
                          "name": "createdAt",
                          "type": "string"
                        }
                      ]
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "loading",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "MapRow",
                      {
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        },
                        "limit": 10,
                        "offset": 0
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "spinner",
                        "size": "sm"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "browsing",
                  "event": "BrowseItemLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "align": "center",
                            "children": [
                              {
                                "className": "text-muted-foreground",
                                "name": "search",
                                "type": "icon"
                              },
                              {
                                "action": "REFETCH_QUERY",
                                "className": "flex-1",
                                "placeholder": "Search…",
                                "inputType": "search",
                                "type": "input"
                              }
                            ],
                            "gap": "sm",
                            "direction": "horizontal",
                            "type": "stack",
                            "className": "w-full max-w-2xl rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm"
                          },
                          {
                            "height": "440px",
                            "markers": "@payload.data",
                            "className": "w-full rounded-lg overflow-hidden border border-[var(--color-border)]",
                            "type": "map-view"
                          },
                          {
                            "gap": "sm",
                            "fields": [
                              {
                                "name": "name",
                                "label": "Name",
                                "variant": "h4"
                              },
                              {
                                "variant": "caption",
                                "name": "address",
                                "label": "Address"
                              },
                              {
                                "label": "Status",
                                "name": "status",
                                "variant": "badge"
                              }
                            ],
                            "itemActions": [],
                            "look": "spacious",
                            "entity": "@payload.data",
                            "type": "data-list"
                          }
                        ],
                        "className": "p-card-md",
                        "direction": "vertical",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "loading",
                  "to": "error",
                  "event": "BrowseItemLoadFailed",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "typography",
                        "color": "error",
                        "content": "@payload.error",
                        "variant": "caption"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "MapRow",
                      {
                        "offset": 0,
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        },
                        "limit": 10
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "size": "sm",
                        "type": "spinner"
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REFETCH_QUERY",
                  "effects": [
                    [
                      "fetch",
                      "MapRow",
                      {
                        "offset": 0,
                        "limit": 10,
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        },
                        "filter": [
                          "or",
                          [
                            "=",
                            "@payload.searchTerm",
                            ""
                          ],
                          [
                            "str/includes",
                            [
                              "object/get",
                              "@entity",
                              "name"
                            ],
                            "@payload.searchTerm"
                          ]
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REFETCH_FILTER",
                  "effects": [
                    [
                      "fetch",
                      "MapRow",
                      {
                        "filter": [
                          "or",
                          [
                            "=",
                            "@payload.value",
                            ""
                          ],
                          [
                            "=",
                            [
                              "object/get",
                              "@entity",
                              "@payload.field"
                            ],
                            "@payload.value"
                          ]
                        ],
                        "offset": 0,
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        },
                        "limit": 10
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "REFETCH_PAGE",
                  "effects": [
                    [
                      "fetch",
                      "MapRow",
                      {
                        "limit": 10,
                        "emit": {
                          "success": "BrowseItemLoaded",
                          "failure": "BrowseItemLoadFailed"
                        },
                        "offset": [
                          "*",
                          [
                            "-",
                            "@payload.page",
                            1
                          ],
                          10
                        ]
                      }
                    ]
                  ]
                },
                {
                  "from": "browsing",
                  "to": "browsing",
                  "event": "BrowseItemLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "align": "center",
                            "children": [
                              {
                                "className": "text-muted-foreground",
                                "name": "search",
                                "type": "icon"
                              },
                              {
                                "action": "REFETCH_QUERY",
                                "className": "flex-1",
                                "placeholder": "Search…",
                                "inputType": "search",
                                "type": "input"
                              }
                            ],
                            "gap": "sm",
                            "direction": "horizontal",
                            "type": "stack",
                            "className": "w-full max-w-2xl rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 shadow-sm"
                          },
                          {
                            "height": "440px",
                            "markers": "@payload.data",
                            "className": "w-full rounded-lg overflow-hidden border border-[var(--color-border)]",
                            "type": "map-view"
                          },
                          {
                            "gap": "sm",
                            "fields": [
                              {
                                "name": "name",
                                "label": "Name",
                                "variant": "h4"
                              },
                              {
                                "variant": "caption",
                                "name": "address",
                                "label": "Address"
                              },
                              {
                                "label": "Status",
                                "name": "status",
                                "variant": "badge"
                              }
                            ],
                            "itemActions": [],
                            "look": "spacious",
                            "entity": "@payload.data",
                            "type": "data-list"
                          }
                        ],
                        "className": "p-card-md",
                        "direction": "vertical",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "error",
                  "to": "loading",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "MapRow",
                      {
                        "limit": 10,
                        "offset": 0,
                        "emit": {
                          "failure": "BrowseItemLoadFailed",
                          "success": "BrowseItemLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "size": "sm",
                        "type": "spinner"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "cols": {
                "type": "number",
                "default": 1,
                "label": "How many columns in the grid?",
                "description": "Number of columns in the responsive card/grid layout.",
                "synonyms": "columns, grid width, card columns, num columns",
                "tier": "presentation"
              },
              "imageLabelBinding": {
                "type": "string",
                "default": "@item.thumbnailLabel",
                "label": "Image label binding",
                "description": "Binding path for the image-area label slot.",
                "tier": "internal"
              },
              "imageField": {
                "type": "string",
                "default": "",
                "label": "Which field holds the row image?",
                "description": "Entity field containing the thumbnail URL for each row.",
                "synonyms": "image field, thumbnail field, photo field, picture column",
                "tier": "presentation"
              },
              "filters": {
                "type": "[FilterSpec]",
                "default": [],
                "label": "Which filters should appear above the list?",
                "description": "Dropdown filter facets by field. Each fires a refetch when the user changes the selection. Empty = no filter bar.",
                "synonyms": "filter bar, faceted filters, field filters, column filters, dropdowns",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "name": "field",
                      "type": "string",
                      "required": true
                    },
                    "options": {
                      "name": "options",
                      "type": "array",
                      "required": false,
                      "items": {
                        "type": "string"
                      }
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "pageSize": {
                "type": "number",
                "default": 10,
                "label": "How many rows to fetch per page?",
                "description": "Records fetched from the server per page request.",
                "synonyms": "fetch limit, records per page, batch size, page limit",
                "tier": "presentation"
              },
              "categoryBinding": {
                "type": "string",
                "default": "@item.category",
                "label": "Category field binding",
                "description": "Binding path for the category/tag slot.",
                "tier": "internal"
              },
              "itemActions": {
                "type": "[ItemAction]",
                "default": [],
                "label": "What actions can users take on each row?",
                "description": "Buttons rendered on each row (e.g. Edit, Delete, View).",
                "synonyms": "row buttons, row actions, item actions, per-row buttons, table actions",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
