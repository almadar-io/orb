                      "type": "string",
                      "required": false
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "descriptionBinding": {
                "type": "string",
