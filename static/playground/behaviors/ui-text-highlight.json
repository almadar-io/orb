{
  "name": "ui-text-highlight",
  "description": "TextHighlight — UI factory (1:1 with the @almadar/ui text-highlight pattern).",
  "level": "atom",
  "topic": "ui/core",
  "schema": {
    "name": "ui-text-highlight",
    "version": "1.0.0",
    "description": "TextHighlight — UI factory (1:1 with the @almadar/ui text-highlight pattern).",
    "orbitals": [
      {
        "name": "TextHighlightOrbital",
        "entity": {
          "name": "TextHighlightItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "TextHighlightRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "TextHighlightItem",
            "emits": [
              {
                "event": "CLICK",
                "description": "Callback when highlight is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "MOUSE_ENTER",
                "description": "Callback when highlight is hovered",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "MOUSE_LEAVE",
                "description": "Callback when hover ends",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "ACTION",
                "description": "Declarative event name — emits UI:{action} via eventBus on click",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "HOVER",
                "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "CLICK",
                  "name": "Click",
                  "description": "Callback when highlight is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "MOUSE_ENTER",
                  "name": "Mouse Enter",
                  "description": "Callback when highlight is hovered",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "MOUSE_LEAVE",
                  "name": "Mouse Leave",
                  "description": "Callback when hover ends",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "ACTION",
                  "name": "Action",
                  "description": "Declarative event name — emits UI:{action} via eventBus on click",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "HOVER",
                  "name": "Hover",
                  "description": "Declarative hover event — emits UI:{hoverEvent} with { hovered: true/false }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "annotationId": "Annotation Id",
                        "onClick": "CLICK",
                        "hoverEvent": "HOVER",
                        "type": "text-highlight",
                        "children": [
                          {
                            "content": "Sample content",
                            "type": "typography"
                          }
                        ],
                        "highlightType": "question",
                        "onMouseEnter": "MOUSE_ENTER",
                        "isActive": false,
                        "action": "ACTION",
                        "onMouseLeave": "MOUSE_LEAVE",
                        "className": ""
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "annotationId": {
                "type": "string",
                "default": "Annotation Id",
                "label": "Annotation Id",
                "description": "Unique ID for the annotation",
                "tier": "presentation"
              },
              "highlightType": {
                "type": "string",
                "default": "question",
                "label": "Highlight Type",
                "description": "Type of highlight (determines color)",
                "tier": "presentation",
                "values": [
                  "question",
                  "note"
                ]
              },
              "isActive": {
                "type": "boolean",
                "default": false,
                "label": "Is Active",
                "description": "Whether the highlight is currently active/focused",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "TextHighlightPage",
            "path": "/text-highlight",
            "traits": [
              {
                "ref": "TextHighlightRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "TextHighlightOrbital": [
          {
            "trait": "TextHighlightRender",
            "patternPath": "root",
            "prop": "annotationId",
            "knob": "annotationId"
          },
          {
            "trait": "TextHighlightRender",
            "patternPath": "root",
            "prop": "highlightType",
            "knob": "highlightType"
          },
          {
            "trait": "TextHighlightRender",
            "patternPath": "root",
            "prop": "isActive",
            "knob": "isActive"
          },
          {
            "trait": "TextHighlightRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
