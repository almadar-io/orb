{
  "name": "ui-page-header",
  "description": "PageHeader — UI factory (1:1 with the @almadar/ui page-header pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-page-header",
    "version": "1.0.0",
    "description": "PageHeader — UI factory (1:1 with the @almadar/ui page-header pattern).",
    "orbitals": [
      {
        "name": "PageHeaderOrbital",
        "entity": {
          "name": "PageHeaderItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "PageHeaderRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "PageHeaderItem",
            "emits": [
              {
                "event": "BACK",
                "description": "Event to emit when back is clicked (default: BACK)",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "TAB_CHANGE",
                "description": "onTabChange prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "BACK",
                  "name": "Back",
                  "description": "Event to emit when back is clicked (default: BACK)",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "TAB_CHANGE",
                  "name": "Tab Change",
                  "description": "onTabChange prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "value",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "onTabChange": "TAB_CHANGE",
                        "title": "Title",
                        "error": "@config.error",
                        "children": [
                          {
                            "content": "Sample content",
                            "type": "typography"
                          }
                        ],
                        "activeTab": "Active Tab",
                        "isLoading": false,
                        "showBack": false,
                        "status": "@config.status",
                        "type": "page-header",
                        "actions": [
                          {
                            "navigatesTo": "Navigates To",
                            "disabled": false,
                            "label": "Label",
                            "loading": false,
                            "variant": "primary",
                            "icon": "circle"
                          },
                          {
                            "loading": true,
                            "icon": "circle",
                            "disabled": true,
                            "navigatesTo": "Navigates To 2",
                            "label": "Label 2",
                            "variant": "secondary"
                          }
                        ],
                        "backEvent": "BACK",
                        "breadcrumbs": [
                          {
                            "label": "Label",
                            "href": "Href"
                          },
                          {
                            "label": "Label 2",
                            "href": "Href 2"
                          }
                        ],
                        "className": "",
                        "subtitle": "Subtitle",
                        "tabs": [
                          {
                            "value": "Value",
                            "count": 1,
                            "label": "Label"
                          },
                          {
                            "label": "Label 2",
                            "count": 2,
                            "value": "Value 2"
                          }
                        ]
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "status": {
                "type": "PageHeaderStatus",
                "label": "Status",
                "description": "Status badge",
                "tier": "presentation",
                "properties": {
                  "variant": {
                    "name": "variant",
                    "type": "string",
                    "required": false,
                    "values": [
                      "default",
                      "success",
                      "warning",
                      "danger",
                      "info"
                    ]
                  },
                  "label": {
                    "name": "label",
                    "type": "string",
                    "required": true
                  }
                }
              },
              "tabs": {
                "type": "[PageHeaderTabsItem]",
                "default": [
                  {
                    "value": "Value",
                    "count": 1,
                    "label": "Label"
                  },
                  {
                    "label": "Label 2",
                    "count": 2,
                    "value": "Value 2"
                  }
                ],
                "label": "Tabs",
                "description": "Tabs for sub-navigation",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "name": "value",
                      "type": "string",
                      "required": true
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "count": {
                      "name": "count",
                      "type": "number",
                      "required": false
                    }
                  }
                }
              },
              "actions": {
                "type": "[PageHeaderActionsItem]",
                "default": [
                  {
                    "navigatesTo": "Navigates To",
                    "disabled": false,
                    "label": "Label",
                    "loading": false,
                    "variant": "primary",
                    "icon": "circle"
                  },
                  {
                    "loading": true,
                    "icon": "circle",
                    "disabled": true,
                    "navigatesTo": "Navigates To 2",
                    "label": "Label 2",
                    "variant": "secondary"
                  }
                ],
                "label": "Actions",
                "description": "Actions array - first action with variant='primary' (or first action) is the main action",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "navigatesTo": {
                      "name": "navigatesTo",
                      "type": "string",
                      "required": false
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost",
                        "danger"
                      ]
                    },
                    "icon": {
                      "name": "icon",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": false
                    },
                    "loading": {
                      "name": "loading",
                      "type": "boolean",
                      "required": false
                    },
                    "disabled": {
                      "name": "disabled",
                      "type": "boolean",
                      "required": false
                    }
                  }
                }
              },
              "showBack": {
                "type": "boolean",
                "default": false,
                "label": "Show Back",
                "description": "Show back button",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "className prop",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Page title - accepts string or number from generated code accessing dynamic entity data",
                "tier": "presentation"
              },
              "subtitle": {
                "type": "string",
                "default": "Subtitle",
                "label": "Subtitle",
                "description": "Optional subtitle/description",
                "tier": "presentation"
              },
              "activeTab": {
                "type": "string",
                "default": "Active Tab",
                "label": "Active Tab",
                "description": "activeTab prop",
                "tier": "presentation"
              },
              "error": {
                "type": "PageHeaderError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "breadcrumbs": {
                "type": "[PageHeaderBreadcrumbsItem]",
                "default": [
                  {
                    "label": "Label",
                    "href": "Href"
                  },
                  {
                    "label": "Label 2",
                    "href": "Href 2"
                  }
                ],
                "label": "Breadcrumbs",
                "description": "Breadcrumbs",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "href": {
                      "name": "href",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "PageHeaderPage",
            "path": "/page-header",
            "traits": [
              {
                "ref": "PageHeaderRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "PageHeaderOrbital": [
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "activeTab",
            "knob": "activeTab"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "isLoading",
            "knob": "isLoading"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "showBack",
            "knob": "showBack"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "actions",
            "knob": "actions"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "breadcrumbs",
            "knob": "breadcrumbs"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "subtitle",
            "knob": "subtitle"
          },
          {
            "trait": "PageHeaderRender",
            "patternPath": "root",
            "prop": "tabs",
            "knob": "tabs"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}