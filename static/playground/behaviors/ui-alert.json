{
  "name": "ui-alert",
  "description": "Alert — UI factory (1:1 with the @almadar/ui alert pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-alert",
    "version": "1.0.0",
    "description": "Alert — UI factory (1:1 with the @almadar/ui alert pattern).",
    "orbitals": [
      {
        "name": "AlertOrbital",
        "entity": {
          "name": "AlertItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "AlertRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "AlertItem",
            "emits": [
              {
                "event": "DISMISS",
                "description": "onDismiss prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CLOSE",
                "description": "onClose prop",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "DISMISS",
                  "name": "Dismiss",
                  "description": "onDismiss prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "onClose prop",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "dismissible": false,
                        "message": "Message",
                        "onClose": "CLOSE",
                        "className": "",
                        "children": [
                          {
                            "type": "typography",
                            "content": "Sample content"
                          }
                        ],
                        "onDismiss": "DISMISS",
                        "actions": "@config.actions",
                        "variant": "info",
                        "title": "Title",
                        "type": "alert",
                        "dismissEvent": "DISMISS"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "className prop",
                "tier": "presentation"
              },
              "actions": {
                "type": "node",
                "label": "Actions",
                "description": "actions prop",
                "tier": "presentation"
              },
              "dismissible": {
                "type": "boolean",
                "default": false,
                "label": "Dismissible",
                "description": "dismissible prop",
                "tier": "presentation"
              },
              "message": {
                "type": "string",
                "default": "Message",
                "label": "Message",
                "description": "Alert message (alias for children)",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "info",
                "label": "Variant",
                "description": "variant prop",
                "tier": "presentation",
                "values": [
                  "info",
                  "success",
                  "warning",
                  "error"
                ]
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "title prop",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "AlertPage",
            "path": "/alert",
            "traits": [
              {
                "ref": "AlertRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "AlertOrbital": [
          {
            "trait": "AlertRender",
            "patternPath": "root",
            "prop": "dismissible",
            "knob": "dismissible"
          },
          {
            "trait": "AlertRender",
            "patternPath": "root",
            "prop": "message",
            "knob": "message"
          },
          {
            "trait": "AlertRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "AlertRender",
            "patternPath": "root",
            "prop": "variant",
            "knob": "variant"
          },
          {
            "trait": "AlertRender",
            "patternPath": "root",
            "prop": "title",
            "knob": "title"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}