{
  "name": "ui-chart",
  "description": "Chart — UI factory (1:1 with the @almadar/ui chart pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-chart",
    "version": "1.0.0",
    "description": "Chart — UI factory (1:1 with the @almadar/ui chart pattern).",
    "orbitals": [
      {
        "name": "ChartOrbital",
        "entity": {
          "name": "ChartItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ChartRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ChartItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "type": "chart",
                        "chartType": "bar",
                        "title": "Title",
                        "showValues": false,
                        "height": 200,
                        "series": [
                          {
                            "dashed": false,
                            "data": [
                              {
                                "value": 1,
                                "label": "Label",
                                "color": "Color"
                              },
                              {
                                "value": 2,
                                "label": "Label 2",
                                "color": "Color 2"
                              }
                            ],
                            "color": "Color",
                            "name": "Name"
                          },
                          {
                            "name": "Name 2",
                            "color": "Color 2",
                            "dashed": true,
                            "data": [
                              {
                                "label": "Label",
                                "value": 1,
                                "color": "Color"
                              },
                              {
                                "value": 2,
                                "color": "Color 2",
                                "label": "Label 2"
                              }
                            ]
                          }
                        ],
                        "actions": [
                          {
                            "variant": "primary",
                            "label": "Label",
                            "navigatesTo": "Navigates To"
                          },
                          {
                            "variant": "secondary",
                            "label": "Label 2",
                            "navigatesTo": "Navigates To 2"
                          }
                        ],
                        "timeAxis": false,
                        "className": "",
                        "drillEvent": "Drill Event",
                        "isLoading": false,
                        "subtitle": "Subtitle",
                        "data": [
                          {
                            "label": "Label",
                            "value": 1,
                            "color": "Color"
                          },
                          {
                            "color": "Color 2",
                            "label": "Label 2",
                            "value": 2
                          }
                        ],
                        "showLegend": true,
                        "look": "bar-vertical",
                        "error": "@config.error",
                        "scatterData": [
                          {
                            "size": 1,
                            "label": "Label",
                            "y": 1,
                            "x": 1,
                            "color": "Color"
                          },
                          {
                            "color": "Color 2",
                            "x": 2,
                            "y": 2,
                            "label": "Label 2",
                            "size": 2
                          }
                        ],
                        "stack": "none"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "showValues": {
                "type": "boolean",
                "default": false,
                "label": "Show Values",
                "description": "Show values on chart",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "error": {
                "type": "ChartError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  }
                }
              },
              "chartType": {
                "type": "string",
                "default": "bar",
                "label": "Chart Type",
                "description": "Chart type (legacy alias for `look`).",
                "synonyms": "chart style, graph type, bar chart, line chart, pie chart, area chart, donut chart, scatter plot, histogram",
                "tier": "domain",
                "values": [
                  "bar",
                  "line",
                  "pie",
                  "area",
                  "donut",
                  "scatter",
                  "histogram"
                ]
              },
              "series": {
                "type": "[ChartSeriesItem]",
                "default": [
                  {
                    "dashed": false,
                    "data": [
                      {
                        "value": 1,
                        "label": "Label",
                        "color": "Color"
                      },
                      {
                        "value": 2,
                        "label": "Label 2",
                        "color": "Color 2"
                      }
                    ],
                    "color": "Color",
                    "name": "Name"
                  },
                  {
                    "name": "Name 2",
                    "color": "Color 2",
                    "dashed": true,
                    "data": [
                      {
                        "label": "Label",
                        "value": 1,
                        "color": "Color"
                      },
                      {
                        "value": 2,
                        "color": "Color 2",
                        "label": "Label 2"
                      }
                    ]
                  }
                ],
                "label": "Series",
                "description": "Multi-series data",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "name": "data",
                      "type": "array",
                      "required": true,
                      "items": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "name": "value",
                            "type": "number",
                            "required": true
                          },
                          "color": {
                            "name": "color",
                            "type": "string",
                            "required": false
                          },
                          "label": {
                            "name": "label",
                            "type": "string",
                            "required": true
                          }
                        }
                      }
                    },
                    "name": {
                      "name": "name",
                      "type": "string",
                      "required": true
                    },
                    "color": {
                      "name": "color",
                      "type": "string",
                      "required": false
                    },
                    "dashed": {
                      "name": "dashed",
                      "type": "boolean",
                      "required": false
                    }
                  }
                }
              },
              "data": {
                "type": "[ChartDataItem]",
                "default": [
                  {
                    "label": "Label",
                    "value": 1,
                    "color": "Color"
                  },
                  {
                    "color": "Color 2",
                    "label": "Label 2",
                    "value": 2
                  }
                ],
                "label": "Data",
                "description": "Simple single-series shorthand (bar/line/pie/area/donut/histogram)",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "color": {
                      "name": "color",
                      "type": "string",
                      "required": false
                    },
                    "value": {
                      "name": "value",
                      "type": "number",
                      "required": true
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    }
                  }
                }
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state",
                "tier": "presentation"
              },
              "look": {
                "type": "string",
                "default": "bar-vertical",
                "label": "Look",
                "description": "Layer 2 visual treatment — drives the chart sub-renderer (bar / line / pie / etc.).",
                "synonyms": "chart style, render style, visual treatment",
                "tier": "presentation",
                "values": [
                  "bar-vertical",
                  "bar-horizontal",
                  "line",
                  "area",
                  "pie",
                  "donut",
                  "scatter",
                  "histogram"
                ]
              },
              "timeAxis": {
                "type": "boolean",
                "default": false,
                "label": "Time Axis",
                "description": "Format X-axis labels as time (ISO date in → 'Mar 2026'-style label out)",
                "tier": "presentation"
              },
              "subtitle": {
                "type": "string",
                "default": "Subtitle",
                "label": "Subtitle",
                "description": "Chart subtitle / description",
                "tier": "presentation"
              },
              "height": {
                "type": "number",
                "default": 200,
                "label": "Height",
                "description": "Chart height in px",
                "tier": "presentation"
              },
              "showLegend": {
                "type": "boolean",
                "default": true,
                "label": "Show Legend",
                "description": "Show legend",
                "tier": "presentation"
              },
              "scatterData": {
                "type": "[ChartScatterDataItem]",
                "default": [
                  {
                    "size": 1,
                    "label": "Label",
                    "y": 1,
                    "x": 1,
                    "color": "Color"
                  },
                  {
                    "color": "Color 2",
                    "x": 2,
                    "y": 2,
                    "label": "Label 2",
                    "size": 2
                  }
                ],
                "label": "Scatter Data",
                "description": "Raw {x,y} points for scatter",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "y": {
                      "name": "y",
                      "type": "number",
                      "required": true
                    },
                    "size": {
                      "name": "size",
                      "type": "number",
                      "required": false
                    },
                    "color": {
                      "name": "color",
                      "type": "string",
                      "required": false
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    },
                    "x": {
                      "name": "x",
                      "type": "number",
                      "required": true
                    }
                  }
                }
              },
              "title": {
                "type": "string",
                "default": "Title",
                "label": "Title",
                "description": "Chart title",
                "tier": "presentation"
              },
              "actions": {
                "type": "[ChartActionsItem]",
                "default": [
                  {
                    "variant": "primary",
                    "label": "Label",
                    "navigatesTo": "Navigates To"
                  },
                  {
                    "variant": "secondary",
                    "label": "Label 2",
                    "navigatesTo": "Navigates To 2"
                  }
                ],
                "label": "Actions",
                "description": "Top-level chart actions (export, refresh, etc.)",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "navigatesTo": {
                      "name": "navigatesTo",
                      "type": "string",
                      "required": false
                    },
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost"
                      ]
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "drillEvent": {
                "type": "string",
                "default": "Drill Event",
                "label": "Drill Event",
                "description": "Event name emitted as `UI:{drillEvent}` with `{ label, value, seriesLabel? }` on data-point click",
                "tier": "presentation"
              },
              "stack": {
                "type": "string",
                "default": "none",
                "label": "Stack",
                "description": "Stack mode for bar / area",
                "tier": "presentation",
                "values": [
                  "none",
                  "stack",
                  "normalize"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ChartPage",
            "path": "/chart",
            "traits": [
              {
                "ref": "ChartRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
