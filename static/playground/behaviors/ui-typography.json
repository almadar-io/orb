                        "level": 1,
                        "size": "xs",
                        "style": {},
                        "truncate": false,
                        "type": "typography",
                        "variant": "h1",
                        "children": [
                          {
                            "type": "typography",
                            "content": "Sample content"
                          }
                        ],
                        "overflow": "visible",
                        "align": "left"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "overflow": {
                "type": "string",
                "default": "visible",
                "label": "Overflow",
                "description": "Overflow handling mode",
                "tier": "presentation",
                "values": [
                  "visible",
                  "hidden",
                  "wrap",
                  "clamp-2",
                  "clamp-3"
                ]
              },
              "style": {
                "type": "json",
                "default": {},
                "label": "Style",
                "description": "Inline style",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional class names",
                "tier": "presentation"
              },
              "truncate": {
                "type": "boolean",
                "default": false,
                "label": "Truncate",
                "description": "Truncate with ellipsis (single line)",
                "tier": "presentation"
              },
              "align": {
                "type": "string",
                "default": "left",
                "label": "Align",
                "description": "Text alignment",
                "tier": "presentation",
                "values": [
                  "left",
                  "center",
                  "right"
                ]
              },
              "color": {
                "type": "string",
                "default": "primary",
                "label": "Color",
                "description": "Text color",
                "tier": "presentation",
                "values": [
                  "primary",
                  "secondary",
                  "muted",
                  "error",
                  "success",
                  "warning",
                  "inherit"
                ]
              },
              "size": {
                "type": "string",
                "default": "xs",
