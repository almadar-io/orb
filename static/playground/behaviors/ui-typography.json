                "tier": "presentation",
                "values": [
                  "light",
                  "normal",
                  "medium",
                  "semibold",
                  "bold"
                ]
              },
              "level": {
                "type": "number",
                "default": 1,
                "label": "Level",
                "description": "Heading level (1-6) - alternative to variant for headings",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
