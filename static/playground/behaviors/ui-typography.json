                  "lg",
                  "xl",
                  "2xl",
                  "3xl"
                ]
              },
              "variant": {
                "type": "string",
                "default": "h1",
                "label": "Variant",
                "description": "Typography variant",
                "tier": "presentation",
                "values": [
                  "h1",
                  "h2",
                  "h3",
                  "h4",
                  "h5",
                  "h6",
                  "heading",
                  "subheading",
                  "body1",
                  "body2",
                  "body",
                  "caption",
                  "overline",
                  "small",
                  "large",
                  "label"
                ]
              },
              "weight": {
                "type": "string",
