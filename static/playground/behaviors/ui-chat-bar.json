{
  "name": "ui-chat-bar",
  "description": "ChatBar — UI factory (1:1 with the @almadar/ui chat-bar pattern).",
  "level": "organism",
  "topic": "ui/core",
  "schema": {
    "name": "ui-chat-bar",
    "version": "1.0.0",
    "description": "ChatBar — UI factory (1:1 with the @almadar/ui chat-bar pattern).",
    "orbitals": [
      {
        "name": "ChatBarOrbital",
        "entity": {
          "name": "ChatBarItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "ChatBarRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "ChatBarItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "page": 0,
                        "jepaValidity": 0,
                        "isLoading": false,
                        "activeFilters": {},
                        "sortDirection": "asc",
                        "placeholder": "Placeholder",
                        "searchValue": "Search Value",
                        "pageSize": 0,
                        "totalCount": 0,
                        "type": "chat-bar",
                        "status": "idle",
                        "context": "",
                        "selectedIds": [],
                        "activeGate": "Active Gate",
                        "className": "",
                        "error": "@config.error",
                        "sortBy": "Sort By"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "totalCount": {
                "type": "number",
                "default": 0,
                "label": "Total Count",
                "description": "Total number of items",
                "tier": "presentation"
              },
              "jepaValidity": {
                "type": "number",
                "default": 0,
                "label": "Jepa Validity",
                "description": "JEPA validity probability 0-1",
                "tier": "presentation"
              },
              "status": {
                "type": "string",
                "default": "idle",
                "label": "Status",
                "description": "Pipeline status",
                "tier": "presentation",
                "values": [
                  "idle",
                  "running",
                  "paused",
                  "complete",
                  "error"
                ]
              },
              "pageProp": {
                "type": "number",
                "default": 0,
                "label": "Page",
                "description": "Current page number",
                "synonyms": "page",
                "tier": "presentation"
              },
              "placeholder": {
                "type": "string",
                "default": "Placeholder",
                "label": "Placeholder",
                "description": "Input placeholder text",
                "tier": "presentation"
              },
              "pageSize": {
                "type": "number",
                "default": 0,
                "label": "Page Size",
                "description": "Number of items per page",
                "tier": "presentation"
              },
              "activeFilters": {
                "type": "json",
                "default": {},
                "label": "Active Filters",
                "description": "Active filters",
                "tier": "presentation"
              },
              "activeGate": {
                "type": "string",
                "default": "Active Gate",
                "label": "Active Gate",
                "description": "Currently active gate label, e.g. 'Gate 2: State machines'",
                "tier": "presentation"
              },
              "context": {
                "type": "string",
                "default": "",
                "label": "Context",
                "description": "Agent context description",
                "tier": "presentation"
              },
              "error": {
                "type": "ChatBarError",
                "label": "Error",
                "description": "Error state (UiError)",
                "tier": "presentation",
                "properties": {
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "searchValue": {
                "type": "string",
                "default": "Search Value",
                "label": "Search Value",
                "description": "Current search query value",
                "tier": "presentation"
              },
              "sortBy": {
                "type": "string",
                "default": "Sort By",
                "label": "Sort By",
                "description": "Current sort field",
                "tier": "presentation"
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state indicator",
                "tier": "presentation"
              },
              "selectedIds": {
                "type": "[string]",
                "default": [],
                "label": "Selected Ids",
                "description": "Currently selected item IDs",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              },
              "sortDirection": {
                "type": "string",
                "default": "asc",
                "label": "Sort Direction",
                "description": "Current sort direction",
                "tier": "presentation",
                "values": [
                  "asc",
                  "desc"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "ChatBarPage",
            "path": "/chat-bar",
            "traits": [
              {
                "ref": "ChatBarRender"
              }
            ]
          }
        ]
      }
    ],
