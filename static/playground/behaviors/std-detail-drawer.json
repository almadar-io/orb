{
  "name": "std-detail-drawer",
  "description": "Drawer detail view. Embeds std-modal with drawer slot override.",
  "level": "atom",
  "topic": "core-variations",
  "schema": {
    "name": "std-detail-drawer",
    "version": "1.0.0",
    "description": "Drawer detail view. Embeds std-modal with drawer slot override.",
    "orbitals": [
      {
        "name": "DetailDrawerOrbital",
        "uses": [
          {
            "from": "std/behaviors/std-modal",
            "as": "Modal"
          }
        ],
        "entity": {
          "name": "DetailDrawerRecord",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string"
            },
            {
              "name": "name",
              "type": "string",
              "description": "A user-facing identifier or title for the record.",
              "synonyms": "title, label, identifier"
            },
            {
              "name": "description",
              "type": "string",
              "description": "A textual explanation or summary of the item.",
              "synonyms": "summary, explanation, details, notes"
            },
            {
              "name": "status",
              "type": "string",
              "description": "Current state or condition of the item.",
              "synonyms": "condition, state, condition, flag"
            },
            {
              "name": "createdAt",
              "type": "string"
            }
          ]
        },
        "traits": [
          {
            "name": "DetailDrawerModal",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "DetailDrawerRecord",
            "emits": [
              {
                "event": "SAVE",
                "description": "Indicates a successful data save operation.",
                "synonyms": "submit, persist, confirm",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "event": "CLOSE",
                "description": "Indicates the modal window is being closed.",
                "synonyms": "dismiss, hide, cancel",
                "tier": "domain"
              },
              {
                "event": "ModalRecordLoadFailed",
                "description": "Indicates a failure to load the record data.",
                "synonyms": "error, failure, problem, unsuccessful",
                "tier": "internal",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "ModalRecordLoaded",
                "description": "Signals that the modal's data has been successfully loaded.",
                "synonyms": "loaded, data ready, populated",
                "tier": "domain",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DetailDrawerRecord]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "closed",
                  "isInitial": true
                },
                {
                  "name": "open"
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "OPEN",
                  "name": "Open",
                  "description": "A request to display the modal window.",
                  "synonyms": "show, display, present, reveal",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    },
                    {
                      "name": "row",
                      "type": "DetailDrawerRecord"
                    }
                  ]
                },
                {
                  "key": "CLOSE",
                  "name": "Close",
                  "description": "Indicates the modal window is being closed.",
                  "synonyms": "dismiss, hide, cancel",
                  "tier": "domain"
                },
                {
                  "key": "SAVE",
                  "name": "Save",
                  "description": "Indicates a successful data save operation.",
                  "synonyms": "submit, persist, confirm",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "object",
                      "required": true
                    }
                  ]
                },
                {
                  "key": "ModalRecordLoadFailed",
                  "name": "ModalRecord load failed",
                  "description": "Indicates a failure to load the record data.",
                  "synonyms": "error, failure, problem, unsuccessful",
                  "tier": "internal",
                  "payloadSchema": [
                    {
                      "name": "error",
                      "type": "string"
                    },
                    {
                      "name": "code",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "ModalRecordLoaded",
                  "name": "ModalRecord loaded",
                  "description": "Signals that the modal's data has been successfully loaded.",
                  "synonyms": "loaded, data ready, populated",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[DetailDrawerRecord]"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "closed",
                  "to": "closed",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "DetailDrawerRecord",
                      {
                        "emit": {
                          "success": "ModalRecordLoaded",
                          "failure": "ModalRecordLoadFailed"
                        }
                      }
                    ]
                  ]
                },
                {
                  "from": "closed",
                  "to": "open",
                  "event": "OPEN",
                  "guard": [
                    "or",
                    [
                      "=",
                      "create",
                      "create"
                    ],
                    "@payload.row"
                  ],
                  "effects": [
                    [
                      "set",
                      "@entity.id",
                      "@payload.id"
                    ],
                    [
                      "render-ui",
                      "drawer",
                      {
                        "type": "stack",
                        "children": [
                          {
                            "children": [
                              {
                                "name": "layout-panel-top",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "variant": "h3",
                                "content": "Details"
                              }
                            ],
                            "type": "stack",
                            "direction": "horizontal",
                            "gap": "sm"
                          },
                          {
                            "type": "divider"
                          },
                          {
                            "cancelEvent": "CLOSE",
                            "mode": "create",
                            "type": "form-section",
                            "submitEvent": "SAVE",
                            "entity": "@payload.row",
                            "fields": []
                          }
                        ],
                        "direction": "vertical",
                        "gap": "md"
                      }
                    ]
                  ]
                },
                {
                  "from": "open",
                  "to": "closed",
                  "event": "CLOSE",
                  "effects": [
                    [
                      "render-ui",
                      "drawer",
                      null
                    ],
                    [
                      "notify",
                      "Cancelled",
                      "info"
                    ]
                  ]
                },
                {
                  "from": "open",
                  "to": "closed",
                  "event": "SAVE",
                  "effects": [
                    [
                      "render-ui",
                      "drawer",
                      null
                    ]
                  ]
                }
              ]
            },
            "config": {
              "detailSlot": {
                "type": "slot",
                "default": "drawer",
                "label": "Render slot",
                "description": "UI slot the modal renders into",
                "tier": "internal"
              },
              "detailPattern": {
                "type": "pattern",
                "default": "stack",
                "label": "Layout pattern",
                "description": "Pattern used to arrange the form body",
                "tier": "internal"
              },
              "fields": {
                "type": "[string]",
                "default": [],
                "label": "Which fields appear in the form?",
                "description": "Entity fields rendered as inputs inside the modal form.",
                "synonyms": "form fields, inputs, editable fields, field list",
                "tier": "domain",
                "items": {
                  "type": "string"
                }
              },
              "mode": {
                "type": "string",
                "default": "create",
                "label": "Is this for creating or editing?",
                "description": "create = blank form; edit = pre-filled from the selected row.",
                "synonyms": "form mode, create or edit, new or update, add or modify",
                "tier": "domain"
              },
              "icon": {
                "type": "string",
                "default": "layout-panel-top",
                "label": "Which icon appears in the modal header?",
                "description": "Lucide icon name shown next to the modal title.",
                "synonyms": "header icon, modal icon, title icon",
                "tier": "presentation"
              },
              "title": {
                "type": "string",
                "default": "Details",
                "label": "What should the modal heading say?",
                "description": "Heading displayed at the top of the modal.",
                "synonyms": "modal title, dialog heading, panel title, form title",
                "tier": "presentation"
              }
            },
            "scope": "instance",
            "sourceBehavior": {
              "behavior": "std/behaviors/std-modal",
              "alias": "Modal",
              "originalName": "ModalRecordModal"
            },
            "sourceEntityDefinition": {
              "name": "ModalRecord",
              "persistence": "runtime",
              "fields": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string",
                  "description": "A user-facing identifier for the modal.",
                  "synonyms": "title, label, identifier"
                },
                {
                  "name": "description",
                  "type": "string",
                  "description": "A textual explanation of the modal's content or function.",
                  "synonyms": "details, explanation, notes, summary"
                },
                {
                  "name": "status",
                  "type": "string",
                  "default": "active",
                  "values": [
                    "active",
                    "inactive",
                    "pending"
                  ],
                  "description": "Current operational state of the record.",
                  "synonyms": "state, condition, flag"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            }
          }
        ],
        "pages": [
          {
            "name": "DetailDrawerPage",
            "path": "/detail-drawer",
            "traits": [
              {
                "ref": "DetailDrawerModal"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "DetailDrawerOrbital": [
          {
            "trait": "DetailDrawerModal",
            "patternPath": "root",
            "prop": "type",
            "knob": "detailPattern"
          },
          {
            "trait": "DetailDrawerModal",
            "patternPath": "root.children.0.children.0",
            "prop": "name",
            "knob": "icon"
          },
          {
            "trait": "DetailDrawerModal",
            "patternPath": "root.children.0.children.1",
            "prop": "content",
            "knob": "title"
          },
          {
            "trait": "DetailDrawerModal",
            "patternPath": "root.children.2",
            "prop": "mode",
            "knob": "mode"
          },
          {
            "trait": "DetailDrawerModal",
            "patternPath": "root.children.2",
            "prop": "fields",
            "knob": "fields"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}