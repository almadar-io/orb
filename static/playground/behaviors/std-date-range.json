{
  "name": "std-date-range",
  "description": "std-date-range — compact calendar button (Looker / Tableau shape) that opens a popover containing the date-range-picker. Owns a DateRange runtime entity; DATE_RANGE_CHANGED persists @payload.from + @payload.to so cross-trait listeners can route the range into data atoms (Browse REFETCH_FILTER, Stats / Graphs requery).",
  "level": "atom",
  "topic": "core",
  "schema": {
    "name": "std-date-range",
    "version": "2.0.0",
    "description": "std-date-range — compact calendar button (Looker / Tableau shape) that opens a popover containing the date-range-picker. Owns a DateRange runtime entity; DATE_RANGE_CHANGED persists @payload.from + @payload.to so cross-trait listeners can route the range into data atoms (Browse REFETCH_FILTER, Stats / Graphs requery).",
    "orbitals": [
      {
        "name": "DateRangeOrbital",
        "entity": {
          "name": "DateRange",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "from",
              "type": "string",
              "description": "The start date of the date range.",
              "synonyms": "start, beginning, initial"
            },
            {
              "name": "to",
              "type": "string",
              "description": "The end date of a date range.",
              "synonyms": "end date, finish date, end, final date"
            }
          ]
        },
        "traits": [
          {
            "name": "DateRangeFilter",
            "category": "interaction",
            "linkedEntity": "DateRange",
            "emits": [
              {
                "event": "DATE_RANGE_CHANGED",
                "description": "Signals a change in the selected date range.",
                "synonyms": "range-updated, date-selection, filter-change",
                "tier": "domain",
                "payloadSchema": [
                  {
                    "name": "from",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "to",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "OPEN_DATE_RANGE",
                  "name": "Open Date Range"
                },
                {
                  "key": "DATE_RANGE_CHANGED",
                  "name": "Date Range Changed",
                  "description": "Signals a change in the selected date range.",
                  "synonyms": "range-updated, date-selection, filter-change",
                  "tier": "domain",
                  "payloadSchema": [
                    {
                      "name": "from",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "to",
                      "type": "string",
                      "required": true
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "children": {
                          "type": "button",
                          "variant": "secondary",
                          "action": "OPEN_DATE_RANGE",
                          "label": "Date range",
                          "icon": "calendar",
                          "size": "sm"
                        },
                        "type": "popover",
                        "content": {
                          "type": "date-range-picker",
                          "fromLabel": "From",
                          "event": "DATE_RANGE_CHANGED",
                          "toLabel": "To"
                        },
                        "position": "bottom"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "OPEN_DATE_RANGE",
                  "effects": [
                    [
                      "set",
                      "@entity.from",
                      "@entity.from"
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "DATE_RANGE_CHANGED",
                  "effects": [
                    [
                      "set",
                      "@entity.from",
                      "@payload.from"
                    ],
                    [
                      "set",
                      "@entity.to",
                      "@payload.to"
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "content": {
                          "to": "@entity.to",
                          "type": "date-range-picker",
                          "toLabel": "To",
                          "from": "@entity.from",
                          "event": "DATE_RANGE_CHANGED",
                          "fromLabel": "From"
                        },
                        "children": {
                          "action": "OPEN_DATE_RANGE",
                          "type": "button",
                          "icon": "calendar",
                          "variant": "secondary",
                          "label": "Date range",
                          "size": "sm"
                        },
                        "position": "bottom",
                        "type": "popover"
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "buttonLabel": {
                "type": "string",
                "default": "Date range",
                "label": "Trigger button",
                "description": "Text on the toolbar button that opens the popover",
                "tier": "presentation"
              },
              "event": {
                "type": "string",
                "default": "DATE_RANGE_CHANGED",
                "label": "Change event",
                "description": "Event name emitted when the user picks a new range",
                "tier": "internal"
              },
              "fromLabel": {
                "type": "string",
                "default": "From",
                "label": "Start-date label",
                "description": "Caption shown above the start-date input",
                "tier": "presentation"
              },
              "toLabel": {
                "type": "string",
                "default": "To",
                "label": "End-date label",
                "description": "Caption shown above the end-date input",
                "tier": "presentation"
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "DateRangeFilterPage",
            "path": "/dateranges/filter",
            "traits": [
              {
                "ref": "DateRangeFilter"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "DateRangeOrbital": [
          {
            "trait": "DateRangeFilter",
            "patternPath": "root",
            "prop": "content",
            "knob": "fromLabel"
          },
          {
            "trait": "DateRangeFilter",
            "patternPath": "root",
            "prop": "content",
            "knob": "event"
          },
          {
            "trait": "DateRangeFilter",
            "patternPath": "root",
            "prop": "content",
            "knob": "toLabel"
          },
          {
            "trait": "DateRangeFilter",
            "patternPath": "root",
            "prop": "content",
            "knob": "toLabel"
          },
          {
            "trait": "DateRangeFilter",
            "patternPath": "root",
            "prop": "content",
            "knob": "event"
          },
          {
            "trait": "DateRangeFilter",
            "patternPath": "root",
            "prop": "content",
            "knob": "fromLabel"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}