{
  "name": "ui-calendar-grid",
  "description": "CalendarGrid — UI factory (1:1 with the @almadar/ui calendar-grid pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-calendar-grid",
    "version": "1.0.0",
    "description": "CalendarGrid — UI factory (1:1 with the @almadar/ui calendar-grid pattern).",
    "orbitals": [
      {
        "name": "CalendarGridOrbital",
        "entity": {
          "name": "CalendarGridItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "title",
              "type": "string",
              "default": "Title"
            },
            {
              "name": "startTime",
              "type": "string",
              "default": "Start Time"
            },
            {
              "name": "endTime",
              "type": "string",
              "default": "End Time"
            },
            {
              "name": "color",
              "type": "string",
              "default": "Color"
            }
          ]
        },
        "traits": [
          {
            "name": "CalendarGridRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "CalendarGridItem",
            "emits": [
              {
                "event": "SLOT_CLICK",
                "description": "Called when a time slot is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "day",
                    "type": "date"
                  },
                  {
                    "name": "time",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "DAY_CLICK",
                "description": "Called when a day header is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "day",
                    "type": "date"
                  }
                ]
              },
              {
                "event": "EVENT_CLICK",
                "description": "Called when an event is clicked",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "event",
                    "type": "object"
                  }
                ]
              },
              {
                "event": "LONG_PRESS",
                "description": "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "date",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "time",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "SWIPE_LEFT",
                "description": "Event emitted on swipe left (next week): UI:{swipeLeftEvent}",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "SWIPE_RIGHT",
                "description": "Event emitted on swipe right (prev week): UI:{swipeRightEvent}",
                "tier": "essential",
                "scope": "external",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "event": "CalendarGridLoaded",
                "description": "CalendarGrid rows finished loading; payload.data holds the collection.",
                "synonyms": "loaded, fetched, retrieved",
                "tier": "essential",
                "scope": "internal",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CalendarGridItem]"
                  }
                ]
              }
            ],
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                },
                {
                  "key": "CalendarGridLoaded",
                  "name": "Calendar grid loaded",
                  "description": "CalendarGrid rows finished loading; payload.data holds the collection.",
                  "synonyms": "loaded, fetched, retrieved",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "data",
                      "type": "[CalendarGridItem]"
                    }
                  ]
                },
                {
                  "key": "SLOT_CLICK",
                  "name": "Slot Click",
                  "description": "Called when a time slot is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "day",
                      "type": "date"
                    },
                    {
                      "name": "time",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "DAY_CLICK",
                  "name": "Day Click",
                  "description": "Called when a day header is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "day",
                      "type": "date"
                    }
                  ]
                },
                {
                  "key": "EVENT_CLICK",
                  "name": "Event Click",
                  "description": "Called when an event is clicked",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "event",
                      "type": "object"
                    }
                  ]
                },
                {
                  "key": "LONG_PRESS",
                  "name": "Long Press",
                  "description": "Event emitted on long-press of a time slot: UI:{longPressEvent} with { date, time, ...longPressPayload }",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "date",
                      "type": "string",
                      "required": true
                    },
                    {
                      "name": "time",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SWIPE_LEFT",
                  "name": "Swipe Left",
                  "description": "Event emitted on swipe left (next week): UI:{swipeLeftEvent}",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                },
                {
                  "key": "SWIPE_RIGHT",
                  "name": "Swipe Right",
                  "description": "Event emitted on swipe right (prev week): UI:{swipeRightEvent}",
                  "tier": "essential",
                  "payloadSchema": [
                    {
                      "name": "id",
                      "type": "string"
                    }
                  ]
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "fetch",
                      "CalendarGridItem",
                      {
                        "emit": {
                          "success": "CalendarGridLoaded"
                        }
                      }
                    ],
                    [
                      "render-ui",
                      "main",
                      {
                        "onDayClick": "DAY_CLICK",
                        "swipeLeftEvent": "SWIPE_LEFT",
                        "longPressPayload": {},
                        "weekStart": "2024-01-01",
                        "timeSlots": [],
                        "onSlotClick": "SLOT_CLICK",
                        "events": "@entity",
                        "onEventClick": "EVENT_CLICK",
                        "swipeRightEvent": "SWIPE_RIGHT",
                        "type": "calendar-grid",
                        "className": "",
                        "dayWindow": "@config.dayWindow",
                        "longPressEvent": "LONG_PRESS"
                      }
                    ]
                  ]
                },
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "CalendarGridLoaded",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "swipeLeftEvent": "SWIPE_LEFT",
                        "timeSlots": [],
                        "className": "",
                        "swipeRightEvent": "SWIPE_RIGHT",
                        "onDayClick": "DAY_CLICK",
                        "longPressEvent": "LONG_PRESS",
                        "dayWindow": "@config.dayWindow",
                        "events": "@payload.data",
                        "onSlotClick": "SLOT_CLICK",
                        "weekStart": "2024-01-01",
                        "type": "calendar-grid",
                        "onEventClick": "EVENT_CLICK",
                        "longPressPayload": {}
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "dayWindow": {
                "type": "string",
                "label": "Day Window",
                "description": "Override the viewport-driven day window. `'auto'` (default) tracks `window.innerWidth` — 1 day on mobile, 3 on tablet, 7 on laptop+. Pass an explicit number to force a fixed window (useful for print layouts or screenshot tests).",
                "tier": "presentation"
              },
              "longPressPayload": {
                "type": "json",
                "default": {},
                "label": "Long Press Payload",
                "description": "Additional payload for long-press events",
                "tier": "presentation"
              },
              "weekStart": {
                "type": "date",
                "default": "2024-01-01",
                "label": "Week Start",
                "description": "Start of the week (defaults to current week's Monday)",
                "tier": "presentation"
              },
              "timeSlots": {
                "type": "[string]",
                "default": [],
                "label": "Time Slots",
                "description": "Time slot labels (defaults to 09:00-17:00)",
                "tier": "presentation",
                "items": {
                  "type": "string"
                }
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "CalendarGridPage",
            "path": "/calendar-grid",
            "traits": [
              {
                "ref": "CalendarGridRender"
              }
            ]
          }
        ]
      }
    ],
    "_metadata": {
      "configProvenance": {
        "CalendarGridOrbital": [
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "longPressPayload",
            "knob": "longPressPayload"
          },
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "weekStart",
            "knob": "weekStart"
          },
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "timeSlots",
            "knob": "timeSlots"
          },
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "timeSlots",
            "knob": "timeSlots"
          },
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "className",
            "knob": "className"
          },
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "weekStart",
            "knob": "weekStart"
          },
          {
            "trait": "CalendarGridRender",
            "patternPath": "root",
            "prop": "longPressPayload",
            "knob": "longPressPayload"
          }
        ]
      }
    }
  },
  "source": "",
  "lolo": ""
}