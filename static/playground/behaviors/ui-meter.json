{
  "name": "ui-meter",
  "description": "Meter — UI factory (1:1 with the @almadar/ui meter pattern).",
  "level": "molecule",
  "topic": "ui/core",
  "schema": {
    "name": "ui-meter",
    "version": "1.0.0",
    "description": "Meter — UI factory (1:1 with the @almadar/ui meter pattern).",
    "orbitals": [
      {
        "name": "MeterOrbital",
        "entity": {
          "name": "MeterItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        },
        "traits": [
          {
            "name": "MeterRender",
            "entityRebindable": true,
            "entityContract": {
              "requires": [],
              "provides": []
            },
            "category": "interaction",
            "linkedEntity": "MeterItem",
            "stateMachine": {
              "states": [
                {
                  "name": "idle",
                  "isInitial": true
                }
              ],
              "events": [
                {
                  "key": "INIT",
                  "name": "Initialize"
                }
              ],
              "transitions": [
                {
                  "from": "idle",
                  "to": "idle",
                  "event": "INIT",
                  "effects": [
                    [
                      "render-ui",
                      "main",
                      {
                        "actions": [
                          {
                            "label": "Label",
                            "navigatesTo": "Navigates To",
                            "variant": "primary"
                          },
                          {
                            "navigatesTo": "Navigates To 2",
                            "variant": "secondary",
                            "label": "Label 2"
                          }
                        ],
                        "segments": 5,
                        "error": "@config.error",
                        "min": 0,
                        "isLoading": false,
                        "size": "md",
                        "label": "Label",
                        "type": "meter",
                        "className": "",
                        "thresholds": [
                          {
                            "label": "Label",
                            "color": "Color",
                            "value": 1
                          },
                          {
                            "value": 2,
                            "label": "Label 2",
                            "color": "Color 2"
                          }
                        ],
                        "variant": "linear",
                        "max": 100,
                        "unit": "Unit",
                        "value": 1,
                        "showValue": true
                      }
                    ]
                  ]
                }
              ]
            },
            "config": {
              "error": {
                "type": "MeterError",
                "label": "Error",
                "description": "Error state",
                "tier": "presentation",
                "properties": {
                  "message": {
                    "name": "message",
                    "type": "string",
                    "required": true
                  },
                  "name": {
                    "name": "name",
                    "type": "string",
                    "required": false
                  },
                  "code": {
                    "name": "code",
                    "type": "string",
                    "required": false
                  },
                  "stack": {
                    "name": "stack",
                    "type": "string",
                    "required": false
                  }
                }
              },
              "thresholds": {
                "type": "[MeterThresholdsItem]",
                "default": [
                  {
                    "label": "Label",
                    "color": "Color",
                    "value": 1
                  },
                  {
                    "value": 2,
                    "label": "Label 2",
                    "color": "Color 2"
                  }
                ],
                "label": "Thresholds",
                "description": "Color thresholds",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": false
                    },
                    "color": {
                      "name": "color",
                      "type": "string",
                      "required": true
                    },
                    "value": {
                      "name": "value",
                      "type": "number",
                      "required": true
                    }
                  }
                }
              },
              "isLoading": {
                "type": "boolean",
                "default": false,
                "label": "Is Loading",
                "description": "Loading state",
                "tier": "presentation"
              },
              "variant": {
                "type": "string",
                "default": "linear",
                "label": "Variant",
                "description": "Display variant",
                "tier": "presentation",
                "values": [
                  "linear",
                  "radial",
                  "segmented"
                ]
              },
              "min": {
                "type": "number",
                "default": 0,
                "label": "Min",
                "description": "Minimum value",
                "tier": "presentation"
              },
              "segments": {
                "type": "number",
                "default": 5,
                "label": "Segments",
                "description": "Number of segments (for segmented variant)",
                "tier": "presentation"
              },
              "unit": {
                "type": "string",
                "default": "Unit",
                "label": "Unit",
                "description": "Unit suffix (e.g., '%', 'MB', 'credits')",
                "tier": "presentation"
              },
              "value": {
                "type": "number",
                "default": 1,
                "label": "Value",
                "description": "Current value",
                "tier": "presentation"
              },
              "label": {
                "type": "string",
                "default": "Label",
                "label": "Label",
                "description": "Display label",
                "tier": "presentation"
              },
              "max": {
                "type": "number",
                "default": 100,
                "label": "Max",
                "description": "Maximum value",
                "tier": "presentation"
              },
              "actions": {
                "type": "[MeterActionsItem]",
                "default": [
                  {
                    "label": "Label",
                    "navigatesTo": "Navigates To",
                    "variant": "primary"
                  },
                  {
                    "navigatesTo": "Navigates To 2",
                    "variant": "secondary",
                    "label": "Label 2"
                  }
                ],
                "label": "Actions",
                "description": "Actions",
                "tier": "presentation",
                "items": {
                  "type": "object",
                  "properties": {
                    "variant": {
                      "name": "variant",
                      "type": "string",
                      "required": false,
                      "values": [
                        "primary",
                        "secondary",
                        "ghost"
                      ]
                    },
                    "label": {
                      "name": "label",
                      "type": "string",
                      "required": true
                    },
                    "navigatesTo": {
                      "name": "navigatesTo",
                      "type": "string",
                      "required": false
                    },
                    "event": {
                      "name": "event",
                      "type": "string",
                      "required": false
                    }
                  }
                }
              },
              "className": {
                "type": "string",
                "default": "",
                "label": "Class Name",
                "description": "Additional CSS classes",
                "tier": "presentation"
              },
              "showValue": {
                "type": "boolean",
                "default": true,
                "label": "Show Value",
                "description": "Show value text",
                "tier": "presentation"
              },
              "size": {
                "type": "string",
                "default": "md",
                "label": "Size",
                "description": "Size (for radial variant)",
                "tier": "presentation",
                "values": [
                  "sm",
                  "md",
                  "lg"
                ]
              }
            },
            "scope": "instance"
          }
        ],
        "pages": [
          {
            "name": "MeterPage",
            "path": "/meter",
            "traits": [
              {
                "ref": "MeterRender"
              }
            ]
