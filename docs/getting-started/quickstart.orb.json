{
  "name": "TaskManager",
  "orbitals": [
    {
      "name": "TaskManager",
      "entity": {
        "name": "Task",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TaskCrud",
          "category": "interaction",
          "linkedEntity": "Task",
          "stateMachine": {
            "states": [
              {
                "name": "Listing",
                "isInitial": true
              },
              {
                "name": "Creating"
              },
              {
                "name": "Editing"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "CREATE"
              },
              {
                "key": "EDIT"
              },
              {
                "key": "DELETE"
              },
              {
                "key": "SAVE"
              },
              {
                "key": "CANCEL"
              }
            ],
            "transitions": [
              {
                "from": "Listing",
                "to": "Listing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Task"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "typography",
                              "content": "My Task Manager",
                              "variant": "h2"
                            },
                            {
                              "label": "New Task",
                              "icon": "plus",
                              "event": "CREATE",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "content": "No tasks yet. Click New Task to get started.",
                          "type": "typography",
                          "variant": "body"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "Listing",
                "to": "Creating",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "content": "New Task",
                          "variant": "h3"
                        },
                        {
                          "placeholder": "Enter task title",
                          "label": "Title",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "label": "Description",
                          "placeholder": "Describe the task"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "pending",
                              "label": "Pending"
                            },
                            {
                              "label": "In Progress",
                              "value": "in_progress"
                            },
                            {
                              "label": "Done",
                              "value": "done"
                            }
                          ],
                          "label": "Status"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "button",
                              "label": "Save",
                              "event": "SAVE",
                              "variant": "primary"
                            },
                            {
                              "variant": "secondary",
                              "label": "Cancel",
                              "event": "CANCEL",
                              "type": "button"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "Listing",
                "to": "Editing",
                "event": "EDIT"
              },
              {
                "from": "Listing",
                "to": "Listing",
                "event": "DELETE"
              },
              {
                "from": "Creating",
                "to": "Listing",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "Task"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "My Task Manager"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "title",
                            "status"
                          ],
                          "type": "data-list",
                          "entity": "Task"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "Creating",
                "to": "Listing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "content": "My Task Manager",
                          "variant": "h2"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "Task",
                          "fields": [
                            "title",
                            "status"
                          ],
                          "type": "data-list"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "Editing",
                "to": "Listing",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "Task"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "content": "My Task Manager",
                          "variant": "h2"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            "title",
                            "status"
                          ],
                          "entity": "Task",
                          "type": "data-list"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "Editing",
                "to": "Listing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "My Task Manager",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "Task",
                          "fields": [
                            "title",
                            "status"
                          ],
                          "type": "data-list"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Tasks",
          "path": "/tasks",
          "traits": [
            {
              "ref": "TaskCrud"
            }
          ]
        }
      ]
    }
  ]
}
