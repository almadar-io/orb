{
  "name": "TaskManager",
  "version": "1.0.0",
  "description": "Quickstart task manager — list, create, edit, delete with mock-seeded rows",
  "orbitals": [
    {
      "name": "TaskManager",
      "entity": {
        "name": "Task",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "pending",
              "in_progress",
              "done"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TaskCrud",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "TaskLoaded",
              "description": "Fired when the Task collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Task]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TaskLoadFailed",
              "description": "Fired when the Task collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskSaved",
              "description": "Fired when a Task is created or updated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "row",
                  "type": "Task"
                }
              ]
            },
            {
              "event": "TaskSaveFailed",
              "description": "Fired when a Task save fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskDeleted",
              "description": "Fired when a Task is removed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TaskDeleteFailed",
              "description": "Fired when a Task delete fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "Listing"
              },
              {
                "name": "Creating"
              },
              {
                "name": "Editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TaskLoaded",
                "name": "Task loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Task]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TaskLoadFailed",
                "name": "Task load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Task"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Task"
                  }
                ]
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "Task"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "TaskSaved",
                "name": "Task saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Task"
                  }
                ]
              },
              {
                "key": "TaskSaveFailed",
                "name": "Task save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TaskDeleted",
                "name": "Task deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TaskDeleteFailed",
                "name": "Task delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "failure": "TaskLoadFailed",
                        "success": "TaskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading tasks…"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "Listing",
                "event": "TaskLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "content": "My Tasks",
                              "variant": "h2",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "icon": "plus",
                              "label": "New Task",
                              "type": "button",
                              "action": "CREATE"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "h4"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "primary"
                            },
                            {
                              "label": "Delete",
                              "event": "DELETE",
                              "variant": "danger"
                            }
                          ]
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TaskLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "color": "destructive",
                          "type": "icon",
                          "name": "alert-triangle"
                        },
                        {
                          "content": "Failed to load tasks",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "variant": "primary",
                          "action": "INIT",
                          "label": "Retry",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "Listing",
                "to": "Creating",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "New Task"
                        },
                        {
                          "placeholder": "Title",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Description"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "label": "Pending",
                              "value": "pending"
                            },
                            {
                              "value": "in_progress",
                              "label": "In Progress"
                            },
                            {
                              "value": "done",
                              "label": "Done"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "action": "SAVE",
                              "label": "Save"
                            },
                            {
                              "type": "button",
                              "label": "Cancel",
                              "action": "CANCEL",
                              "variant": "secondary"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "Listing",
                "to": "Editing",
                "event": "EDIT",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "content": "Edit Task",
                          "variant": "h3"
                        },
                        {
                          "type": "input",
                          "placeholder": "Title"
                        },
                        {
                          "placeholder": "Description",
                          "type": "textarea"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "pending",
                              "label": "Pending"
                            },
                            {
                              "label": "In Progress",
                              "value": "in_progress"
                            },
                            {
                              "label": "Done",
                              "value": "done"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "label": "Save",
                              "action": "SAVE"
                            },
                            {
                              "variant": "secondary",
                              "label": "Cancel",
                              "action": "CANCEL",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "Listing",
                "to": "loading",
                "event": "DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Task",
                    "@payload.row.id",
                    {
                      "emit": {
                        "success": "TaskDeleted",
                        "failure": "TaskDeleteFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "success": "TaskLoaded",
                        "failure": "TaskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "Creating",
                "to": "loading",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Task",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TaskSaved",
                        "failure": "TaskSaveFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "failure": "TaskLoadFailed",
                        "success": "TaskLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "Creating",
                "to": "Listing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between",
                          "children": [
                            {
                              "content": "My Tasks",
                              "variant": "h2",
                              "type": "typography"
                            },
                            {
                              "variant": "primary",
                              "icon": "plus",
                              "label": "New Task",
                              "action": "CREATE",
                              "type": "button"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "primary"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "event": "DELETE"
                            }
                          ],
                          "entity": "@entity",
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Title",
                              "variant": "h4",
                              "name": "title"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "Editing",
                "to": "loading",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Task",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TaskSaved",
                        "failure": "TaskSaveFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "success": "TaskLoaded",
                        "failure": "TaskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "Editing",
                "to": "Listing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "typography",
                              "content": "My Tasks",
                              "variant": "h2"
                            },
                            {
                              "action": "CREATE",
                              "label": "New Task",
                              "type": "button",
                              "variant": "primary",
                              "icon": "plus"
                            }
                          ],
                          "gap": "md",
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "label": "Title",
                              "name": "title",
                              "variant": "h4"
                            },
                            {
                              "name": "description",
                              "variant": "caption",
                              "label": "Description"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "entity": "@entity",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "EDIT",
                              "label": "Edit"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "event": "DELETE"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Task",
                    {
                      "emit": {
                        "success": "TaskLoaded",
                        "failure": "TaskLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TasksPage",
          "path": "/tasks",
          "traits": [
            {
              "ref": "TaskCrud"
            }
          ]
        }
      ]
    }
  ]
}
