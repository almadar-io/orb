{
  "name": "std-rich-editor",
  "version": "1.0.0",
  "description": "std-rich-editor — wiki / CMS Notion-style block editor. Owns a Document entity (page / doc / post) with a serialized RichBlock[] payload, browses documents in a data-grid, opens the rich-block-editor on a selected row, and persists block edits + publish status back to the row.",
  "orbitals": [
    {
      "name": "DocumentOrbital",
      "entity": {
        "name": "Document",
        "collection": "documents",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "blocksJson",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          {
            "name": "authorId",
            "type": "string"
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "kind",
            "type": "string",
            "default": "page",
            "values": [
              "page",
              "doc",
              "post"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "archived"
            ]
          },
          {
            "name": "version",
            "type": "number",
            "default": 1
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "updatedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DocumentEdit",
          "category": "interaction",
          "linkedEntity": "Document",
          "emits": [
            {
              "event": "OPEN",
              "payloadSchema": [
                {
                  "name": "documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BLOCKS_CHANGE",
              "payloadSchema": [
                {
                  "name": "blocks",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "SAVE",
              "payloadSchema": [
                {
                  "name": "documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "blocks",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Document]"
                }
              ]
            },
            {
              "event": "DocumentLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentSaved",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentPublished",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DocumentLoaded",
                "name": "Document loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Document]"
                  }
                ]
              },
              {
                "key": "DocumentLoadFailed",
                "name": "Document load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "documentId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "documentId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "BLOCKS_CHANGE",
                "name": "Blocks Change",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "documentId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "DocumentSaved",
                "name": "Document saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "DocumentPublished",
                "name": "Document published",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "DocumentSaveFailed",
                "name": "Document save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "success": "DocumentLoaded",
                        "failure": "DocumentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading documents…",
                          "variant": "caption"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DocumentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "author": "Team Knowledge Base",
                          "subtitle": "Wiki / CMS Notion-style Docs",
                          "type": "book-cover-page",
                          "coverImageUrl": "https://picsum.photos/seed/notes-cover/1200/400",
                          "title": "Documents"
                        },
                        {
                          "type": "book-nav-bar",
                          "chapterTitle": "Getting Started",
                          "currentPage": 1,
                          "totalPages": 24
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Documents"
                            }
                          ]
                        },
                        {
                          "type": "doc-toc",
                          "items": [
                            {
                              "id": "intro",
                              "label": "Introduction",
                              "level": 1
                            },
                            {
                              "level": 1,
                              "id": "blocks",
                              "label": "Block Types"
                            },
                            {
                              "id": "publish",
                              "label": "Publishing Workflow",
                              "level": 1
                            },
                            {
                              "label": "Archived Docs",
                              "level": 2,
                              "id": "archive"
                            }
                          ],
                          "activeId": "blocks"
                        },
                        {
                          "tags": [
                            {
                              "label": "Engineering"
                            },
                            {
                              "label": "Product"
                            },
                            {
                              "label": "Design"
                            },
                            {
                              "label": "Operations"
                            },
                            {
                              "label": "Onboarding"
                            },
                            {
                              "label": "Runbooks"
                            }
                          ],
                          "variant": "primary",
                          "type": "tag-cloud"
                        },
                        {
                          "items": [
                            {
                              "title": "Drafts",
                              "id": "drafts",
                              "content": "All in-progress documents that have not yet been published."
                            },
                            {
                              "id": "published",
                              "content": "Documents visible to readers across the workspace.",
                              "title": "Published"
                            },
                            {
                              "title": "Archived",
                              "content": "Read-only legacy documents preserved for historical reference.",
                              "id": "archived"
                            }
                          ],
                          "type": "accordion"
                        },
                        {
                          "children": "Documents are the long-term memory of the organization.",
                          "type": "pull-quote"
                        },
                        {
                          "type": "markdown-content",
                          "content": "Welcome to the wiki workspace.",
                          "direction": "ltr"
                        },
                        {
                          "chapter": {
                            "body": "This chapter walks through composing your first document and publishing it to the workspace.",
                            "title": "Introduction",
                            "id": "intro",
                            "number": 1
                          },
                          "type": "book-chapter-view"
                        },
                        {
                          "code": "const greet = name => 'Hello ' + name",
                          "showCopyButton": true,
                          "showLanguageBadge": true,
                          "language": "javascript",
                          "foldable": true,
                          "type": "code-block"
                        },
                        {
                          "code": "title: Release Notes, version: 1.2.0, status: published",
                          "showLineNumbers": true,
                          "type": "doc-code-block",
                          "language": "json",
                          "title": "Sample document payload"
                        },
                        {
                          "label": "Inspect document JSON",
                          "type": "code-view",
                          "data": {
                            "kind": "document",
                            "status": "published",
                            "version": 12,
                            "blocks": 7
                          },
                          "defaultExpanded": false
                        },
                        {
                          "type": "text-highlight",
                          "children": [
                            {
                              "content": "Pro tip: pin the most-edited document to the workspace home for one-click access.",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "annotationId": "tip-1",
                          "highlightType": "note"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "cols": 1,
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Open",
                              "event": "OPEN",
                              "icon": "edit"
                            },
                            {
                              "variant": "secondary",
                              "event": "PUBLISH",
                              "label": "Publish",
                              "icon": "send"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Title",
                              "name": "title"
                            },
                            {
                              "variant": "badge",
                              "label": "Kind",
                              "name": "kind"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "label": "v",
                              "variant": "caption",
                              "name": "version"
                            },
                            {
                              "name": "updatedAt",
                              "label": "Updated",
                              "variant": "caption"
                            }
                          ]
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DocumentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "OPEN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.row.blocksJson"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.version",
                    "@payload.row.version"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.title"
                            },
                            {
                              "type": "badge",
                              "variant": "secondary",
                              "label": "@entity.status"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "initialBlocks": "@entity.blocksJson",
                          "showToolbar": true,
                          "type": "rich-block-editor",
                          "placeholder": "Start writing…",
                          "changeEvent": "BLOCKS_CHANGE"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "icon": "save",
                              "type": "button",
                              "variant": "primary",
                              "action": "SAVE",
                              "label": "Save"
                            },
                            {
                              "action": "PUBLISH",
                              "label": "Publish",
                              "type": "button",
                              "icon": "send",
                              "variant": "secondary"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.row.blocksJson"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "published"
                  ],
                  [
                    "set",
                    "@entity.version",
                    "@payload.row.version"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "success": "DocumentPublished",
                        "failure": "DocumentSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "BLOCKS_CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.blocks"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "SAVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.blocks"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "failure": "DocumentSaveFailed",
                        "success": "DocumentSaved"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.row.blocksJson"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "published"
                  ],
                  [
                    "set",
                    "@entity.version",
                    "@payload.row.version"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "failure": "DocumentSaveFailed",
                        "success": "DocumentPublished"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "DocumentSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Saved",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "DocumentPublished",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "success": "DocumentLoaded",
                        "failure": "DocumentLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "DocumentSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "success": "DocumentLoaded",
                        "failure": "DocumentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Documents"
            }
          },
          "scope": "collection"
        }
      ],
