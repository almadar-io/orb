{
  "name": "std-rich-editor",
  "version": "1.0.0",
  "description": "std-rich-editor — wiki / CMS Notion-style block editor. Owns a Document entity (page / doc / post) with a serialized RichBlock[] payload, browses documents in a data-grid, opens the rich-block-editor on a selected row, and persists block edits + publish status back to the row.",
  "orbitals": [
    {
      "name": "DocumentOrbital",
      "entity": {
        "name": "Document",
        "collection": "documents",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "blocksJson",
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          {
            "name": "authorId",
            "type": "string"
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "kind",
            "type": "string",
            "default": "page",
            "values": [
              "page",
              "doc",
              "post"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "archived"
            ]
          },
          {
            "name": "version",
            "type": "number",
            "default": 1
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "updatedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DocumentEdit",
          "category": "interaction",
          "linkedEntity": "Document",
          "emits": [
            {
              "event": "OPEN",
              "payloadSchema": [
                {
                  "name": "documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BLOCKS_CHANGE",
              "payloadSchema": [
                {
                  "name": "blocks",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "SAVE",
              "payloadSchema": [
                {
                  "name": "documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "blocks",
                  "type": "[object]"
                }
              ]
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "documentId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Document]"
                }
              ]
            },
            {
              "event": "DocumentLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentSaved",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentPublished",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.blocksJson",
                  "type": "[object]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.kind",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.version",
                  "type": "number"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DocumentSaveFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DocumentLoaded",
                "name": "Document loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Document]"
                  }
                ]
              },
              {
                "key": "DocumentLoadFailed",
                "name": "Document load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "documentId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "documentId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "BLOCKS_CHANGE",
                "name": "Blocks Change",
                "payloadSchema": [
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "documentId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "blocks",
                    "type": "[object]"
                  }
                ]
              },
              {
                "key": "DocumentSaved",
                "name": "Document saved",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "DocumentPublished",
                "name": "Document published",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Document"
                  }
                ]
              },
              {
                "key": "DocumentSaveFailed",
                "name": "Document save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "success": "DocumentLoaded",
                        "failure": "DocumentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading documents…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DocumentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "content": "Documents",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "gap": "sm",
                          "fields": [
                            {
                              "label": "Title",
                              "name": "title",
                              "variant": "caption"
                            },
                            {
                              "label": "Kind",
                              "variant": "badge",
                              "name": "kind"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "name": "version",
                              "variant": "caption",
                              "label": "v"
                            },
                            {
                              "label": "Updated",
                              "variant": "caption",
                              "name": "updatedAt"
                            }
                          ],
                          "itemActions": [
                            {
                              "icon": "edit",
                              "label": "Open",
                              "event": "OPEN",
                              "variant": "primary"
                            },
                            {
                              "variant": "secondary",
                              "icon": "send",
                              "event": "PUBLISH",
                              "label": "Publish"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DocumentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "OPEN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.row.blocksJson"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.version",
                    "@payload.row.version"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "file-text"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.title"
                            },
                            {
                              "label": "@entity.status",
                              "type": "badge",
                              "variant": "secondary"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "rich-block-editor",
                          "changeEvent": "BLOCKS_CHANGE",
                          "showToolbar": true,
                          "initialBlocks": "@entity.blocksJson",
                          "placeholder": "Start writing…"
                        },
                        {
                          "children": [
                            {
                              "action": "SAVE",
                              "label": "Save",
                              "variant": "primary",
                              "type": "button",
                              "icon": "save"
                            },
                            {
                              "variant": "secondary",
                              "type": "button",
                              "label": "Publish",
                              "action": "PUBLISH",
                              "icon": "send"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.row.blocksJson"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "published"
                  ],
                  [
                    "set",
                    "@entity.version",
                    "@payload.row.version"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "failure": "DocumentSaveFailed",
                        "success": "DocumentPublished"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "BLOCKS_CHANGE",
                "effects": [
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.blocks"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "SAVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.blocks"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "failure": "DocumentSaveFailed",
                        "success": "DocumentSaved"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.documentId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.blocksJson",
                    "@payload.row.blocksJson"
                  ],
                  [
                    "set",
                    "@entity.authorId",
                    "@payload.row.authorId"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.row.parentId"
                  ],
                  [
                    "set",
                    "@entity.kind",
                    "@payload.row.kind"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "published"
                  ],
                  [
                    "set",
                    "@entity.version",
                    "@payload.row.version"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "set",
                    "@entity.updatedAt",
                    "@payload.row.updatedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Document",
                    "@entity",
                    {
                      "emit": {
                        "success": "DocumentPublished",
                        "failure": "DocumentSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "DocumentSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "type": "alert",
                      "message": "Saved"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "DocumentPublished",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "failure": "DocumentLoadFailed",
                        "success": "DocumentLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "editing",
                "event": "DocumentSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Document",
                    {
                      "emit": {
                        "failure": "DocumentLoadFailed",
                        "success": "DocumentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Documents"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DocumentEditPage",
          "path": "/documents/edit",
          "traits": [
            {
              "ref": "DocumentEdit"
            }
          ]
        }
      ]
    }
  ]
}
