{
  "name": "std-page-tree",
  "version": "1.0.0",
  "description": "std-page-tree — hierarchical wiki navigation with parent/child PageNode rows. PageNodeBrowse loads pages on INIT, renders a reorderable data-list with Open / Delete actions plus an Add Page button, and persists select / reorder / add / delete via SELECT_PAGE / REORDER / ADD_PAGE / DELETE_PAGE events.",
  "orbitals": [
    {
      "name": "PageTreeOrbital",
      "entity": {
        "name": "PageNode",
        "collection": "pagenodes",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "slug",
            "type": "string"
          },
          {
            "name": "order",
            "type": "number",
            "default": 0
          },
          {
            "name": "documentId",
            "type": "string"
          },
          {
            "name": "iconName",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PageNodeBrowse",
          "category": "interaction",
          "linkedEntity": "PageNode",
          "emits": [
            {
              "event": "SELECT_PAGE",
              "payloadSchema": [
                {
                  "name": "pageId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.slug",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "row.documentId",
                  "type": "string"
                },
                {
                  "name": "row.iconName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REORDER",
              "payloadSchema": [
                {
                  "name": "pageId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.slug",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "row.documentId",
                  "type": "string"
                },
                {
                  "name": "row.iconName",
                  "type": "string"
                },
                {
                  "name": "newOrder",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "newParentId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ADD_PAGE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE_PAGE",
              "payloadSchema": [
                {
                  "name": "pageId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.slug",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "row.documentId",
                  "type": "string"
                },
                {
                  "name": "row.iconName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PageNodeLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PageNode]"
                }
              ]
            },
            {
              "event": "PageNodeLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PageSelected",
              "payloadSchema": [
                {
                  "name": "pageId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PageNodeUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.slug",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "row.documentId",
                  "type": "string"
                },
                {
                  "name": "row.iconName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PageNodeAdded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.slug",
                  "type": "string"
                },
                {
                  "name": "row.order",
                  "type": "number"
                },
                {
                  "name": "row.documentId",
                  "type": "string"
                },
                {
                  "name": "row.iconName",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PageNodeDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PageNodeLoaded",
                "name": "PageNode loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PageNode]"
                  }
                ]
              },
              {
                "key": "PageNodeLoadFailed",
                "name": "PageNode load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_PAGE",
                "name": "Select Page",
                "payloadSchema": [
                  {
                    "name": "pageId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "PageNode"
                  }
                ]
              },
              {
                "key": "ADD_PAGE",
                "name": "Add Page",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "REORDER",
                "name": "Reorder",
                "payloadSchema": [
                  {
                    "name": "pageId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "PageNode"
                  },
                  {
                    "name": "newOrder",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "newParentId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DELETE_PAGE",
                "name": "Delete Page",
                "payloadSchema": [
                  {
                    "name": "pageId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "PageNode"
                  }
                ]
              },
              {
                "key": "PageSelected",
                "name": "Page selected",
                "payloadSchema": [
                  {
                    "name": "pageId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PageNodeAdded",
                "name": "PageNode added",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "PageNode"
                  }
                ]
              },
              {
                "key": "PageNodeUpdated",
                "name": "PageNode updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "PageNode"
                  }
                ]
              },
              {
                "key": "PageNodeDeleted",
                "name": "PageNode deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "failure": "PageNodeLoadFailed",
                        "success": "PageNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading pages…"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "PageNodeLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "children": [
                            {
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "list-tree",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h3",
                                  "type": "typography",
                                  "content": "Pages"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack"
                            },
                            {
                              "label": "Add Page",
                              "action": "ADD_PAGE",
                              "icon": "plus",
                              "variant": "primary",
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": [
                            {
                              "variant": "h4",
                              "name": "title",
                              "label": "Title"
                            },
                            {
                              "variant": "caption",
                              "name": "slug",
                              "label": "Slug"
                            },
                            {
                              "name": "parentId",
                              "variant": "caption",
                              "label": "Parent"
                            },
                            {
                              "variant": "badge",
                              "name": "order",
                              "label": "Order"
                            }
                          ],
                          "reorderable": true,
                          "reorderEvent": "REORDER",
                          "itemActions": [
                            {
                              "icon": "chevron-right",
                              "variant": "ghost",
                              "label": "Open",
                              "event": "SELECT_PAGE"
                            },
                            {
                              "icon": "trash",
                              "label": "Delete",
                              "variant": "danger",
                              "event": "DELETE_PAGE"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-list"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "PageNodeLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "SELECT_PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.pageId"
                  ],
                  [
                    "emit",
                    "PageSelected",
                    {
                      "pageId": "@payload.pageId"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "ADD_PAGE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "PageNode",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "PageNodeAdded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "REORDER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.pageId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.slug",
                    "@payload.row.slug"
                  ],
                  [
                    "set",
                    "@entity.documentId",
                    "@payload.row.documentId"
                  ],
                  [
                    "set",
                    "@entity.iconName",
                    "@payload.row.iconName"
                  ],
                  [
                    "set",
                    "@entity.order",
                    "@payload.newOrder"
                  ],
                  [
                    "set",
                    "@entity.parentId",
                    "@payload.newParentId"
                  ],
                  [
                    "persist",
                    "update",
                    "PageNode",
                    "@entity",
                    {
                      "emit": {
                        "success": "PageNodeUpdated",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "DELETE_PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.pageId"
                  ],
                  [
                    "persist",
                    "delete",
                    "PageNode",
                    "@entity.id",
                    {
                      "emit": {
                        "success": "PageNodeDeleted",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PageSelected",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.pageId"
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PageNodeAdded",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "failure": "PageNodeLoadFailed",
                        "success": "PageNodeLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PageNodeUpdated",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "success": "PageNodeLoaded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PageNodeDeleted",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "failure": "PageNodeLoadFailed",
                        "success": "PageNodeLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "PageNodeLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "PageSelected",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.pageId"
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "PageNodeAdded",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "success": "PageNodeLoaded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "PageNodeUpdated",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "success": "PageNodeLoaded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "PageNodeDeleted",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "success": "PageNodeLoaded",
                        "failure": "PageNodeLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "error",
                "event": "PageNodeLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PageNode",
                    {
                      "emit": {
                        "failure": "PageNodeLoadFailed",
                        "success": "PageNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Pages"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "PageNodeBrowsePage",
          "path": "/pages/browse",
          "traits": [
            {
              "ref": "PageNodeBrowse"
            }
          ]
        }
      ]
    }
  ]
}
