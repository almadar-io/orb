{
  "name": "std-donation-receipt",
  "version": "1.0.0",
  "description": "std-donation-receipt — tax-deductible donation receipt atom. Owns a DonationReceipt entity with IRS-compliance fields (taxYear, taxDeductible, nonprofitEin). Browses receipts in a data-grid with Email / Void actions.",
  "orbitals": [
    {
      "name": "DonationReceiptOrbital",
      "entity": {
        "name": "DonationReceipt",
        "collection": "donationreceipts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "receiptNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "donorId",
            "type": "string",
            "required": true
          },
          {
            "name": "donorName",
            "type": "string",
            "default": ""
          },
          {
            "name": "campaignId",
            "type": "string",
            "default": ""
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0
          },
          {
            "name": "donationDate",
            "type": "string",
            "required": true
          },
          {
            "name": "taxYear",
            "type": "number",
            "default": 0
          },
          {
            "name": "taxDeductible",
            "type": "boolean",
            "default": true
          },
          {
            "name": "nonprofitEin",
            "type": "string",
            "default": ""
          },
          {
            "name": "isEmailed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "DonationReceiptIssuer",
          "category": "interaction",
          "linkedEntity": "DonationReceipt",
          "emits": [
            {
              "event": "EMAIL_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DonationReceiptLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DonationReceipt]"
                }
              ]
            },
            {
              "event": "DonationReceiptLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DonationReceiptLoaded",
                "name": "DonationReceipt loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DonationReceipt]"
                  }
                ]
              },
              {
                "key": "DonationReceiptLoadFailed",
                "name": "DonationReceipt load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EMAIL_RECEIPT",
                "name": "Email Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VOID_RECEIPT",
                "name": "Void Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "failure": "DonationReceiptLoadFailed",
                        "success": "DonationReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading donation receipts…"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DonationReceiptLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "receipt"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Donation Receipts"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "stats": [
                            {
                              "label": "Receipts issued",
                              "value": "1,248"
                            },
                            {
                              "value": "$482,300",
                              "label": "Total deductible"
                            },
                            {
                              "value": "2025",
                              "label": "Tax year"
                            },
                            {
                              "label": "Emailed",
                              "value": "94%"
                            }
                          ],
                          "type": "stats-grid",
                          "columns": 4
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Email",
                              "event": "EMAIL_RECEIPT",
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "event": "VOID_RECEIPT",
                              "label": "Void"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Receipt #",
                              "name": "receiptNumber"
                            },
                            {
                              "label": "Donor",
                              "name": "donorName",
                              "variant": "caption"
                            },
                            {
                              "label": "Amount",
                              "variant": "caption",
                              "name": "amount"
                            },
                            {
                              "label": "Date",
                              "name": "donationDate",
                              "variant": "caption"
                            },
                            {
                              "name": "taxYear",
                              "label": "Tax Year",
                              "variant": "caption"
                            },
                            {
                              "label": "Emailed",
                              "name": "isEmailed",
                              "variant": "badge"
                            }
                          ],
                          "type": "data-grid",
                          "gap": "sm"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DonationReceiptLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Receipt emailed",
                      "variant": "success",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "VOID_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Receipt voided",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DonationReceipt",
                    {
                      "emit": {
                        "success": "DonationReceiptLoaded",
                        "failure": "DonationReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Donation Receipts"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DonationReceiptPage",
          "path": "/donation-receipts",
          "traits": [
            {
              "ref": "DonationReceiptIssuer"
            }
          ]
        }
      ]
    }
  ]
}
