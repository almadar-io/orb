{
  "name": "std-wizard-form",
  "version": "1.0.0",
  "description": "std-wizard-form — canonical molecule-level wizard example",
  "orbitals": [
    {
      "name": "WizardFormOrbital",
      "entity": {
        "name": "WizardFormEntry",
        "collection": "wizardformentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "email",
            "type": "string"
          },
          {
            "name": "theme",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WizardFormFlow",
          "category": "interaction",
          "linkedEntity": "WizardFormEntry",
          "emits": [
            {
              "event": "WizardFormSaved",
              "description": "Fired when wizard flow completes successfully",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WizardFormSaveFailed",
              "description": "Fired when the final persist fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WizardFormEntryLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[WizardFormEntry]"
                }
              ]
            },
            {
              "event": "WizardFormEntryLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "personal",
                "isInitial": true
              },
              {
                "name": "preferences"
              },
              {
                "name": "review"
              },
              {
                "name": "persisting"
              },
              {
                "name": "complete"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NEXT",
                "name": "Next",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PREV",
                "name": "Prev"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "WizardFormSaved",
                "name": "Wizard form saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "WizardFormSaveFailed",
                "name": "Wizard form save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "WizardFormEntryLoaded",
                "name": "WizardFormEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[WizardFormEntry]"
                  }
                ]
              },
              {
                "key": "WizardFormEntryLoadFailed",
                "name": "WizardFormEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "personal",
                "to": "personal",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WizardFormEntry",
                    {
                      "emit": {
                        "success": "WizardFormEntryLoaded",
                        "failure": "WizardFormEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "Sign-up"
                        },
                        {
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress",
                          "currentStep": 0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "content": "Personal Info",
                          "type": "typography"
                        },
                        {
                          "type": "form-section",
                          "mode": "create",
                          "fields": [
                            "name",
                            "email"
                          ],
                          "submitEvent": "NEXT",
                          "cancelEvent": "INIT"
                        },
                        {
                          "showBack": false,
                          "currentStep": 0,
                          "type": "wizard-navigation",
                          "showComplete": false,
                          "showNext": true,
                          "onNext": "NEXT",
                          "totalSteps": 3
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "max-w-xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "personal",
                "to": "preferences",
                "event": "NEXT",
                "effects": [
                  [
                    "set",
                    "@entity.name",
                    "@payload.data.name"
                  ],
                  [
                    "set",
                    "@entity.email",
                    "@payload.data.email"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "max-w-xl mx-auto w-full",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Sign-up",
                          "variant": "h2"
                        },
                        {
                          "currentStep": 1,
                          "type": "wizard-progress",
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Preferences"
                        },
                        {
                          "mode": "edit",
                          "type": "form-section",
                          "cancelEvent": "PREV",
                          "submitEvent": "NEXT",
                          "entity": "@entity",
                          "fields": [
                            "theme"
                          ]
                        },
                        {
                          "currentStep": 1,
                          "showNext": true,
                          "onNext": "NEXT",
                          "showComplete": false,
                          "totalSteps": 3,
                          "type": "wizard-navigation",
                          "showBack": true,
                          "onBack": "PREV"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "preferences",
                "to": "review",
                "event": "NEXT",
                "effects": [
                  [
                    "set",
                    "@entity.theme",
                    "@payload.data.theme"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "content": "Sign-up",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress",
                          "currentStep": 2
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Review"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Name",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.name",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "justify": "between",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "justify": "between",
                              "children": [
                                {
                                  "content": "Email",
                                  "variant": "caption",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.email",
                                  "variant": "body",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "variant": "caption",
                                  "content": "Theme",
                                  "type": "typography"
                                },
                                {
                                  "content": "@entity.theme",
                                  "type": "typography",
                                  "variant": "body"
                                }
                              ],
                              "gap": "md",
                              "justify": "between",
                              "type": "stack"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "showNext": false,
                          "totalSteps": 3,
                          "onBack": "PREV",
                          "onComplete": "COMPLETE",
                          "currentStep": 2,
                          "showBack": true,
                          "showComplete": true,
                          "type": "wizard-navigation"
                        }
                      ],
                      "gap": "lg",
                      "className": "max-w-xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "preferences",
                "to": "personal",
                "event": "PREV",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "variant": "h2",
                          "content": "Sign-up",
                          "type": "typography"
                        },
                        {
                          "type": "wizard-progress",
                          "currentStep": 0,
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "h3",
                          "content": "Personal Info",
                          "type": "typography"
                        },
                        {
                          "entity": "@entity",
                          "submitEvent": "NEXT",
                          "mode": "edit",
                          "cancelEvent": "INIT",
                          "type": "form-section",
                          "fields": [
                            "name",
                            "email"
                          ]
                        },
                        {
                          "onNext": "NEXT",
                          "showComplete": false,
                          "showNext": true,
                          "totalSteps": 3,
                          "showBack": false,
                          "type": "wizard-navigation",
                          "currentStep": 0
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "className": "max-w-xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "review",
                "to": "persisting",
                "event": "COMPLETE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "WizardFormEntry",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "WizardFormSaveFailed",
                        "success": "WizardFormSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Completing sign-up…"
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full py-12",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "review",
                "to": "preferences",
                "event": "PREV",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Sign-up"
                        },
                        {
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ],
                          "type": "wizard-progress",
                          "currentStep": 1
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Preferences",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "entity": "@entity",
                          "type": "form-section",
                          "mode": "edit",
                          "submitEvent": "NEXT",
                          "cancelEvent": "PREV",
                          "fields": [
                            "theme"
                          ]
                        },
                        {
                          "showBack": true,
                          "showComplete": false,
                          "onNext": "NEXT",
                          "showNext": true,
                          "currentStep": 1,
                          "onBack": "PREV",
                          "type": "wizard-navigation",
                          "totalSteps": 3
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "complete",
                "event": "WizardFormSaved",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "className": "max-w-xl mx-auto w-full py-12",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Welcome!",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "type": "typography",
                          "content": "Your account has been created.",
                          "variant": "body",
                          "color": "muted"
                        },
                        {
                          "action": "RESTART",
                          "type": "button",
                          "label": "Start Over",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "review",
                "event": "WizardFormSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "max-w-xl mx-auto w-full py-12",
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h2",
                          "content": "Sign-up Failed",
                          "type": "typography"
                        },
                        {
                          "message": "@payload.error",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary",
                          "icon": "refresh-cw",
                          "action": "COMPLETE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "personal",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Sign-up",
                          "type": "typography",
                          "variant": "h2"
                        },
                        {
                          "currentStep": 0,
                          "type": "wizard-progress",
                          "steps": [
                            "Personal",
                            "Preferences",
                            "Review"
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Personal Info",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "mode": "create",
                          "cancelEvent": "INIT",
                          "submitEvent": "NEXT",
                          "fields": [
                            "name",
                            "email"
                          ],
                          "type": "form-section"
                        },
                        {
                          "onNext": "NEXT",
                          "showBack": false,
                          "totalSteps": 3,
                          "type": "wizard-navigation",
                          "showNext": true,
                          "currentStep": 0,
                          "showComplete": false
                        }
                      ],
                      "className": "max-w-xl mx-auto w-full",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "WizardForm",
          "path": "/wizard-form",
          "traits": [
            {
              "ref": "WizardFormFlow"
            }
          ]
        }
      ]
    }
  ]
}
