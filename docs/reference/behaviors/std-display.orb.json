{
  "name": "std-display",
  "version": "1.1.0",
  "description": "std-display — DEPRECATED. Use std-stats (stat-cards) + std-graphs (charts) composed in a molecule (see std-dashboard); the original violated the explicit-binding rule. Preserved so existing imports keep loading.",
  "orbitals": [
    {
      "name": "DisplayItemOrbital",
      "entity": {
        "name": "DisplayItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DisplayItemDisplay",
          "category": "interaction",
          "linkedEntity": "DisplayItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "std-display is deprecated",
                      "message": "std-display is deprecated — use std-stats and std-graphs instead. See docs/Almadar_Std_Verification.md gap #25.",
                      "type": "alert",
                      "variant": "warning"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "message": {
              "type": "string",
              "default": "std-display is deprecated — use std-stats and std-graphs instead. See docs/Almadar_Std_Verification.md gap #25."
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DisplayItemDisplayPage",
          "path": "/displayitems",
          "traits": [
            {
              "ref": "DisplayItemDisplay"
            }
          ]
        }
      ]
    }
  ]
}
