{
  "name": "std-customer-account",
  "version": "1.0.0",
  "description": "Retail customer profile primitive with purchase history reference, store credit, and loyalty points.",
  "orbitals": [
    {
      "name": "CustomerAccountOrbital",
      "entity": {
        "name": "CustomerAccount",
        "collection": "customeraccounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "loyaltyPoints",
            "type": "number",
            "default": 0
          },
          {
            "name": "storeCreditAmount",
            "type": "number",
            "default": 0
          },
          {
            "name": "totalSpent",
            "type": "number",
            "default": 0
          },
          {
            "name": "joinedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastVisitAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "banned"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "CustomerAccountDirectory",
          "category": "interaction",
          "linkedEntity": "CustomerAccount",
          "emits": [
            {
              "event": "GRANT_POINTS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "GRANT_CREDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CustomerAccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CustomerAccount]"
                }
              ]
            },
            {
              "event": "CustomerAccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CustomerAccountLoaded",
                "name": "CustomerAccount loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CustomerAccount]"
                  }
                ]
              },
              {
                "key": "CustomerAccountLoadFailed",
                "name": "CustomerAccount load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GRANT_POINTS",
                "name": "Grant Points",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "GRANT_CREDIT",
                "name": "Grant Credit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CustomerAccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "data": [
                            {
                              "name": "Receipt #1024",
                              "imageUrl": "https://picsum.photos/seed/receipt1/400/300",
                              "id": "r1"
                            },
                            {
                              "name": "Receipt #1025",
                              "id": "r2",
                              "imageUrl": "https://picsum.photos/seed/receipt2/400/300"
                            },
                            {
                              "id": "r3",
                              "imageUrl": "https://picsum.photos/seed/receipt3/400/300",
                              "name": "Receipt #1026"
                            },
                            {
                              "name": "Receipt #1027",
                              "id": "r4",
                              "imageUrl": "https://picsum.photos/seed/receipt4/400/300"
                            }
                          ],
                          "type": "media-gallery"
                        },
                        {
                          "height": "h-48",
                          "back": {
                            "direction": "vertical",
                            "children": [
                              {
                                "type": "typography",
                                "variant": "h4",
                                "content": "2,450 points"
                              },
                              {
                                "type": "typography",
                                "variant": "body",
                                "content": "Next reward at 3,000 points"
                              }
                            ],
                            "align": "center",
                            "type": "stack",
                            "gap": "sm"
                          },
                          "front": {
                            "children": [
                              {
                                "name": "award",
                                "type": "icon"
                              },
                              {
                                "variant": "h4",
                                "type": "typography",
                                "content": "Loyalty Tier: Gold"
                              },
                              {
                                "variant": "caption",
                                "color": "muted",
                                "content": "Tap to view points",
                                "type": "typography"
                              }
                            ],
                            "align": "center",
                            "gap": "sm",
                            "direction": "vertical",
                            "type": "stack"
                          },
                          "type": "flip-card"
                        },
                        {
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Add Points",
                              "event": "GRANT_POINTS",
                              "variant": "primary"
                            },
                            {
                              "variant": "ghost",
                              "label": "Issue Credit",
                              "event": "GRANT_CREDIT"
                            }
                          ],
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name",
                              "variant": "h4"
                            },
                            {
                              "variant": "body",
                              "label": "Email",
                              "name": "email"
                            },
                            {
                              "label": "Phone",
                              "name": "phone",
                              "variant": "caption"
                            },
                            {
                              "label": "Points",
                              "variant": "caption",
                              "name": "loyaltyPoints"
                            },
                            {
                              "name": "totalSpent",
                              "label": "Total Spent",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CustomerAccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "GRANT_POINTS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Points granted",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "GRANT_CREDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Store credit issued",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CustomerAccount",
                    {
                      "emit": {
                        "success": "CustomerAccountLoaded",
                        "failure": "CustomerAccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Customers"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CustomerAccountPage",
          "path": "/customers",
          "traits": [
            {
              "ref": "CustomerAccountDirectory"
            }
          ]
        }
      ]
    }
  ]
}
