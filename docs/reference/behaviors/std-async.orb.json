{
  "name": "AsyncTaskOrbital",
  "orbitals": [
    {
      "name": "AsyncTaskOrbital",
      "entity": {
        "name": "AsyncTask",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "AsyncTaskAsync",
          "category": "interaction",
          "linkedEntity": "AsyncTask",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "success"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "START"
              },
              {
                "key": "LOADED"
              },
              {
                "key": "FAILED"
              },
              {
                "key": "RESET"
              },
              {
                "key": "RETRY"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AsyncTask"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "size": "lg",
                              "name": "loader",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "AsyncTask",
                              "variant": "h2"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "content": "Ready to start asynctask operation.",
                          "type": "typography"
                        },
                        {
                          "label": "Start",
                          "variant": "primary",
                          "icon": "play",
                          "type": "button",
                          "event": "START"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "loading",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "title": "Loading...",
                          "message": "Processing asynctask...",
                          "type": "loading-state"
                        },
                        {
                          "type": "skeleton",
                          "variant": "text"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "success",
                "event": "LOADED",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AsyncTask",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "size": "lg",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "message": "Operation completed successfully.",
                          "variant": "success"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "type": "button",
                              "event": "RESET",
                              "label": "Reset"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center"
                    }
                  ],
                  [
                    "notify",
                    "AsyncTask created successfully"
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "onRetry": "RETRY",
                          "type": "error-state",
                          "title": "Operation Failed",
                          "message": "An error occurred. Please try again."
                        },
                        {
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Retry",
                              "type": "button",
                              "event": "RETRY",
                              "icon": "refresh-cw",
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "label": "Reset",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "event": "RESET"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "success",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "name": "loader",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "content": "AsyncTask",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "content": "Ready to start asynctask operation.",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "label": "Start",
                          "event": "START",
                          "icon": "play",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "loader"
                            },
                            {
                              "type": "typography",
                              "content": "AsyncTask",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "content": "Ready to start asynctask operation.",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "event": "START",
                          "icon": "play",
                          "label": "Start"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "title": "Loading...",
                          "message": "Processing asynctask...",
                          "type": "loading-state"
                        },
                        {
                          "variant": "text",
                          "type": "skeleton"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Asynctasks",
          "path": "/asynctasks",
          "traits": [
            {
              "ref": "AsyncTaskAsync"
            }
          ]
        }
      ]
    }
  ]
}
