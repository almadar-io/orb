{
  "name": "std-calendar",
  "version": "1.0.0",
  "description": "std-calendar as a Function",
  "orbitals": [
    {
      "name": "CalendarEventOrbital",
      "entity": {
        "name": "CalendarEvent",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "date",
            "type": "string",
            "default": ""
          },
          {
            "name": "time",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 60
          }
        ]
      },
      "traits": [
        {
          "name": "CalendarEventCalendar",
          "category": "interaction",
          "linkedEntity": "CalendarEvent",
          "emits": [
            {
              "event": "CalendarEventLoaded",
              "description": "Fired when CalendarEvent finishes loading; payload.data holds the events",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CalendarEvent]"
                }
              ]
            },
            {
              "event": "CalendarEventLoadFailed",
              "description": "Fired when CalendarEvent fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "month-view"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CalendarEventLoaded",
                "name": "CalendarEvent loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CalendarEvent]"
                  }
                ]
              },
              {
                "key": "CalendarEventLoadFailed",
                "name": "CalendarEvent load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT_DAY",
                "name": "Select Day",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELECT_SLOT",
                "name": "Select Slot",
                "payloadSchema": [
                  {
                    "name": "time",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "failure": "CalendarEventLoadFailed",
                        "success": "CalendarEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading calendar…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "month-view",
                "event": "CalendarEventLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "calendar",
                                  "type": "icon"
                                },
                                {
                                  "content": "CalendarEvents Calendar",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "gap": "sm"
                            },
                            {
                              "type": "date-range-selector",
                              "onSelect": "SELECT_DAY"
                            }
                          ],
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "calendar-grid"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "h4",
                          "content": "Upcoming Events"
                        },
                        {
                          "fields": [
                            {
                              "icon": "calendar",
                              "variant": "h4",
                              "name": "name",
                              "label": "Event"
                            },
                            {
                              "variant": "badge",
                              "name": "time",
                              "label": "Time"
                            },
                            {
                              "variant": "caption",
                              "format": "date",
                              "label": "Date",
                              "name": "date"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "SELECT_DAY",
                              "label": "View",
                              "icon": "eye"
                            }
                          ],
                          "type": "data-list"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CalendarEventLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to load"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "action": "INIT",
                          "label": "Retry"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "month-view",
                "to": "loading",
                "event": "SELECT_DAY",
                "effects": [
                  [
                    "set",
                    "@entity.date",
                    "@payload.value"
                  ],
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "success": "CalendarEventLoaded",
                        "failure": "CalendarEventLoadFailed"
                      },
                      "filter": [
                        "=",
                        "@entity.date",
                        "@payload.value"
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CalendarEvent",
                    {
                      "emit": {
                        "success": "CalendarEventLoaded",
                        "failure": "CalendarEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CalendarEventCalendarPage",
          "path": "/calendarevents/calendar",
          "traits": [
            {
              "ref": "CalendarEventCalendar"
            }
          ]
        }
      ]
    }
  ]
}
