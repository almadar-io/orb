{
  "name": "std-collision",
  "version": "1.0.0",
  "description": "std-collision as a Function",
  "orbitals": [
    {
      "name": "CollidableBodyOrbital",
      "entity": {
        "name": "CollidableBody",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "x",
            "type": "number",
            "default": 0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0
          },
          {
            "name": "collisionStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "targetId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CollidableBodyCollision",
          "category": "interaction",
          "linkedEntity": "CollidableBody",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "detecting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CHECK",
                "name": "Check"
              },
              {
                "key": "COLLISION_DETECTED",
                "name": "Collision Detected",
                "payloadSchema": [
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "crosshair"
                                },
                                {
                                  "content": "CollidableBody Collision",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "status": "offline",
                              "type": "status-dot",
                              "label": "Idle"
                            }
                          ],
                          "gap": "md",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 2,
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.x",
                              "label": "X",
                              "type": "stat-display"
                            },
                            {
                              "type": "stat-display",
                              "value": "@entity.y",
                              "label": "Y"
                            }
                          ]
                        },
                        {
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "icon": "scan",
                              "type": "button",
                              "variant": "primary",
                              "action": "CHECK",
                              "label": "Check"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "detecting",
                "event": "CHECK",
                "effects": [
                  [
                    "set",
                    "@entity.collisionStatus",
                    "detecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "md",
                              "align": "center",
                              "children": [
                                {
                                  "name": "crosshair",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "CollidableBody Collision",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "status-dot",
                              "status": "warning",
                              "pulse": true,
                              "label": "Detecting"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "warning",
                          "message": "Collision detection in progress..."
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.x",
                              "label": "X"
                            },
                            {
                              "label": "Y",
                              "value": "@entity.y",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 2,
                          "type": "simple-grid"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.targetId",
                          "color": "muted",
                          "variant": "caption"
                        },
                        {
                          "children": [
                            {
                              "icon": "x",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Clear",
                              "action": "CLEAR"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center",
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "detecting",
                "to": "detecting",
                "event": "COLLISION_DETECTED",
                "effects": [
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.targetId"
                  ],
                  [
                    "set",
                    "@entity.collisionStatus",
                    "detected"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "crosshair",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "CollidableBody Collision",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "label": "Detecting",
                              "status": "warning",
                              "pulse": true,
                              "type": "status-dot"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "warning",
                          "type": "alert",
                          "message": "Collision detection in progress..."
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2,
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.x",
                              "label": "X"
                            },
                            {
                              "type": "stat-display",
                              "label": "Y",
                              "value": "@entity.y"
                            }
                          ]
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "@entity.targetId",
                          "type": "typography"
                        },
                        {
                          "justify": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "ghost",
                              "icon": "x",
                              "label": "Clear",
                              "type": "button",
                              "action": "CLEAR"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "detecting",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "set",
                    "@entity.collisionStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.targetId",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "crosshair"
                                },
                                {
                                  "variant": "h2",
                                  "content": "CollidableBody Collision",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "status-dot",
                              "label": "Idle",
                              "status": "offline"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "value": "@entity.x",
                              "label": "X",
                              "type": "stat-display"
                            },
                            {
                              "label": "Y",
                              "type": "stat-display",
                              "value": "@entity.y"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "primary",
                              "icon": "scan",
                              "action": "CHECK",
                              "type": "button",
                              "label": "Check"
                            }
                          ],
                          "justify": "center"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "detecting",
                "to": "detecting",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "crosshair"
                                },
                                {
                                  "content": "CollidableBody Collision",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "label": "Detecting",
                              "status": "warning",
                              "pulse": true,
                              "type": "status-dot"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "warning",
                          "message": "Collision detection in progress..."
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "value": "@entity.x",
                              "label": "X",
                              "type": "stat-display"
                            },
                            {
                              "label": "Y",
                              "type": "stat-display",
                              "value": "@entity.y"
                            }
                          ],
                          "cols": 2
                        },
                        {
                          "color": "muted",
                          "content": "@entity.targetId",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "label": "Clear",
                              "action": "CLEAR",
                              "icon": "x",
                              "variant": "ghost"
                            }
                          ],
                          "justify": "center",
                          "gap": "sm"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CollidableBodyCollisionPage",
          "path": "/collidablebodys/collision",
          "traits": [
            {
              "ref": "CollidableBodyCollision"
            }
          ]
        }
      ]
    }
  ]
}
