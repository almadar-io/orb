{
  "name": "std-game-canvas2d",
  "version": "1.0.0",
  "description": "std-game-canvas2d as a Function",
  "orbitals": [
    {
      "name": "GameCanvas2dOrbital",
      "entity": {
        "name": "GameCanvas2d",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "GameCanvas2dGameCanvas2d",
          "category": "interaction",
          "linkedEntity": "GameCanvas2d",
          "emits": [
            {
              "event": "GameCanvas2dLoaded",
              "description": "Fired when GameCanvas2d finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GameCanvas2dLoadFailed",
              "description": "Fired when GameCanvas2d fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "rendering"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "TICK",
                "name": "Tick"
              },
              {
                "key": "STOP",
                "name": "Stop"
              },
              {
                "key": "GameCanvas2dLoaded",
                "name": "GameCanvas2d loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GameCanvas2dLoadFailed",
                "name": "GameCanvas2d load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GameCanvas2d",
                    {
                      "emit": {
                        "failure": "GameCanvas2dLoadFailed",
                        "success": "GameCanvas2dLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "monitor",
                              "type": "icon"
                            },
                            {
                              "content": "GameCanvas2d Canvas",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "800x600 @ 60fps"
                        },
                        {
                          "type": "game-canvas-2d",
                          "width": 800,
                          "fps": 60,
                          "height": 600
                        },
                        {
                          "type": "button",
                          "icon": "play",
                          "action": "START",
                          "variant": "primary",
                          "label": "Start"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "rendering",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "monitor"
                            },
                            {
                              "variant": "h3",
                              "content": "GameCanvas2d Canvas",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "fps": 60,
                          "width": 800,
                          "height": 600,
                          "type": "game-canvas-2d"
                        },
                        {
                          "action": "STOP",
                          "icon": "square",
                          "variant": "ghost",
                          "label": "Stop",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "rendering",
                "to": "rendering",
                "event": "TICK"
              },
              {
                "from": "rendering",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "monitor",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "GameCanvas2d Canvas",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "color": "muted",
                          "content": "800x600 @ 60fps",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "height": 600,
                          "fps": 60,
                          "type": "game-canvas-2d",
                          "width": 800
                        },
                        {
                          "variant": "primary",
                          "action": "START",
                          "type": "button",
                          "label": "Start",
                          "icon": "play"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameCanvas2dCanvas2dPage",
          "path": "/gamecanvas2ds",
          "traits": [
            {
              "ref": "GameCanvas2dGameCanvas2d"
            }
          ]
        }
      ]
    }
  ]
}
