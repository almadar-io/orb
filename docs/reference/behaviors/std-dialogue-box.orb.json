{
  "name": "std-dialogue-box",
  "version": "1.0.0",
  "description": "std-dialogue-box as a Function",
  "orbitals": [
    {
      "name": "DialogueNodeOrbital",
      "entity": {
        "name": "DialogueNode",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "speaker",
            "type": "string",
            "default": "Narrator"
          },
          {
            "name": "text",
            "type": "string",
            "default": "Welcome, adventurer. Your journey begins here."
          }
        ]
      },
      "traits": [
        {
          "name": "DialogueNodeDialogue",
          "category": "interaction",
          "linkedEntity": "DialogueNode",
          "emits": [
            {
              "event": "DialogueNodeLoaded",
              "description": "Fired when DialogueNode finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "speaker",
                  "type": "string"
                },
                {
                  "name": "text",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DialogueNodeLoadFailed",
              "description": "Fired when DialogueNode fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "talking",
                "isInitial": true
              },
              {
                "name": "idle"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ADVANCE",
                "name": "Advance"
              },
              {
                "key": "CHOICE",
                "name": "Choice",
                "payloadSchema": [
                  {
                    "name": "choiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "START_DIALOGUE",
                "name": "Start Dialogue"
              },
              {
                "key": "DialogueNodeLoaded",
                "name": "DialogueNode loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "speaker",
                    "type": "string"
                  },
                  {
                    "name": "text",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DialogueNodeLoadFailed",
                "name": "DialogueNode load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "talking",
                "to": "talking",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DialogueNode",
                    {
                      "emit": {
                        "success": "DialogueNodeLoaded",
                        "failure": "DialogueNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "set",
                    "@entity.speaker",
                    "Narrator"
                  ],
                  [
                    "set",
                    "@entity.text",
                    "Welcome, adventurer. Your journey begins here."
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "position": "bottom",
                      "type": "dialogue-box",
                      "dialogue": {
                        "speaker": "@entity.speaker",
                        "text": "@entity.text"
                      },
                      "typewriterSpeed": 30
                    }
                  ]
                ]
              },
              {
                "from": "talking",
                "to": "talking",
                "event": "ADVANCE",
                "effects": [
                  [
                    "fetch",
                    "DialogueNode",
                    {
                      "emit": {
                        "failure": "DialogueNodeLoadFailed",
                        "success": "DialogueNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "position": "bottom",
                      "type": "dialogue-box",
                      "typewriterSpeed": 30,
                      "dialogue": {
                        "text": "@entity.text",
                        "speaker": "@entity.speaker"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "talking",
                "to": "talking",
                "event": "CHOICE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "position": "bottom",
                      "type": "dialogue-box",
                      "typewriterSpeed": 30,
                      "dialogue": {
                        "text": "@entity.text",
                        "speaker": "@entity.speaker"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "talking",
                "to": "idle",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Dialogue complete",
                          "variant": "caption"
                        },
                        {
                          "variant": "primary",
                          "action": "START_DIALOGUE",
                          "label": "New Dialogue",
                          "icon": "message-circle",
                          "type": "button"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "talking",
                "event": "START_DIALOGUE",
                "effects": [
                  [
                    "fetch",
                    "DialogueNode",
                    {
                      "emit": {
                        "failure": "DialogueNodeLoadFailed",
                        "success": "DialogueNodeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "position": "bottom",
                      "typewriterSpeed": 30,
                      "dialogue": {
                        "text": "@entity.text",
                        "speaker": "@entity.speaker"
                      },
                      "type": "dialogue-box"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DialogueNodeDialoguePage",
          "path": "/dialoguenodes",
          "traits": [
            {
              "ref": "DialogueNodeDialogue"
            }
          ]
        }
      ]
    }
  ]
}
