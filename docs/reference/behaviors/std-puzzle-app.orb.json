                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "score": "@entity.score",
                          "multiplier": "@entity.multiplier",
                          "highScore": "@entity.highScore",
                          "level": "@entity.level",
                          "combo": "@entity.combo",
                          "type": "score-board"
                        }
                      ],
                      "appName": "Puzzle App"
