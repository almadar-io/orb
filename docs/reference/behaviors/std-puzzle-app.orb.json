                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
