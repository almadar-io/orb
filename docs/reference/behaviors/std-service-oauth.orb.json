{
  "name": "std-service-oauth",
  "version": "1.0.0",
  "description": "std-service-oauth as a Function",
  "orbitals": [
    {
      "name": "ServiceOauthOrbital",
      "entity": {
        "name": "ServiceOauth",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "provider",
            "type": "string",
            "default": "google"
          },
          {
            "name": "authUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "accessToken",
            "type": "string",
            "default": ""
          },
          {
            "name": "refreshToken",
            "type": "string",
            "default": ""
          },
          {
            "name": "authStatus",
            "type": "string",
            "default": "unauthenticated"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceOauthOauth",
          "category": "interaction",
          "linkedEntity": "ServiceOauth",
          "emits": [
            {
              "event": "ServiceOauthLoaded",
              "description": "Fired when ServiceOauth finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "provider",
                  "type": "string"
                },
                {
                  "name": "authUrl",
                  "type": "string"
                },
                {
                  "name": "accessToken",
                  "type": "string"
                },
                {
                  "name": "refreshToken",
                  "type": "string"
                },
                {
                  "name": "authStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceOauthLoadFailed",
              "description": "Fired when ServiceOauth fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceOauthOauthCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceOauthOauthFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "unauthenticated",
                "isInitial": true
              },
              {
                "name": "authorizing"
              },
              {
                "name": "authenticated"
              },
              {
                "name": "refreshing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOGIN",
                "name": "Login"
              },
              {
                "key": "AUTH_URL_RECEIVED",
                "name": "Auth Url Received",
                "payloadSchema": [
                  {
                    "name": "authUrl",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CALLBACK",
                "name": "Callback",
                "payloadSchema": [
                  {
                    "name": "code",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TOKEN_RECEIVED",
                "name": "Token Received",
                "payloadSchema": [
                  {
                    "name": "accessToken",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "refreshToken",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "LOGOUT",
                "name": "Logout"
              },
              {
                "key": "TOKEN_REFRESHED",
                "name": "Token Refreshed",
                "payloadSchema": [
                  {
                    "name": "accessToken",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceOauthLoaded",
                "name": "ServiceOauth loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "provider",
                    "type": "string"
                  },
                  {
                    "name": "authUrl",
                    "type": "string"
                  },
                  {
                    "name": "accessToken",
                    "type": "string"
                  },
                  {
                    "name": "refreshToken",
                    "type": "string"
                  },
                  {
                    "name": "authStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceOauthLoadFailed",
                "name": "ServiceOauth load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceOauthOauthCompleted",
                "name": "ServiceOauth oauth completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceOauthOauthFailed",
                "name": "ServiceOauth oauth failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "unauthenticated",
                "to": "unauthenticated",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    "google"
                  ],
                  [
                    "fetch",
                    "ServiceOauth",
                    {
                      "emit": {
                        "failure": "ServiceOauthLoadFailed",
                        "success": "ServiceOauthLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "lock",
                              "type": "icon"
                            },
                            {
                              "content": "Sign In",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "label": "Google",
                              "value": "google"
                            },
                            {
                              "label": "GitHub",
                              "value": "github"
                            },
                            {
                              "value": "microsoft",
                              "label": "Microsoft"
                            }
                          ]
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "label": "Login",
                          "action": "LOGIN",
                          "icon": "log-in"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "unauthenticated",
                "to": "authorizing",
                "event": "LOGIN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Authorizing...",
                      "message": "Redirecting to provider for authorization.",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "oauth",
                    "authorize",
                    {
                      "scopes": [
                        "openid",
                        "email"
                      ],
                      "provider": "@entity.provider"
                    },
                    {
                      "emit": {
                        "failure": "ServiceOauthOauthFailed",
                        "success": "ServiceOauthOauthCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "authorizing",
                "event": "AUTH_URL_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.authUrl",
                    "@payload.authUrl"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "external-link"
                        },
                        {
                          "type": "typography",
                          "content": "Authorization Required",
                          "variant": "h2"
                        },
                        {
                          "variant": "body",
                          "content": "@entity.authUrl",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "type": "input",
                          "placeholder": "Paste authorization code here"
                        },
                        {
                          "icon": "check",
                          "label": "Submit",
                          "type": "button",
                          "variant": "primary",
                          "action": "CALLBACK"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "authenticated",
                "event": "CALLBACK",
                "effects": [
                  [
                    "call-service",
                    "oauth",
                    "token",
                    {
                      "code": "@payload.code"
                    },
                    {
                      "emit": {
                        "failure": "ServiceOauthOauthFailed",
                        "success": "ServiceOauthOauthCompleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "success",
                          "message": "Authenticated successfully",
                          "type": "alert"
                        },
                        {
                          "justify": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "label": "Refresh Token",
                              "icon": "refresh-cw",
                              "action": "REFRESH",
                              "variant": "ghost"
                            },
                            {
                              "label": "Logout",
                              "icon": "log-out",
                              "type": "button",
                              "variant": "ghost",
                              "action": "LOGOUT"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "authorizing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "onRetry": "RETRY",
                          "title": "Authentication Failed",
                          "type": "error-state",
                          "message": "@entity.error"
                        },
                        {
                          "action": "RETRY",
                          "label": "Try Again",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "authenticated",
                "event": "TOKEN_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.accessToken",
                    "@payload.accessToken"
                  ],
                  [
                    "set",
                    "@entity.refreshToken",
                    "@payload.refreshToken"
                  ],
                  [
                    "set",
                    "@entity.authStatus",
                    "authenticated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Authenticated successfully",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "label": "Refresh Token",
                              "icon": "refresh-cw",
                              "action": "REFRESH",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "icon": "log-out",
                              "type": "button",
                              "action": "LOGOUT",
                              "variant": "ghost",
                              "label": "Logout"
                            }
                          ],
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal"
                        }
                      ],
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "refreshing",
                "event": "REFRESH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Obtaining a new access token.",
                      "title": "Refreshing token..."
                    }
                  ],
                  [
                    "call-service",
                    "oauth",
                    "refresh",
                    {
                      "refreshToken": "@entity.refreshToken"
                    },
                    {
                      "emit": {
                        "success": "ServiceOauthOauthCompleted",
                        "failure": "ServiceOauthOauthFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "unauthenticated",
                "event": "LOGOUT",
                "effects": [
                  [
                    "set",
                    "@entity.authStatus",
                    "unauthenticated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "content": "Sign In",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "google",
                              "label": "Google"
                            },
                            {
                              "label": "GitHub",
                              "value": "github"
                            },
                            {
                              "label": "Microsoft",
                              "value": "microsoft"
                            }
                          ]
                        },
                        {
                          "variant": "primary",
                          "label": "Login",
                          "type": "button",
                          "icon": "log-in",
                          "action": "LOGIN"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "refreshing",
                "to": "authenticated",
                "event": "TOKEN_REFRESHED",
                "effects": [
                  [
                    "set",
                    "@entity.accessToken",
                    "@payload.accessToken"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "message": "Authenticated successfully",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "icon": "refresh-cw",
                              "label": "Refresh Token",
                              "type": "button",
                              "variant": "ghost",
                              "action": "REFRESH"
                            },
                            {
                              "variant": "ghost",
                              "action": "LOGOUT",
                              "icon": "log-out",
                              "label": "Logout",
                              "type": "button"
                            }
                          ],
                          "justify": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "refreshing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "title": "Authentication Failed",
                          "onRetry": "RETRY",
                          "type": "error-state",
                          "message": "@entity.error"
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "action": "RETRY",
                          "label": "Try Again"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "unauthenticated",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Sign In"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "options": [
                            {
                              "label": "Google",
                              "value": "google"
                            },
                            {
                              "value": "github",
                              "label": "GitHub"
                            },
                            {
                              "label": "Microsoft",
                              "value": "microsoft"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "type": "button",
                          "icon": "log-in",
                          "label": "Login",
                          "action": "LOGIN",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceOauthPage",
          "path": "/serviceoauths",
          "traits": [
            {
              "ref": "ServiceOauthOauth"
            }
          ]
        }
      ]
    }
  ]
}
