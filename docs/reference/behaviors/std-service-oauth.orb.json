{
  "name": "std-service-oauth",
  "version": "2.0.0",
  "description": "std-service-oauth — OAuth sign-in service. Bind via `uses Oauth from \"std/behaviors/std-service-oauth\"` and configure `provider` / `scopes` / `redirectUri` at the call site. Pass `uiTrait: \"@trait.YourLoginForm\"` to inject your own provider button; leave unset to render the atom's default sign-in form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceOauthOrbital",
      "entity": {
        "name": "ServiceOauth",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "provider",
            "type": "string",
            "default": "google"
          },
          {
            "name": "accessToken",
            "type": "string",
            "default": ""
          },
          {
            "name": "authStatus",
            "type": "string",
            "default": "unauthenticated"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceOauthDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "LOGIN",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOGIN",
                "name": "Login"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "lock"
                            },
                            {
                              "variant": "h2",
                              "content": "Sign In",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "options": [
                            {
                              "value": "google",
                              "label": "Google"
                            },
                            {
                              "label": "GitHub",
                              "value": "github"
                            },
                            {
                              "label": "Microsoft",
                              "value": "microsoft"
                            },
                            {
                              "value": "okta",
                              "label": "Okta"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "icon": "log-in",
                          "type": "button",
                          "label": "Sign in with provider",
                          "action": "LOGIN",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceOauthOauth",
          "category": "interaction",
          "linkedEntity": "ServiceOauth",
          "emits": [
            {
              "event": "ServiceOauthLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceOauthLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "OAuthLoggedIn",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "accessToken",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceOauthOauthFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "LOGIN",
              "triggers": "LOGIN",
              "source": {
                "kind": "trait",
                "trait": "ServiceOauthDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "authenticating"
              },
              {
                "name": "authenticated"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LOGIN",
                "name": "Login"
              },
              {
                "key": "ServiceOauthLoaded",
                "name": "ServiceOauth loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceOauthLoadFailed",
                "name": "ServiceOauth load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OAuthLoggedIn",
                "name": "OAuth logged in",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "accessToken",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceOauthOauthFailed",
                "name": "ServiceOauth oauth failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    "google"
                  ],
                  [
                    "fetch",
                    "ServiceOauth",
                    {
                      "emit": {
                        "success": "ServiceOauthLoaded",
                        "failure": "ServiceOauthLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        "@trait.ServiceOauthDefaultForm"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "authenticating",
                "event": "LOGIN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Signing in...",
                      "type": "loading-state",
                      "message": "Authenticating with provider."
                    }
                  ],
                  [
                    "call-service",
                    "oauth",
                    "authorize",
                    {
                      "scopes": [],
                      "provider": "google",
                      "redirectUri": ""
                    },
                    {
                      "emit": {
                        "success": "OAuthLoggedIn",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceOauthLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceOauthLoadFailed"
              },
              {
                "from": "authenticating",
                "to": "authenticated",
                "event": "OAuthLoggedIn",
                "effects": [
                  [
                    "set",
                    "@entity.accessToken",
                    "@payload.accessToken"
                  ],
                  [
                    "set",
                    "@entity.authStatus",
                    "authenticated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Signed in successfully"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.accessToken"
                        },
                        {
                          "variant": "ghost",
                          "label": "Sign Out",
                          "icon": "log-out",
                          "action": "RESET",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "authenticating",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceOauthOauthFailed",
                    {
                      "code": "oauth_login_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "type": "error-state",
                      "message": "@entity.error",
                      "title": "Sign In Failed"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.authStatus",
                    "unauthenticated"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        "@trait.ServiceOauthDefaultForm"
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "authenticated",
                "to": "authenticated",
                "event": "OAuthLoggedIn"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceOauthOauthFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceOauthDefaultForm"
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceOauthDefaultForm"
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceOauthDefaultForm"
            },
            "provider": {
              "type": "string",
              "default": "google",
              "values": [
                "google",
                "github",
                "microsoft",
                "okta"
              ]
            },
            "redirectUri": {
              "type": "string",
              "default": ""
            },
            "scopes": {
              "type": "[string]",
              "default": []
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceOauthPage",
          "path": "/serviceoauths",
          "traits": [
            {
              "ref": "ServiceOauthOauth"
            }
          ]
        }
      ]
    }
  ]
}
