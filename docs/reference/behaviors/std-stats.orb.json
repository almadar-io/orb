{
  "name": "std-stats",
  "version": "2.0.0",
  "description": "std-stats — embeddable analytics-card atom. ITEMS_LOADED aggregates @payload.data per @config.metrics (count|sum|avg|min|max with optional filter, format, icon, max, target, trend) and renders one stat-display per entry. Drop into a dashboard alongside std-browse / std-search / std-filter.",
  "orbitals": [
    {
      "name": "StatsItemOrbital",
      "entity": {
        "name": "StatsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "cards",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "trendPolarity": {
                  "name": "trendPolarity",
                  "type": "string",
                  "values": [
                    "higher-is-better",
                    "lower-is-better"
                  ]
                },
                "label": {
                  "name": "label",
                  "type": "string"
                },
                "max": {
                  "name": "max",
                  "type": "number"
                },
                "icon": {
                  "name": "icon",
                  "type": "string"
                },
                "target": {
                  "name": "target",
                  "type": "number"
                },
                "prefix": {
                  "name": "prefix",
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "type": "string",
                  "values": [
                    "default",
                    "primary",
                    "success",
                    "warning",
                    "error",
                    "info"
                  ]
                },
                "value": {
                  "name": "value",
                  "type": "number"
                },
                "format": {
                  "name": "format",
                  "type": "string",
                  "values": [
                    "number",
                    "currency",
                    "percent"
                  ]
                },
                "suffix": {
                  "name": "suffix",
                  "type": "string"
                },
                "trend": {
                  "name": "trend",
                  "type": "number"
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "StatsItemStats",
          "category": "interaction",
          "linkedEntity": "StatsItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      [
                        {
                          "aggregation": "count",
                          "icon": "list",
                          "variant": "primary",
                          "label": "Total Items",
                          "format": "number"
                        },
                        {
                          "aggregation": "count",
                          "icon": "check-circle",
                          "variant": "success",
                          "label": "Active",
                          "format": "number"
                        },
                        {
                          "label": "Avg Value",
                          "variant": "info",
                          "aggregation": "avg",
                          "format": "number",
                          "icon": "trending-up",
                          "field": "value"
                        }
                      ],
                      [
                        "fn",
                        "metric",
                        {
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "value": 0,
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0
                          ],
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0
                          ],
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "trend": [
                            "object/get",
                            "@metric",
                            "trend",
                            0
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "renderItem": [
                        "fn",
                        "card",
                        {
                          "type": "stat-display",
                          "format": "@card.format",
                          "label": "@card.label",
                          "value": "@card.value",
                          "variant": "@card.variant",
                          "max": "@card.max",
                          "icon": "@card.icon"
                        }
                      ],
                      "type": "data-grid",
                      "fields": [],
                      "entity": "@entity.cards"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.cards",
                    [
                      "array/map",
                      [
                        {
                          "aggregation": "count",
                          "icon": "list",
                          "variant": "primary",
                          "label": "Total Items",
                          "format": "number"
                        },
                        {
                          "aggregation": "count",
                          "icon": "check-circle",
                          "variant": "success",
                          "label": "Active",
                          "format": "number"
                        },
                        {
                          "label": "Avg Value",
                          "variant": "info",
                          "aggregation": "avg",
                          "format": "number",
                          "icon": "trending-up",
                          "field": "value"
                        }
                      ],
                      [
                        "fn",
                        "metric",
                        {
                          "target": [
                            "object/get",
                            "@metric",
                            "target",
                            0
                          ],
                          "prefix": [
                            "object/get",
                            "@metric",
                            "prefix",
                            ""
                          ],
                          "max": [
                            "object/get",
                            "@metric",
                            "max",
                            0
                          ],
                          "suffix": [
                            "object/get",
                            "@metric",
                            "suffix",
                            ""
                          ],
                          "value": [
                            "if",
                            [
                              "=",
                              [
                                "object/get",
                                "@metric",
                                "aggregation",
                                "count"
                              ],
                              "sum"
                            ],
                            [
                              "array/sum",
                              [
                                "array/filter",
                                "@payload.data",
                                [
                                  "object/get",
                                  "@metric",
                                  "filter",
                                  true
                                ]
                              ],
                              [
                                "object/get",
                                "@metric",
                                "field",
                                ""
                              ]
                            ],
                            [
                              "if",
                              [
                                "=",
                                [
                                  "object/get",
                                  "@metric",
                                  "aggregation",
                                  "count"
                                ],
                                "avg"
                              ],
                              [
                                "array/avg",
                                [
                                  "array/filter",
                                  "@payload.data",
                                  [
                                    "object/get",
                                    "@metric",
                                    "filter",
                                    true
                                  ]
                                ],
                                [
                                  "object/get",
                                  "@metric",
                                  "field",
                                  ""
                                ]
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  [
                                    "object/get",
                                    "@metric",
                                    "aggregation",
                                    "count"
                                  ],
                                  "min"
                                ],
                                [
                                  "array/min",
                                  [
                                    "array/filter",
                                    "@payload.data",
                                    [
                                      "object/get",
                                      "@metric",
                                      "filter",
                                      true
                                    ]
                                  ],
                                  [
                                    "object/get",
                                    "@metric",
                                    "field",
                                    ""
                                  ]
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    [
                                      "object/get",
                                      "@metric",
                                      "aggregation",
                                      "count"
                                    ],
                                    "max"
                                  ],
                                  [
                                    "array/max",
                                    [
                                      "array/filter",
                                      "@payload.data",
                                      [
                                        "object/get",
                                        "@metric",
                                        "filter",
                                        true
                                      ]
                                    ],
                                    [
                                      "object/get",
                                      "@metric",
                                      "field",
                                      ""
                                    ]
                                  ],
                                  [
                                    "array/len",
                                    [
                                      "array/filter",
                                      "@payload.data",
                                      [
                                        "object/get",
                                        "@metric",
                                        "filter",
                                        true
                                      ]
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          "format": [
                            "object/get",
                            "@metric",
                            "format",
                            "number"
                          ],
                          "icon": [
                            "object/get",
                            "@metric",
                            "icon",
                            ""
                          ],
                          "variant": [
                            "object/get",
                            "@metric",
                            "variant",
                            "default"
                          ],
                          "trend": [
                            "object/get",
                            "@metric",
                            "trend",
                            0
                          ],
                          "trendPolarity": [
                            "object/get",
                            "@metric",
                            "trendPolarity",
                            "higher-is-better"
                          ],
                          "label": [
                            "object/get",
                            "@metric",
                            "label"
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "data-list",
                      "renderItem": [
                        "fn",
                        "card",
                        {
                          "type": "stat-display",
                          "suffix": "@card.suffix",
                          "icon": "@card.icon",
                          "prefix": "@card.prefix",
                          "trend": "@card.trend",
                          "max": "@card.max",
                          "label": "@card.label",
                          "value": "@card.value",
                          "trendPolarity": "@card.trendPolarity",
                          "format": "@card.format",
                          "variant": "@card.variant",
                          "target": "@card.target"
                        }
                      ],
                      "entity": "@entity.cards",
                      "fields": []
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "metrics": {
              "type": "[object]",
              "default": [
                {
                  "aggregation": "count",
                  "icon": "list",
                  "variant": "primary",
                  "label": "Total Items",
                  "format": "number"
                },
                {
                  "aggregation": "count",
                  "icon": "check-circle",
                  "variant": "success",
                  "label": "Active",
                  "format": "number"
                },
                {
                  "label": "Avg Value",
                  "variant": "info",
                  "aggregation": "avg",
                  "format": "number",
                  "icon": "trending-up",
                  "field": "value"
                }
              ]
            },
            "title": {
              "type": "string",
              "default": "Summary"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StatsItemStatsPage",
          "path": "/statsitems",
          "traits": [
            {
              "ref": "StatsItemStats"
            }
          ]
        }
      ]
    }
  ]
}
