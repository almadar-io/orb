{
  "name": "std-receipt",
  "version": "1.0.0",
  "description": "std-receipt — receipt primitive. Proof of completed transaction (retail purchase or charitable donation). Browses receipts in a data-grid with Email / Reprint actions.",
  "orbitals": [
    {
      "name": "ReceiptOrbital",
      "entity": {
        "name": "Receipt",
        "collection": "receipts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "receiptNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "recipientName",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientEmail",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionId",
            "type": "string",
            "default": ""
          },
          {
            "name": "transactionType",
            "type": "string",
            "default": "purchase",
            "values": [
              "purchase",
              "refund",
              "donation",
              "service"
            ]
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0
          },
          {
            "name": "lineItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "issuedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isEmailed",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "ReceiptIssuer",
          "category": "interaction",
          "linkedEntity": "Receipt",
          "emits": [
            {
              "event": "EMAIL_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REPRINT_RECEIPT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ReceiptLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Receipt]"
                }
              ]
            },
            {
              "event": "ReceiptLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReceiptLoaded",
                "name": "Receipt loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Receipt]"
                  }
                ]
              },
              {
                "key": "ReceiptLoadFailed",
                "name": "Receipt load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EMAIL_RECEIPT",
                "name": "Email Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REPRINT_RECEIPT",
                "name": "Reprint Receipt",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "failure": "ReceiptLoadFailed",
                        "success": "ReceiptLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading receipts…"
                        }
                      ],
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ReceiptLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "receipt"
                            },
                            {
                              "content": "Receipts",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "receiptNumber",
                              "label": "Receipt #"
                            },
                            {
                              "variant": "caption",
                              "name": "recipientName",
                              "label": "Recipient"
                            },
                            {
                              "label": "Type",
                              "variant": "badge",
                              "name": "transactionType"
                            },
                            {
                              "variant": "caption",
                              "name": "total",
                              "label": "Total"
                            },
                            {
                              "name": "issuedAt",
                              "variant": "caption",
                              "label": "Issued"
                            },
                            {
                              "label": "Emailed",
                              "variant": "badge",
                              "name": "isEmailed"
                            }
                          ],
                          "gap": "sm",
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "event": "EMAIL_RECEIPT",
                              "variant": "primary",
                              "label": "Email"
                            },
                            {
                              "event": "REPRINT_RECEIPT",
                              "label": "Reprint",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ReceiptLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EMAIL_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Receipt emailed"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REPRINT_RECEIPT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Receipt reprinted"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Receipt",
                    {
                      "emit": {
                        "success": "ReceiptLoaded",
                        "failure": "ReceiptLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Receipts"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ReceiptPage",
          "path": "/receipts",
          "traits": [
            {
              "ref": "ReceiptIssuer"
            }
          ]
        }
      ]
    }
  ]
}
