{
  "name": "std-agent-activity-log",
  "version": "1.0.0",
  "description": "std-agent-activity-log as a Function",
  "orbitals": [
    {
      "name": "AgentActivityLogOrbital",
      "entity": {
        "name": "AgentActivityLog",
        "collection": "agentactivitylogs",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "action",
            "type": "string",
            "default": ""
          },
          {
            "name": "detail",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "duration",
            "type": "number",
            "default": 0
          },
          {
            "name": "icon",
            "type": "string",
            "default": "circle"
          }
        ]
      },
      "traits": [
        {
          "name": "AgentActivityLogLog",
          "category": "interaction",
          "linkedEntity": "AgentActivityLog",
          "emits": [
            {
              "event": "AgentActivityLogLoaded",
              "description": "Fired when the AgentActivityLog collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentActivityLog]"
                }
              ]
            },
            {
              "event": "AgentActivityLogLoadFailed",
              "description": "Fired when the AgentActivityLog collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogSaved",
              "description": "Fired when a LOG_ENTRY persist succeeds",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogSaveFailed",
              "description": "Fired when a LOG_ENTRY persist fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogDeleted",
              "description": "Fired when CLEAR deletes activity log rows",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentActivityLogDeleteFailed",
              "description": "Fired when CLEAR fails to delete",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "logging"
              },
              {
                "name": "persisting"
              },
              {
                "name": "deleting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentActivityLogLoaded",
                "name": "AgentActivityLog loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentActivityLog]"
                  }
                ]
              },
              {
                "key": "AgentActivityLogLoadFailed",
                "name": "AgentActivityLog load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LOG_ENTRY",
                "name": "Log Entry",
                "payloadSchema": [
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "detail",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "AgentActivityLogSaved",
                "name": "AgentActivityLog saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogSaveFailed",
                "name": "AgentActivityLog save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleted",
                "name": "AgentActivityLog deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentActivityLogDeleteFailed",
                "name": "AgentActivityLog delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogLoadFailed",
                        "success": "AgentActivityLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Loading activity log…",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "logging",
                "event": "AgentActivityLogLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "activity",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Activity Log"
                                }
                              ],
                              "gap": "sm",
                              "align": "center",
                              "type": "stack"
                            },
                            {
                              "icon": "trash",
                              "action": "CLEAR",
                              "label": "Clear",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "timeline",
                          "fields": [],
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentActivityLogLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load activity log"
                        },
                        {
                          "content": "@payload.error",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "action": "INIT",
                          "variant": "primary",
                          "label": "Retry",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "persisting",
                "event": "LOG_ENTRY",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentActivityLog",
                    {
                      "timestamp": "@now",
                      "status": "@payload.status",
                      "action": "@payload.action",
                      "detail": "@payload.detail"
                    },
                    {
                      "emit": {
                        "failure": "AgentActivityLogSaveFailed",
                        "success": "AgentActivityLogSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Recording entry…"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "logging",
                "to": "deleting",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogDeleteFailed",
                        "success": "AgentActivityLogDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Clearing activity log…"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "loading",
                "event": "AgentActivityLogSaved",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "failure": "AgentActivityLogLoadFailed",
                        "success": "AgentActivityLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "error",
                "event": "AgentActivityLogSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to record entry",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Retry",
                          "action": "INIT",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "loading",
                "event": "AgentActivityLogDeleted",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "error",
                "event": "AgentActivityLogDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "content": "Failed to clear activity log",
                          "variant": "h3"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "color": "muted",
                          "variant": "body"
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "action": "INIT",
                          "variant": "primary",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentActivityLog",
                    {
                      "emit": {
                        "success": "AgentActivityLogLoaded",
                        "failure": "AgentActivityLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentActivityLogPage",
          "path": "/agentactivitylogs",
          "traits": [
            {
              "ref": "AgentActivityLogLog"
            }
          ]
        }
      ]
    }
  ]
}
