{
  "name": "std-drip-sequence",
  "version": "1.0.0",
  "description": "std-drip-sequence — ordered email drip campaign primitive. Owns a DripSequence collection; ACTIVATE flips a sequence live, PAUSE halts it, and load failures surface as alerts. Pure topology atom; downstream coordinators persist status flips.",
  "orbitals": [
    {
      "name": "DripSequenceOrbital",
      "entity": {
        "name": "DripSequence",
        "collection": "dripsequences",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "triggerEvent",
            "type": "string",
            "default": ""
          },
          {
            "name": "stepsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "active",
              "paused",
              "archived"
            ]
          },
          {
            "name": "totalEnrolled",
            "type": "number",
            "default": 0
          },
          {
            "name": "totalCompleted",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "DripSequenceSequence",
          "category": "interaction",
          "linkedEntity": "DripSequence",
          "emits": [
            {
              "event": "ACTIVATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PAUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DripSequenceLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DripSequence]"
                }
              ]
            },
            {
              "event": "DripSequenceLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DripSequenceLoaded",
                "name": "DripSequence loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DripSequence]"
                  }
                ]
              },
              {
                "key": "DripSequenceLoadFailed",
                "name": "DripSequence load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ACTIVATE",
                "name": "Activate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PAUSE",
                "name": "Pause",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading drip sequences…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DripSequenceLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Drip Sequences",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name",
                              "variant": "caption"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "name": "triggerEvent",
                              "label": "Trigger",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "totalEnrolled",
                              "label": "Enrolled"
                            },
                            {
                              "label": "Completed",
                              "name": "totalCompleted",
                              "variant": "caption"
                            }
                          ],
                          "gap": "sm",
                          "cols": 1,
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "ACTIVATE",
                              "label": "Activate"
                            },
                            {
                              "label": "Pause",
                              "event": "PAUSE",
                              "variant": "ghost"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DripSequenceLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ACTIVATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Drip sequence activated",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PAUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Drip sequence paused",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DripSequence",
                    {
                      "emit": {
                        "success": "DripSequenceLoaded",
                        "failure": "DripSequenceLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Drip Sequences"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DripSequencePage",
          "path": "/sequences",
          "traits": [
            {
              "ref": "DripSequenceSequence"
            }
          ]
        }
      ]
    }
  ]
}
