{
  "name": "ChatMessageOrbital",
  "orbitals": [
    {
      "name": "ChatMessageOrbital",
      "entity": {
        "name": "ChatMessage",
        "collection": "chatmessages",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ChatMessageBrowse",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "listens": [
            {
              "event": "*.SEND",
              "triggers": "SEND"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "SEND"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "justify": "space-between",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "gap": "sm",
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "size": "lg",
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "content": "ChatMessages",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm",
                              "children": [
                                {
                                  "label": "Compose",
                                  "icon": "edit",
                                  "event": "COMPOSE",
                                  "type": "button",
                                  "variant": "primary"
                                }
                              ]
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "ChatMessage",
                          "emptyTitle": "No messages yet",
                          "emptyIcon": "inbox",
                          "emptyDescription": "Start a new conversation.",
                          "columns": [
                            {
                              "icon": "message-circle",
                              "variant": "h4",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "variant": "caption",
                              "label": "Status",
                              "name": "status",
                              "format": "date"
                            }
                          ],
                          "variant": "compact",
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "ghost",
                              "size": "sm"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SEND",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "ChatMessageCompose",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "emits": [
            {
              "event": "SEND"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "COMPOSE"
              },
              {
                "key": "CLOSE"
              },
              {
                "key": "SEND"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit",
                              "size": "md"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "New ChatMessage"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "type": "form-section",
                          "submitEvent": "SEND",
                          "entity": "ChatMessage",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "name",
                            "description",
                            "status"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ChatMessage",
                    "@payload.data"
                  ],
                  [
                    "fetch",
                    "ChatMessage"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "SEND"
                  ],
                  [
                    "notify",
                    "ChatMessage created successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "ChatMessageView",
          "category": "interaction",
          "linkedEntity": "ChatMessage",
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "VIEW"
              },
              {
                "key": "CLOSE"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "ChatMessage",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "eye",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "@entity.name"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Name"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Description",
                              "variant": "caption"
                            },
                            {
                              "variant": "body",
                              "type": "typography",
                              "content": "@entity.description"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "typography",
                              "content": "Status",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.status",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Created At"
                            },
                            {
                              "content": "@entity.createdAt",
                              "type": "typography",
                              "variant": "body"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "end",
                          "children": [
                            {
                              "label": "Close",
                              "type": "button",
                              "event": "CLOSE",
                              "variant": "ghost"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Chatmessages",
          "path": "/chatmessages",
          "traits": [
            {
              "ref": "ChatMessageBrowse"
            },
            {
              "ref": "ChatMessageCompose"
            },
            {
              "ref": "ChatMessageView"
            }
          ]
        }
      ]
    }
  ]
}
