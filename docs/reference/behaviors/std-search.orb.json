{
  "name": "std-search",
  "version": "1.0.0",
  "description": "std-search — single primitive: search-input. Owns a SearchResult runtime entity; SEARCH persists @payload.searchTerm (matching SearchInput's emit shape) so cross-trait listeners can route it into data atoms (Browse REFETCH_QUERY).",
  "orbitals": [
    {
      "name": "SearchResultOrbital",
      "entity": {
        "name": "SearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "searchTerm",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SearchResultSearch",
          "category": "interaction",
          "linkedEntity": "SearchResult",
          "emits": [
            {
              "event": "SEARCH",
              "payloadSchema": [
                {
                  "name": "searchTerm",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "search-input",
                      "placeholder": "Search…",
                      "event": "SEARCH"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.searchTerm"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "placeholder": "Search…",
                      "event": "SEARCH",
                      "type": "search-input"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "event": {
              "type": "string",
              "default": "SEARCH"
            },
            "placeholder": {
              "type": "string",
              "default": "Search…"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "SearchResultSearchPage",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}
