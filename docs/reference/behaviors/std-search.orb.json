{
  "name": "SearchResultOrbital",
  "orbitals": [
    {
      "name": "SearchResultOrbital",
      "entity": {
        "name": "SearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SearchResultSearch",
          "category": "interaction",
          "linkedEntity": "SearchResult",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "SEARCH"
              },
              {
                "key": "CLEAR"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "variant": "h2",
                              "content": "Search SearchResults",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "search-input",
                          "placeholder": "Search...",
                          "event": "SEARCH"
                        },
                        {
                          "description": "Type a query to search across searchresults.",
                          "icon": "search",
                          "title": "Search to find results",
                          "type": "empty-state"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "search",
                                  "size": "lg"
                                },
                                {
                                  "content": [
                                    "concat",
                                    "Results for \"",
                                    "@payload.query",
                                    "\""
                                  ],
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "icon": "x",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Clear",
                              "event": "CLEAR"
                            }
                          ],
                          "justify": "space-between",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "trigger": "click",
                          "children": [
                            {
                              "entity": "SearchResult",
                              "emptyIcon": "search",
                              "emptyTitle": "No results found",
                              "emptyDescription": "Try a different search term.",
                              "type": "data-grid",
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "gap": "sm",
                                  "type": "stack",
                                  "direction": "vertical",
                                  "children": [
                                    {
                                      "content": "@item.name",
                                      "variant": "h4",
                                      "type": "typography"
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "type": "popover",
                          "position": "bottom"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "search",
                                  "size": "lg"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": [
                                    "concat",
                                    "Results for \"",
                                    "@payload.query",
                                    "\""
                                  ]
                                }
                              ],
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center"
                            },
                            {
                              "event": "CLEAR",
                              "variant": "ghost",
                              "type": "button",
                              "label": "Clear",
                              "icon": "x"
                            }
                          ],
                          "align": "center",
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "trigger": "click",
                          "position": "bottom",
                          "type": "popover",
                          "children": [
                            {
                              "type": "data-grid",
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "children": [
                                    {
                                      "variant": "h4",
                                      "type": "typography",
                                      "content": "@item.name"
                                    }
                                  ],
                                  "gap": "sm",
                                  "direction": "vertical",
                                  "type": "stack"
                                }
                              ],
                              "emptyDescription": "Try a different search term.",
                              "entity": "SearchResult",
                              "emptyIcon": "search",
                              "emptyTitle": "No results found"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "idle",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SearchResult"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "search"
                            },
                            {
                              "variant": "h2",
                              "content": "Search SearchResults",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "event": "SEARCH",
                          "type": "search-input",
                          "placeholder": "Search..."
                        },
                        {
                          "description": "Type a query to search across searchresults.",
                          "icon": "search",
                          "type": "empty-state",
                          "title": "Search to find results"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "SearchresultsSearch",
          "path": "/searchresults/search",
          "traits": [
            {
              "ref": "SearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}
