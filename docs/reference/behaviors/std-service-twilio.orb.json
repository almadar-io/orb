{
  "name": "std-service-twilio",
  "version": "2.0.0",
  "description": "std-service-twilio — Twilio messaging service. Bind via `uses Twilio from \"std/behaviors/std-service-twilio\"` and configure `recipient` / `body` / `sender` / `mode` at the call site (mapped to Twilio `to`/`body`/`from`/`mode`). Pass `uiTrait: \"@trait.YourMessagingForm\"` to inject your own form; leave unset to render the atom's default test form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceTwilioOrbital",
      "entity": {
        "name": "ServiceTwilio",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "to",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "from",
            "type": "string",
            "default": ""
          },
          {
            "name": "mode",
            "type": "string",
            "default": "sms",
            "values": [
              "sms",
              "voice",
              "whatsapp"
            ]
          },
          {
            "name": "messageSid",
            "type": "string",
            "default": ""
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceTwilioDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "SEND",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "stretch",
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "content": "Twilio Messaging",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "inputType": "tel",
                          "type": "input",
                          "placeholder": "+1234567890"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "sms",
                              "label": "SMS"
                            },
                            {
                              "value": "voice",
                              "label": "Voice"
                            },
                            {
                              "value": "whatsapp",
                              "label": "WhatsApp"
                            }
                          ]
                        },
                        {
                          "icon": "send",
                          "label": "Send",
                          "action": "SEND",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceTwilioTwilio",
          "category": "interaction",
          "linkedEntity": "ServiceTwilio",
          "emits": [
            {
              "event": "ServiceTwilioLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TwilioSent",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioCompleted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEND",
              "triggers": "SEND",
              "source": {
                "kind": "trait",
                "trait": "ServiceTwilioDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              },
              {
                "key": "ServiceTwilioLoaded",
                "name": "ServiceTwilio loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioLoadFailed",
                "name": "ServiceTwilio load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TwilioSent",
                "name": "Twilio sent",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceTwilioTwilioCompleted",
                "name": "ServiceTwilio twilio completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioTwilioFailed",
                "name": "ServiceTwilio twilio failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.to",
                    ""
                  ],
                  [
                    "set",
                    "@entity.body",
                    ""
                  ],
                  [
                    "set",
                    "@entity.mode",
                    "sms"
                  ],
                  [
                    "fetch",
                    "ServiceTwilio",
                    {
                      "emit": {
                        "failure": "ServiceTwilioLoadFailed",
                        "success": "ServiceTwilioLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceTwilioDefaultForm"
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Delivering your message.",
                      "title": "Sending message..."
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendSMS",
                    {
                      "body": "",
                      "to": ""
                    },
                    {
                      "emit": {
                        "success": "TwilioSent",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceTwilioLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceTwilioLoadFailed"
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "TwilioSent",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.messageSid",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "ServiceTwilioTwilioCompleted",
                    {
                      "id": "@entity.messageSid"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "message": "Message sent successfully",
                          "variant": "success"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "color": "muted",
                          "content": "@entity.messageSid"
                        },
                        {
                          "type": "button",
                          "label": "Send Another",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "variant": "ghost"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceTwilioTwilioFailed",
                    {
                      "code": "send_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "message": "@entity.error",
                      "type": "error-state",
                      "title": "Send Failed"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceTwilioDefaultForm"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "sent",
                "event": "ServiceTwilioTwilioCompleted"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceTwilioTwilioFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        "@trait.ServiceTwilioDefaultForm"
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceTwilioDefaultForm"
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceTwilioDefaultForm"
            },
            "sender": {
              "type": "string",
              "default": ""
            },
            "mode": {
              "type": "string",
              "default": "sms",
              "values": [
                "sms",
                "voice",
                "whatsapp"
              ]
            },
            "recipient": {
              "type": "string",
              "default": ""
            },
            "body": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceTwilioPage",
          "path": "/servicetwilios",
          "traits": [
            {
              "ref": "ServiceTwilioTwilio"
            }
          ]
        }
      ]
    }
  ]
}
