{
  "name": "std-service-twilio",
  "version": "1.0.0",
  "description": "std-service-twilio as a Function",
  "orbitals": [
    {
      "name": "ServiceTwilioOrbital",
      "entity": {
        "name": "ServiceTwilio",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "messageBody",
            "type": "string"
          },
          {
            "name": "channel",
            "type": "string",
            "default": "sms"
          },
          {
            "name": "messageSid",
            "type": "string"
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceTwilioTwilio",
          "category": "interaction",
          "linkedEntity": "ServiceTwilio",
          "emits": [
            {
              "event": "ServiceTwilioLoaded",
              "description": "Fired when ServiceTwilio finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "to",
                  "type": "string"
                },
                {
                  "name": "messageBody",
                  "type": "string"
                },
                {
                  "name": "channel",
                  "type": "string"
                },
                {
                  "name": "messageSid",
                  "type": "string"
                },
                {
                  "name": "sendStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioLoadFailed",
              "description": "Fired when ServiceTwilio fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceTwilioTwilioFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND_SMS",
                "name": "Send Sms"
              },
              {
                "key": "SEND_WHATSAPP",
                "name": "Send Whatsapp"
              },
              {
                "key": "SENT",
                "name": "Sent",
                "payloadSchema": [
                  {
                    "name": "messageSid",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceTwilioLoaded",
                "name": "ServiceTwilio loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "to",
                    "type": "string"
                  },
                  {
                    "name": "messageBody",
                    "type": "string"
                  },
                  {
                    "name": "channel",
                    "type": "string"
                  },
                  {
                    "name": "messageSid",
                    "type": "string"
                  },
                  {
                    "name": "sendStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioLoadFailed",
                "name": "ServiceTwilio load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceTwilioTwilioCompleted",
                "name": "ServiceTwilio twilio completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceTwilioTwilioFailed",
                "name": "ServiceTwilio twilio failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.messageBody",
                    ""
                  ],
                  [
                    "set",
                    "@entity.to",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceTwilio",
                    {
                      "emit": {
                        "success": "ServiceTwilioLoaded",
                        "failure": "ServiceTwilioLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "content": "ServiceTwilio Messaging",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "+1234567890",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "children": [
                            {
                              "label": "Send SMS",
                              "action": "SEND_SMS",
                              "variant": "primary",
                              "type": "button",
                              "icon": "message-circle"
                            },
                            {
                              "label": "Send WhatsApp",
                              "action": "SEND_WHATSAPP",
                              "type": "button",
                              "icon": "phone",
                              "variant": "secondary"
                            }
                          ],
                          "type": "stack",
                          "justify": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "align": "stretch",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND_SMS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Delivering servicetwilio message...",
                      "title": "Sending message...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendSMS",
                    {
                      "to": "@entity.to",
                      "body": "@entity.messageBody"
                    },
                    {
                      "emit": {
                        "failure": "ServiceTwilioTwilioFailed",
                        "success": "ServiceTwilioTwilioCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND_WHATSAPP",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Sending message...",
                      "message": "Delivering servicetwilio message...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "twilio",
                    "sendWhatsApp",
                    {
                      "body": "@entity.messageBody",
                      "to": "@entity.to"
                    },
                    {
                      "emit": {
                        "failure": "ServiceTwilioTwilioFailed",
                        "success": "ServiceTwilioTwilioCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "SENT",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.messageSid",
                    "@payload.messageSid"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "message": "Message sent successfully",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "icon": "rotate-ccw",
                          "label": "Send Another",
                          "type": "button",
                          "action": "RESET",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "error-state",
                          "onRetry": "RETRY",
                          "message": "Could not deliver the message.",
                          "title": "Send Failed"
                        },
                        {
                          "children": [
                            {
                              "icon": "refresh-cw",
                              "action": "RETRY",
                              "variant": "primary",
                              "label": "Retry",
                              "type": "button"
                            },
                            {
                              "type": "button",
                              "action": "RESET",
                              "label": "Reset",
                              "variant": "ghost",
                              "icon": "rotate-ccw"
                            }
                          ],
                          "gap": "sm",
                          "justify": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "content": "ServiceTwilio Messaging",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "+1234567890"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "icon": "message-circle",
                              "action": "SEND_SMS",
                              "variant": "primary",
                              "type": "button",
                              "label": "Send SMS"
                            },
                            {
                              "label": "Send WhatsApp",
                              "type": "button",
                              "icon": "phone",
                              "action": "SEND_WHATSAPP",
                              "variant": "secondary"
                            }
                          ],
                          "justify": "center"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "stretch",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "stretch",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "content": "ServiceTwilio Messaging",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "+1234567890"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "type": "stack",
                          "justify": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "icon": "message-circle",
                              "type": "button",
                              "variant": "primary",
                              "label": "Send SMS",
                              "action": "SEND_SMS"
                            },
                            {
                              "icon": "phone",
                              "variant": "secondary",
                              "label": "Send WhatsApp",
                              "action": "SEND_WHATSAPP",
                              "type": "button"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-circle"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "ServiceTwilio Messaging"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "+1234567890",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "justify": "center",
                          "children": [
                            {
                              "variant": "primary",
                              "icon": "message-circle",
                              "action": "SEND_SMS",
                              "type": "button",
                              "label": "Send SMS"
                            },
                            {
                              "icon": "phone",
                              "type": "button",
                              "variant": "secondary",
                              "action": "SEND_WHATSAPP",
                              "label": "Send WhatsApp"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceTwilioPage",
          "path": "/servicetwilios",
          "traits": [
            {
              "ref": "ServiceTwilioTwilio"
            }
          ]
        }
      ]
    }
  ]
}
