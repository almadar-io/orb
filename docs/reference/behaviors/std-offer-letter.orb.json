{
  "name": "std-offer-letter",
  "version": "1.0.0",
  "description": "std-offer-letter — formal job offer primitive. Owns an OfferLetter entity (applicant, position, salary, start date, acceptance status). Browses offers in a data-grid with Send / Revoke actions.",
  "orbitals": [
    {
      "name": "OfferLetterOrbital",
      "entity": {
        "name": "OfferLetter",
        "collection": "offerletters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantId",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "position",
            "type": "string",
            "default": ""
          },
          {
            "name": "salary",
            "type": "number",
            "default": 0
          },
          {
            "name": "startDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "accepted",
              "rejected",
              "expired"
            ]
          },
          {
            "name": "expiresAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "OfferLetterFlow",
          "category": "interaction",
          "linkedEntity": "OfferLetter",
          "emits": [
            {
              "event": "SEND_OFFER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVOKE_OFFER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "OfferLetterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[OfferLetter]"
                }
              ]
            },
            {
              "event": "OfferLetterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OfferLetterLoaded",
                "name": "OfferLetter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[OfferLetter]"
                  }
                ]
              },
              {
                "key": "OfferLetterLoadFailed",
                "name": "OfferLetter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEND_OFFER",
                "name": "Send Offer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REVOKE_OFFER",
                "name": "Revoke Offer",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "failure": "OfferLetterLoadFailed",
                        "success": "OfferLetterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading offer letters…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "OfferLetterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "name": "file-text",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Offer Letters"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "SEND_OFFER",
                              "label": "Send"
                            },
                            {
                              "label": "Revoke",
                              "event": "REVOKE_OFFER",
                              "variant": "danger"
                            }
                          ],
                          "cols": 1,
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "applicantName",
                              "label": "Applicant"
                            },
                            {
                              "variant": "caption",
                              "name": "position",
                              "label": "Position"
                            },
                            {
                              "label": "Salary",
                              "name": "salary",
                              "variant": "caption"
                            },
                            {
                              "label": "Start Date",
                              "variant": "caption",
                              "name": "startDate"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "OfferLetterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SEND_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Offer sent"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REVOKE_OFFER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Offer revoked",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "OfferLetter",
                    {
                      "emit": {
                        "success": "OfferLetterLoaded",
                        "failure": "OfferLetterLoadFailed"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Offer Letters"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "OfferLetterPage",
          "path": "/offers",
          "traits": [
            {
              "ref": "OfferLetterFlow"
            }
          ]
        }
      ]
    }
  ]
}
