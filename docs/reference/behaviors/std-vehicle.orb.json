              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "VehicleLoaded",
                "name": "Vehicle loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Vehicle]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "VehicleLoadFailed",
                "name": "Vehicle load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
