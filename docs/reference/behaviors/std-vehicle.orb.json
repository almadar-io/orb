            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Vehicle",
                    {
                      "emit": {
                        "failure": "VehicleLoadFailed",
                        "success": "VehicleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading vehicles…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "VehicleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "truck",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Fleet"
                            },
                            {
                              "type": "button",
                              "action": "CREATE",
                              "variant": "primary",
                              "label": "New Vehicle"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "fields": [
                            {
                              "name": "licensePlate",
                              "variant": "caption",
                              "label": "Plate"
                            },
                            {
                              "variant": "caption",
                              "name": "make",
                              "label": "Make"
                            },
                            {
                              "label": "Model",
                              "variant": "caption",
                              "name": "model"
                            },
                            {
                              "name": "year",
                              "label": "Year",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "label": "Type",
                              "name": "vehicleType"
                            },
                            {
                              "variant": "caption",
                              "name": "odometer",
                              "label": "Odometer"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "label": "Driver",
                              "name": "assignedDriverId",
                              "variant": "caption"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "secondary"
                            },
                            {
                              "event": "EDIT",
                              "variant": "secondary",
                              "label": "Edit"
                            },
                            {
                              "event": "ASSIGN_DRIVER",
                              "label": "Assign Driver",
                              "variant": "primary"
                            },
                            {
                              "variant": "secondary",
                              "event": "MARK_MAINTENANCE",
                              "label": "Maintenance"
                            },
                            {
                              "event": "RETIRE",
                              "label": "Retire",
                              "variant": "ghost"
                            },
                            {
                              "label": "Delete",
                              "event": "REQUEST_DELETE",
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm",
                          "type": "data-grid",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
