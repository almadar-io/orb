                    "emit",
                    "LOG_ENTRY"
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "failed",
                "event": "CANCEL",
                "guard": [
                  "=",
                  "@entity.status",
                  "executing"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "failed"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "Cancelled"
                  ],
                  [
                    "emit",
                    "TOOL_COMPLETED"
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "idle"
                  ],
                  [
                    "emit",
                    "TOOL_COMPLETED"
                  ]
                ]
              },
              {
                "from": "completed",
                "to": "executing",
                "event": "DO_INVOKE",
                "effects": [
