{
  "name": "std-stock-adjustment",
  "version": "1.0.0",
  "description": "Tracks stock-level adjustments as deltas to onHand per sku/warehouse",
  "orbitals": [
    {
      "name": "StockAdjustmentOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-stock-level",
          "as": "StockLevel"
        },
        {
          "from": "std/behaviors/std-warehouse",
          "as": "Warehouse"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "StockAdjustment",
        "collection": "stockadjustments",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "stockLevelId",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "default": ""
          },
          {
            "name": "warehouseId",
            "type": "string",
            "default": ""
          },
          {
            "name": "warehouseName",
            "type": "string",
            "default": ""
          },
          {
            "name": "quantityDelta",
            "type": "number",
            "default": 0
          },
          {
            "name": "reason",
            "type": "string",
            "default": "manual",
            "values": [
              "manual",
              "damaged",
              "transfer_in",
              "transfer_out",
              "shrinkage",
              "recount"
            ]
          },
          {
            "name": "adjustedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "adjustedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "StockAdjustmentBrowse",
          "category": "interaction",
          "linkedEntity": "StockAdjustment",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.stockLevelId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.sku",
                  "type": "string"
                },
                {
                  "name": "row.warehouseId",
                  "type": "string"
                },
                {
                  "name": "row.warehouseName",
                  "type": "string"
                },
                {
                  "name": "row.quantityDelta",
                  "type": "number"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.adjustedBy",
                  "type": "string"
                },
                {
                  "name": "row.adjustedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StockAdjustmentLoaded",
              "description": "Fired when the stock-adjustment collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StockAdjustment]"
                }
              ]
            },
            {
              "event": "StockAdjustmentLoadFailed",
              "description": "Fired when the stock-adjustment collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ADJUSTMENT_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentPersistor"
              }
            },
            {
              "event": "ADJUSTMENT_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StockAdjustmentLoaded",
                "name": "StockAdjustment loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StockAdjustment]"
                  }
                ]
              },
              {
                "key": "StockAdjustmentLoadFailed",
                "name": "StockAdjustment load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "failure": "StockAdjustmentLoadFailed",
                        "success": "StockAdjustmentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading adjustments…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StockAdjustmentLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "sliders",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Stock Adjustments",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "type": "button",
                              "label": "New Adjustment",
                              "icon": "plus",
                              "variant": "primary",
                              "action": "CREATE"
                            }
                          ],
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal"
                        },
                        {
                          "maxFiles": 1,
                          "label": "Drop CSV here for bulk import",
                          "action": "CREATE",
                          "icon": "file-spreadsheet",
                          "type": "upload-drop-zone",
                          "accept": ".csv,text/csv",
                          "maxSize": 10485760,
                          "description": "or click to browse"
                        },
                        {
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "content": "Quick quantity adjust",
                              "color": "muted",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "step": 1,
                              "type": "number-stepper",
                              "value": 0,
                              "max": 100,
                              "size": "md",
                              "action": "CREATE",
                              "min": -100
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "SKU",
                              "name": "sku",
                              "icon": "tag",
                              "variant": "h4"
                            },
                            {
                              "name": "warehouseName",
                              "label": "Warehouse",
                              "variant": "body"
                            },
                            {
                              "name": "quantityDelta",
                              "label": "Delta",
                              "variant": "badge"
                            },
                            {
                              "name": "reason",
                              "label": "Reason",
                              "variant": "badge"
                            },
                            {
                              "name": "adjustedAt",
                              "variant": "caption",
                              "label": "Adjusted At"
                            },
                            {
                              "variant": "caption",
                              "label": "Adjusted By",
                              "name": "adjustedBy"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "danger",
                              "event": "REQUEST_DELETE",
                              "label": "Delete"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StockAdjustmentLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load adjustments",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "action": "INIT",
                          "label": "Retry"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "success": "StockAdjustmentLoaded",
                        "failure": "StockAdjustmentLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "failure": "StockAdjustmentLoadFailed",
                        "success": "StockAdjustmentLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "StockAdjustmentCreate",
          "category": "interaction",
          "linkedEntity": "StockAdjustment",
          "emits": [
            {
              "event": "SAVE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE"
            },
            {
              "event": "ModalRecordLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModalRecordLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ModalRecord]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "ModalRecord"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ModalRecordLoadFailed",
                "name": "ModalRecord load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ModalRecordLoaded",
                "name": "ModalRecord loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ModalRecord]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "failure": "ModalRecordLoadFailed",
                        "success": "ModalRecordLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "guard": [
                  "or",
                  [
                    "=",
                    "create",
                    "create"
                  ],
                  "@payload.row"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "New Adjustment"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "entity": "@payload.row",
                          "type": "form-section",
                          "fields": [
                            "sku",
                            "warehouseId",
                            "quantityDelta",
                            "reason",
                            "notes"
                          ],
                          "cancelEvent": "CLOSE"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "icon": {
              "type": "string",
              "default": "layout-panel-top"
            },
            "title": {
              "type": "string",
              "default": "Details"
            },
            "fields": {
              "type": "[string]",
              "default": []
            },
            "mode": {
              "type": "string",
              "default": "create"
            }
          },
          "scope": "instance"
        },
        {
          "name": "StockAdjustmentDelete",
          "category": "interaction",
          "linkedEntity": "StockAdjustment",
          "emits": [
            {
              "event": "CONFIRM_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL"
            },
            {
              "event": "ConfirmActionLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConfirmActionLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ConfirmAction]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ConfirmAction"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ConfirmActionLoadFailed",
                "name": "ConfirmAction load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConfirmActionLoaded",
                "name": "ConfirmAction loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ConfirmAction]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StockAdjustment",
                    {
                      "emit": {
                        "success": "ConfirmActionLoaded",
                        "failure": "ConfirmActionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "guard": "@payload.row",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "content": "Delete Adjustment",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "variant": "error",
                          "message": "This action cannot be undone."
                        },
                        {
                          "type": "typography",
                          "content": "@entity.name",
                          "variant": "h4"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.pendingId",
                          "variant": "caption",
                          "type": "typography"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "children": [
                            {
                              "action": "CANCEL",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Cancel"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "icon": "check",
                              "actionPayload": {
                                "id": "@payload.id"
                              },
                              "type": "button",
                              "action": "CONFIRM_DELETE"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "confirmLabel": {
              "type": "string",
              "default": "Confirm"
            },
            "icon": {
              "type": "string",
              "default": "alert-triangle"
            },
            "alertMessage": {
              "type": "string",
              "default": "Are you sure?"
            },
            "title": {
              "type": "string",
              "default": "Confirm Action"
            }
          },
          "scope": "instance"
        },
        {
          "name": "StockAdjustmentPersistor",
          "category": "lifecycle",
          "linkedEntity": "StockAdjustment",
          "emits": [
            {
              "event": "ADJUSTMENT_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ADJUSTMENT_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SAVE",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentCreate"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "StockAdjustmentDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
