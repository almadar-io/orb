{
  "name": "std-image-upload-multi",
  "version": "1.0.0",
  "description": "std-image-upload-multi — multi-image upload with drop zone, gallery preview, and per-batch progress. Owns an UploadedImage entity scoped by parentId/parentType so listings, marketplaces, restaurant menus, and vendor onboarding can all reuse the same upload contract.",
  "orbitals": [
    {
      "name": "UploadedImageOrbital",
      "entity": {
        "name": "UploadedImage",
        "collection": "uploadedimages",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "url",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "sizeBytes",
            "type": "number"
          },
          {
            "name": "mimeType",
            "type": "string"
          },
          {
            "name": "width",
            "type": "number"
          },
          {
            "name": "height",
            "type": "number"
          },
          {
            "name": "parentId",
            "type": "string"
          },
          {
            "name": "parentType",
            "type": "string"
          },
          {
            "name": "uploadedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "UploadedImageUpload",
          "category": "interaction",
          "linkedEntity": "UploadedImage",
          "emits": [
            {
              "event": "UPLOAD",
              "payloadSchema": [
                {
                  "name": "files",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "UploadedImageLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[UploadedImage]"
                }
              ]
            },
            {
              "event": "UploadedImageLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.url",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string"
                },
                {
                  "name": "row.sizeBytes",
                  "type": "number"
                },
                {
                  "name": "row.mimeType",
                  "type": "string"
                },
                {
                  "name": "row.width",
                  "type": "number"
                },
                {
                  "name": "row.height",
                  "type": "number"
                },
                {
                  "name": "row.parentId",
                  "type": "string"
                },
                {
                  "name": "row.parentType",
                  "type": "string"
                },
                {
                  "name": "row.uploadedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageUploadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "UploadedImageDeleted",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "UploadedImageDeleteFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "uploading"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UploadedImageLoaded",
                "name": "UploadedImage loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[UploadedImage]"
                  }
                ]
              },
              {
                "key": "UploadedImageLoadFailed",
                "name": "UploadedImage load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "files",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UploadedImageDeleted",
                "name": "UploadedImage deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "UploadedImageDeleteFailed",
                "name": "UploadedImage delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UploadedImageCreated",
                "name": "UploadedImage created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "UploadedImage"
                  }
                ]
              },
              {
                "key": "UploadedImageUploadFailed",
                "name": "UploadedImage upload failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading images…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "UploadedImageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Upload Images"
                        },
                        {
                          "type": "upload-drop-zone",
                          "maxFiles": 10,
                          "accept": "image/*",
                          "icon": "image-plus",
                          "label": "Drop images here",
                          "maxSize": 10485760,
                          "action": "UPLOAD",
                          "description": "or click to browse"
                        },
                        {
                          "type": "media-gallery",
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "UploadedImageLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "persist",
                    "create",
                    "UploadedImage",
                    "@payload.files",
                    {
                      "emit": {
                        "success": "UploadedImageCreated",
                        "failure": "UploadedImageUploadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Uploading images…",
                          "variant": "h3"
                        },
                        {
                          "type": "progress-bar",
                          "progressType": "linear",
                          "max": 100,
                          "value": 0
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "UploadedImage",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "UploadedImageDeleted",
                        "failure": "UploadedImageDeleteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UploadedImageDeleted",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "UploadedImageDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "loading",
                "event": "UploadedImageCreated",
                "effects": [
                  [
                    "fetch",
                    "UploadedImage",
                    {
                      "emit": {
                        "success": "UploadedImageLoaded",
                        "failure": "UploadedImageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "success",
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Upload complete",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "error",
                "event": "UploadedImageUploadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "browsing",
                "event": "UploadedImageLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Upload Images",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "action": "UPLOAD",
                          "icon": "image-plus",
                          "type": "upload-drop-zone",
                          "maxFiles": 10,
                          "label": "Drop images here",
                          "maxSize": 10485760,
                          "description": "or click to browse",
                          "accept": "image/*"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "media-gallery"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "accept": {
              "type": "string",
              "default": "image/*"
            },
            "title": {
              "type": "string",
              "default": "Upload Images"
            },
            "maxImages": {
              "type": "number",
              "default": 10
            },
            "maxBytesPerImage": {
              "type": "number",
              "default": 10485760
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "UploadedImageUploadPage",
          "path": "/uploadedimages/upload",
          "traits": [
            {
              "ref": "UploadedImageUpload"
            }
          ]
        }
      ]
    }
  ]
}
