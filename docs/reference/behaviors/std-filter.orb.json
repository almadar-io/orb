{
  "name": "std-filter",
  "version": "1.0.0",
  "description": "std-filter — single primitive: filter-group. Owns a FilterTarget runtime entity; every FILTER transition persists field/value so cross-trait listeners can route the latest selection into data atoms.",
  "orbitals": [
    {
      "name": "FilterTargetOrbital",
      "entity": {
        "name": "FilterTarget",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "field",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FilterTargetFilter",
          "category": "interaction",
          "linkedEntity": "FilterTarget",
          "emits": [
            {
              "event": "FILTER",
              "payloadSchema": [
                {
                  "name": "field",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FILTER",
                "name": "Filter",
                "payloadSchema": [
                  {
                    "name": "field",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR_FILTERS",
                "name": "Clear Filters"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "FilterTarget",
                    {}
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": [
                        {
                          "label": "Status",
                          "filterType": "select",
                          "options": [
                            "active",
                            "inactive",
                            "pending"
                          ],
                          "field": "status"
                        }
                      ],
                      "type": "filter-group"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FILTER",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    "@payload.field"
                  ],
                  [
                    "set",
                    "@entity.value",
                    "@payload.value"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": [
                        {
                          "label": "Status",
                          "filterType": "select",
                          "options": [
                            "active",
                            "inactive",
                            "pending"
                          ],
                          "field": "status"
                        }
                      ],
                      "type": "filter-group"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "CLEAR_FILTERS",
                "effects": [
                  [
                    "set",
                    "@entity.field",
                    ""
                  ],
                  [
                    "set",
                    "@entity.value",
                    ""
                  ],
                  [
                    "emit",
                    "FILTER",
                    {
                      "field": "",
                      "value": ""
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "entity": "FilterTarget",
                      "filters": [
                        {
                          "label": "Status",
                          "filterType": "select",
                          "options": [
                            "active",
                            "inactive",
                            "pending"
                          ],
                          "field": "status"
                        }
                      ],
                      "type": "filter-group"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "filters": {
              "type": "[object]",
              "default": [
                {
                  "label": "Status",
                  "filterType": "select",
                  "options": [
                    "active",
                    "inactive",
                    "pending"
                  ],
                  "field": "status"
                }
              ]
            },
            "event": {
              "type": "string",
              "default": "FILTER"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FilterTargetFilterPage",
          "path": "/filtertargets",
          "traits": [
            {
              "ref": "FilterTargetFilter"
            }
          ]
        }
      ]
    }
  ]
}
