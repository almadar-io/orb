{
  "name": "std-chart-of-accounts",
  "version": "1.0.0",
  "description": "std-chart-of-accounts — list of all accounts (asset, liability, equity, revenue, expense) that ledger entries post against. Owns an Account entity and a single chart trait that loads accounts, renders them in a data-grid, and surfaces Activate / Deactivate per row.",
  "orbitals": [
    {
      "name": "ChartOfAccountsOrbital",
      "entity": {
        "name": "Account",
        "collection": "accounts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "type",
            "type": "string",
            "default": "asset",
            "values": [
              "asset",
              "liability",
              "equity",
              "revenue",
              "expense"
            ]
          },
          {
            "name": "parentCode",
            "type": "string",
            "default": ""
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "balance",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "AccountChart",
          "category": "interaction",
          "linkedEntity": "Account",
          "emits": [
            {
              "event": "ACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DEACTIVATE_ACCOUNT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "AccountLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Account]"
                }
              ]
            },
            {
              "event": "AccountLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AccountLoaded",
                "name": "Account loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Account]"
                  }
                ]
              },
              {
                "key": "AccountLoadFailed",
                "name": "Account load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ACTIVATE_ACCOUNT",
                "name": "Activate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DEACTIVATE_ACCOUNT",
                "name": "Deactivate Account",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "success": "AccountLoaded",
                        "failure": "AccountLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading accounts…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "AccountLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Chart of Accounts"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "code",
                              "label": "Code"
                            },
                            {
                              "variant": "caption",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "name": "type",
                              "variant": "caption",
                              "label": "Type"
                            },
                            {
                              "name": "parentCode",
                              "label": "Parent",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "balance",
                              "label": "Balance"
                            },
                            {
                              "variant": "caption",
                              "label": "Active",
                              "name": "isActive"
                            }
                          ],
                          "itemActions": [
                            {
                              "icon": "check-circle",
                              "event": "ACTIVATE_ACCOUNT",
                              "variant": "primary",
                              "label": "Activate"
                            },
                            {
                              "label": "Deactivate",
                              "variant": "danger",
                              "icon": "x-circle",
                              "event": "DEACTIVATE_ACCOUNT"
                            }
                          ],
                          "entity": "@payload.data",
                          "cols": 1,
                          "type": "data-grid"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AccountLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "type": "alert",
                      "message": "Account activated"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DEACTIVATE_ACCOUNT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Account deactivated",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Account",
                    {
                      "emit": {
                        "failure": "AccountLoadFailed",
                        "success": "AccountLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Chart of Accounts"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AccountPage",
          "path": "/accounts",
          "traits": [
            {
              "ref": "AccountChart"
            }
          ]
        }
      ]
    }
  ]
}
