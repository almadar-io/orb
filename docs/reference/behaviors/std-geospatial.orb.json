{
  "name": "LocationOrbital",
  "orbitals": [
    {
      "name": "LocationOrbital",
      "entity": {
        "name": "Location",
        "collection": "locations",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "LocationBrowse",
          "category": "interaction",
          "linkedEntity": "Location",
          "listens": [
            {
              "event": "*.CONFIRMED",
              "triggers": "CONFIRMED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "CONFIRMED"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Location"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "justify": "space-between",
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "map-pin",
                                  "type": "icon",
                                  "size": "lg"
                                },
                                {
                                  "content": "Locations Picker",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "event": "SELECT",
                              "variant": "ghost",
                              "size": "sm",
                              "label": "Select Location"
                            }
                          ],
                          "emptyDescription": "No locations are available to select.",
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "entity": "Location",
                          "emptyTitle": "No locations found",
                          "columns": [
                            {
                              "name": "name",
                              "icon": "map-pin",
                              "variant": "h4",
                              "label": "Name"
                            },
                            {
                              "colorMap": {
                                "cancelled": "destructive",
                                "active": "success",
                                "scheduled": "warning",
                                "failed": "destructive",
                                "draft": "warning",
                                "done": "success",
                                "pending": "warning",
                                "archived": "neutral",
                                "completed": "success",
                                "disabled": "neutral",
                                "error": "destructive",
                                "inactive": "neutral"
                              },
                              "label": "Description",
                              "name": "description",
                              "variant": "badge"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "caption"
                            }
                          ]
                        },
                        {
                          "icon": "plus",
                          "label": "Create",
                          "type": "floating-action-button",
                          "tooltip": "Create",
                          "event": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CONFIRMED",
                "effects": [
                  [
                    "fetch",
                    "Location"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "LocationSelect",
          "category": "interaction",
          "linkedEntity": "Location",
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "SELECT"
              },
              {
                "key": "CLOSE"
              },
              {
                "key": "CONFIRM_SELECT"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Location"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "SELECT",
                "effects": [
                  [
                    "fetch",
                    "Location",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "map-pin"
                            },
                            {
                              "content": "@entity.name",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Name",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.name"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "caption",
                              "type": "typography",
                              "content": "Description"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.description"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "children": [
                            {
                              "content": "Status",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.status"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Created At"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.createdAt",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "gap": "md",
                          "children": [
                            {
                              "variant": "caption",
                              "content": "Pending ID",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.pendingId"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "label": "Cancel",
                              "event": "CLOSE",
                              "type": "button",
                              "variant": "ghost"
                            },
                            {
                              "variant": "primary",
                              "label": "Confirm Selection",
                              "type": "button",
                              "event": "CONFIRM_SELECT",
                              "icon": "check"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CONFIRM_SELECT",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "LocationConfirmSelect",
          "category": "interaction",
          "linkedEntity": "Location",
          "emits": [
            {
              "event": "CONFIRMED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "CONFIRM_SELECT"
              },
              {
                "key": "CONFIRMED"
              },
              {
                "key": "CANCEL"
              },
              {
                "key": "CLOSE"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Location"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "CONFIRM_SELECT",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "Location",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "size": "md",
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Confirm Location Selection"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Are you sure you want to select this location?",
                          "variant": "danger",
                          "type": "alert"
                        },
                        {
                          "type": "stack",
                          "justify": "end",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "event": "CANCEL",
                              "label": "Cancel",
                              "variant": "ghost"
                            },
                            {
                              "icon": "check",
                              "event": "CONFIRMED",
                              "type": "button",
                              "label": "Confirm",
                              "variant": "danger"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRMED",
                "effects": [
                  [
                    "fetch",
                    "Location"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "Location"
                  ],
                  [
                    "emit",
                    "CONFIRMED"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "Location"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "Location"
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Locations",
          "path": "/locations",
          "traits": [
            {
              "ref": "LocationBrowse"
            },
            {
              "ref": "LocationSelect"
            },
            {
              "ref": "LocationConfirmSelect"
            }
          ]
        }
      ]
    }
  ]
}
