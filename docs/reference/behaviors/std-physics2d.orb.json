{
  "name": "std-physics2d",
  "version": "1.0.0",
  "description": "std-physics2d as a Function",
  "orbitals": [
    {
      "name": "PhysicsBodyOrbital",
      "entity": {
        "name": "PhysicsBody",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "x",
            "type": "number",
            "default": 0
          },
          {
            "name": "y",
            "type": "number",
            "default": 0
          },
          {
            "name": "vx",
            "type": "number",
            "default": 0
          },
          {
            "name": "vy",
            "type": "number",
            "default": 0
          },
          {
            "name": "forceX",
            "type": "number",
            "default": 0
          },
          {
            "name": "forceY",
            "type": "number",
            "default": 0
          },
          {
            "name": "physicsStatus",
            "type": "string",
            "default": "idle"
          }
        ]
      },
      "traits": [
        {
          "name": "PhysicsBodyPhysics",
          "category": "interaction",
          "linkedEntity": "PhysicsBody",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "simulating"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "TICK",
                "name": "Tick"
              },
              {
                "key": "APPLY_FORCE",
                "name": "Apply Force",
                "payloadSchema": [
                  {
                    "name": "forceX",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "forceY",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "STOP",
                "name": "Stop"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "running": false,
                          "preset": "spring",
                          "height": 400,
                          "type": "simulation-canvas",
                          "speed": 1,
                          "width": 800
                        },
                        {
                          "icon": "play",
                          "variant": "primary",
                          "action": "START",
                          "label": "Start",
                          "type": "button"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "simulating",
                "event": "START",
                "effects": [
                  [
                    "set",
                    "@entity.physicsStatus",
                    "simulating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "simulation-canvas",
                          "width": 800,
                          "speed": 1,
                          "preset": "spring",
                          "running": true,
                          "height": 400
                        },
                        {
                          "children": [
                            {
                              "icon": "move",
                              "type": "button",
                              "action": "APPLY_FORCE",
                              "variant": "secondary",
                              "label": "Apply Force"
                            },
                            {
                              "label": "Stop",
                              "action": "STOP",
                              "variant": "ghost",
                              "icon": "square",
                              "type": "button"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "simulating",
                "event": "TICK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "running": true,
                          "speed": 1,
                          "type": "simulation-canvas",
                          "width": 800,
                          "preset": "spring",
                          "height": 400
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "variant": "secondary",
                              "icon": "move",
                              "label": "Apply Force",
                              "action": "APPLY_FORCE"
                            },
                            {
                              "icon": "square",
                              "label": "Stop",
                              "action": "STOP",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "center",
                          "gap": "sm"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "simulating",
                "event": "APPLY_FORCE",
                "effects": [
                  [
                    "set",
                    "@entity.forceX",
                    "@payload.forceX"
                  ],
                  [
                    "set",
                    "@entity.forceY",
                    "@payload.forceY"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "height": 400,
                          "preset": "spring",
                          "running": true,
                          "width": 800,
                          "type": "simulation-canvas",
                          "speed": 1
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "APPLY_FORCE",
                              "label": "Apply Force",
                              "type": "button",
                              "variant": "secondary",
                              "icon": "move"
                            },
                            {
                              "variant": "ghost",
                              "label": "Stop",
                              "icon": "square",
                              "type": "button",
                              "action": "STOP"
                            }
                          ],
                          "direction": "horizontal",
                          "justify": "center"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "idle",
                "event": "STOP",
                "effects": [
                  [
                    "set",
                    "@entity.physicsStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "width": 800,
                          "preset": "spring",
                          "running": false,
                          "type": "simulation-canvas",
                          "speed": 1,
                          "height": 400
                        },
                        {
                          "icon": "play",
                          "label": "Start",
                          "variant": "primary",
                          "type": "button",
                          "action": "START"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "simulating",
                "to": "simulating",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "running": true,
                          "type": "simulation-canvas",
                          "preset": "spring",
                          "width": 800,
                          "height": 400,
                          "speed": 1
                        },
                        {
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "APPLY_FORCE",
                              "variant": "secondary",
                              "label": "Apply Force",
                              "type": "button",
                              "icon": "move"
                            },
                            {
                              "type": "button",
                              "icon": "square",
                              "variant": "ghost",
                              "action": "STOP",
                              "label": "Stop"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PhysicsBodyPhysicsPage",
          "path": "/physicsbodys/physics",
          "traits": [
            {
              "ref": "PhysicsBodyPhysics"
            }
          ]
        }
      ]
    }
  ]
}
