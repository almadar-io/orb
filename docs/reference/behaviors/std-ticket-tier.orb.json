              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TicketTierLoaded",
                "name": "TicketTier loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TicketTier]"
                  }
                ]
              },
              {
                "key": "TicketTierLoadFailed",
                "name": "TicketTier load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELL",
                "name": "Sell",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  },
                  {
                    "name": "qty",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close",
                "payloadSchema": [
                  {
                    "name": "tierId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierCreated",
                "name": "TicketTier created",
                "payloadSchema": [
