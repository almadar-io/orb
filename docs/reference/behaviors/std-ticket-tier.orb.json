                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading ticket tiers…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TicketTierLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "name": "ticket",
                              "type": "icon"
                            },
                            {
                              "content": "Ticket Tiers",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1,
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "UPDATE",
                              "icon": "edit",
                              "label": "Update",
                              "variant": "secondary"
                            },
                            {
                              "label": "Sell",
                              "variant": "primary",
                              "icon": "shopping-cart",
                              "event": "SELL"
                            },
                            {
                              "label": "Close",
                              "event": "CLOSE",
                              "icon": "x",
                              "variant": "danger"
                            }
                          ],
                          "fields": [
                            {
                              "name": "name",
                              "label": "Tier",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "price",
                              "label": "Price"
                            },
                            {
                              "variant": "badge",
                              "label": "Currency",
                              "name": "currency"
                            },
                            {
                              "label": "Total",
                              "name": "quantityTotal",
                              "variant": "caption"
                            },
                            {
                              "label": "Sold",
                              "name": "quantitySold",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "variant": "primary",
                          "label": "New Tier",
                          "action": "CREATE",
                          "type": "button",
                          "icon": "plus"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TicketTierLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "TicketTier",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "TicketTierCreated",
                        "failure": "TicketTierWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    "@payload.row.quantitySold"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "persist",
                    "update",
                    "TicketTier",
                    "@entity",
                    {
                      "emit": {
                        "success": "TicketTierUpdated",
                        "failure": "TicketTierWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SELL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    [
                      "+",
                      "@payload.row.quantitySold",
                      "@payload.qty"
                    ]
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    [
                      "if",
                      [
                        ">=",
                        [
                          "+",
                          "@payload.row.quantitySold",
                          "@payload.qty"
                        ],
                        [
                          "+",
                          "@payload.row.quantityTotal",
                          0
                        ]
                      ],
                      "sold-out",
                      "available"
                    ]
                  ],
                  [
                    "persist",
                    "update",
                    "TicketTier",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TicketTierWriteFailed",
                        "success": "TicketTierSold"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.tierId"
                  ],
                  [
                    "set",
                    "@entity.eventId",
                    "@payload.row.eventId"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "set",
                    "@entity.price",
                    "@payload.row.price"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.quantityTotal",
                    "@payload.row.quantityTotal"
                  ],
                  [
                    "set",
                    "@entity.quantitySold",
                    "@payload.row.quantitySold"
                  ],
                  [
                    "set",
                    "@entity.availableFrom",
                    "@payload.row.availableFrom"
                  ],
                  [
                    "set",
                    "@entity.availableUntil",
                    "@payload.row.availableUntil"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "closed"
                  ],
                  [
                    "persist",
                    "update",
                    "TicketTier",
                    "@entity",
                    {
                      "emit": {
                        "success": "TicketTierClosed",
                        "failure": "TicketTierWriteFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierCreated",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierUpdated",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierSold",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TicketTierClosed",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "success": "TicketTierLoaded",
                        "failure": "TicketTierLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TicketTierWriteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TicketTier",
                    {
                      "emit": {
                        "failure": "TicketTierLoadFailed",
                        "success": "TicketTierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Ticket Tiers"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TicketTierManagePage",
          "path": "/tickettiers/manage",
          "traits": [
            {
              "ref": "TicketTierManage"
            }
          ]
        }
      ]
    }
  ]
}
