                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierSold",
                "name": "TicketTier sold",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierClosed",
                "name": "TicketTier closed",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "TicketTier"
                  }
                ]
              },
              {
                "key": "TicketTierWriteFailed",
                "name": "TicketTier write failed",
                "payloadSchema": [
