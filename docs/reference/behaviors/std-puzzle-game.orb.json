{
  "name": "PuzzleBoardOrbital",
  "orbitals": [
    {
      "name": "PuzzleBoardOrbital",
      "entity": {
        "name": "PuzzleBoard",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number"
          },
          {
            "name": "highScore",
            "type": "number"
          },
          {
            "name": "combo",
            "type": "number"
          },
          {
            "name": "multiplier",
            "type": "number"
          },
          {
            "name": "level",
            "type": "number"
          },
          {
            "name": "moves",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "PuzzleBoardPuzzleFlow",
          "category": "interaction",
          "linkedEntity": "PuzzleBoard",
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "START"
              },
              {
                "key": "NAVIGATE"
              },
              {
                "key": "MOVE"
              },
              {
                "key": "HINT"
              },
              {
                "key": "PAUSE"
              },
              {
                "key": "GAME_OVER"
              },
              {
                "key": "RESUME"
              },
              {
                "key": "CLOSE"
              },
              {
                "key": "RESTART"
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PuzzleBoard"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "subtitle": "Puzzle Challenge",
                      "type": "game-menu",
                      "title": "Puzzle",
                      "menuItems": [
                        {
                          "label": "Start Puzzle",
                          "event": "START",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-canvas-2d",
                      "width": 800.0,
                      "fps": 60.0,
                      "height": 600.0
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "MOVE",
                "effects": [
                  [
                    "set",
                    "@entity.moves",
                    [
                      "+",
                      "@entity.moves",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "width": 800.0,
                      "type": "game-canvas-2d",
                      "fps": 60.0,
                      "height": 600.0
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "playing",
                "event": "HINT"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "game-menu",
                      "title": "Paused",
                      "menuItems": [
                        {
                          "label": "Resume",
                          "event": "RESUME",
                          "variant": "primary"
                        },
                        {
                          "event": "RESTART",
                          "label": "Quit",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Puzzle Complete",
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "label": "Moves",
                          "value": "@entity.moves"
                        }
                      ],
                      "menuItems": [
                        {
                          "label": "Play Again",
                          "event": "RESTART",
                          "variant": "primary"
                        },
                        {
                          "event": "RESTART",
                          "label": "Main Menu",
                          "variant": "secondary"
                        }
                      ],
                      "type": "game-over-screen"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-canvas-2d",
                      "width": 800.0,
                      "fps": 60.0,
                      "height": 600.0
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "width": 800.0,
                      "height": 600.0,
                      "type": "game-canvas-2d",
                      "fps": 60.0
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "label": "Start Puzzle",
                          "event": "START",
                          "variant": "primary"
                        }
                      ],
                      "type": "game-menu",
                      "title": "Puzzle",
                      "subtitle": "Puzzle Challenge"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "variant": "primary",
                          "label": "Start Puzzle",
                          "event": "START"
                        }
                      ],
                      "title": "Puzzle",
                      "subtitle": "Puzzle Challenge",
                      "type": "game-menu"
                    }
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "PuzzleBoardPuzzleScore",
          "category": "interaction",
          "linkedEntity": "PuzzleBoard",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "ADD_SCORE"
              },
              {
                "key": "COMBO"
              },
              {
                "key": "RESET"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PuzzleBoard"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "score-board",
                      "score": "@entity.score",
                      "highScore": "@entity.highScore",
                      "combo": "@entity.combo",
                      "multiplier": "@entity.multiplier",
                      "level": "@entity.level"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "level": "@entity.level",
                      "multiplier": "@entity.multiplier",
                      "highScore": "@entity.highScore",
                      "type": "score-board",
                      "score": "@entity.score",
                      "combo": "@entity.combo"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "score-board",
                      "multiplier": "@entity.multiplier",
                      "combo": "@entity.combo",
                      "level": "@entity.level",
                      "score": "@entity.score",
                      "highScore": "@entity.highScore"
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Puzzleboards",
          "path": "/puzzleboards",
          "traits": [
            {
              "ref": "PuzzleBoardPuzzleFlow"
            },
            {
              "ref": "PuzzleBoardPuzzleScore"
            }
          ]
        }
      ]
    }
  ]
}
