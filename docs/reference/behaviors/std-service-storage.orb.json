{
  "name": "std-service-storage",
  "version": "2.0.0",
  "description": "std-service-storage — Object storage upload service. Bind via `uses Storage from \"std/behaviors/std-service-storage\"` and configure `bucket` / `acl` / `maxSize` / `allowedMimeTypes` at the call site. Pass `uiTrait: \"@trait.YourUploadForm\"` to inject your own picker; leave unset to render the atom's default file picker (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceStorageOrbital",
      "entity": {
        "name": "ServiceStorage",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "bucket",
            "type": "string",
            "default": ""
          },
          {
            "name": "fileKey",
            "type": "string",
            "default": ""
          },
          {
            "name": "url",
            "type": "string",
            "default": ""
          },
          {
            "name": "storageStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceStorageDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "UPLOAD",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                },
                {
                  "name": "file",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "hard-drive",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Upload File"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "inputType": "text",
                          "placeholder": "Choose file..."
                        },
                        {
                          "icon": "upload",
                          "action": "UPLOAD",
                          "label": "Upload",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceStorageStorage",
          "category": "interaction",
          "linkedEntity": "ServiceStorage",
          "emits": [
            {
              "event": "ServiceStorageLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStorageLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "StorageUploaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "url",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStorageStorageFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "UPLOAD",
              "triggers": "UPLOAD",
              "source": {
                "kind": "trait",
                "trait": "ServiceStorageDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "uploading"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD",
                "name": "Upload",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  },
                  {
                    "name": "file",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStorageLoaded",
                "name": "ServiceStorage loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStorageLoadFailed",
                "name": "ServiceStorage load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "StorageUploaded",
                "name": "Storage uploaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "url",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceStorageStorageFailed",
                "name": "ServiceStorage storage failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.bucket",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceStorage",
                    {
                      "emit": {
                        "success": "ServiceStorageLoaded",
                        "failure": "ServiceStorageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceStorageDefaultForm"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Uploading file to storage.",
                      "title": "Uploading...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "upload",
                    {
                      "bucket": "",
                      "acl": "private",
                      "file": "@payload.file"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "StorageUploaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceStorageLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceStorageLoadFailed"
              },
              {
                "from": "uploading",
                "to": "succeeded",
                "event": "StorageUploaded",
                "effects": [
                  [
                    "set",
                    "@entity.fileKey",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.url",
                    "@payload.url"
                  ],
                  [
                    "set",
                    "@entity.storageStatus",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "success",
                          "message": "Upload successful!",
                          "type": "alert"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.url",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "action": "RESET",
                          "label": "Upload Another",
                          "variant": "ghost",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceStorageStorageFailed",
                    {
                      "code": "upload_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Upload Failed",
                      "message": "@entity.error",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceStorageDefaultForm"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "succeeded",
                "event": "StorageUploaded"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceStorageStorageFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceStorageDefaultForm"
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceStorageDefaultForm"
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceStorageDefaultForm"
            },
            "maxSize": {
              "type": "number",
              "default": 10485760
            },
            "allowedMimeTypes": {
              "type": "[string]",
              "default": []
            },
            "acl": {
              "type": "string",
              "default": "private",
              "values": [
                "public",
                "private"
              ]
            },
            "bucket": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceStoragePage",
          "path": "/servicestorages",
          "traits": [
            {
              "ref": "ServiceStorageStorage"
            }
          ]
        }
      ]
    }
  ]
}
