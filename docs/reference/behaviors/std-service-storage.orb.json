{
  "name": "std-service-storage",
  "version": "1.0.0",
  "description": "std-service-storage as a Function",
  "orbitals": [
    {
      "name": "ServiceStorageOrbital",
      "entity": {
        "name": "ServiceStorage",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "bucket",
            "type": "string",
            "default": "uploads"
          },
          {
            "name": "fileKey",
            "type": "string"
          },
          {
            "name": "prefix",
            "type": "string"
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "storageStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "result",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceStorageStorage",
          "category": "interaction",
          "linkedEntity": "ServiceStorage",
          "emits": [
            {
              "event": "ServiceStorageLoaded",
              "description": "Fired when ServiceStorage finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "bucket",
                  "type": "string"
                },
                {
                  "name": "fileKey",
                  "type": "string"
                },
                {
                  "name": "prefix",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                },
                {
                  "name": "storageStatus",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStorageLoadFailed",
              "description": "Fired when ServiceStorage fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStorageStorageCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceStorageStorageFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "executing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "UPLOAD_FILE",
                "name": "Upload File"
              },
              {
                "key": "DOWNLOAD_FILE",
                "name": "Download File"
              },
              {
                "key": "LIST_FILES",
                "name": "List Files"
              },
              {
                "key": "DELETE_FILE",
                "name": "Delete File"
              },
              {
                "key": "EXECUTED",
                "name": "Executed",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceStorageLoaded",
                "name": "ServiceStorage loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "bucket",
                    "type": "string"
                  },
                  {
                    "name": "fileKey",
                    "type": "string"
                  },
                  {
                    "name": "prefix",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  },
                  {
                    "name": "storageStatus",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStorageLoadFailed",
                "name": "ServiceStorage load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStorageStorageCompleted",
                "name": "ServiceStorage storage completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceStorageStorageFailed",
                "name": "ServiceStorage storage failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.bucket",
                    "uploads"
                  ],
                  [
                    "set",
                    "@entity.content",
                    ""
                  ],
                  [
                    "set",
                    "@entity.fileKey",
                    ""
                  ],
                  [
                    "set",
                    "@entity.prefix",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceStorage",
                    {
                      "emit": {
                        "success": "ServiceStorageLoaded",
                        "failure": "ServiceStorageLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "stretch",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "name": "hard-drive",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "ServiceStorage Storage"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "bucket-name",
                          "type": "input"
                        },
                        {
                          "type": "input",
                          "placeholder": "path/to/file.txt"
                        },
                        {
                          "type": "input",
                          "placeholder": "path/prefix/"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "File content..."
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "icon": "upload",
                              "type": "button",
                              "label": "Upload",
                              "action": "UPLOAD_FILE",
                              "variant": "primary"
                            },
                            {
                              "icon": "download",
                              "type": "button",
                              "action": "DOWNLOAD_FILE",
                              "variant": "secondary",
                              "label": "Download"
                            },
                            {
                              "icon": "list",
                              "label": "List",
                              "action": "LIST_FILES",
                              "variant": "secondary",
                              "type": "button"
                            },
                            {
                              "variant": "danger",
                              "action": "DELETE_FILE",
                              "icon": "trash-2",
                              "label": "Delete",
                              "type": "button"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "UPLOAD_FILE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Executing storage operation on servicestorage...",
                      "title": "Processing...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "upload",
                    {
                      "content": "@entity.content",
                      "key": "@entity.fileKey",
                      "bucket": "@entity.bucket"
                    },
                    {
                      "emit": {
                        "failure": "ServiceStorageStorageFailed",
                        "success": "ServiceStorageStorageCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "DOWNLOAD_FILE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Executing storage operation on servicestorage...",
                      "type": "loading-state",
                      "title": "Processing..."
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "download",
                    {
                      "key": "@entity.fileKey",
                      "bucket": "@entity.bucket"
                    },
                    {
                      "emit": {
                        "success": "ServiceStorageStorageCompleted",
                        "failure": "ServiceStorageStorageFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "LIST_FILES",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Processing...",
                      "message": "Executing storage operation on servicestorage..."
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "list",
                    {
                      "prefix": "@entity.prefix",
                      "bucket": "@entity.bucket"
                    },
                    {
                      "emit": {
                        "failure": "ServiceStorageStorageFailed",
                        "success": "ServiceStorageStorageCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "DELETE_FILE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Processing...",
                      "type": "loading-state",
                      "message": "Executing storage operation on servicestorage..."
                    }
                  ],
                  [
                    "call-service",
                    "storage",
                    "delete",
                    {
                      "key": "@entity.fileKey",
                      "bucket": "@entity.bucket"
                    },
                    {
                      "emit": {
                        "failure": "ServiceStorageStorageFailed",
                        "success": "ServiceStorageStorageCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "complete",
                "event": "EXECUTED",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.data"
                  ],
                  [
                    "set",
                    "@entity.storageStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Operation completed successfully",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "content": "@entity.result",
                          "color": "muted",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "label": "Back",
                          "action": "RESET",
                          "variant": "ghost",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.storageStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "error-state",
                          "title": "Operation Failed",
                          "message": "@entity.error"
                        },
                        {
                          "variant": "ghost",
                          "action": "RESET",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "label": "Back"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.storageStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "hard-drive",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "ServiceStorage Storage"
                            }
                          ],
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "bucket-name",
                          "type": "input"
                        },
                        {
                          "type": "input",
                          "placeholder": "path/to/file.txt"
                        },
                        {
                          "placeholder": "path/prefix/",
                          "type": "input"
                        },
                        {
                          "placeholder": "File content...",
                          "type": "textarea"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "button",
                              "action": "UPLOAD_FILE",
                              "icon": "upload",
                              "label": "Upload",
                              "variant": "primary"
                            },
                            {
                              "label": "Download",
                              "variant": "secondary",
                              "type": "button",
                              "action": "DOWNLOAD_FILE",
                              "icon": "download"
                            },
                            {
                              "icon": "list",
                              "type": "button",
                              "variant": "secondary",
                              "action": "LIST_FILES",
                              "label": "List"
                            },
                            {
                              "variant": "danger",
                              "action": "DELETE_FILE",
                              "label": "Delete",
                              "icon": "trash-2",
                              "type": "button"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "align": "stretch",
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.storageStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "stretch",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "hard-drive"
                            },
                            {
                              "content": "ServiceStorage Storage",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "bucket-name"
                        },
                        {
                          "type": "input",
                          "placeholder": "path/to/file.txt"
                        },
                        {
                          "placeholder": "path/prefix/",
                          "type": "input"
                        },
                        {
                          "placeholder": "File content...",
                          "type": "textarea"
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "label": "Upload",
                              "icon": "upload",
                              "action": "UPLOAD_FILE",
                              "variant": "primary"
                            },
                            {
                              "icon": "download",
                              "action": "DOWNLOAD_FILE",
                              "type": "button",
                              "variant": "secondary",
                              "label": "Download"
                            },
                            {
                              "action": "LIST_FILES",
                              "label": "List",
                              "icon": "list",
                              "type": "button",
                              "variant": "secondary"
                            },
                            {
                              "action": "DELETE_FILE",
                              "icon": "trash-2",
                              "variant": "danger",
                              "type": "button",
                              "label": "Delete"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceStoragePage",
          "path": "/servicestorages",
          "traits": [
            {
              "ref": "ServiceStorageStorage"
            }
          ]
        }
      ]
    }
  ]
}
