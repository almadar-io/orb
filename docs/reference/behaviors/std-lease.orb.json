{
  "name": "std-lease",
  "version": "1.0.0",
  "description": "std-lease — owner-side lease records that tie tenants to property units with dates, monthly rent, and lifecycle status (pending/active/expired/terminated).",
  "orbitals": [
    {
      "name": "LeaseOrbital",
      "entity": {
        "name": "Lease",
        "collection": "leases",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantId",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "unitId",
            "type": "string",
            "default": ""
          },
          {
            "name": "unitLabel",
            "type": "string",
            "default": ""
          },
          {
            "name": "startDate",
            "type": "string",
            "required": true
          },
          {
            "name": "endDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "monthlyRent",
            "type": "number",
            "default": 0
          },
          {
            "name": "status",
            "type": "string",
            "default": "pending",
            "values": [
              "active",
              "expired",
              "terminated",
              "pending"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "LeaseManager",
          "category": "interaction",
          "linkedEntity": "Lease",
          "emits": [
            {
              "event": "RENEW_LEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "TERMINATE_LEASE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "LeaseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Lease]"
                }
              ]
            },
            {
              "event": "LeaseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LeaseLoaded",
                "name": "Lease loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Lease]"
                  }
                ]
              },
              {
                "key": "LeaseLoadFailed",
                "name": "Lease load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RENEW_LEASE",
                "name": "Renew Lease",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "TERMINATE_LEASE",
                "name": "Terminate Lease",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "success": "LeaseLoaded",
                        "failure": "LeaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading leases…"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LeaseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "mode": "background",
                          "type": "geometric-pattern",
                          "color": "primary",
                          "opacity": 0.05,
                          "variant": "star8"
                        },
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "name": "file-text",
                                  "type": "icon"
                                },
                                {
                                  "content": "Leases",
                                  "variant": "h3",
                                  "type": "typography"
                                },
                                {
                                  "label": "Active",
                                  "variant": "success",
                                  "type": "badge"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "split",
                          "gap": "lg",
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "accordion",
                                  "items": [
                                    {
                                      "content": "Start to end dates, renewal options, notice period.",
                                      "title": "Lease Term",
                                      "id": "term"
                                    },
                                    {
                                      "content": "Monthly rent, security deposit, late fees.",
                                      "id": "rent",
                                      "title": "Rent & Fees"
                                    },
                                    {
                                      "content": "Tenant responsibilities, owner obligations, restrictions.",
                                      "id": "terms",
                                      "title": "Terms & Conditions"
                                    }
                                  ]
                                },
                                {
                                  "options": [
                                    {
                                      "label": "Current Term",
                                      "value": "current"
                                    },
                                    {
                                      "label": "Renewal Period",
                                      "value": "next"
                                    }
                                  ],
                                  "selected": "current",
                                  "type": "date-range-selector"
                                }
                              ],
                              "direction": "vertical"
                            },
                            {
                              "children": [
                                {
                                  "items": [
                                    {
                                      "src": "https://picsum.photos/seed/lease1/800/600",
                                      "type": "image",
                                      "id": "Property",
                                      "alt": "Property"
                                    },
                                    {
                                      "id": "Property",
                                      "type": "image",
                                      "alt": "Property",
                                      "src": "https://picsum.photos/seed/lease2/800/600"
                                    },
                                    {
                                      "src": "https://picsum.photos/seed/lease3/800/600",
                                      "id": "Property",
                                      "type": "image",
                                      "alt": "Property"
                                    },
                                    {
                                      "alt": "Property",
                                      "type": "image",
                                      "id": "Property",
                                      "src": "https://picsum.photos/seed/lease4/800/600"
                                    }
                                  ],
                                  "type": "media-gallery",
                                  "title": "Property photos",
                                  "columns": 2
                                },
                                {
                                  "items": [
                                    {
                                      "alt": "Photo 1",
                                      "src": "https://picsum.photos/seed/lease1/1200/800"
                                    },
                                    {
                                      "src": "https://picsum.photos/seed/lease2/1200/800",
                                      "alt": "Photo 2"
                                    },
                                    {
                                      "alt": "Photo 3",
                                      "src": "https://picsum.photos/seed/lease3/1200/800"
                                    }
                                  ],
                                  "showArrows": true,
                                  "type": "carousel",
                                  "showDots": true
                                }
                              ],
                              "direction": "vertical",
                              "type": "stack",
                              "gap": "md"
                            }
                          ],
                          "ratio": "1:1"
                        },
                        {
                          "showCounter": true,
                          "type": "lightbox",
                          "currentIndex": 0,
                          "isOpen": false,
                          "images": [
                            {
                              "src": "https://picsum.photos/seed/lease1/1200/800",
                              "caption": "Property",
                              "alt": "Property"
                            }
                          ]
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "tenantName",
                              "label": "Tenant"
                            },
                            {
                              "variant": "caption",
                              "label": "Unit",
                              "name": "unitLabel"
                            },
                            {
                              "variant": "caption",
                              "name": "startDate",
                              "label": "Start"
                            },
                            {
                              "label": "End",
                              "name": "endDate",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "monthlyRent",
                              "label": "Monthly Rent"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "RENEW_LEASE",
                              "label": "Renew"
                            },
                            {
                              "variant": "danger",
                              "event": "TERMINATE_LEASE",
                              "label": "Terminate"
                            }
                          ],
                          "cols": 1,
                          "entity": "@payload.data",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LeaseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RENEW_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Lease renewal requested"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TERMINATE_LEASE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Lease termination requested",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Lease",
                    {
                      "emit": {
                        "success": "LeaseLoaded",
                        "failure": "LeaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Leases"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "LeasePage",
          "path": "/leases",
          "traits": [
            {
              "ref": "LeaseManager"
            }
          ]
        }
      ]
    }
  ]
}
