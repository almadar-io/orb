            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentClassifier",
                    {
                      "emit": {
                        "failure": "AgentClassifierLoadFailed",
                        "success": "AgentClassifierLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "tag",
                      "description": "Classifier is ready",
                      "type": "empty-state",
                      "title": "Classifier"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "classifying",
                "event": "DO_CLASSIFY",
                "effects": [
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify the following text into one of these categories: ",
                      "positive, negative, neutral",
                      ". Text: ",
                      "@entity.input",
                      ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"
                    ]
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "classifying",
                "event": "CLASSIFIED",
                "effects": [
                  [
                    "agent/generate",
                    [
                      "str/concat",
                      "Classify the following text into one of these categories: ",
                      "positive, negative, neutral",
                      ". Text: ",
                      "@entity.input",
                      ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"
                    ]
                  ]
                ]
              },
              {
                "from": "classifying",
                "to": "classified",
                "event": "DO_CLASSIFY",
                "effects": [
                  [
                    "set",
                    "@entity.category",
                    "@payload.data.input"
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "notificationType": "success",
                      "message": "Classification complete"
                    }
                  ]
                ]
              },
              {
                "from": "classified",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.input",
                    ""
                  ],
                  [
                    "set",
                    "@entity.category",
                    ""
                  ],
                  [
                    "set",
                    "@entity.confidence",
                    0
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AgentClassifierPage",
          "path": "/agentclassifiers",
          "traits": [
            {
              "ref": "AgentClassifierModal"
            },
            {
              "ref": "AgentClassifierNotification"
            },
            {
              "ref": "AgentClassifierAgent"
            }
          ]
        }
      ]
    }
  ]
}
