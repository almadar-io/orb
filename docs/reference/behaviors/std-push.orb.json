{
  "name": "std-push",
  "version": "1.0.0",
  "description": "std-push as a Function",
  "orbitals": [
    {
      "name": "PushSubscriberOrbital",
      "entity": {
        "name": "PushSubscriber",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "PushSubscriberIndicator",
          "category": "interaction",
          "linkedEntity": "PushSubscriber",
          "emits": [
            {
              "event": "PUSH_RECEIVED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PUSH_DISCONNECTED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "reason",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PushSubscriberLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PushSubscriberLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PushSubscriber]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "connecting"
              },
              {
                "name": "subscribed"
              },
              {
                "name": "reconnecting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PUSH_RECEIVED",
                "name": "Push Received",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PUSH_DISCONNECTED",
                "name": "Push Disconnected",
                "payloadSchema": [
                  {
                    "name": "reason",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PushSubscriberLoadFailed",
                "name": "PushSubscriber load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PushSubscriberLoaded",
                "name": "PushSubscriber loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PushSubscriber]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "connecting",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "PushSubscriber",
                    {
                      "emit": {
                        "success": "PushSubscriberLoaded",
                        "failure": "PushSubscriberLoadFailed"
                      }
                    }
                  ],
                  [
                    "os/watch-http",
                    "wss://push.example.com",
                    {
                      "emit": {
                        "on_message": "PUSH_RECEIVED",
                        "failure": "PUSH_DISCONNECTED"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "sm",
                      "direction": "horizontal",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Connecting…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "connecting",
                "to": "subscribed",
                "event": "PUSH_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "horizontal",
                      "children": [
                        {
                          "color": "success",
                          "name": "wifi",
                          "type": "icon"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Connected"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "connecting",
                "to": "reconnecting",
                "event": "PUSH_DISCONNECTED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "reconnecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "sm",
                      "children": [
                        {
                          "color": "warning",
                          "type": "icon",
                          "name": "wifi-off"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Reconnecting…"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal"
                    }
                  ]
                ]
              },
              {
                "from": "subscribed",
                "to": "subscribed",
                "event": "PUSH_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "sm",
                      "children": [
                        {
                          "name": "wifi",
                          "color": "success",
                          "type": "icon"
                        },
                        {
                          "content": "Connected",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "subscribed",
                "to": "reconnecting",
                "event": "PUSH_DISCONNECTED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "reconnecting"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "horizontal",
                      "children": [
                        {
                          "type": "icon",
                          "color": "warning",
                          "name": "wifi-off"
                        },
                        {
                          "type": "typography",
                          "content": "Reconnecting…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "gap": "sm",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "reconnecting",
                "to": "subscribed",
                "event": "PUSH_RECEIVED",
                "effects": [
                  [
                    "set",
                    "@entity.status",
                    "subscribed"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "name": "wifi",
                          "color": "success",
                          "type": "icon"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Connected"
                        }
                      ],
                      "type": "stack",
                      "direction": "horizontal",
                      "gap": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "reconnecting",
                "to": "reconnecting",
                "event": "PUSH_DISCONNECTED",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "sm",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "wifi-off"
                        },
                        {
                          "type": "typography",
                          "content": "Disconnected",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "direction": "horizontal"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "Push",
          "path": "/push",
          "traits": [
            {
              "ref": "PushSubscriberIndicator"
            }
          ]
        }
      ]
    }
  ]
}
