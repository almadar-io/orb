            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "RulesSaveFailed",
                        "success": "SurveyHydrated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "git-branch",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Branching rules",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "rules": [],
                          "questions": [],
                          "type": "branching-logic-builder"
                        },
                        {
                          "action": "EDIT_RULES_JSON",
                          "placeholder": "Rules JSON",
                          "value": "@entity.rulesJson",
                          "type": "input"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "action": "SAVE_RULES",
                          "label": "Save rules",
                          "icon": "save"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_RULES_JSON",
                "effects": [
                  [
                    "set",
                    "@entity.rulesJson",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SAVE_RULES",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "failure": "RulesSaveFailed",
                        "success": "RulesChanged"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SurveyHydrated"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RulesChanged"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RulesSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Branching rules"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FormBuilderPage",
          "path": "/survey-builder",
          "traits": [
            {
              "ref": "SurveyManage"
            },
            {
              "ref": "SurveyQuestions"
            },
            {
              "ref": "SurveyBranching"
            }
          ]
        }
      ]
    }
  ]
}
