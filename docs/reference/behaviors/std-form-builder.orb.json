                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyHydrated",
                        "failure": "QuestionsSaveFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "list-checks",
                              "type": "icon"
                            },
                            {
                              "content": "Survey questions",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "Questions JSON",
                          "action": "EDIT_QUESTIONS_JSON",
                          "value": "@entity.questionsJson"
                        },
                        {
                          "variant": "primary",
                          "icon": "save",
                          "action": "SAVE_QUESTIONS",
                          "label": "Save questions",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_QUESTIONS_JSON",
                "effects": [
                  [
                    "set",
                    "@entity.questionsJson",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SAVE_QUESTIONS",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "success": "QuestionsChanged",
                        "failure": "QuestionsSaveFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SurveyHydrated"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "QuestionsChanged"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "QuestionsSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "sidebar",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Survey questions"
            }
          },
          "scope": "instance"
        },
        {
          "name": "SurveyBranching",
