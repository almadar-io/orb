              },
              {
                "key": "SurveyHydrated",
                "name": "Survey hydrated",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Survey]"
                  }
                ]
              },
              {
                "key": "RulesChanged",
                "name": "Rules changed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RulesSaveFailed",
