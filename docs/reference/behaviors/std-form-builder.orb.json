{
  "name": "std-form-builder",
  "version": "1.0.0",
  "description": "std-form-builder — survey form composer. One Survey entity holds metadata, a JSON-encoded question library, and JSON-encoded branching rules. Three traits coordinate authoring on a single page: SurveyManage (CRUD on the survey), SurveyQuestions (in-place editing of questionsJson), SurveyBranching (in-place editing of rulesJson).",
  "orbitals": [
    {
      "name": "FormBuilderOrbital",
      "entity": {
        "name": "Survey",
        "collection": "surveys",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "questionsJson",
            "type": "string"
          },
          {
            "name": "rulesJson",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SurveyManage",
          "category": "interaction",
          "linkedEntity": "Survey",
          "emits": [
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "UPDATE",
              "payloadSchema": [
                {
                  "name": "surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "surveyId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Survey]"
                }
              ]
            },
            {
              "event": "SurveyLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyCreated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.questionsJson",
                  "type": "string"
                },
                {
                  "name": "row.rulesJson",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SurveyPublished",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "QuestionsChanged",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyQuestions"
              }
            },
            {
              "event": "RulesChanged",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "SurveyBranching"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "editing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SurveyLoaded",
                "name": "Survey loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Survey]"
                  }
                ]
              },
              {
                "key": "SurveyLoadFailed",
                "name": "Survey load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "UPDATE",
                "name": "Update",
                "payloadSchema": [
                  {
                    "name": "surveyId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Survey"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "surveyId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Survey"
                  }
                ]
              },
              {
                "key": "SurveyCreated",
                "name": "Survey created",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Survey"
                  }
                ]
              },
              {
                "key": "SurveyUpdated",
                "name": "Survey updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Survey"
                  }
                ]
              },
              {
                "key": "SurveyPublished",
                "name": "Survey published",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading surveys…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "SurveyLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "clipboard-list",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "Survey Builder"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            },
                            {
                              "icon": "plus",
                              "action": "CREATE",
                              "type": "button",
                              "variant": "primary",
                              "label": "New survey"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "event": "UPDATE",
                              "icon": "edit",
                              "label": "Edit",
                              "variant": "ghost"
                            },
                            {
                              "event": "PUBLISH",
                              "variant": "primary",
                              "label": "Publish",
                              "icon": "send"
                            }
                          ],
                          "type": "data-grid",
                          "cols": 1,
                          "fields": [
                            {
                              "label": "Title",
                              "variant": "h4",
                              "name": "title"
                            },
                            {
                              "variant": "caption",
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            },
                            {
                              "name": "createdAt",
                              "variant": "caption",
                              "label": "Created"
                            }
                          ],
                          "entity": "@payload.data",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Survey",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "SurveyCreated",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "UPDATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.surveyId"
                  ],
                  [
                    "set",
                    "@entity.title",
                    "@payload.row.title"
                  ],
                  [
                    "set",
                    "@entity.description",
                    "@payload.row.description"
                  ],
                  [
                    "set",
                    "@entity.questionsJson",
                    "@payload.row.questionsJson"
                  ],
                  [
                    "set",
                    "@entity.rulesJson",
                    "@payload.row.rulesJson"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "success": "SurveyUpdated",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "PUBLISH",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.surveyId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "published"
                  ],
                  [
                    "persist",
                    "update",
                    "Survey",
                    "@entity",
                    {
                      "emit": {
                        "success": "SurveyPublished",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SurveyCreated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SurveyUpdated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "SurveyPublished",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "error",
                "event": "SurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "SurveyCreated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "SurveyUpdated",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "failure": "SurveyLoadFailed",
                        "success": "SurveyLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "loading",
                "event": "SurveyPublished",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "error",
                "event": "SurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Survey",
                    {
                      "emit": {
                        "success": "SurveyLoaded",
                        "failure": "SurveyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Survey Builder"
            }
          },
          "scope": "collection"
        },
        {
          "name": "SurveyQuestions",
          "category": "interaction",
          "linkedEntity": "Survey",
          "emits": [
            {
              "event": "EDIT_QUESTIONS_JSON",
