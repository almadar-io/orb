              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT_QUESTIONS_JSON",
                "name": "Edit Questions Json",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SAVE_QUESTIONS",
                "name": "Save Questions"
              },
              {
                "key": "SurveyHydrated",
                "name": "Survey hydrated",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Survey]"
                  }
                ]
              },
              {
                "key": "QuestionsChanged",
                "name": "Questions changed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
