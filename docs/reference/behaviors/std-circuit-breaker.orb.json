{
  "name": "std-circuit-breaker",
  "version": "1.0.0",
  "description": "std-circuit-breaker as a Function",
  "orbitals": [
    {
      "name": "ServiceNodeOrbital",
      "entity": {
        "name": "ServiceNode",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "failureCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "successCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "threshold",
            "type": "number",
            "default": 5
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceNodeCircuitBreaker",
          "category": "interaction",
          "linkedEntity": "ServiceNode",
          "emits": [
            {
              "event": "ServiceNodeLoaded",
              "description": "Fired when ServiceNode finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "failureCount",
                  "type": "number"
                },
                {
                  "name": "successCount",
                  "type": "number"
                },
                {
                  "name": "threshold",
                  "type": "number"
                }
              ]
            },
            {
              "event": "ServiceNodeLoadFailed",
              "description": "Fired when ServiceNode fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              },
              {
                "name": "halfOpen"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FAILURE",
                "name": "Failure"
              },
              {
                "key": "SUCCESS",
                "name": "Success"
              },
              {
                "key": "TIMEOUT",
                "name": "Timeout"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceNodeLoaded",
                "name": "ServiceNode loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "failureCount",
                    "type": "number"
                  },
                  {
                    "name": "successCount",
                    "type": "number"
                  },
                  {
                    "name": "threshold",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ServiceNodeLoadFailed",
                "name": "ServiceNode load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.failureCount",
                    0
                  ],
                  [
                    "set",
                    "@entity.successCount",
                    0
                  ],
                  [
                    "set",
                    "@entity.threshold",
                    5
                  ],
                  [
                    "fetch",
                    "ServiceNode",
                    {
                      "emit": {
                        "success": "ServiceNodeLoaded",
                        "failure": "ServiceNodeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "md",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "ServiceNode"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "label": "Circuit Closed",
                              "status": "online",
                              "type": "status-dot",
                              "pulse": false
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed."
                        },
                        {
                          "cols": 2,
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "type": "meter",
                          "max": "@entity.threshold",
                          "min": 0,
                          "value": "@entity.failureCount"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "content": "ServiceNode",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "md",
                              "align": "center"
                            },
                            {
                              "pulse": true,
                              "status": "critical",
                              "label": "Circuit Open",
                              "type": "status-dot"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures."
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "type": "stat-display",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ],
                          "cols": 2
                        },
                        {
                          "min": 0,
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "type": "meter"
                        },
                        {
                          "icon": "rotate-ccw",
                          "label": "Reset",
                          "action": "RESET",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "ServiceNode"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "pulse": false,
                              "label": "Circuit Closed",
                              "status": "online",
                              "type": "status-dot"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ],
                          "cols": 2,
                          "type": "simple-grid"
                        },
                        {
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "min": 0
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "halfOpen",
                "event": "TIMEOUT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "activity"
                                },
                                {
                                  "type": "typography",
                                  "content": "ServiceNode",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "md"
                            },
                            {
                              "pulse": true,
                              "label": "Circuit Half-Open",
                              "type": "status-dot",
                              "status": "warning"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "warning",
                          "message": "Testing recovery. Limited requests are being allowed through.",
                          "type": "alert"
                        },
                        {
                          "children": [
                            {
                              "type": "stat-display",
                              "value": "@entity.failureCount",
                              "label": "Failures"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "value": "@entity.successCount"
                            }
                          ],
                          "cols": 2,
                          "type": "simple-grid"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "justify": "between",
                          "children": [
                            {
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "ServiceNode"
                                }
                              ],
                              "align": "center",
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "pulse": false,
                              "type": "status-dot",
                              "label": "Circuit Closed",
                              "status": "online"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed.",
                          "variant": "success"
                        },
                        {
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "type": "stat-display",
                              "label": "Successes",
                              "value": "@entity.successCount"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2
                        },
                        {
                          "value": "@entity.failureCount",
                          "max": "@entity.threshold",
                          "type": "meter",
                          "min": 0
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "stack",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "content": "ServiceNode",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "status-dot",
                              "pulse": false,
                              "status": "online",
                              "label": "Circuit Closed"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "justify": "between",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Service is healthy. All requests are being processed.",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "type": "simple-grid",
                          "cols": 2,
                          "children": [
                            {
                              "label": "Failures",
                              "value": "@entity.failureCount",
                              "type": "stat-display"
                            },
                            {
                              "label": "Successes",
                              "value": "@entity.successCount",
                              "type": "stat-display"
                            }
                          ]
                        },
                        {
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "min": 0
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "open",
                "event": "FAILURE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "alert-triangle",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "ServiceNode"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal",
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "status": "critical",
                              "label": "Circuit Open",
                              "pulse": true
                            }
                          ],
                          "justify": "between",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Circuit is open. Requests are being rejected to prevent cascading failures.",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "value": "@entity.successCount"
                            }
                          ],
                          "cols": 2
                        },
                        {
                          "value": "@entity.failureCount",
                          "type": "meter",
                          "min": 0,
                          "max": "@entity.threshold"
                        },
                        {
                          "label": "Reset",
                          "action": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "halfOpen",
                "to": "closed",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "shield"
                                },
                                {
                                  "content": "ServiceNode",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "align": "center"
                            },
                            {
                              "type": "status-dot",
                              "pulse": false,
                              "label": "Circuit Closed",
                              "status": "online"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Service is healthy. All requests are being processed."
                        },
                        {
                          "children": [
                            {
                              "label": "Failures",
                              "type": "stat-display",
                              "value": "@entity.failureCount"
                            },
                            {
                              "label": "Successes",
                              "type": "stat-display",
                              "value": "@entity.successCount"
                            }
                          ],
                          "type": "simple-grid",
                          "cols": 2
                        },
                        {
                          "type": "meter",
                          "max": "@entity.threshold",
                          "value": "@entity.failureCount",
                          "min": 0
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ServiceNodePage",
          "path": "/servicenodes",
          "traits": [
            {
              "ref": "ServiceNodeCircuitBreaker"
            }
          ]
        }
      ]
    }
  ]
}
