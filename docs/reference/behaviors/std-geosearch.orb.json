{
  "name": "std-geosearch",
  "version": "1.0.0",
  "description": "std-geosearch — location-aware search variant: search-input + map-view + range-slider for radius. Owns a GeoSearchResult runtime entity; GEO_SEARCH persists @payload.searchTerm/lat/lng/radiusKm so cross-trait listeners can route them into geo-aware data atoms.",
  "orbitals": [
    {
      "name": "GeoSearchResultOrbital",
      "entity": {
        "name": "GeoSearchResult",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "searchTerm",
            "type": "string"
          },
          {
            "name": "centerLat",
            "type": "number"
          },
          {
            "name": "centerLng",
            "type": "number"
          },
          {
            "name": "radiusKm",
            "type": "number",
            "default": 10
          },
          {
            "name": "boundsNorth",
            "type": "number"
          },
          {
            "name": "boundsSouth",
            "type": "number"
          },
          {
            "name": "boundsEast",
            "type": "number"
          },
          {
            "name": "boundsWest",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "GeoSearchResultSearch",
          "category": "interaction",
          "linkedEntity": "GeoSearchResult",
          "emits": [
            {
              "event": "GEO_SEARCH",
              "payloadSchema": [
                {
                  "name": "searchTerm",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "lat",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "lng",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "radiusKm",
                  "type": "number",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GEO_SEARCH",
                "name": "Geo Search",
                "payloadSchema": [
                  {
                    "name": "searchTerm",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "lat",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "lng",
                    "type": "number",
                    "required": true
                  },
                  {
                    "name": "radiusKm",
                    "type": "number",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "event": "GEO_SEARCH",
                          "type": "search-input",
                          "placeholder": "Search nearby…"
                        },
                        {
                          "height": "240px",
                          "type": "map-view",
                          "centerLat": "@entity.centerLat",
                          "markers": [],
                          "centerLng": "@entity.centerLng",
                          "zoom": 12
                        },
                        {
                          "action": "GEO_SEARCH",
                          "max": 100,
                          "type": "range-slider",
                          "min": 1,
                          "step": 1,
                          "showTooltip": true,
                          "value": "@entity.radiusKm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "GEO_SEARCH",
                "effects": [
                  [
                    "set",
                    "@entity.searchTerm",
                    "@payload.searchTerm"
                  ],
                  [
                    "set",
                    "@entity.centerLat",
                    "@payload.lat"
                  ],
                  [
                    "set",
                    "@entity.centerLng",
                    "@payload.lng"
                  ],
                  [
                    "set",
                    "@entity.radiusKm",
                    "@payload.radiusKm"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "search-input",
                          "placeholder": "Search nearby…",
                          "event": "GEO_SEARCH"
                        },
                        {
                          "markers": [],
                          "type": "map-view",
                          "height": "240px",
                          "centerLat": "@entity.centerLat",
                          "centerLng": "@entity.centerLng",
                          "zoom": 12
                        },
                        {
                          "max": 100,
                          "action": "GEO_SEARCH",
                          "step": 1,
                          "min": 1,
                          "type": "range-slider",
                          "value": "@entity.radiusKm",
                          "showTooltip": true
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "placeholder": {
              "type": "string",
              "default": "Search nearby…"
            },
            "event": {
              "type": "string",
              "default": "GEO_SEARCH"
            },
            "defaultRadiusKm": {
              "type": "number",
              "default": 10
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GeoSearchResultSearchPage",
          "path": "/geosearchresults/search",
          "traits": [
            {
              "ref": "GeoSearchResultSearch"
            }
          ]
        }
      ]
    }
  ]
}
