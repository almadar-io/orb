{
  "name": "std-service-github",
  "version": "1.0.0",
  "description": "std-service-github as a Function",
  "orbitals": [
    {
      "name": "ServiceGithubOrbital",
      "entity": {
        "name": "ServiceGithub",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "head",
            "type": "string",
            "default": ""
          },
          {
            "name": "base",
            "type": "string",
            "default": "main"
          },
          {
            "name": "prUrl",
            "type": "string",
            "default": ""
          },
          {
            "name": "prNumber",
            "type": "number",
            "default": 0
          },
          {
            "name": "ghStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceGithubGithub",
          "category": "interaction",
          "linkedEntity": "ServiceGithub",
          "emits": [
            {
              "event": "ServiceGithubLoaded",
              "description": "Fired when ServiceGithub finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "title",
                  "type": "string"
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "head",
                  "type": "string"
                },
                {
                  "name": "base",
                  "type": "string"
                },
                {
                  "name": "prUrl",
                  "type": "string"
                },
                {
                  "name": "prNumber",
                  "type": "number"
                },
                {
                  "name": "ghStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceGithubLoadFailed",
              "description": "Fired when ServiceGithub fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceGithubGithubCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceGithubGithubFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "creatingPR"
              },
              {
                "name": "prCreated"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PR",
                "name": "Create Pr"
              },
              {
                "key": "PR_CREATED",
                "name": "Pr Created",
                "payloadSchema": [
                  {
                    "name": "url",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "number",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceGithubLoaded",
                "name": "ServiceGithub loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "title",
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "type": "string"
                  },
                  {
                    "name": "head",
                    "type": "string"
                  },
                  {
                    "name": "base",
                    "type": "string"
                  },
                  {
                    "name": "prUrl",
                    "type": "string"
                  },
                  {
                    "name": "prNumber",
                    "type": "number"
                  },
                  {
                    "name": "ghStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceGithubLoadFailed",
                "name": "ServiceGithub load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceGithubGithubCompleted",
                "name": "ServiceGithub github completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceGithubGithubFailed",
                "name": "ServiceGithub github failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.base",
                    "main"
                  ],
                  [
                    "set",
                    "@entity.body",
                    ""
                  ],
                  [
                    "set",
                    "@entity.head",
                    ""
                  ],
                  [
                    "set",
                    "@entity.title",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceGithub",
                    {
                      "emit": {
                        "success": "ServiceGithubLoaded",
                        "failure": "ServiceGithubLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
                              "content": "Create Pull Request",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "placeholder": "PR title",
                              "type": "input"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "Describe your changes..."
                            },
                            {
                              "placeholder": "feature-branch",
                              "type": "input"
                            },
                            {
                              "placeholder": "main",
                              "type": "input"
                            }
                          ],
                          "gap": "md",
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "action": "CREATE_PR",
                          "icon": "git-pull-request",
                          "type": "button",
                          "variant": "primary",
                          "label": "Create PR"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "creatingPR",
                "event": "CREATE_PR",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Submitting your PR to GitHub.",
                      "title": "Creating pull request..."
                    }
                  ],
                  [
                    "call-service",
                    "github",
                    "createPR",
                    {
                      "base": "@entity.base",
                      "head": "@entity.head",
                      "title": "@entity.title",
                      "body": "@entity.body"
                    },
                    {
                      "emit": {
                        "failure": "ServiceGithubGithubFailed",
                        "success": "ServiceGithubGithubCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creatingPR",
                "to": "prCreated",
                "event": "PR_CREATED",
                "effects": [
                  [
                    "set",
                    "@entity.prUrl",
                    "@payload.url"
                  ],
                  [
                    "set",
                    "@entity.prNumber",
                    "@payload.number"
                  ],
                  [
                    "set",
                    "@entity.ghStatus",
                    "created"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "message": "Pull request created!",
                          "type": "alert",
                          "variant": "success"
                        },
                        {
                          "content": "@entity.prUrl",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "label": "Create Another",
                          "variant": "ghost",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "creatingPR",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.error",
                      "title": "PR Creation Failed",
                      "onRetry": "RETRY",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "prCreated",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "name": "git-pull-request",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Create Pull Request",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "PR title"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "Describe your changes..."
                            },
                            {
                              "type": "input",
                              "placeholder": "feature-branch"
                            },
                            {
                              "type": "input",
                              "placeholder": "main"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "action": "CREATE_PR",
                          "icon": "git-pull-request",
                          "variant": "primary",
                          "label": "Create PR",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
                              "content": "Create Pull Request",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "children": [
                            {
                              "placeholder": "PR title",
                              "type": "input"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "Describe your changes..."
                            },
                            {
                              "placeholder": "feature-branch",
                              "type": "input"
                            },
                            {
                              "placeholder": "main",
                              "type": "input"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "action": "CREATE_PR",
                          "type": "button",
                          "icon": "git-pull-request",
                          "label": "Create PR",
                          "variant": "primary"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "git-pull-request"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Create Pull Request"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "type": "stack",
                          "children": [
                            {
                              "placeholder": "PR title",
                              "type": "input"
                            },
                            {
                              "placeholder": "Describe your changes...",
                              "type": "textarea"
                            },
                            {
                              "type": "input",
                              "placeholder": "feature-branch"
                            },
                            {
                              "placeholder": "main",
                              "type": "input"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "icon": "git-pull-request",
                          "variant": "primary",
                          "type": "button",
                          "action": "CREATE_PR",
                          "label": "Create PR"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceGithubPage",
          "path": "/servicegithubs",
          "traits": [
            {
              "ref": "ServiceGithubGithub"
            }
          ]
        }
      ]
    }
  ]
}
