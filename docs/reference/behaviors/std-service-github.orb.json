{
  "name": "std-service-github",
  "version": "2.0.0",
  "description": "std-service-github — GitHub service. Bind via `uses Github from \"std/behaviors/std-service-github\"` and configure `owner` / `repo` / `path` / `ref` / `op` at the call site. Pass `uiTrait: \"@trait.YourGithubForm\"` to inject your own form; leave unset to render the atom's default form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceGithubOrbital",
      "entity": {
        "name": "ServiceGithub",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "owner",
            "type": "string",
            "default": ""
          },
          {
            "name": "repo",
            "type": "string",
            "default": ""
          },
          {
            "name": "path",
            "type": "string",
            "default": ""
          },
          {
            "name": "ref",
            "type": "string",
            "default": "main"
          },
          {
            "name": "result",
            "type": "object",
            "default": {}
          },
          {
            "name": "ghStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceGithubDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "RUN",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RUN",
                "name": "Run"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "name": "github",
                              "type": "icon"
                            },
                            {
                              "content": "GitHub",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "options": [
                                {
                                  "label": "Get File",
                                  "value": "getFile"
                                },
                                {
                                  "label": "List Commits",
                                  "value": "listCommits"
                                },
                                {
                                  "label": "Create Issue",
                                  "value": "createIssue"
                                }
                              ],
                              "type": "select"
                            },
                            {
                              "type": "input",
                              "placeholder": "owner"
                            },
                            {
                              "placeholder": "repo",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "placeholder": "path"
                            },
                            {
                              "placeholder": "ref (default: main)",
                              "type": "input"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "icon": "play",
                          "action": "RUN",
                          "label": "Run",
                          "variant": "primary",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceGithubGithub",
          "category": "interaction",
          "linkedEntity": "ServiceGithub",
          "emits": [
            {
              "event": "ServiceGithubLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceGithubLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "GithubDone",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceGithubGithubFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "RUN",
              "triggers": "RUN",
              "source": {
                "kind": "trait",
                "trait": "ServiceGithubDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "running"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RUN",
                "name": "Run"
              },
              {
                "key": "ServiceGithubLoaded",
                "name": "ServiceGithub loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceGithubLoadFailed",
                "name": "ServiceGithub load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "GithubDone",
                "name": "Github done",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceGithubGithubFailed",
                "name": "ServiceGithub github failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.owner",
                    ""
                  ],
                  [
                    "set",
                    "@entity.repo",
                    ""
                  ],
                  [
                    "set",
                    "@entity.path",
                    ""
                  ],
                  [
                    "set",
                    "@entity.ref",
                    "main"
                  ],
                  [
                    "fetch",
                    "ServiceGithub",
                    {
                      "emit": {
                        "failure": "ServiceGithubLoadFailed",
                        "success": "ServiceGithubLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceGithubDefaultForm"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "running",
                "event": "RUN",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Calling the GitHub service.",
                      "type": "loading-state",
                      "title": "Running GitHub operation..."
                    }
                  ],
                  [
                    "call-service",
                    "github",
                    "getFile",
                    {
                      "repo": "",
                      "ref": "main",
                      "path": "",
                      "owner": ""
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "GithubDone"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceGithubLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceGithubLoadFailed"
              },
              {
                "from": "running",
                "to": "succeeded",
                "event": "GithubDone",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.ghStatus",
                    "succeeded"
                  ],
                  [
                    "emit",
                    "GithubDone",
                    {
                      "id": "@entity.id",
                      "result": "@payload.result"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "GitHub operation completed!"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.id",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "action": "RESET",
                          "label": "Run Again",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "running",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceGithubGithubFailed",
                    {
                      "code": "github_op_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "title": "GitHub Operation Failed",
                      "type": "error-state",
                      "message": "@entity.error"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceGithubDefaultForm"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "succeeded",
                "event": "GithubDone"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceGithubGithubFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceGithubDefaultForm"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceGithubDefaultForm"
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "ref": {
              "type": "string",
              "default": "main"
            },
            "repo": {
              "type": "string",
              "default": ""
            },
            "path": {
              "type": "string",
              "default": ""
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceGithubDefaultForm"
            },
            "op": {
              "type": "string",
              "default": "getFile",
              "values": [
                "getFile",
                "listCommits",
                "createIssue"
              ]
            },
            "owner": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceGithubPage",
          "path": "/servicegithubs",
          "traits": [
            {
              "ref": "ServiceGithubGithub"
            }
          ]
        }
      ]
    }
  ]
}
