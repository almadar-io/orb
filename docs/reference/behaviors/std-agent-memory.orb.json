            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_MEMORIZE",
                "name": "Do Memorize",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "AgentMemory"
                  }
                ]
              },
              {
                "key": "DECAY",
                "name": "Decay"
              },
              {
                "key": "MEMORIZED",
                "name": "Memorized",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "AgentMemory"
                  }
                ]
              },
              {
                "key": "RECALL",
                "name": "Recall",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PIN",
                "name": "Pin",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FORGET",
                "name": "Forget",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REINFORCE",
                "name": "Reinforce",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FORGOT",
                "name": "Forgot"
              },
              {
                "key": "REINFORCED",
                "name": "Reinforced"
              },
              {
                "key": "DECAYED",
                "name": "Decayed"
              },
              {
                "key": "PINNED",
                "name": "Pinned"
              },
              {
                "key": "AgentMemoryLoaded",
                "name": "AgentMemory loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentMemory]"
                  }
                ]
              },
              {
                "key": "AgentMemoryLoadFailed",
                "name": "AgentMemory load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaved",
                "name": "AgentMemory saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentMemorySaveFailed",
                "name": "AgentMemory save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "failure": "AgentMemoryLoadFailed",
                        "success": "AgentMemoryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Memory",
                      "type": "empty-state",
                      "description": "Memory is ready",
                      "icon": "brain"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "DO_MEMORIZE",
                "effects": [
                  [
                    "agent/memorize",
                    "@payload.data.content",
                    "@payload.data.category"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentMemory",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentMemorySaveFailed",
                        "success": "AgentMemorySaved"
                      }
                    }
                  ],
                  [
                    "emit",
                    "MEMORIZED",
                    {
                      "id": "@payload.data.id"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED",
                    {
                      "id": ""
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "active",
                "event": "MEMORIZED",
                "effects": [
                  [
                    "fetch",
                    "AgentMemory",
                    {
                      "emit": {
                        "failure": "AgentMemoryLoadFailed",
                        "success": "AgentMemoryLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "RECALL",
                "effects": [
                  [
                    "agent/recall",
                    "@payload.query"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "PIN",
                "guard": [
                  "not",
                  [
                    "agent/is-pinned",
                    "@payload.id"
                  ]
                ],
                "effects": [
                  [
                    "agent/pin",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "PINNED",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "idle",
                "event": "FORGET",
                "effects": [
                  [
                    "agent/forget",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "FORGOT",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "REINFORCE",
                "effects": [
                  [
                    "agent/reinforce",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "REINFORCED",
                    {
                      "id": "@payload.id"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "active",
                "event": "DECAY",
                "effects": [
                  [
                    "agent/decay"
                  ],
                  [
                    "emit",
                    "DECAYED",
                    {
                      "id": ""
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentMemoryPage",
          "path": "/agentmemorys",
          "traits": [
            {
              "ref": "AgentMemoryBrowse"
            },
            {
              "ref": "AgentMemoryCreate"
            },
            {
              "ref": "AgentMemoryAgent"
            }
          ]
        }
      ]
    }
  ]
}
