{
  "name": "std-quest",
  "version": "1.0.0",
  "description": "std-quest as a Function",
  "orbitals": [
    {
      "name": "QuestLogOrbital",
      "entity": {
        "name": "QuestLog",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending",
              "complete",
              "failed"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "activeId",
            "type": "string",
            "default": ""
          },
          {
            "name": "activeName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "QuestLogTracking",
          "category": "interaction",
          "linkedEntity": "QuestLog",
          "emits": [
            {
              "event": "QuestLogLoaded",
              "description": "Fired when QuestLog finishes loading; payload.data holds the quests",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[QuestLog]"
                }
              ]
            },
            {
              "event": "QuestLogLoadFailed",
              "description": "Fired when QuestLog fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QuestLogUpdated",
              "description": "Fired when a quest is updated",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "QuestLogUpdateFailed",
              "description": "Fired when updating a quest fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "available"
              },
              {
                "name": "active"
              },
              {
                "name": "progressing"
              },
              {
                "name": "complete"
              },
              {
                "name": "failed"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "QuestLogLoaded",
                "name": "QuestLog loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[QuestLog]"
                  }
                ]
              },
              {
                "key": "QuestLogLoadFailed",
                "name": "QuestLog load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ACCEPT",
                "name": "Accept",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "QuestLog"
                  }
                ]
              },
              {
                "key": "PROGRESS",
                "name": "Progress"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "FAIL",
                "name": "Fail"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "QuestLogUpdated",
                "name": "QuestLog updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "QuestLogUpdateFailed",
                "name": "QuestLog update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "success": "QuestLogLoaded",
                        "failure": "QuestLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading quests…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "available",
                "event": "QuestLogLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "flag"
                                },
                                {
                                  "content": "QuestLogs Board",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "gap": "md",
                              "direction": "horizontal"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [],
                          "groupBy": "status",
                          "itemActions": [
                            {
                              "label": "Accept",
                              "event": "ACCEPT"
                            }
                          ],
                          "type": "data-list",
                          "entity": "@payload.data",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "direction": "horizontal",
                                  "type": "stack",
                                  "justify": "between",
                                  "align": "center",
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "type": "stack",
                                      "align": "center",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "name": "flag",
                                          "type": "icon"
                                        },
                                        {
                                          "type": "typography",
                                          "content": "@item.name",
                                          "variant": "h4"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "badge",
                                      "label": "@item.description"
                                    }
                                  ]
                                },
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "content": "@item.status"
                                }
                              ],
                              "gap": "sm"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "QuestLogLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load quests",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "content": "@payload.error",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "action": "INIT",
                          "label": "Retry",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "available",
                "to": "active",
                "event": "ACCEPT",
                "effects": [
                  [
                    "set",
                    "@entity.activeId",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.activeName",
                    "@payload.row.name"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "variant": "h2",
                          "content": "@entity.activeName",
                          "type": "typography"
                        },
                        {
                          "value": 50,
                          "showPercentage": true,
                          "type": "progress-bar"
                        },
                        {
                          "children": [
                            {
                              "type": "button",
                              "label": "Progress",
                              "action": "PROGRESS",
                              "variant": "primary"
                            },
                            {
                              "label": "Complete",
                              "type": "button",
                              "variant": "success",
                              "action": "COMPLETE"
                            },
                            {
                              "label": "Fail",
                              "variant": "danger",
                              "action": "FAIL",
                              "type": "button"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "progressing",
                "event": "PROGRESS",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "id": "@entity.activeId",
                      "status": "active"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "@entity.activeName"
                        },
                        {
                          "showPercentage": true,
                          "value": 75,
                          "type": "progress-bar"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "action": "COMPLETE",
                              "variant": "success",
                              "type": "button",
                              "label": "Complete"
                            },
                            {
                              "label": "Fail",
                              "variant": "danger",
                              "type": "button",
                              "action": "FAIL"
                            }
                          ],
                          "type": "stack"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "id": "@entity.activeId",
                      "status": "complete"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h2",
                          "content": "Quest Complete",
                          "type": "typography"
                        },
                        {
                          "message": "Congratulations! The quest has been completed.",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "label": "View Quests",
                          "variant": "primary",
                          "type": "button",
                          "action": "RESET",
                          "icon": "arrow-left"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "active",
                "to": "failed",
                "event": "FAIL",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "status": "failed",
                      "id": "@entity.activeId"
                    },
                    {
                      "emit": {
                        "success": "QuestLogUpdated",
                        "failure": "QuestLogUpdateFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "name": "x-circle",
                          "type": "icon"
                        },
                        {
                          "content": "Quest Failed",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "message": "The quest was not completed. You can try again.",
                          "type": "alert",
                          "variant": "error"
                        },
                        {
                          "label": "View Quests",
                          "icon": "arrow-left",
                          "action": "RESET",
                          "type": "button",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "progressing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "id": "@entity.activeId",
                      "status": "complete"
                    },
                    {
                      "emit": {
                        "failure": "QuestLogUpdateFailed",
                        "success": "QuestLogUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Quest Complete"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "Congratulations! The quest has been completed."
                        },
                        {
                          "type": "button",
                          "label": "View Quests",
                          "icon": "arrow-left",
                          "variant": "primary",
                          "action": "RESET"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "progressing",
                "to": "failed",
                "event": "FAIL",
                "effects": [
                  [
                    "persist",
                    "update",
                    "QuestLog",
                    {
                      "id": "@entity.activeId",
                      "status": "failed"
                    },
                    {
                      "emit": {
                        "failure": "QuestLogUpdateFailed",
                        "success": "QuestLogUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "x-circle"
                        },
                        {
                          "content": "Quest Failed",
                          "variant": "h2",
                          "type": "typography"
                        },
                        {
                          "variant": "error",
                          "type": "alert",
                          "message": "The quest was not completed. You can try again."
                        },
                        {
                          "label": "View Quests",
                          "action": "RESET",
                          "type": "button",
                          "icon": "arrow-left",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "loading",
                "event": "RESET",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "failure": "QuestLogLoadFailed",
                        "success": "QuestLogLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "failed",
                "to": "loading",
                "event": "RESET",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "success": "QuestLogLoaded",
                        "failure": "QuestLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "QuestLog",
                    {
                      "emit": {
                        "success": "QuestLogLoaded",
                        "failure": "QuestLogLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "QuestLogPage",
          "path": "/questlogs",
          "traits": [
            {
              "ref": "QuestLogTracking"
            }
          ]
        }
      ]
    }
  ]
}
