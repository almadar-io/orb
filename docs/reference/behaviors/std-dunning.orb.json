{
  "name": "std-dunning",
  "version": "1.0.0",
  "description": "std-dunning — failed-payment escalation ladder for subscriptions. Owns a DunningCase entity and a single trait that loads open cases, renders them in a data-grid alongside a per-case dunning-banner, and advances severity (soft -> urgent -> final -> suspend) or marks resolved.",
  "orbitals": [
    {
      "name": "DunningCaseOrbital",
      "entity": {
        "name": "DunningCase",
        "collection": "dunningcases",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "severity",
            "type": "string",
            "default": "soft",
            "values": [
              "soft",
              "urgent",
              "final"
            ]
          },
          {
            "name": "attemptNumber",
            "type": "number",
            "default": 1
          },
          {
            "name": "attemptsTotal",
            "type": "number",
            "default": 4
          },
          {
            "name": "failedAt",
            "type": "string"
          },
          {
            "name": "nextRetryAt",
            "type": "string"
          },
          {
            "name": "amountDue",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "resolvedAt",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "resolved",
              "suspended"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "DunningEscalate",
          "category": "interaction",
          "linkedEntity": "DunningCase",
          "emits": [
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESOLVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SUSPEND",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DunningCase]"
                }
              ]
            },
            {
              "event": "DunningCaseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceSuspended",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "escalating"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DunningCaseLoaded",
                "name": "DunningCase loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DunningCase]"
                  }
                ]
              },
              {
                "key": "DunningCaseLoadFailed",
                "name": "DunningCase load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "RESOLVE",
                "name": "Resolve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "SUSPEND",
                "name": "Suspend",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "DunningCaseUpdated",
                "name": "DunningCase updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "ServiceSuspended",
                "name": "Service suspended",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "DunningCaseUpdateFailed",
                "name": "DunningCase update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading dunning cases…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DunningCaseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Dunning Cases",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "subscriptionId",
                              "label": "Subscription",
                              "variant": "caption"
                            },
                            {
                              "name": "customerId",
                              "label": "Customer",
                              "variant": "caption"
                            },
                            {
                              "name": "severity",
                              "variant": "badge",
                              "label": "Severity"
                            },
                            {
                              "variant": "caption",
                              "name": "attemptNumber",
                              "label": "Attempt"
                            },
                            {
                              "variant": "caption",
                              "name": "amountDue",
                              "label": "Amount Due"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "cols": 1,
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "ESCALATE",
                              "label": "Escalate",
                              "icon": "arrow-up",
                              "variant": "primary"
                            },
                            {
                              "variant": "secondary",
                              "label": "Resolve",
                              "icon": "check",
                              "event": "RESOLVE"
                            },
                            {
                              "event": "SUSPEND",
                              "icon": "ban",
                              "variant": "danger",
                              "label": "Suspend"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DunningCaseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.severity",
                    [
                      "cond",
                      [
                        "=",
                        "@payload.row.severity",
                        "soft"
                      ],
                      "urgent",
                      [
                        "=",
                        "@payload.row.severity",
                        "urgent"
                      ],
                      "final",
                      "final"
                    ]
                  ],
                  [
                    "set",
                    "@entity.attemptNumber",
                    [
                      "+",
                      "@payload.row.attemptNumber",
                      1
                    ]
                  ],
                  [
                    "set",
                    "@entity.attemptsTotal",
                    "@payload.row.attemptsTotal"
                  ],
                  [
                    "set",
                    "@entity.failedAt",
                    "@payload.row.failedAt"
                  ],
                  [
                    "set",
                    "@entity.nextRetryAt",
                    "@payload.row.nextRetryAt"
                  ],
                  [
                    "set",
                    "@entity.amountDue",
                    "@payload.row.amountDue"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Attempt @entity.attemptNumber of @entity.attemptsTotal — amount @entity.amountDue @entity.currency. Next retry @entity.nextRetryAt.",
                      "variant": "warning",
                      "type": "alert",
                      "dismissible": false,
                      "title": "Payment failed"
                    }
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "success": "DunningCaseUpdated",
                        "failure": "DunningCaseUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "RESOLVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "resolved"
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "failure": "DunningCaseUpdateFailed",
                        "success": "DunningCaseUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "SUSPEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "suspended"
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "failure": "DunningCaseUpdateFailed",
                        "success": "ServiceSuspended"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "loading",
                "event": "DunningCaseUpdated",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "loading",
                "event": "ServiceSuspended",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "browsing",
                "event": "DunningCaseUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Dunning Cases"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DunningEscalatePage",
          "path": "/dunningcases/escalate",
          "traits": [
            {
              "ref": "DunningEscalate"
            }
          ]
        }
      ]
    }
  ]
}
