{
  "name": "std-dunning",
  "version": "1.0.0",
  "description": "std-dunning — failed-payment escalation ladder for subscriptions. Owns a DunningCase entity and a single trait that loads open cases, renders them in a data-grid alongside a per-case dunning-banner, and advances severity (soft -> urgent -> final -> suspend) or marks resolved.",
  "orbitals": [
    {
      "name": "DunningCaseOrbital",
      "entity": {
        "name": "DunningCase",
        "collection": "dunningcases",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "severity",
            "type": "string",
            "default": "soft",
            "values": [
              "soft",
              "urgent",
              "final"
            ]
          },
          {
            "name": "attemptNumber",
            "type": "number",
            "default": 1
          },
          {
            "name": "attemptsTotal",
            "type": "number",
            "default": 4
          },
          {
            "name": "failedAt",
            "type": "string"
          },
          {
            "name": "nextRetryAt",
            "type": "string"
          },
          {
            "name": "amountDue",
            "type": "number"
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "resolvedAt",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "resolved",
              "suspended"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "DunningEscalate",
          "category": "interaction",
          "linkedEntity": "DunningCase",
          "emits": [
            {
              "event": "ESCALATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RESOLVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SUSPEND",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[DunningCase]"
                }
              ]
            },
            {
              "event": "DunningCaseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DunningCaseUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceSuspended",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.attemptNumber",
                  "type": "number"
                },
                {
                  "name": "row.attemptsTotal",
                  "type": "number"
                },
                {
                  "name": "row.failedAt",
                  "type": "string"
                },
                {
                  "name": "row.nextRetryAt",
                  "type": "string"
                },
                {
                  "name": "row.amountDue",
                  "type": "number"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.resolvedAt",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "escalating"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DunningCaseLoaded",
                "name": "DunningCase loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[DunningCase]"
                  }
                ]
              },
              {
                "key": "DunningCaseLoadFailed",
                "name": "DunningCase load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ESCALATE",
                "name": "Escalate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "RESOLVE",
                "name": "Resolve",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "SUSPEND",
                "name": "Suspend",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "DunningCaseUpdated",
                "name": "DunningCase updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "ServiceSuspended",
                "name": "Service suspended",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "DunningCase"
                  }
                ]
              },
              {
                "key": "DunningCaseUpdateFailed",
                "name": "DunningCase update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading dunning cases…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DunningCaseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "content": "Dunning Cases",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "imagePosition": "right",
                          "type": "split-section",
                          "title": "Collections health",
                          "description": "Track recovery against open cases and route the right escalation to each customer.",
                          "background": "alt",
                          "bullets": [
                            "Severity ladders from soft to final",
                            "Auto-suspend at the last attempt",
                            "Resolve when payment recovers"
                          ]
                        },
                        {
                          "type": "stats-grid",
                          "stats": [
                            {
                              "label": "Open cases",
                              "value": 42
                            },
                            {
                              "label": "Recovered",
                              "value": 18
                            },
                            {
                              "value": 3,
                              "label": "Suspended"
                            },
                            {
                              "label": "Recovery rate",
                              "value": "62%"
                            }
                          ],
                          "columns": 4
                        },
                        {
                          "columns": 4,
                          "type": "stats-organism",
                          "entity": "DunningCase"
                        },
                        {
                          "heading": "Watchlist accounts",
                          "type": "showcase-organism",
                          "entity": "DunningCase",
                          "subtitle": "High-value cases with elevated severity."
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "title": "Acme Corp",
                              "accentColor": "danger",
                              "type": "showcase-card",
                              "description": "Final notice. Suspension in 2 days.",
                              "image": {
                                "alt": "Acme",
                                "src": "https://picsum.photos/seed/dun-acme/600/400"
                              },
                              "badge": "Final"
                            },
                            {
                              "accentColor": "warning",
                              "badge": "Urgent",
                              "type": "showcase-card",
                              "image": {
                                "alt": "Globex",
                                "src": "https://picsum.photos/seed/dun-globex/600/400"
                              },
                              "title": "Globex Ltd",
                              "description": "Urgent — second retry failed."
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "children": {
                            "gap": "md",
                            "direction": "horizontal",
                            "children": [
                              {
                                "name": "alert-triangle",
                                "type": "icon"
                              },
                              {
                                "type": "typography",
                                "variant": "body",
                                "content": "Swipe a case row for quick actions"
                              }
                            ],
                            "type": "stack",
                            "align": "center"
                          },
                          "threshold": 80,
                          "leftActions": [
                            {
                              "event": "RESOLVE",
                              "color": "primary",
                              "label": "Resolve"
                            }
                          ],
                          "type": "swipeable-row",
                          "rightActions": [
                            {
                              "label": "Suspend",
                              "event": "SUSPEND",
                              "color": "danger"
                            }
                          ]
                        },
                        {
                          "entity": "@payload.data",
                          "cols": 1,
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "subscriptionId",
                              "label": "Subscription"
                            },
                            {
                              "name": "customerId",
                              "label": "Customer",
                              "variant": "caption"
                            },
                            {
                              "label": "Severity",
                              "name": "severity",
                              "variant": "badge"
                            },
                            {
                              "label": "Attempt",
                              "variant": "caption",
                              "name": "attemptNumber"
                            },
                            {
                              "variant": "caption",
                              "label": "Amount Due",
                              "name": "amountDue"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "itemActions": [
                            {
                              "icon": "arrow-up",
                              "variant": "primary",
                              "label": "Escalate",
                              "event": "ESCALATE"
                            },
                            {
                              "variant": "secondary",
                              "icon": "check",
                              "label": "Resolve",
                              "event": "RESOLVE"
                            },
                            {
                              "label": "Suspend",
                              "event": "SUSPEND",
                              "variant": "danger",
                              "icon": "ban"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "isOpen": false,
                          "type": "drawer",
                          "position": "right",
                          "title": "Case detail",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Selected case"
                                },
                                {
                                  "type": "typography",
                                  "content": "Use the grid actions to escalate, resolve, or suspend.",
                                  "variant": "body"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ],
                          "width": "md"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DunningCaseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "ESCALATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.severity",
                    [
                      "cond",
                      [
                        "=",
                        "@payload.row.severity",
                        "soft"
                      ],
                      "urgent",
                      [
                        "=",
                        "@payload.row.severity",
                        "urgent"
                      ],
                      "final",
                      "final"
                    ]
                  ],
                  [
                    "set",
                    "@entity.attemptNumber",
                    [
                      "+",
                      "@payload.row.attemptNumber",
                      1
                    ]
                  ],
                  [
                    "set",
                    "@entity.attemptsTotal",
                    "@payload.row.attemptsTotal"
                  ],
                  [
                    "set",
                    "@entity.failedAt",
                    "@payload.row.failedAt"
                  ],
                  [
                    "set",
                    "@entity.nextRetryAt",
                    "@payload.row.nextRetryAt"
                  ],
                  [
                    "set",
                    "@entity.amountDue",
                    "@payload.row.amountDue"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Attempt @entity.attemptNumber of @entity.attemptsTotal — amount @entity.amountDue @entity.currency. Next retry @entity.nextRetryAt.",
                      "variant": "warning",
                      "title": "Payment failed",
                      "dismissible": false
                    }
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "success": "DunningCaseUpdated",
                        "failure": "DunningCaseUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "RESOLVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "resolved"
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "success": "DunningCaseUpdated",
                        "failure": "DunningCaseUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "escalating",
                "event": "SUSPEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "suspended"
                  ],
                  [
                    "persist",
                    "update",
                    "DunningCase",
                    "@entity",
                    {
                      "emit": {
                        "success": "ServiceSuspended",
                        "failure": "DunningCaseUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "loading",
                "event": "DunningCaseUpdated",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "loading",
                "event": "ServiceSuspended",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "failure": "DunningCaseLoadFailed",
                        "success": "DunningCaseLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "escalating",
                "to": "browsing",
                "event": "DunningCaseUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DunningCase",
                    {
                      "emit": {
                        "success": "DunningCaseLoaded",
                        "failure": "DunningCaseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Dunning Cases"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DunningEscalatePage",
          "path": "/dunningcases/escalate",
          "traits": [
            {
              "ref": "DunningEscalate"
            }
          ]
        }
      ]
    }
  ]
}
