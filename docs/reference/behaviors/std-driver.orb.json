                            {
                              "event": "VIEW",
                              "variant": "secondary",
                              "label": "View"
                            },
                            {
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "secondary"
                            },
                            {
                              "event": "SUSPEND",
                              "variant": "secondary",
                              "label": "Suspend"
                            },
                            {
                              "variant": "secondary",
                              "event": "REINSTATE",
                              "label": "Reinstate"
                            },
                            {
                              "variant": "danger",
                              "label": "Terminate",
                              "event": "TERMINATE"
