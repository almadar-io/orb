                "effects": [
                  [
                    "fetch",
                    "Driver",
                    {
                      "emit": {
                        "failure": "DriverLoadFailed",
                        "success": "DriverLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading drivers…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "DriverLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "truck"
                            },
                            {
                              "content": "Drivers",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "type": "status-dot",
                              "label": "On duty",
                              "pulse": true,
                              "size": "md",
                              "status": "online"
                            },
                            {
                              "type": "badge",
                              "variant": "default",
                              "label": "On Duty"
                            },
                            {
                              "label": "New Driver",
                              "variant": "primary",
                              "type": "button",
                              "action": "CREATE"
                            }
