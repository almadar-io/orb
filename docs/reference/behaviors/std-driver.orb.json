                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Name",
                              "variant": "caption",
                              "name": "name"
                            },
                            {
                              "label": "License #",
                              "variant": "caption",
                              "name": "licenseNumber"
                            },
                            {
                              "name": "licenseClass",
                              "variant": "badge",
                              "label": "Class"
                            },
                            {
                              "variant": "caption",
                              "name": "licenseExpiresAt",
                              "label": "Expires"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "name": "assignedVehicleId",
                              "variant": "caption",
                              "label": "Vehicle"
                            }
                          ],
