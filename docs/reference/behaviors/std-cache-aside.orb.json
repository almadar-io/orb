{
  "name": "std-cache-aside",
  "version": "1.0.0",
  "description": "std-cache-aside as a Function",
  "orbitals": [
    {
      "name": "CacheEntryOrbital",
      "entity": {
        "name": "CacheEntry",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "hitCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "cacheAge",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "CacheEntryCacheManager",
          "category": "interaction",
          "linkedEntity": "CacheEntry",
          "emits": [
            {
              "event": "CacheEntryLoaded",
              "description": "Fired when CacheEntry finishes loading; payload.data holds the entries",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CacheEntry]"
                }
              ]
            },
            {
              "event": "CacheEntryLoadFailed",
              "description": "Fired when CacheEntry fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CacheEntryUpdated",
              "description": "Fired when persist update succeeds",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CacheEntryUpdateFailed",
              "description": "Fired when persist update fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "empty",
                "isInitial": true
              },
              {
                "name": "loading"
              },
              {
                "name": "cached"
              },
              {
                "name": "stale"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "FETCH",
                "name": "Fetch"
              },
              {
                "key": "CacheEntryLoaded",
                "name": "CacheEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CacheEntry]"
                  }
                ]
              },
              {
                "key": "CacheEntryLoadFailed",
                "name": "CacheEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "INVALIDATE",
                "name": "Invalidate"
              },
              {
                "key": "CACHED",
                "name": "Cached",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "CacheEntry"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "CacheEntryUpdated",
                "name": "CacheEntry updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CacheEntryUpdateFailed",
                "name": "CacheEntry update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "empty",
                "to": "empty",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "database"
                                },
                                {
                                  "type": "typography",
                                  "content": "Cache (empty)",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal"
                            },
                            {
                              "type": "button",
                              "label": "Fetch",
                              "variant": "primary",
                              "action": "FETCH",
                              "icon": "download"
                            }
                          ],
                          "justify": "between",
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "description": "Fetch data to populate the cache.",
                          "icon": "inbox",
                          "title": "Cache is empty",
                          "type": "empty-state"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "empty",
                "to": "loading",
                "event": "FETCH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "failure": "CacheEntryLoadFailed",
                        "success": "CacheEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Fetching cache…",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "cached",
                "event": "CacheEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "name": "database",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Cache (hot)"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "align": "center",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "label": "Cached",
                                  "pulse": false,
                                  "status": "online",
                                  "type": "status-dot"
                                },
                                {
                                  "label": "Invalidate",
                                  "action": "INVALIDATE",
                                  "icon": "trash",
                                  "type": "button",
                                  "variant": "ghost"
                                }
                              ]
                            }
                          ],
                          "justify": "between",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "children": [
                                {
                                  "children": [
                                    {
                                      "direction": "horizontal",
                                      "type": "stack",
                                      "align": "center",
                                      "gap": "sm",
                                      "children": [
                                        {
                                          "name": "database",
                                          "type": "icon"
                                        },
                                        {
                                          "variant": "h4",
                                          "type": "typography",
                                          "content": "@item.name"
                                        }
                                      ]
                                    },
                                    {
                                      "label": "@item.description",
                                      "type": "badge"
                                    }
                                  ],
                                  "align": "center",
                                  "direction": "horizontal",
                                  "justify": "between",
                                  "type": "stack"
                                },
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "@item.status"
                                }
                              ],
                              "gap": "sm",
                              "direction": "vertical",
                              "type": "stack"
                            }
                          ],
                          "fields": [],
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CacheEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to load"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "label": "Retry",
                          "variant": "primary",
                          "icon": "rotate-ccw",
                          "action": "FETCH"
                        }
                      ],
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "cached",
                "to": "stale",
                "event": "INVALIDATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "database"
                                },
                                {
                                  "content": "Cache (stale)",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "gap": "sm",
                              "children": [
                                {
                                  "pulse": true,
                                  "label": "Stale",
                                  "status": "warning",
                                  "type": "status-dot"
                                },
                                {
                                  "action": "REFRESH",
                                  "label": "Refresh",
                                  "icon": "refresh-cw",
                                  "type": "button",
                                  "variant": "primary"
                                }
                              ],
                              "type": "stack"
                            }
                          ],
                          "type": "stack",
                          "justify": "between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "Cache data is stale. Refresh to get the latest data.",
                          "variant": "warning"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "cached",
                "to": "loading",
                "event": "CACHED",
                "effects": [
                  [
                    "persist",
                    "update",
                    "CacheEntry",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "CacheEntryUpdated",
                        "failure": "CacheEntryUpdateFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "failure": "CacheEntryLoadFailed",
                        "success": "CacheEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "stale",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "success": "CacheEntryLoaded",
                        "failure": "CacheEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "stale",
                "to": "loading",
                "event": "FETCH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "failure": "CacheEntryLoadFailed",
                        "success": "CacheEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "empty",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "empty-state",
                      "icon": "inbox",
                      "description": "Fetch data to populate the cache.",
                      "title": "Cache is empty"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "FETCH",
                "effects": [
                  [
                    "fetch",
                    "CacheEntry",
                    {
                      "emit": {
                        "success": "CacheEntryLoaded",
                        "failure": "CacheEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CacheEntryPage",
          "path": "/cacheentrys",
          "traits": [
            {
              "ref": "CacheEntryCacheManager"
            }
          ]
        }
      ]
    }
  ]
}
