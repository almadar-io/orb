{
  "name": "std-stack-layout",
  "version": "2.0.0",
  "description": "std-stack-layout — minimal chrome (title + divider) with one contentTrait config slot.",
  "orbitals": [
    {
      "name": "StackLayoutOrbital",
      "entity": {
        "name": "StackLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "StackLayout",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "list"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "List"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        "@config.contentTrait"
                      ],
                      "className": "max-w-5xl mx-auto w-full",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "List"
            },
            "contentTrait": {
              "type": "trait"
            },
            "icon": {
              "type": "string",
              "default": "list"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "StackLayoutPage",
          "path": "/stack-layout",
          "traits": [
            {
              "ref": "StackLayout"
            }
          ]
        }
      ]
    }
  ]
}
