{
  "name": "std-gameflow",
  "version": "1.0.0",
  "description": "std-gameflow as a Function",
  "orbitals": [
    {
      "name": "GameSessionOrbital",
      "entity": {
        "name": "GameSession",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "score",
            "type": "number",
            "default": 0
          },
          {
            "name": "level",
            "type": "number",
            "default": 1
          }
        ]
      },
      "traits": [
        {
          "name": "GameSessionGameflow",
          "category": "interaction",
          "linkedEntity": "GameSession",
          "emits": [
            {
              "event": "GameSessionLoaded",
              "description": "Fired when GameSession finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "score",
                  "type": "number"
                },
                {
                  "name": "level",
                  "type": "number"
                }
              ]
            },
            {
              "event": "GameSessionLoadFailed",
              "description": "Fired when GameSession fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "menu",
                "isInitial": true
              },
              {
                "name": "playing"
              },
              {
                "name": "paused"
              },
              {
                "name": "gameover"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "START",
                "name": "Start"
              },
              {
                "key": "NAVIGATE",
                "name": "Navigate"
              },
              {
                "key": "PAUSE",
                "name": "Pause"
              },
              {
                "key": "GAME_OVER",
                "name": "Game Over"
              },
              {
                "key": "RESUME",
                "name": "Resume"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "RESTART",
                "name": "Restart"
              },
              {
                "key": "GameSessionLoaded",
                "name": "GameSession loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "score",
                    "type": "number"
                  },
                  {
                    "name": "level",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "GameSessionLoadFailed",
                "name": "GameSession load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GameSession",
                    {
                      "emit": {
                        "success": "GameSessionLoaded",
                        "failure": "GameSessionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "label": "Start Game",
                          "event": "START",
                          "variant": "primary"
                        }
                      ],
                      "subtitle": "Main Menu",
                      "type": "game-menu",
                      "title": "GameSession"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-hud",
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "value": "@entity.level",
                          "label": "Level"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "title": "Paused",
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "event": "RESUME",
                          "variant": "primary",
                          "label": "Resume"
                        },
                        {
                          "variant": "ghost",
                          "event": "RESTART",
                          "label": "Quit"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "playing",
                "to": "gameover",
                "event": "GAME_OVER",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": [
                        {
                          "value": "@entity.score",
                          "label": "Score"
                        },
                        {
                          "value": "@entity.level",
                          "label": "Level"
                        }
                      ],
                      "title": "Game Over",
                      "menuItems": [
                        {
                          "variant": "primary",
                          "label": "Play Again",
                          "event": "RESTART"
                        },
                        {
                          "label": "Main Menu",
                          "variant": "secondary",
                          "event": "RESTART"
                        }
                      ],
                      "type": "game-over-screen"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "stats": [
                        {
                          "value": "@entity.score",
                          "label": "Score"
                        },
                        {
                          "label": "Level",
                          "value": "@entity.level"
                        }
                      ],
                      "type": "game-hud"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-hud",
                      "stats": [
                        {
                          "label": "Score",
                          "value": "@entity.score"
                        },
                        {
                          "value": "@entity.level",
                          "label": "Level"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "menuItems": [
                        {
                          "label": "Start Game",
                          "event": "START",
                          "variant": "primary"
                        }
                      ],
                      "type": "game-menu",
                      "subtitle": "Main Menu",
                      "title": "GameSession"
                    }
                  ]
                ]
              },
              {
                "from": "gameover",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "GameSession",
                      "subtitle": "Main Menu",
                      "menuItems": [
                        {
                          "event": "START",
                          "variant": "primary",
                          "label": "Start Game"
                        }
                      ],
                      "type": "game-menu"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GameSessionPage",
          "path": "/gamesessions",
          "traits": [
            {
              "ref": "GameSessionGameflow"
            }
          ]
        }
      ]
    }
  ]
}
