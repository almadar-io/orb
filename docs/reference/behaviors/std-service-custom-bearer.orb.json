                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "endpoint",
                  "type": "string"
                },
                {
                  "name": "method",
                  "type": "string"
                },
                {
                  "name": "requestBody",
                  "type": "string"
                },
                {
                  "name": "responseData",
                  "type": "string"
                },
                {
                  "name": "statusCode",
                  "type": "string"
                },
                {
                  "name": "callStatus",
                  "type": "string"
