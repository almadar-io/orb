              },
              {
                "key": "API_RESPONSE",
                "name": "Api Response",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "statusCode",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
