                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Sending request to servicecustombearer endpoint...",
                      "type": "loading-state",
                      "title": "Calling API..."
                    }
                  ],
                  [
                    "call-service",
                    "custom-bearer-api",
                    "execute",
                    {
                      "method": "@entity.method",
                      "endpoint": "@entity.endpoint",
                      "body": "@entity.requestBody"
                    },
                    {
                      "emit": {
                        "failure": "ServiceCustomBearerCustomBearerApiFailed",
                        "success": "ServiceCustomBearerCustomBearerApiCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "complete",
                "event": "API_RESPONSE",
                "effects": [
                  [
                    "set",
                    "@entity.responseData",
                    "@payload.data"
                  ],
                  [
                    "set",
                    "@entity.statusCode",
                    "@payload.statusCode"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Response"
                        },
                        {
                          "label": "@entity.statusCode",
                          "type": "badge",
                          "variant": "info"
                        },
                        {
                          "code": "@entity.responseData",
                          "language": "json",
                          "type": "code-block"
                        },
                        {
                          "label": "New Request",
                          "type": "button",
                          "variant": "ghost",
                          "action": "RESET",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "error",
                "event": "FAILED",
