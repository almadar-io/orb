{
  "name": "std-service-custom-bearer",
  "version": "2.0.0",
  "description": "std-service-custom-bearer — Bearer-token HTTP service. Bind via `uses CustomBearer from \"std/behaviors/std-service-custom-bearer\"` and configure `endpoint` / `method` / `body` / `token` at the call site. Pass `uiTrait: \"@trait.YourBearerForm\"` to inject your own request form; leave unset to render the atom's default test form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceCustomBearerOrbital",
      "entity": {
        "name": "ServiceCustomBearer",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "endpoint",
            "type": "string",
            "default": ""
          },
          {
            "name": "method",
            "type": "string",
            "default": "GET"
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "token",
            "type": "string",
            "default": ""
          },
          {
            "name": "callId",
            "type": "string",
            "default": ""
          },
          {
            "name": "statusCode",
            "type": "string",
            "default": ""
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceCustomBearerDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "SEND",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "shield"
                            },
                            {
                              "content": "Bearer API Tester",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "select",
                              "options": [
                                {
                                  "label": "GET",
                                  "value": "GET"
                                },
                                {
                                  "label": "POST",
                                  "value": "POST"
                                },
                                {
                                  "label": "PUT",
                                  "value": "PUT"
                                },
                                {
                                  "label": "DELETE",
                                  "value": "DELETE"
                                }
                              ]
                            },
                            {
                              "type": "input",
                              "placeholder": "/users"
                            },
                            {
                              "type": "textarea",
                              "placeholder": "JSON request body"
                            },
                            {
                              "type": "input",
                              "placeholder": "Bearer token",
                              "inputType": "password"
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "icon": "send",
                          "action": "SEND",
                          "type": "button",
                          "label": "Send",
                          "variant": "primary"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceCustomBearerCustomBearer",
          "category": "interaction",
          "linkedEntity": "ServiceCustomBearer",
          "emits": [
            {
              "event": "ServiceCustomBearerLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomBearerLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceCustomBearerCustomBearerCompleted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceCustomBearerCustomBearerFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BearerDone",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEND",
              "triggers": "SEND",
              "source": {
                "kind": "trait",
                "trait": "ServiceCustomBearerDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "calling"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              },
              {
                "key": "ServiceCustomBearerLoaded",
                "name": "ServiceCustomBearer loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceCustomBearerLoadFailed",
                "name": "ServiceCustomBearer load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "BearerDone",
                "name": "Bearer done",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceCustomBearerCustomBearerCompleted",
                "name": "ServiceCustomBearer custom bearer completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceCustomBearerCustomBearerFailed",
                "name": "ServiceCustomBearer custom bearer failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.endpoint",
                    ""
                  ],
                  [
                    "set",
                    "@entity.method",
                    "GET"
                  ],
                  [
                    "set",
                    "@entity.body",
                    ""
                  ],
                  [
                    "set",
                    "@entity.token",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceCustomBearer",
                    {
                      "emit": {
                        "success": "ServiceCustomBearerLoaded",
                        "failure": "ServiceCustomBearerLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceCustomBearerDefaultForm"
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "calling",
                "event": "SEND",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Sending bearer-authenticated request...",
                      "type": "loading-state",
                      "title": "Calling API..."
                    }
                  ],
                  [
                    "call-service",
                    "customBearer",
                    "GET",
                    {
                      "body": "",
                      "token": "",
                      "endpoint": ""
                    },
                    {
                      "emit": {
                        "success": "BearerDone",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceCustomBearerLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceCustomBearerLoadFailed"
              },
              {
                "from": "calling",
                "to": "complete",
                "event": "BearerDone",
                "effects": [
                  [
                    "set",
                    "@entity.callId",
                    "@payload.id"
                  ],
                  [
                    "emit",
                    "ServiceCustomBearerCustomBearerCompleted",
                    {
                      "result": "@payload.result",
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "success",
                          "message": "Request successful!",
                          "type": "alert"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.callId",
                          "color": "muted",
                          "variant": "body"
                        },
                        {
                          "label": "New Request",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "calling",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceCustomBearerCustomBearerFailed",
                    {
                      "error": "@entity.error",
                      "code": "bearer_call_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "message": "@entity.error",
                      "title": "Request Failed",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceCustomBearerDefaultForm"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "complete",
                "event": "ServiceCustomBearerCustomBearerCompleted"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceCustomBearerCustomBearerFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceCustomBearerDefaultForm"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        "@trait.ServiceCustomBearerDefaultForm"
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "token": {
              "type": "string",
              "default": ""
            },
            "endpoint": {
              "type": "string",
              "default": ""
            },
            "body": {
              "type": "string",
              "default": ""
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceCustomBearerDefaultForm"
            },
            "method": {
              "type": "string",
              "default": "GET",
              "values": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceCustomBearerPage",
          "path": "/servicecustombearers",
          "traits": [
            {
              "ref": "ServiceCustomBearerCustomBearer"
            }
          ]
        }
      ]
    }
  ]
}
