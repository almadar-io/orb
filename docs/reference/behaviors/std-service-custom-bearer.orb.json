                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Bearer API Tester"
                        },
                        {
                          "type": "input",
                          "placeholder": "/users"
                        },
                        {
                          "type": "select",
                          "options": [
                            {
                              "value": "GET",
                              "label": "GET"
                            },
                            {
                              "label": "POST",
                              "value": "POST"
                            },
                            {
                              "label": "PUT",
                              "value": "PUT"
                            },
                            {
                              "label": "DELETE",
