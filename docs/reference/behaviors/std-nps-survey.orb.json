{
  "name": "std-nps-survey",
  "version": "1.0.0",
  "description": "std-nps-survey — NPS survey primitive tracking per-customer Net Promoter Score responses with category, comment, and follow-up status.",
  "orbitals": [
    {
      "name": "NpsSurveyOrbital",
      "entity": {
        "name": "NpsSurvey",
        "collection": "npssurveys",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "score",
            "type": "number",
            "default": 0
          },
          {
            "name": "category",
            "type": "string",
            "default": "passive",
            "values": [
              "promoter",
              "passive",
              "detractor"
            ]
          },
          {
            "name": "comment",
            "type": "string",
            "default": ""
          },
          {
            "name": "surveyedAt",
            "type": "string",
            "required": true
          },
          {
            "name": "channel",
            "type": "string",
            "default": "email",
            "values": [
              "email",
              "in-app",
              "sms",
              "phone"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "sent",
            "values": [
              "sent",
              "responded",
              "expired",
              "no-response"
            ]
          },
          {
            "name": "followedUp",
            "type": "boolean",
            "default": false
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "NpsSurveyTracker",
          "category": "interaction",
          "linkedEntity": "NpsSurvey",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MARK_FOLLOWED_UP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "NpsSurveyLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[NpsSurvey]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "NpsSurveyLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "NpsSurveyLoaded",
                "name": "NpsSurvey loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[NpsSurvey]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "NpsSurveyLoadFailed",
                "name": "NpsSurvey load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_CATEGORY",
                "name": "Filter Category",
                "payloadSchema": [
                  {
                    "name": "category",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_STATUS",
                "name": "Filter Status",
                "payloadSchema": [
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_FOLLOWED_UP",
                "name": "Mark Followed Up",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "failure": "NpsSurveyLoadFailed",
                        "success": "NpsSurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading NPS surveys…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "NpsSurveyLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "message-square"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "NPS Surveys"
                            },
                            {
                              "action": "CREATE",
                              "type": "button",
                              "variant": "primary",
                              "label": "Send Survey"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "name": "Top promoter",
                              "src": "https://i.pravatar.cc/64?u=nps-top-promoter",
                              "status": "online",
                              "size": "md",
                              "type": "avatar"
                            },
                            {
                              "readOnly": true,
                              "value": 4,
                              "type": "star-rating",
                              "max": 5,
                              "label": "Latest NPS sample",
                              "precision": "half",
                              "size": "md"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "gap": "sm",
                          "itemActions": [
                            {
                              "label": "View",
                              "event": "VIEW",
                              "variant": "secondary"
                            },
                            {
                              "label": "Edit",
                              "event": "EDIT",
                              "variant": "secondary"
                            },
                            {
                              "event": "MARK_FOLLOWED_UP",
                              "label": "Mark Followed Up",
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "event": "REQUEST_DELETE"
                            }
                          ],
                          "fields": [
                            {
                              "name": "customerName",
                              "variant": "caption",
                              "label": "Customer"
                            },
                            {
                              "variant": "caption",
                              "name": "score",
                              "label": "Score"
                            },
                            {
                              "label": "Category",
                              "variant": "badge",
                              "name": "category"
                            },
                            {
                              "name": "surveyedAt",
                              "label": "Surveyed",
                              "variant": "caption"
                            },
                            {
                              "name": "channel",
                              "label": "Channel",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            },
                            {
                              "variant": "caption",
                              "name": "followedUp",
                              "label": "Followed Up"
                            }
                          ],
                          "cols": 1,
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "NpsSurveyLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "failure": "NpsSurveyLoadFailed",
                        "success": "NpsSurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Refreshing NPS surveys…",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "success": "NpsSurveyLoaded",
                        "failure": "NpsSurveyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Searching NPS surveys…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_CATEGORY",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "failure": "NpsSurveyLoadFailed",
                        "success": "NpsSurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Filtering NPS surveys…"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_STATUS",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "success": "NpsSurveyLoaded",
                        "failure": "NpsSurveyLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Filtering NPS surveys…",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Sending new NPS survey",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Viewing NPS survey",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Editing NPS survey",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "MARK_FOLLOWED_UP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Marked as followed up",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "REQUEST_DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "warning",
                      "message": "Delete requested"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "NpsSurvey",
                    {
                      "emit": {
                        "failure": "NpsSurveyLoadFailed",
                        "success": "NpsSurveyLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "NPS Surveys"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "NpsSurveyPage",
          "path": "/nps-surveys",
          "traits": [
            {
              "ref": "NpsSurveyTracker"
            }
          ]
        }
      ]
    }
  ]
}
