{
  "name": "std-checkout-terminal",
  "version": "1.0.0",
  "description": "std-checkout-terminal — retail POS checkout terminal. Owns a CheckoutSession entity (one row per active register session) and a single terminal trait that loads open sessions, renders cart + total + status in a data-grid, and supports tender / void session actions.",
  "orbitals": [
    {
      "name": "CheckoutSessionOrbital",
      "entity": {
        "name": "CheckoutSession",
        "collection": "checkoutsessions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "terminalId",
            "type": "string",
            "required": true
          },
          {
            "name": "cashierId",
            "type": "string",
            "default": ""
          },
          {
            "name": "cashierName",
            "type": "string",
            "default": ""
          },
          {
            "name": "cartItemsJson",
            "type": "string",
            "default": ""
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0
          },
          {
            "name": "paymentMethod",
            "type": "string",
            "default": "card",
            "values": [
              "cash",
              "card",
              "gift_card",
              "split"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "paying",
              "completed",
              "voided"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CheckoutSessionTerminal",
          "category": "interaction",
          "linkedEntity": "CheckoutSession",
          "emits": [
            {
              "event": "TENDER_PAYMENT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID_SESSION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CheckoutSessionLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CheckoutSession]"
                }
              ]
            },
            {
              "event": "CheckoutSessionLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CheckoutSessionLoaded",
                "name": "CheckoutSession loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CheckoutSession]"
                  }
                ]
              },
              {
                "key": "CheckoutSessionLoadFailed",
                "name": "CheckoutSession load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TENDER_PAYMENT",
                "name": "Tender Payment",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VOID_SESSION",
                "name": "Void Session",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "failure": "CheckoutSessionLoadFailed",
                        "success": "CheckoutSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "size": "md",
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading terminals…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CheckoutSessionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "variant": "h3",
                              "content": "Terminals",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "autoPlayInterval": 5000,
                          "showArrows": true,
                          "type": "carousel",
                          "loop": true,
                          "showDots": true,
                          "autoPlay": true,
                          "items": [
                            {
                              "src": "https://picsum.photos/seed/feat1/800/300",
                              "alt": "Featured promo",
                              "caption": "Buy 2 get 1 free"
                            },
                            {
                              "src": "https://picsum.photos/seed/feat2/800/300",
                              "alt": "Seasonal sale",
                              "caption": "Holiday bundle 20% off"
                            },
                            {
                              "alt": "New arrival",
                              "src": "https://picsum.photos/seed/feat3/800/300",
                              "caption": "Just landed in store"
                            }
                          ]
                        },
                        {
                          "type": "pricing-grid",
                          "plans": [
                            {
                              "description": "One item",
                              "features": [
                                "Standard pricing"
                              ],
                              "name": "Single",
                              "action": {
                                "label": "Add",
                                "href": "#tender"
                              },
                              "price": "$4.99"
                            },
                            {
                              "description": "Three items",
                              "price": "$12.99",
                              "highlighted": true,
                              "action": {
                                "href": "#tender",
                                "label": "Add"
                              },
                              "name": "Bundle",
                              "features": [
                                "10% off",
                                "Free wrap"
                              ]
                            },
                            {
                              "price": "$24.99",
                              "action": {
                                "href": "#tender",
                                "label": "Add"
                              },
                              "features": [
                                "20% off",
                                "Free wrap",
                                "Priority pickup"
                              ],
                              "description": "Six items",
                              "name": "Family"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "color": "muted",
                              "content": "Qty",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "min": 1,
                              "action": "TENDER_PAYMENT",
                              "value": 1,
                              "size": "md",
                              "step": 1,
                              "type": "number-stepper",
                              "max": 99
                            },
                            {
                              "streak": 5,
                              "type": "combo-counter",
                              "size": "md",
                              "multiplier": 2,
                              "combo": 3
                            },
                            {
                              "resources": [
                                {
                                  "value": 42.5,
                                  "icon": "wallet",
                                  "label": "Subtotal"
                                },
                                {
                                  "id": "tax",
                                  "label": "Tax",
                                  "value": 3.4,
                                  "icon": "percent"
                                },
                                {
                                  "value": 45.9,
                                  "label": "Total",
                                  "icon": "credit-card",
                                  "id": "total"
                                }
                              ],
                              "type": "resource-bar",
                              "size": "md"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "icon": "credit-card",
                              "type": "action-button",
                              "variant": "primary",
                              "hotkey": "T",
                              "size": "md",
                              "label": "Tender"
                            },
                            {
                              "text": "Cash",
                              "type": "choice-button",
                              "index": 1
                            },
                            {
                              "type": "choice-button",
                              "index": 2,
                              "selected": true,
                              "text": "Card"
                            },
                            {
                              "index": 3,
                              "type": "choice-button",
                              "text": "Gift"
                            },
                            {
                              "size": "md",
                              "shape": "round",
                              "icon": "pause",
                              "variant": "secondary",
                              "label": "Hold",
                              "type": "control-button"
                            },
                            {
                              "size": "md",
                              "includeDiagonals": false,
                              "type": "d-pad"
                            }
                          ],
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "label": "Cashier actions",
                          "actions": [
                            {
                              "id": "discount",
                              "category": "promo",
                              "label": "Discount"
                            },
                            {
                              "id": "refund",
                              "category": "ops",
                              "label": "Refund"
                            },
                            {
                              "label": "Void",
                              "category": "ops",
                              "id": "void"
                            },
                            {
                              "label": "Split",
                              "id": "split",
                              "category": "tender"
                            }
                          ],
                          "size": "md",
                          "allowDuplicates": true,
                          "type": "action-palette"
                        },
                        {
                          "isOpen": true,
                          "onClose": "VOID_SESSION",
                          "closeEvent": "VOID_SESSION",
                          "width": "w-96",
                          "position": "right",
                          "title": "Cart",
                          "type": "side-panel",
                          "children": [
                            {
                              "direction": "vertical",
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Items in cart",
                                  "variant": "h4",
                                  "type": "typography"
                                },
                                {
                                  "content": "Cart side panel preview",
                                  "variant": "caption",
                                  "type": "typography",
                                  "color": "muted"
                                }
                              ],
                              "gap": "sm"
                            }
                          ]
                        },
                        {
                          "type": "toast-slot",
                          "variant": "success",
                          "title": "Payment ready",
                          "duration": 4000
                        },
                        {
                          "variant": "primary",
                          "action": "TENDER_PAYMENT",
                          "icon": "zap",
                          "type": "floating-action-button",
                          "position": "bottom-right",
                          "label": "Quick sale"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Tender",
                              "event": "TENDER_PAYMENT",
                              "variant": "primary"
                            },
                            {
                              "event": "VOID_SESSION",
                              "label": "Void",
                              "variant": "danger"
                            }
                          ],
                          "fields": [
                            {
                              "name": "terminalId",
                              "label": "Terminal",
                              "variant": "caption"
                            },
                            {
                              "name": "cashierName",
                              "variant": "caption",
                              "label": "Cashier"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "name": "total",
                              "label": "Total",
                              "variant": "caption"
                            },
                            {
                              "label": "Opened",
                              "name": "openedAt",
                              "variant": "caption"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CheckoutSessionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "TENDER_PAYMENT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "type": "alert",
                      "message": "Payment tendered"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "VOID_SESSION",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Session voided",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CheckoutSession",
                    {
                      "emit": {
                        "failure": "CheckoutSessionLoadFailed",
                        "success": "CheckoutSessionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Terminals"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CheckoutSessionPage",
          "path": "/terminals",
          "traits": [
            {
              "ref": "CheckoutSessionTerminal"
            }
          ]
        }
      ]
    }
  ]
}
