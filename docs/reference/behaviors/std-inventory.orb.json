{
  "name": "InventoryItemOrbital",
  "orbitals": [
    {
      "name": "InventoryItemOrbital",
      "entity": {
        "name": "InventoryItem",
        "collection": "inventoryitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "InventoryItemBrowse",
          "category": "interaction",
          "linkedEntity": "InventoryItem",
          "listens": [
            {
              "event": "*.ITEM_ADDED",
              "triggers": "ITEM_ADDED"
            },
            {
              "event": "*.ITEM_USED",
              "triggers": "ITEM_USED"
            },
            {
              "event": "*.CONFIRM_DROP",
              "triggers": "CONFIRM_DROP"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "ITEM_ADDED"
              },
              {
                "key": "ITEM_USED"
              },
              {
                "key": "CONFIRM_DROP"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "className": "max-w-5xl mx-auto w-full",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "package",
                                  "size": "lg"
                                },
                                {
                                  "variant": "h2",
                                  "content": "InventoryItems Inventory",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "icon": "plus",
                                  "type": "button",
                                  "variant": "primary",
                                  "label": "Add InventoryItem",
                                  "event": "ADD_ITEM"
                                }
                              ],
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "type": "stack",
                          "gap": "md",
                          "direction": "horizontal",
                          "justify": "space-between"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Use",
                              "event": "USE_ITEM",
                              "size": "sm",
                              "variant": "ghost"
                            },
                            {
                              "label": "Drop",
                              "variant": "danger",
                              "event": "DROP",
                              "size": "sm"
                            }
                          ],
                          "emptyTitle": "No items yet",
                          "emptyIcon": "inbox",
                          "entity": "InventoryItem",
                          "emptyDescription": "Add your first item to get started.",
                          "columns": [
                            {
                              "name": "name",
                              "variant": "h4",
                              "icon": "package",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "colorMap": {
                                "completed": "success",
                                "disabled": "neutral",
                                "active": "success",
                                "done": "success",
                                "error": "destructive",
                                "pending": "warning",
                                "inactive": "neutral",
                                "cancelled": "destructive",
                                "draft": "warning",
                                "failed": "destructive",
                                "scheduled": "warning",
                                "archived": "neutral"
                              },
                              "name": "description",
                              "variant": "badge"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "caption"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ITEM_ADDED",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ITEM_USED",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CONFIRM_DROP",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "InventoryItemAdd",
          "category": "interaction",
          "linkedEntity": "InventoryItem",
          "emits": [
            {
              "event": "ITEM_ADDED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "ADD_ITEM"
              },
              {
                "key": "CLOSE"
              },
              {
                "key": "SAVE"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "ADD_ITEM",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Add InventoryItem"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "entity": "InventoryItem",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "name",
                            "description",
                            "status"
                          ],
                          "type": "form-section"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "InventoryItem",
                    "@payload.data"
                  ],
                  [
                    "fetch",
                    "InventoryItem"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "ITEM_ADDED"
                  ],
                  [
                    "notify",
                    "InventoryItem created successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "InventoryItemUse",
          "category": "interaction",
          "linkedEntity": "InventoryItem",
          "emits": [
            {
              "event": "ITEM_USED"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "USE_ITEM"
              },
              {
                "key": "CLOSE"
              },
              {
                "key": "SAVE"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "USE_ITEM",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "zap",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "content": "Use InventoryItem",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.name"
                        },
                        {
                          "gap": "sm",
                          "justify": "center",
                          "children": [
                            {
                              "label": "Cancel",
                              "variant": "ghost",
                              "type": "button",
                              "event": "CLOSE"
                            },
                            {
                              "label": "Confirm Use",
                              "event": "SAVE",
                              "icon": "check",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "InventoryItem",
                    "@payload.data"
                  ],
                  [
                    "fetch",
                    "InventoryItem"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "ITEM_USED"
                  ],
                  [
                    "notify",
                    "InventoryItem updated successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "InventoryItemDrop",
          "category": "interaction",
          "linkedEntity": "InventoryItem",
          "emits": [
            {
              "event": "CONFIRM_DROP"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "DROP"
              },
              {
                "key": "CONFIRM_DROP"
              },
              {
                "key": "CANCEL"
              },
              {
                "key": "CLOSE"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DROP",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InventoryItem",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "size": "md",
                              "type": "icon",
                              "name": "alert-triangle"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Drop InventoryItem"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "Are you sure you want to drop this inventoryitem?",
                          "type": "alert",
                          "variant": "danger"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "event": "CANCEL",
                              "variant": "ghost",
                              "label": "Cancel",
                              "type": "button"
                            },
                            {
                              "label": "Drop",
                              "type": "button",
                              "icon": "check",
                              "event": "CONFIRM_DROP",
                              "variant": "danger"
                            }
                          ],
                          "justify": "end",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DROP",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "InventoryItem",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "InventoryItem"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "InventoryItem"
                  ],
                  [
                    "emit",
                    "CONFIRM_DROP"
                  ],
                  [
                    "notify",
                    "InventoryItem deleted successfully"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "InventoryItem"
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Inventoryitems",
          "path": "/inventoryitems",
          "traits": [
            {
              "ref": "InventoryItemBrowse"
            },
            {
              "ref": "InventoryItemAdd"
            },
            {
              "ref": "InventoryItemUse"
            },
            {
              "ref": "InventoryItemDrop"
            }
          ]
        }
      ]
    }
  ]
}
