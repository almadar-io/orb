{
  "name": "std-reorder-rule",
  "version": "1.0.0",
  "description": "std-reorder-rule — automatic stock-replenishment rule for a SKU at a location. Owns a ReorderRule entity and a single manager trait that loads rules, renders them in a data-grid, and surfaces Enable / Disable actions per row.",
  "orbitals": [
    {
      "name": "ReorderRuleOrbital",
      "entity": {
        "name": "ReorderRule",
        "collection": "reorderrules",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sku",
            "type": "string",
            "required": true
          },
          {
            "name": "locationId",
            "type": "string",
            "default": ""
          },
          {
            "name": "thresholdQty",
            "type": "number",
            "default": 0
          },
          {
            "name": "reorderQty",
            "type": "number",
            "default": 0
          },
          {
            "name": "vendor",
            "type": "string",
            "default": ""
          },
          {
            "name": "leadTimeDays",
            "type": "number",
            "default": 0
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          }
        ]
      },
      "traits": [
        {
          "name": "ReorderRuleManager",
          "category": "interaction",
          "linkedEntity": "ReorderRule",
          "emits": [
            {
              "event": "ENABLE_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "DISABLE_RULE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ReorderRuleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ReorderRule]"
                }
              ]
            },
            {
              "event": "ReorderRuleLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ReorderRuleLoaded",
                "name": "ReorderRule loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ReorderRule]"
                  }
                ]
              },
              {
                "key": "ReorderRuleLoadFailed",
                "name": "ReorderRule load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ENABLE_RULE",
                "name": "Enable Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "DISABLE_RULE",
                "name": "Disable Rule",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "success": "ReorderRuleLoaded",
                        "failure": "ReorderRuleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading reorder rules…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ReorderRuleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "content": "Reorder Rules",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "name": "sku",
                              "label": "SKU",
                              "variant": "caption"
                            },
                            {
                              "label": "Location",
                              "variant": "caption",
                              "name": "locationId"
                            },
                            {
                              "variant": "caption",
                              "label": "Threshold",
                              "name": "thresholdQty"
                            },
                            {
                              "name": "reorderQty",
                              "variant": "caption",
                              "label": "Reorder Qty"
                            },
                            {
                              "variant": "caption",
                              "label": "Vendor",
                              "name": "vendor"
                            },
                            {
                              "variant": "caption",
                              "name": "isActive",
                              "label": "Active"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "ENABLE_RULE",
                              "variant": "primary",
                              "icon": "check",
                              "label": "Enable"
                            },
                            {
                              "variant": "danger",
                              "label": "Disable",
                              "icon": "x",
                              "event": "DISABLE_RULE"
                            }
                          ],
                          "entity": "@payload.data",
                          "cols": 1,
                          "type": "data-grid",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ReorderRuleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ENABLE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Reorder rule enabled",
                      "variant": "success",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DISABLE_RULE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Reorder rule disabled"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ReorderRule",
                    {
                      "emit": {
                        "failure": "ReorderRuleLoadFailed",
                        "success": "ReorderRuleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Reorder Rules"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "ReorderRulePage",
          "path": "/reorder-rules",
          "traits": [
            {
              "ref": "ReorderRuleManager"
            }
          ]
        }
      ]
    }
  ]
}
