{
  "name": "std-service-email",
  "version": "2.0.0",
  "description": "std-service-email — Email send service. Bind via `uses Email from \"std/behaviors/std-service-email\"` and configure `to` / `subject` / `body` / `from` / `replyTo` / `templateId` / `htmlBody` at the call site. Pass `uiTrait: \"@trait.YourEmailForm\"` to inject your own composer; leave unset to render the atom's default test form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceEmailOrbital",
      "entity": {
        "name": "ServiceEmail",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "to",
            "type": "string",
            "default": ""
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "from",
            "type": "string",
            "default": ""
          },
          {
            "name": "replyTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "templateId",
            "type": "string",
            "default": ""
          },
          {
            "name": "htmlBody",
            "type": "string",
            "default": ""
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "messageId",
            "type": "string",
            "default": ""
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceEmailDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "SEND",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "mail"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Email"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "recipient@example.com"
                            },
                            {
                              "placeholder": "Email subject",
                              "type": "input"
                            },
                            {
                              "placeholder": "Write your message...",
                              "type": "textarea"
                            }
                          ],
                          "type": "stack",
                          "direction": "vertical"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "icon": "send",
                          "action": "SEND",
                          "label": "Send"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceEmailEmail",
          "category": "interaction",
          "linkedEntity": "ServiceEmail",
          "emits": [
            {
              "event": "ServiceEmailLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceEmailLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EmailSent",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceEmailEmailFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEND",
              "triggers": "SEND",
              "source": {
                "kind": "trait",
                "trait": "ServiceEmailDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              },
              {
                "key": "ServiceEmailLoaded",
                "name": "ServiceEmail loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceEmailLoadFailed",
                "name": "ServiceEmail load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EmailSent",
                "name": "Email sent",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceEmailEmailFailed",
                "name": "ServiceEmail email failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.to",
                    ""
                  ],
                  [
                    "set",
                    "@entity.subject",
                    ""
                  ],
                  [
                    "set",
                    "@entity.body",
                    ""
                  ],
                  [
                    "set",
                    "@entity.from",
                    ""
                  ],
                  [
                    "set",
                    "@entity.replyTo",
                    ""
                  ],
                  [
                    "set",
                    "@entity.templateId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.htmlBody",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceEmail",
                    {
                      "emit": {
                        "failure": "ServiceEmailLoadFailed",
                        "success": "ServiceEmailLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceEmailDefaultForm"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Sending email...",
                      "message": "Delivering your message."
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "to": "",
                      "templateId": "",
                      "body": "",
                      "subject": "",
                      "from": "",
                      "htmlBody": "",
                      "replyTo": ""
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "EmailSent"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceEmailLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceEmailLoadFailed"
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "EmailSent",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.messageId",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "message": "Email sent successfully",
                          "variant": "success"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "@entity.messageId",
                          "color": "muted"
                        },
                        {
                          "variant": "ghost",
                          "label": "Send Another",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceEmailEmailFailed",
                    {
                      "code": "send_email_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Send Failed",
                      "onRetry": "RETRY",
                      "type": "error-state",
                      "message": "@entity.error"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceEmailDefaultForm"
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "sent",
                "event": "EmailSent"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceEmailEmailFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        "@trait.ServiceEmailDefaultForm"
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        "@trait.ServiceEmailDefaultForm"
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "htmlBody": {
              "type": "string",
              "default": ""
            },
            "body": {
              "type": "string",
              "default": ""
            },
            "subject": {
              "type": "string",
              "default": ""
            },
            "templateId": {
              "type": "string",
              "default": ""
            },
            "recipient": {
              "type": "string",
              "default": ""
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceEmailDefaultForm"
            },
            "replyTo": {
              "type": "string",
              "default": ""
            },
            "sender": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceEmailPage",
          "path": "/serviceemails",
          "traits": [
            {
              "ref": "ServiceEmailEmail"
            }
          ]
        }
      ]
    }
  ]
}
