{
  "name": "std-service-email",
  "version": "1.0.0",
  "description": "std-service-email as a Function",
  "orbitals": [
    {
      "name": "ServiceEmailOrbital",
      "entity": {
        "name": "ServiceEmail",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "subject",
            "type": "string"
          },
          {
            "name": "body",
            "type": "string"
          },
          {
            "name": "from",
            "type": "string"
          },
          {
            "name": "sendStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "messageId",
            "type": "string"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceEmailEmail",
          "category": "interaction",
          "linkedEntity": "ServiceEmail",
          "emits": [
            {
              "event": "ServiceEmailLoaded",
              "description": "Fired when ServiceEmail finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "to",
                  "type": "string"
                },
                {
                  "name": "subject",
                  "type": "string"
                },
                {
                  "name": "body",
                  "type": "string"
                },
                {
                  "name": "from",
                  "type": "string"
                },
                {
                  "name": "sendStatus",
                  "type": "string"
                },
                {
                  "name": "messageId",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceEmailLoadFailed",
              "description": "Fired when ServiceEmail fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceEmailEmailCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceEmailEmailFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "sending"
              },
              {
                "name": "sent"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEND",
                "name": "Send"
              },
              {
                "key": "SENT",
                "name": "Sent",
                "payloadSchema": [
                  {
                    "name": "messageId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceEmailLoaded",
                "name": "ServiceEmail loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "to",
                    "type": "string"
                  },
                  {
                    "name": "subject",
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "type": "string"
                  },
                  {
                    "name": "from",
                    "type": "string"
                  },
                  {
                    "name": "sendStatus",
                    "type": "string"
                  },
                  {
                    "name": "messageId",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceEmailLoadFailed",
                "name": "ServiceEmail load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceEmailEmailCompleted",
                "name": "ServiceEmail email completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceEmailEmailFailed",
                "name": "ServiceEmail email failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.body",
                    ""
                  ],
                  [
                    "set",
                    "@entity.subject",
                    ""
                  ],
                  [
                    "set",
                    "@entity.to",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceEmail",
                    {
                      "emit": {
                        "success": "ServiceEmailLoaded",
                        "failure": "ServiceEmailLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "stretch",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "mail"
                            },
                            {
                              "content": "ServiceEmail Email",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "recipient@example.com"
                        },
                        {
                          "type": "input",
                          "placeholder": "Email subject"
                        },
                        {
                          "placeholder": "Write your message...",
                          "type": "textarea"
                        },
                        {
                          "type": "button",
                          "label": "Send",
                          "variant": "primary",
                          "icon": "send",
                          "action": "SEND"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "sending",
                "event": "SEND",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Sending email...",
                      "type": "loading-state",
                      "message": "Delivering serviceemail email..."
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "body": "@entity.body",
                      "subject": "@entity.subject",
                      "to": "@entity.to"
                    },
                    {
                      "emit": {
                        "success": "ServiceEmailEmailCompleted",
                        "failure": "ServiceEmailEmailFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "sent",
                "event": "SENT",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "sent"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "message": "Email sent successfully",
                          "type": "alert"
                        },
                        {
                          "type": "button",
                          "variant": "ghost",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "label": "Send Another"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "error-state",
                          "onRetry": "RETRY",
                          "title": "Send Failed",
                          "message": "Could not deliver the email."
                        },
                        {
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "action": "RETRY",
                              "label": "Retry",
                              "type": "button",
                              "icon": "refresh-cw"
                            },
                            {
                              "type": "button",
                              "icon": "rotate-ccw",
                              "variant": "ghost",
                              "label": "Reset",
                              "action": "RESET"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "sent",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "ServiceEmail Email",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "recipient@example.com"
                        },
                        {
                          "type": "input",
                          "placeholder": "Email subject"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "type": "button",
                          "icon": "send",
                          "variant": "primary",
                          "action": "SEND",
                          "label": "Send"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "name": "mail",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "ServiceEmail Email"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "recipient@example.com",
                          "type": "input"
                        },
                        {
                          "placeholder": "Email subject",
                          "type": "input"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Write your message..."
                        },
                        {
                          "type": "button",
                          "icon": "send",
                          "label": "Send",
                          "action": "SEND",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "stretch",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.sendStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "mail"
                            },
                            {
                              "type": "typography",
                              "content": "ServiceEmail Email",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "input",
                          "placeholder": "recipient@example.com"
                        },
                        {
                          "placeholder": "Email subject",
                          "type": "input"
                        },
                        {
                          "placeholder": "Write your message...",
                          "type": "textarea"
                        },
                        {
                          "icon": "send",
                          "action": "SEND",
                          "variant": "primary",
                          "label": "Send",
                          "type": "button"
                        }
                      ],
                      "align": "stretch"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceEmailPage",
          "path": "/serviceemails",
          "traits": [
            {
              "ref": "ServiceEmailEmail"
            }
          ]
        }
      ]
    }
  ]
}
