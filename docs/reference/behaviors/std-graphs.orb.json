{
  "name": "std-graphs",
  "version": "1.0.0",
  "description": "std-graphs — embeddable chart atom. ITEMS_LOADED groups @payload.data by @config.categoryField and applies the configured aggregation (count|sum|avg|min|max) per bucket, emitting {label,value} points into the chart pattern. Drop into a dashboard alongside std-stats / std-browse.",
  "orbitals": [
    {
      "name": "GraphItemOrbital",
      "entity": {
        "name": "GraphItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "chartData",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "name": "value",
                  "type": "number"
                },
                "label": {
                  "name": "label",
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "GraphItemGraph",
          "category": "interaction",
          "linkedEntity": "GraphItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      {
                        "value": 6,
                        "label": "Active"
                      },
                      {
                        "label": "Pending",
                        "value": 3
                      },
                      {
                        "value": 1,
                        "label": "Inactive"
                      }
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "data": "@entity.chartData",
                      "title": "Distribution",
                      "subtitle": "Counts per category",
                      "height": 280,
                      "showValues": false,
                      "chartType": "bar",
                      "type": "chart",
                      "showLegend": true
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.chartData",
                    [
                      "array/map",
                      [
                        "object/entries",
                        [
                          "array/groupBy",
                          "@payload.data",
                          "status"
                        ]
                      ],
                      [
                        "fn",
                        "entry",
                        {
                          "label": [
                            "object/get",
                            "@entry",
                            "0"
                          ],
                          "value": [
                            "if",
                            [
                              "=",
                              "count",
                              "sum"
                            ],
                            [
                              "array/sum",
                              [
                                "object/get",
                                "@entry",
                                "1"
                              ],
                              ""
                            ],
                            [
                              "if",
                              [
                                "=",
                                "count",
                                "avg"
                              ],
                              [
                                "array/avg",
                                [
                                  "object/get",
                                  "@entry",
                                  "1"
                                ],
                                ""
                              ],
                              [
                                "if",
                                [
                                  "=",
                                  "count",
                                  "min"
                                ],
                                [
                                  "array/min",
                                  [
                                    "object/get",
                                    "@entry",
                                    "1"
                                  ],
                                  ""
                                ],
                                [
                                  "if",
                                  [
                                    "=",
                                    "count",
                                    "max"
                                  ],
                                  [
                                    "array/max",
                                    [
                                      "object/get",
                                      "@entry",
                                      "1"
                                    ],
                                    ""
                                  ],
                                  [
                                    "array/len",
                                    [
                                      "object/get",
                                      "@entry",
                                      "1"
                                    ]
                                  ]
                                ]
                              ]
                            ]
                          ]
                        }
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "chart",
                      "chartType": "bar",
                      "data": "@entity.chartData",
                      "showValues": false,
                      "showLegend": true,
                      "title": "Distribution",
                      "subtitle": "Counts per category",
                      "height": 280
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "aggregation": {
              "type": "string",
              "default": "count",
              "values": [
                "count",
                "sum",
                "avg",
                "min",
                "max"
              ]
            },
            "showValues": {
              "type": "boolean",
              "default": false
            },
            "showLegend": {
              "type": "boolean",
              "default": true
            },
            "chartType": {
              "type": "string",
              "default": "bar",
              "values": [
                "bar",
                "line",
                "pie",
                "area"
              ]
            },
            "categoryField": {
              "type": "string",
              "default": "status"
            },
            "subtitle": {
              "type": "string",
              "default": "Counts per category"
            },
            "title": {
              "type": "string",
              "default": "Distribution"
            },
            "height": {
              "type": "number",
              "default": 280
            },
            "valueField": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "GraphItemGraphPage",
          "path": "/graphitems",
          "traits": [
            {
              "ref": "GraphItemGraph"
            }
          ]
        }
      ]
    }
  ]
}
