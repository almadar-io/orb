{
  "name": "std-gallery",
  "version": "1.0.0",
  "description": "std-gallery as a Function",
  "orbitals": [
    {
      "name": "GalleryItemOrbital",
      "entity": {
        "name": "GalleryItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "imageUrl",
            "type": "string",
            "default": "https://picsum.photos/seed/gallery/800/600"
          }
        ]
      },
      "traits": [
        {
          "name": "GalleryItemGallery",
          "category": "interaction",
          "linkedEntity": "GalleryItem",
          "emits": [
            {
              "event": "GalleryItemLoaded",
              "description": "Fired when GalleryItem finishes loading; payload.data holds the gallery",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[GalleryItem]"
                }
              ]
            },
            {
              "event": "GalleryItemLoadFailed",
              "description": "Fired when GalleryItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GalleryItemLoaded",
                "name": "GalleryItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[GalleryItem]"
                  }
                ]
              },
              {
                "key": "GalleryItemLoadFailed",
                "name": "GalleryItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "success": "GalleryItemLoaded",
                        "failure": "GalleryItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "GalleryItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "children": [
                            {
                              "direction": "horizontal",
                              "align": "center",
                              "type": "stack",
                              "gap": "sm",
                              "children": [
                                {
                                  "name": "image",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "content": "GalleryItems Gallery",
                                  "variant": "h2"
                                }
                              ]
                            },
                            {
                              "content": "Click any image to view full size",
                              "type": "typography",
                              "variant": "caption",
                              "color": "muted"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "imageField": "imageUrl",
                          "fields": [
                            {
                              "label": "Title",
                              "variant": "h4",
                              "name": "name"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "gap": "md",
                          "type": "data-grid",
                          "cols": 3,
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "icon": "maximize"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "GalleryItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "content": "Failed to load",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "label": "Retry",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "closeAction": "CLOSE",
                      "showCounter": true,
                      "images": [
                        {
                          "src": "https://picsum.photos/seed/gallery1/800/600",
                          "alt": "Image",
                          "caption": "Image"
                        }
                      ],
                      "type": "lightbox",
                      "currentIndex": 0,
                      "isOpen": true
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "failure": "GalleryItemLoadFailed",
                        "success": "GalleryItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "GalleryItem",
                    {
                      "emit": {
                        "success": "GalleryItemLoaded",
                        "failure": "GalleryItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "GalleryItemGalleryPage",
          "path": "/galleryitems/gallery",
          "traits": [
            {
              "ref": "GalleryItemGallery"
            }
          ]
        }
      ]
    }
  ]
}
