                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MatterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Matter]"
                }
              ]
            },
            {
              "event": "MatterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
