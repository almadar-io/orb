{
  "name": "std-matter",
  "version": "1.0.0",
  "description": "std-matter — legal matter primitive: a single legal case (litigation, contract review, immigration filing) with client, status, lead attorney, and billing reference.",
  "orbitals": [
    {
      "name": "MatterOrbital",
      "entity": {
        "name": "Matter",
        "collection": "matters",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "clientName",
            "type": "string",
            "required": true
          },
          {
            "name": "practiceArea",
            "type": "string",
            "default": "other",
            "values": [
              "litigation",
              "transactional",
              "regulatory",
              "ip",
              "immigration",
              "family",
              "other"
            ]
          },
          {
            "name": "leadAttorney",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "active",
              "on_hold",
              "closed",
              "archived"
            ]
          },
          {
            "name": "openedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "closedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MatterDocket",
          "category": "interaction",
          "linkedEntity": "Matter",
          "emits": [
            {
              "event": "CLOSE_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HOLD_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REOPEN_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MatterLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Matter]"
                }
              ]
            },
            {
              "event": "MatterLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MatterLoaded",
                "name": "Matter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Matter]"
                  }
                ]
              },
              {
                "key": "MatterLoadFailed",
                "name": "Matter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE_MATTER",
                "name": "Close Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HOLD_MATTER",
                "name": "Hold Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REOPEN_MATTER",
                "name": "Reopen Matter",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "failure": "MatterLoadFailed",
                        "success": "MatterLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading matters…",
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MatterLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "scale"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Matters"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "cols": 1,
                          "entity": "@payload.data",
                          "gap": "sm",
                          "fields": [
                            {
                              "label": "Matter #",
                              "variant": "caption",
                              "name": "matterNumber"
                            },
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "caption"
                            },
                            {
                              "name": "clientName",
                              "label": "Client",
                              "variant": "caption"
                            },
                            {
                              "name": "practiceArea",
                              "label": "Practice",
                              "variant": "badge"
                            },
                            {
                              "name": "leadAttorney",
                              "label": "Lead",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "CLOSE_MATTER",
                              "variant": "primary",
                              "label": "Close"
                            },
                            {
                              "label": "Hold",
                              "variant": "ghost",
                              "event": "HOLD_MATTER"
                            },
                            {
                              "label": "Reopen",
                              "event": "REOPEN_MATTER",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MatterLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CLOSE_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "Matter closed",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "HOLD_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Matter on hold"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REOPEN_MATTER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Matter reopened",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Matter",
                    {
                      "emit": {
                        "success": "MatterLoaded",
                        "failure": "MatterLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Matters"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MatterPage",
          "path": "/matters",
          "traits": [
            {
              "ref": "MatterDocket"
            }
          ]
        }
      ]
    }
  ]
}
