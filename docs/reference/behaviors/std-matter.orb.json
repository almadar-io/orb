                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HOLD_MATTER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.matterNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.clientName",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.practiceArea",
                  "type": "string"
                },
                {
                  "name": "row.leadAttorney",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.openedAt",
                  "type": "string"
                },
                {
                  "name": "row.closedAt",
