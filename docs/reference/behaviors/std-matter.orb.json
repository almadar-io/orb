{
  "name": "std-matter",
  "version": "1.0.0",
  "description": "std-matter — legal matter primitive: a single legal case (litigation, contract review, immigration filing) with client, status, lead attorney, and billing reference.",
  "orbitals": [
    {
      "name": "MatterOrbital",
