              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MatterLoaded",
                "name": "Matter loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Matter]"
                  }
                ]
              },
              {
                "key": "MatterLoadFailed",
                "name": "Matter load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
