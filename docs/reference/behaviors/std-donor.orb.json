{
  "name": "std-donor",
  "version": "1.0.0",
  "description": "std-donor — donor primitive: person or organization that has donated to a nonprofit, with lifetime giving total and contact info.",
  "orbitals": [
    {
      "name": "DonorOrbital",
      "entity": {
        "name": "Donor",
        "collection": "donors",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "default": ""
          },
          {
            "name": "phone",
            "type": "string",
            "default": ""
          },
          {
            "name": "donorType",
            "type": "string",
            "default": "individual",
            "values": [
              "individual",
              "organization",
              "foundation",
              "anonymous"
            ]
          },
          {
            "name": "lifetimeAmount",
            "type": "number",
            "default": 0
          },
          {
            "name": "firstDonationAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "lastDonationAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "preferredCampaign",
            "type": "string",
            "default": ""
          },
          {
            "name": "isRecurring",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "DonorRoster",
          "category": "interaction",
          "linkedEntity": "Donor",
          "emits": [
            {
              "event": "THANK_DONOR",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.donorType",
                  "type": "string"
                },
                {
                  "name": "row.lifetimeAmount",
                  "type": "number"
                },
                {
                  "name": "row.firstDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.lastDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.preferredCampaign",
                  "type": "string"
                },
                {
                  "name": "row.isRecurring",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "SOLICIT_DONOR",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.email",
                  "type": "string"
                },
                {
                  "name": "row.phone",
                  "type": "string"
                },
                {
                  "name": "row.donorType",
                  "type": "string"
                },
                {
                  "name": "row.lifetimeAmount",
                  "type": "number"
                },
                {
                  "name": "row.firstDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.lastDonationAt",
                  "type": "string"
                },
                {
                  "name": "row.preferredCampaign",
                  "type": "string"
                },
                {
                  "name": "row.isRecurring",
                  "type": "boolean"
                }
              ]
            },
            {
              "event": "DonorLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Donor]"
                }
              ]
            },
            {
              "event": "DonorLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DonorLoaded",
                "name": "Donor loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Donor]"
                  }
                ]
              },
              {
                "key": "DonorLoadFailed",
                "name": "Donor load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "THANK_DONOR",
                "name": "Thank Donor",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SOLICIT_DONOR",
                "name": "Solicit Donor",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Donor",
                    {
                      "emit": {
                        "failure": "DonorLoadFailed",
                        "success": "DonorLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading donors…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "DonorLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "heart-handshake"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Donors"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "event": "THANK_DONOR",
                              "variant": "primary",
                              "label": "Thank"
                            },
                            {
                              "variant": "ghost",
                              "label": "Solicit",
                              "event": "SOLICIT_DONOR"
                            }
                          ],
                          "cols": 1,
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "name": "email",
                              "label": "Email",
                              "variant": "caption"
                            },
                            {
                              "name": "donorType",
                              "label": "Type",
                              "variant": "badge"
                            },
                            {
                              "name": "lifetimeAmount",
                              "label": "Lifetime",
                              "variant": "caption"
                            },
                            {
                              "name": "lastDonationAt",
                              "label": "Last Gift",
                              "variant": "caption"
                            }
                          ],
                          "gap": "sm",
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "DonorLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "THANK_DONOR",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Thank-you sent"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SOLICIT_DONOR",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Solicitation queued",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Donor",
                    {
                      "emit": {
                        "success": "DonorLoaded",
                        "failure": "DonorLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Donors"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "DonorPage",
          "path": "/donors",
          "traits": [
            {
              "ref": "DonorRoster"
            }
          ]
        }
      ]
    }
  ]
}
