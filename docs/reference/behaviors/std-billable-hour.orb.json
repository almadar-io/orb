{
  "name": "std-billable-hour",
  "version": "1.0.0",
  "description": "std-billable-hour — generic billable-hour timesheet primitive for legal, agency, and consulting domains. Owns a BillableHour entity (one row per time entry against a matter/project) and a single trait that loads entries, renders them in a data-grid with Invoice / Write Off actions.",
  "orbitals": [
    {
      "name": "BillableHourOrbital",
      "entity": {
        "name": "BillableHour",
        "collection": "billablehours",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "workerId",
            "type": "string",
            "required": true
          },
          {
            "name": "workerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "matterId",
            "type": "string",
            "default": ""
          },
          {
            "name": "projectId",
            "type": "string",
            "default": ""
          },
          {
            "name": "workDate",
            "type": "string",
            "required": true
          },
          {
            "name": "hours",
            "type": "number",
            "default": 0
          },
          {
            "name": "rate",
            "type": "number",
            "default": 0
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "isBillable",
            "type": "boolean",
            "default": true
          },
          {
            "name": "invoiceStatus",
            "type": "string",
            "default": "unbilled",
            "values": [
              "unbilled",
              "invoiced",
              "paid",
              "written_off"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "BillableHourTimesheet",
          "category": "interaction",
          "linkedEntity": "BillableHour",
          "emits": [
            {
              "event": "INVOICE_HOURS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WRITE_OFF_HOURS",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "BillableHourLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[BillableHour]"
                }
              ]
            },
            {
              "event": "BillableHourLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "BillableHourLoaded",
                "name": "BillableHour loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[BillableHour]"
                  }
                ]
              },
              {
                "key": "BillableHourLoadFailed",
                "name": "BillableHour load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "INVOICE_HOURS",
                "name": "Invoice Hours",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "WRITE_OFF_HOURS",
                "name": "Write Off Hours",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "failure": "BillableHourLoadFailed",
                        "success": "BillableHourLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading time entries…",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "BillableHourLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "type": "typography",
                              "content": "Time Entries",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "gap": "sm",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "INVOICE_HOURS",
                              "variant": "primary",
                              "label": "Invoice"
                            },
                            {
                              "event": "WRITE_OFF_HOURS",
                              "variant": "ghost",
                              "label": "Write Off"
                            }
                          ],
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "workerName",
                              "label": "Worker"
                            },
                            {
                              "variant": "caption",
                              "name": "matterId",
                              "label": "Matter"
                            },
                            {
                              "label": "Date",
                              "name": "workDate",
                              "variant": "caption"
                            },
                            {
                              "label": "Hours",
                              "variant": "caption",
                              "name": "hours"
                            },
                            {
                              "variant": "caption",
                              "name": "rate",
                              "label": "Rate"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "invoiceStatus"
                            }
                          ],
                          "cols": 1
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "BillableHourLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INVOICE_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Hours invoiced"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "WRITE_OFF_HOURS",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Hours written off"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "BillableHour",
                    {
                      "emit": {
                        "success": "BillableHourLoaded",
                        "failure": "BillableHourLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Time Entries"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "BillableHourPage",
          "path": "/timesheet",
          "traits": [
            {
              "ref": "BillableHourTimesheet"
            }
          ]
        }
      ]
    }
  ]
}
