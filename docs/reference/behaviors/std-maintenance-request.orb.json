{
  "name": "std-maintenance-request",
  "version": "1.0.0",
  "description": "std-maintenance-request — tenant-submitted request lifecycle (open → scheduled → in_progress → completed). Request-flow primitive (distinct from work-order's dispatch-flow).",
  "orbitals": [
    {
      "name": "MaintenanceRequestOrbital",
      "entity": {
        "name": "MaintenanceRequest",
        "collection": "maintenancerequests",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "unitId",
            "type": "string",
            "required": true
          },
          {
            "name": "tenantId",
            "type": "string",
            "default": ""
          },
          {
            "name": "requesterName",
            "type": "string",
            "default": ""
          },
          {
            "name": "description",
            "type": "string",
            "required": true
          },
          {
            "name": "priority",
            "type": "string",
            "default": "medium",
            "values": [
              "low",
              "medium",
              "high",
              "urgent"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "open",
            "values": [
              "open",
              "scheduled",
              "in_progress",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "requestedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "completedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MaintenanceRequestQueue",
          "category": "interaction",
          "linkedEntity": "MaintenanceRequest",
          "emits": [
            {
              "event": "SCHEDULE_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "scheduledAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "COMPLETE_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "completedAt",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL_REQUEST",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "notes",
                  "type": "string"
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[MaintenanceRequest]"
                }
              ]
            },
            {
              "event": "MaintenanceRequestLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.unitId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.tenantId",
                  "type": "string"
                },
                {
                  "name": "row.requesterName",
                  "type": "string"
                },
                {
                  "name": "row.description",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.priority",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.assignedTo",
                  "type": "string"
                },
                {
                  "name": "row.requestedAt",
                  "type": "string"
                },
                {
                  "name": "row.scheduledAt",
                  "type": "string"
                },
                {
                  "name": "row.completedAt",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "MaintenanceRequestUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MaintenanceRequestLoaded",
                "name": "MaintenanceRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[MaintenanceRequest]"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestLoadFailed",
                "name": "MaintenanceRequest load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SCHEDULE_REQUEST",
                "name": "Schedule Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "scheduledAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "COMPLETE_REQUEST",
                "name": "Complete Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "completedAt",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "CANCEL_REQUEST",
                "name": "Cancel Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "notes",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestUpdated",
                "name": "MaintenanceRequest updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "MaintenanceRequest"
                  }
                ]
              },
              {
                "key": "MaintenanceRequestUpdateFailed",
                "name": "MaintenanceRequest update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "success": "MaintenanceRequestLoaded",
                        "failure": "MaintenanceRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading maintenance requests…",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MaintenanceRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "wrench",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Maintenance Requests"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "variant": "primary",
                              "event": "SCHEDULE_REQUEST",
                              "label": "Schedule",
                              "icon": "calendar"
                            },
                            {
                              "variant": "primary",
                              "label": "Complete",
                              "icon": "check",
                              "event": "COMPLETE_REQUEST"
                            },
                            {
                              "event": "CANCEL_REQUEST",
                              "variant": "danger",
                              "label": "Cancel",
                              "icon": "x"
                            }
                          ],
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "label": "Unit",
                              "variant": "caption",
                              "name": "unitId"
                            },
                            {
                              "name": "requesterName",
                              "variant": "caption",
                              "label": "Requester"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "caption"
                            },
                            {
                              "name": "priority",
                              "label": "Priority",
                              "variant": "badge"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            },
                            {
                              "name": "requestedAt",
                              "label": "Requested",
                              "variant": "caption"
                            }
                          ],
                          "cols": 1
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MaintenanceRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SCHEDULE_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.scheduledAt",
                    "@payload.scheduledAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "scheduled"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestUpdateFailed",
                        "success": "MaintenanceRequestUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "COMPLETE_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.completedAt",
                    "@payload.completedAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "MaintenanceRequestUpdated",
                        "failure": "MaintenanceRequestUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL_REQUEST",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.notes"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "persist",
                    "update",
                    "MaintenanceRequest",
                    "@entity",
                    {
                      "emit": {
                        "success": "MaintenanceRequestUpdated",
                        "failure": "MaintenanceRequestUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MaintenanceRequestUpdated",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestLoadFailed",
                        "success": "MaintenanceRequestLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MaintenanceRequestUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MaintenanceRequest",
                    {
                      "emit": {
                        "failure": "MaintenanceRequestLoadFailed",
                        "success": "MaintenanceRequestLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Maintenance Requests"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MaintenanceRequestPage",
          "path": "/maintenance",
          "traits": [
            {
              "ref": "MaintenanceRequestQueue"
            }
          ]
        }
      ]
    }
  ]
}
