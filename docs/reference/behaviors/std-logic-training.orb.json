    {
      "name": "TrainingScoreOrbital",
      "entity": {
        "name": "TrainingScore",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "playerName",
            "type": "string",
            "required": true
          },
          {
            "name": "score",
            "type": "number",
            "required": true
          },
          {
            "name": "category",
            "type": "string"
          },
          {
            "name": "completedAt",
            "type": "string"
          },
          {
            "name": "highScore",
            "type": "number"
          },
          {
            "name": "combo",
            "type": "number"
          },
          {
            "name": "multiplier",
            "type": "number"
          },
          {
            "name": "level",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "TrainingScoreScoreBoard",
          "category": "interaction",
          "linkedEntity": "TrainingScore",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "ADD_SCORE"
              },
              {
                "key": "COMBO"
              },
              {
                "key": "RESET"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TrainingScore"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Logic Training",
                      "children": [
                        {
                          "highScore": "@entity.highScore",
                          "combo": "@entity.combo",
                          "type": "score-board",
                          "level": "@entity.level",
                          "multiplier": "@entity.multiplier",
                          "score": "@entity.score"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "highScore": "@entity.highScore",
                          "score": "@entity.score",
                          "multiplier": "@entity.multiplier",
                          "combo": "@entity.combo",
                          "type": "score-board",
                          "level": "@entity.level"
                        }
                      ],
                      "appName": "Logic Training",
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "appName": "Logic Training",
                      "showTopBar": true,
                      "children": [
                        {
                          "combo": "@entity.combo",
                          "multiplier": "@entity.multiplier",
                          "score": "@entity.score",
                          "type": "score-board",
                          "level": "@entity.level",
                          "highScore": "@entity.highScore"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "type": "score-board",
                          "multiplier": "@entity.multiplier",
                          "score": "@entity.score",
                          "highScore": "@entity.highScore",
                          "combo": "@entity.combo",
                          "level": "@entity.level"
                        }
                      ],
                      "appName": "Logic Training"
                    }
                  ]
                ]
              }
            ]
          }
        }
