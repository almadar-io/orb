              {
                "from": "menu",
                "to": "menu",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DebugChallenge"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "game-menu",
                          "title": "Debug Challenge",
                          "menuItems": [
                            {
                              "event": "START",
                              "variant": "primary",
                              "label": "Start"
                            }
                          ]
                        }
                      ],
                      "appName": "Logic Training",
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "playing",
                "event": "START",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "children": [
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "stats": [
                                {
                                  "value": "@entity.score",
                                  "label": "Score"
                                },
                                {
                                  "label": "Level",
                                  "value": "@entity.level"
                                }
                              ],
                              "type": "game-hud"
                            },
                            {
                              "type": "debugger-board",
                              "entity": "DebugChallenge",
                              "completeEvent": "COMPLETE"
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "appName": "Logic Training"
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "appName": "Logic Training",
                      "children": [
                        {
                          "menuItems": [
                            {
                              "variant": "primary",
                              "label": "Play Again",
                              "event": "RESTART"
                            }
                          ],
                          "title": "Well Done!",
                          "type": "game-over-screen"
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "menu",
                "event": "RESTART",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Logic Training",
                      "children": [
                        {
                          "menuItems": [
                            {
                              "variant": "primary",
                              "event": "START",
                              "label": "Start"
                            }
                          ],
                          "title": "Debug Challenge",
                          "type": "game-menu"
                        }
                      ],
                      "type": "game-shell",
                      "showTopBar": true
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Debugger",
          "path": "/debugger",
          "traits": [
            {
              "ref": "DebugChallengeDebuggerGame"
            }
          ]
        }
      ]
    },
