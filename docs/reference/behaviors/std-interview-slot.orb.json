{
  "name": "std-interview-slot",
  "version": "1.0.0",
  "description": "std-interview-slot — scheduled interview between an applicant and one or more interviewers, with date/time, format, and status.",
  "orbitals": [
    {
      "name": "InterviewSlotOrbital",
      "entity": {
        "name": "InterviewSlot",
        "collection": "interviewslots",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantId",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "default": ""
          },
          {
            "name": "interviewerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "required": true
          },
          {
            "name": "durationMinutes",
            "type": "number",
            "default": 60
          },
          {
            "name": "format",
            "type": "string",
            "default": "video",
            "values": [
              "phone",
              "video",
              "onsite"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "scheduled",
            "values": [
              "scheduled",
              "completed",
              "cancelled",
              "no_show"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "InterviewSlotSchedule",
          "category": "interaction",
          "linkedEntity": "InterviewSlot",
          "emits": [
            {
              "event": "COMPLETE_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_INTERVIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "InterviewSlotLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[InterviewSlot]"
                }
              ]
            },
            {
              "event": "InterviewSlotLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InterviewSlotLoaded",
                "name": "InterviewSlot loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[InterviewSlot]"
                  }
                ]
              },
              {
                "key": "InterviewSlotLoadFailed",
                "name": "InterviewSlot load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPLETE_INTERVIEW",
                "name": "Complete Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_INTERVIEW",
                "name": "Cancel Interview",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "failure": "InterviewSlotLoadFailed",
                        "success": "InterviewSlotLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading interviews…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InterviewSlotLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "name": "calendar",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "Interviews",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Applicant",
                              "name": "applicantName"
                            },
                            {
                              "name": "interviewerName",
                              "variant": "caption",
                              "label": "Interviewer"
                            },
                            {
                              "name": "scheduledAt",
                              "label": "Scheduled",
                              "variant": "caption"
                            },
                            {
                              "label": "Format",
                              "variant": "badge",
                              "name": "format"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            }
                          ],
                          "itemActions": [
                            {
                              "label": "Complete",
                              "variant": "primary",
                              "event": "COMPLETE_INTERVIEW"
                            },
                            {
                              "variant": "danger",
                              "event": "CANCEL_INTERVIEW",
                              "label": "Cancel"
                            }
                          ],
                          "gap": "sm",
                          "entity": "@payload.data",
                          "type": "data-grid"
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InterviewSlotLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "COMPLETE_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Interview marked complete",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL_INTERVIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Interview cancelled"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InterviewSlot",
                    {
                      "emit": {
                        "failure": "InterviewSlotLoadFailed",
                        "success": "InterviewSlotLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Interviews"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "InterviewSlotPage",
          "path": "/interviews",
          "traits": [
            {
              "ref": "InterviewSlotSchedule"
            }
          ]
        }
      ]
    }
  ]
}
