{
  "name": "std-help-article",
  "version": "1.0.0",
  "description": "std-help-article — Public help center article primitive with title, body, category, view count, and published/draft status.",
  "orbitals": [
    {
      "name": "HelpArticleOrbital",
      "entity": {
        "name": "HelpArticle",
        "collection": "helparticles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "slug",
            "type": "string",
            "required": true
          },
          {
            "name": "body",
            "type": "string",
            "default": ""
          },
          {
            "name": "summary",
            "type": "string",
            "default": ""
          },
          {
            "name": "categoryId",
            "type": "string",
            "default": ""
          },
          {
            "name": "categoryName",
            "type": "string",
            "default": ""
          },
          {
            "name": "author",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "published",
              "archived",
              "needs-update"
            ]
          },
          {
            "name": "viewCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "helpfulCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "notHelpfulCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "publishedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "updatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HelpArticleManage",
          "category": "interaction",
          "linkedEntity": "HelpArticle",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CREATE",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PUBLISH",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.body",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.categoryId",
                  "type": "string"
                },
                {
                  "name": "row.categoryName",
                  "type": "string"
                },
                {
                  "name": "row.author",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.viewCount",
                  "type": "number"
                },
                {
                  "name": "row.helpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.notHelpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.publishedAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ARCHIVE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.title",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.slug",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.body",
                  "type": "string"
                },
                {
                  "name": "row.summary",
                  "type": "string"
                },
                {
                  "name": "row.categoryId",
                  "type": "string"
                },
                {
                  "name": "row.categoryName",
                  "type": "string"
                },
                {
                  "name": "row.author",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.viewCount",
                  "type": "number"
                },
                {
                  "name": "row.helpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.notHelpfulCount",
                  "type": "number"
                },
                {
                  "name": "row.publishedAt",
                  "type": "string"
                },
                {
                  "name": "row.updatedAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HelpArticleLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HelpArticle]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HelpArticleLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HelpArticleLoaded",
                "name": "HelpArticle loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HelpArticle]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HelpArticleLoadFailed",
                "name": "HelpArticle load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_STATUS",
                "name": "Filter Status",
                "payloadSchema": [
                  {
                    "name": "status",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_CATEGORY",
                "name": "Filter Category",
                "payloadSchema": [
                  {
                    "name": "categoryId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PUBLISH",
                "name": "Publish",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARCHIVE",
                "name": "Archive",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "success": "HelpArticleLoaded",
                        "failure": "HelpArticleLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading help articles…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "HelpArticleLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "entity": "@payload.data",
                          "type": "hero-organism"
                        },
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "book-open",
                              "type": "icon"
                            },
                            {
                              "content": "Help Articles",
                              "variant": "h3",
                              "type": "typography"
                            },
                            {
                              "type": "button",
                              "action": "CREATE",
                              "variant": "primary",
                              "label": "New Article"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "items": [
                            {
                              "label": "Help Center"
                            },
                            {
                              "label": "Articles"
                            },
                            {
                              "label": "Help Articles"
                            }
                          ],
                          "type": "doc-breadcrumb"
                        },
                        {
                          "placeholder": "Search articles…",
                          "type": "doc-search"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "items": [
                                {
                                  "id": "getting-started",
                                  "href": "#getting-started",
                                  "label": "Getting Started"
                                },
                                {
                                  "id": "billing",
                                  "label": "Billing",
                                  "href": "#billing"
                                },
                                {
                                  "id": "api",
                                  "label": "API Reference",
                                  "href": "#api"
                                },
                                {
                                  "id": "troubleshooting",
                                  "label": "Troubleshooting",
                                  "href": "#troubleshooting"
                                }
                              ],
                              "type": "doc-sidebar"
                            },
                            {
                              "direction": "vertical",
                              "gap": "md",
                              "type": "stack",
                              "children": [
                                {
                                  "children": [
                                    {
                                      "content": "These articles cover everything from setup to advanced workflows.",
                                      "direction": "ltr",
                                      "type": "content-renderer"
                                    }
                                  ],
                                  "title": "Overview",
                                  "type": "article-section"
                                },
                                {
                                  "defaultTab": "popular",
                                  "tabs": [
                                    {
                                      "id": "popular",
                                      "label": "Popular",
                                      "content": {
                                        "type": "typography",
                                        "content": "Most-viewed help articles this week."
                                      }
                                    },
                                    {
                                      "content": {
                                        "content": "Freshly revised guidance.",
                                        "type": "typography"
                                      },
                                      "id": "recent",
                                      "label": "Recently Updated"
                                    },
                                    {
                                      "content": {
                                        "type": "typography",
                                        "content": "Articles still in review."
                                      },
                                      "id": "drafts",
                                      "label": "Drafts"
                                    }
                                  ],
                                  "type": "tabbed-container"
                                },
                                {
                                  "entity": "@payload.data",
                                  "type": "book-viewer"
                                },
                                {
                                  "title": "How Acme reduced support volume 40%",
                                  "href": "/help-articles/case-study-acme",
                                  "linkLabel": "Read case study",
                                  "description": "A walkthrough of the self-serve content strategy that cut inbound tickets.",
                                  "category": "Customer Story",
                                  "type": "case-study-card"
                                },
                                {
                                  "type": "case-study-organism",
                                  "entity": "HelpArticle"
                                },
                                {
                                  "entity": "HelpArticle",
                                  "type": "step-flow-organism"
                                },
                                {
                                  "features": [
                                    {
                                      "id": "search",
                                      "label": "Smart Search",
                                      "type": "feature"
                                    },
                                    {
                                      "label": "Tag Index",
                                      "id": "tags",
                                      "type": "feature"
                                    },
                                    {
                                      "label": "Helpfulness Voting",
                                      "type": "feature",
                                      "id": "feedback"
                                    }
                                  ],
                                  "type": "feature-renderer-3d"
                                }
                              ]
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "variant": "secondary",
                              "label": "View"
                            },
                            {
                              "variant": "secondary",
                              "event": "EDIT",
                              "label": "Edit"
                            },
                            {
                              "variant": "primary",
                              "event": "PUBLISH",
                              "label": "Publish"
                            },
                            {
                              "label": "Archive",
                              "variant": "ghost",
                              "event": "ARCHIVE"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "event": "REQUEST_DELETE"
                            }
                          ],
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "cols": 1,
                          "fields": [
                            {
                              "label": "Title",
                              "variant": "caption",
                              "name": "title"
                            },
                            {
                              "name": "slug",
                              "label": "Slug",
                              "variant": "caption"
                            },
                            {
                              "name": "categoryName",
                              "variant": "caption",
                              "label": "Category"
                            },
                            {
                              "name": "author",
                              "label": "Author",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "name": "viewCount",
                              "variant": "caption",
                              "label": "Views"
                            },
                            {
                              "name": "helpfulCount",
                              "label": "Helpful",
                              "variant": "caption"
                            },
                            {
                              "label": "Published",
                              "variant": "caption",
                              "name": "publishedAt"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HelpArticleLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.message",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "HelpArticle",
                    {
                      "emit": {
                        "failure": "HelpArticleLoadFailed",
                        "success": "HelpArticleLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Refreshing help articles…"
