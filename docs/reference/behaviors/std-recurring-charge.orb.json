                    "set",
                    "@entity.id",
                    "@payload.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.newPlanId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    [
                      "*",
                      "@payload.row.amount",
                      [
                        "-",
                        1,
                        [
                          "/",
                          "@payload.daysIntoPeriod",
                          30
                        ]
                      ]
                    ]
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    "@payload.row.attemptCount"
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.row.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "success": "SubscriptionUpdated",
                        "failure": "ChargeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    "@payload.row.attemptCount"
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "success": "SubscriptionUpdated",
                        "failure": "ChargeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SubscriptionUpdated",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Subscription updated",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "charging",
                "to": "loading",
                "event": "ChargeSucceeded",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.row.id"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.amount",
                    "@payload.row.amount"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.interval",
                    "@payload.row.interval"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodStart",
                    "@payload.row.currentPeriodStart"
                  ],
                  [
                    "set",
                    "@entity.currentPeriodEnd",
                    "@payload.row.currentPeriodEnd"
                  ],
                  [
                    "set",
                    "@entity.nextBillingAt",
                    "@payload.row.nextBillingAt"
                  ],
                  [
                    "set",
                    "@entity.attemptCount",
                    0
                  ],
                  [
                    "set",
                    "@entity.lastChargeAt",
                    "@payload.row.lastChargeAt"
                  ],
                  [
                    "set",
                    "@entity.cancelledAt",
                    "@payload.row.cancelledAt"
                  ],
                  [
                    "set",
                    "@entity.createdAt",
                    "@payload.row.createdAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "success": "SubscriptionUpdated",
                        "failure": "ChargeFailed"
                      }
                    }
                  ],
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "success": "SubscriptionLoaded",
                        "failure": "SubscriptionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "charging",
                "to": "browsing",
                "event": "ChargeFailed",
                "effects": [
                  [
                    "set",
                    "@entity.attemptCount",
                    [
                      "+",
                      "@entity.attemptCount",
                      1
                    ]
                  ],
                  [
                    "persist",
                    "update",
                    "Subscription",
                    "@entity",
                    {
                      "emit": {
                        "failure": "ChargeFailed",
                        "success": "SubscriptionUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Subscription",
                    {
                      "emit": {
                        "failure": "SubscriptionLoadFailed",
                        "success": "SubscriptionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
