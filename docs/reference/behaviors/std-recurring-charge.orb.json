                "name": "Subscription loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Subscription]"
                  }
                ]
              },
              {
                "key": "SubscriptionLoadFailed",
                "name": "Subscription load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHARGE",
                "name": "Charge",
                "payloadSchema": [
                  {
                    "name": "subscriptionId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
