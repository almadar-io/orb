                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "SubscriptionUpdated",
                "name": "Subscription updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "ChargeSucceeded",
                "name": "Charge succeeded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Subscription"
                  }
                ]
              },
              {
                "key": "ChargeFailed",
                "name": "Charge failed",
                "payloadSchema": [
