{
  "name": "std-health-score",
  "version": "1.0.0",
  "description": "std-health-score — Customer success health score primitive surfacing churn risk via composite usage/support/engagement signals.",
  "orbitals": [
    {
      "name": "HealthScoreOrbital",
      "entity": {
        "name": "HealthScore",
        "collection": "healthscores",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "default": ""
          },
          {
            "name": "score",
            "type": "number",
            "default": 50
          },
          {
            "name": "tier",
            "type": "string",
            "default": "green",
            "values": [
              "green",
              "yellow",
              "red"
            ]
          },
          {
            "name": "usageScore",
            "type": "number",
            "default": 0
          },
          {
            "name": "supportScore",
            "type": "number",
            "default": 0
          },
          {
            "name": "engagementScore",
            "type": "number",
            "default": 0
          },
          {
            "name": "trend",
            "type": "string",
            "default": "stable",
            "values": [
              "improving",
              "stable",
              "declining"
            ]
          },
          {
            "name": "lastCalculatedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedCsm",
            "type": "string",
            "default": ""
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "HealthScoreDashboard",
          "category": "interaction",
          "linkedEntity": "HealthScore",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RECALCULATE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ASSIGN_CSM",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "HealthScoreLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[HealthScore]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "HealthScoreLoadFailed",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "HealthScoreLoaded",
                "name": "HealthScore loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[HealthScore]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "HealthScoreLoadFailed",
                "name": "HealthScore load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
                  {
                    "name": "source",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_TIER",
                "name": "Filter Tier",
                "payloadSchema": [
                  {
                    "name": "tier",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FILTER_TREND",
                "name": "Filter Trend",
                "payloadSchema": [
                  {
                    "name": "trend",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RECALCULATE",
                "name": "Recalculate",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ASSIGN_CSM",
                "name": "Assign Csm",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading health scores…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "HealthScoreLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "activity"
                            },
                            {
                              "type": "typography",
                              "content": "Customer Health Scores",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "level": 2,
                          "title": "Customer Health Overview",
                          "align": "left",
                          "subtitle": "Composite signals across usage, support, and engagement",
                          "type": "section-header"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "min": 0,
                              "type": "meter",
                              "showValue": true,
                              "max": 100,
                              "label": "Composite Health",
                              "value": 78,
                              "variant": "radial",
                              "size": "md",
                              "unit": "%",
                              "thresholds": [
                                {
                                  "value": 40,
                                  "color": "danger"
                                },
                                {
                                  "color": "warning",
                                  "value": 70
                                }
                              ]
                            },
                            {
                              "max": 100,
                              "type": "health-bar",
                              "current": 78,
                              "animated": true,
                              "format": "bar",
                              "size": "md"
                            },
                            {
                              "direction": "up",
                              "label": "30d trend",
                              "showValue": true,
                              "size": "md",
                              "type": "trend-indicator",
                              "value": 4.2
                            },
                            {
                              "type": "combo-counter",
                              "combo": 6,
                              "size": "md",
                              "streak": 4,
                              "multiplier": 2
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center"
                        },
                        {
                          "activeTab": "health",
                          "orientation": "horizontal",
                          "items": [
                            {
                              "id": "engagement",
                              "label": "Engagement"
                            },
                            {
                              "label": "Usage",
                              "id": "usage"
                            },
                            {
                              "id": "health",
                              "label": "Health"
                            }
                          ],
                          "type": "tabs",
                          "variant": "default"
                        },
                        {
                          "items": [
                            {
                              "label": "Summary",
                              "id": "summary"
                            },
                            {
                              "id": "history",
                              "label": "History"
                            },
                            {
                              "id": "playbook",
                              "label": "Playbook"
                            },
                            {
                              "id": "csm",
                              "label": "CSM Notes"
                            }
                          ],
                          "showCloseButton": false,
                          "brandName": "Health Detail",
                          "hideCollapseButton": true,
                          "type": "sidebar"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "size": "md",
                              "icon": "refresh-cw",
                              "title": "Auto-Renewal Insights",
                              "type": "feature-card",
                              "description": "Identifies subscribers trending toward renewal vs churn",
                              "variant": "elevated"
                            },
                            {
                              "variant": "bordered",
                              "type": "feature-card",
                              "size": "md",
                              "icon": "alert-triangle",
                              "title": "Risk Escalation",
                              "description": "Triggers CSM workflows when health drops below threshold"
                            },
                            {
                              "bio": "Owns enterprise accounts across NA West",
                              "name": "Priya Sharma",
                              "avatar": "https://i.pravatar.cc/120?u=priya",
                              "type": "team-card",
                              "role": "Senior CSM"
                            }
                          ]
                        },
                        {
                          "columns": 3,
                          "type": "feature-grid-organism",
                          "subtitle": "Top contributors to composite score",
                          "heading": "Health Signal Drivers"
                        },
                        {
                          "subtitle": "CSMs supporting this segment",
                          "heading": "Customer Success Team",
                          "type": "team-organism"
                        },
                        {
                          "columns": 4,
                          "type": "stats-organism"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Customer",
                              "variant": "caption",
                              "name": "customerName"
                            },
                            {
                              "name": "score",
                              "label": "Score",
                              "variant": "badge"
                            },
                            {
                              "name": "tier",
                              "label": "Tier",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "usageScore",
                              "label": "Usage"
                            },
                            {
                              "variant": "caption",
                              "label": "Support",
                              "name": "supportScore"
                            },
                            {
                              "name": "trend",
                              "variant": "badge",
                              "label": "Trend"
                            },
                            {
                              "label": "CSM",
                              "variant": "caption",
                              "name": "assignedCsm"
                            },
                            {
                              "label": "Updated",
                              "variant": "caption",
                              "name": "lastCalculatedAt"
                            }
                          ],
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "View",
                              "event": "VIEW",
                              "variant": "secondary"
                            },
                            {
                              "event": "EDIT",
                              "variant": "secondary",
                              "label": "Edit"
                            },
                            {
                              "label": "Recalculate",
                              "event": "RECALCULATE",
                              "variant": "primary"
                            },
                            {
                              "variant": "ghost",
                              "event": "ASSIGN_CSM",
                              "label": "Assign CSM"
                            }
                          ],
                          "cols": 1
                        }
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "HealthScoreLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.message",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography",
                          "content": "Refreshing health scores…"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Searching health scores…",
                          "color": "muted"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TIER",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Filtering by tier…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TREND",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "failure": "HealthScoreLoadFailed",
                        "success": "HealthScoreLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Filtering by trend…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "message": "Viewing health score",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Editing health score",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "RECALCULATE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Recalculation triggered",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "ASSIGN_CSM",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Assigning CSM"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "HealthScore",
                    {
                      "emit": {
                        "success": "HealthScoreLoaded",
                        "failure": "HealthScoreLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Customer Health Scores"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "HealthScorePage",
          "path": "/health-scores",
          "traits": [
            {
              "ref": "HealthScoreDashboard"
            }
          ]
        }
      ]
    }
  ]
}
