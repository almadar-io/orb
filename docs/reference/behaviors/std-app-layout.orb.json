{
  "name": "std-app-layout",
  "version": "1.4.0",
  "description": "std-app-layout — dashboard-layout chrome (sidebar nav + top bar with search + topBarActions + notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data, and the consumer can add domain icons (cart / profile / help) via topBarActions. Bind once per orbital — the consumer rebinds linkedEntity via `XAppLayout = AppShell.traits.AppLayout -> XEntity` so multiple orbitals in one file each get their own chrome without colliding on a shared atom entity.",
  "orbitals": [
    {
      "name": "AppLayoutOrbital",
      "entity": {
        "name": "AppLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "AppLayout",
          "category": "interaction",
          "linkedEntity": "AppLayoutState",
          "emits": [
            {
              "event": "SEARCH",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            },
            {
              "event": "NOTIFY_CLICK",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AppLayoutStateLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AppLayoutState]"
                }
              ]
            },
            {
              "event": "AppLayoutStateLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AppLayoutStateLoaded",
                "name": "AppLayoutState loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AppLayoutState]"
                  }
                ]
              },
              {
                "key": "AppLayoutStateLoadFailed",
                "name": "AppLayoutState load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "NOTIFY_CLICK",
                "name": "Notify Click"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AppLayoutState",
                    {
                      "emit": {
                        "success": "AppLayoutStateLoaded",
                        "failure": "AppLayoutStateLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "navItems": [],
                      "notifications": [],
                      "topBarActions": [],
                      "notificationClickEvent": "NOTIFY_CLICK",
                      "type": "dashboard-layout",
                      "appName": "App",
                      "children": [
                        {
                          "direction": "vertical",
                          "children": [
                            "@config.contentTrait"
                          ],
                          "type": "stack",
                          "gap": "lg",
                          "className": "max-w-5xl mx-auto w-full"
                        }
                      ],
                      "searchEvent": "SEARCH"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "AppLayoutStateLoaded"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "AppLayoutStateLoadFailed"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "NOTIFY_CLICK"
              }
            ]
          },
          "config": {
            "searchEvent": {
              "type": "string",
              "default": "SEARCH"
            },
            "contentTrait": {
              "type": "trait"
            },
            "topBarActions": {
              "type": "[object]",
              "default": []
            },
            "navItems": {
              "type": "[object]",
              "default": []
            },
            "notifications": {
              "type": "[object]",
              "default": []
            },
            "appName": {
              "type": "string",
              "default": "App"
            },
            "notificationClickEvent": {
              "type": "string",
              "default": "NOTIFY_CLICK"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AppLayoutPage",
          "path": "/app-layout",
          "traits": [
            {
              "ref": "AppLayout"
            }
          ]
        }
      ]
    }
  ]
}
