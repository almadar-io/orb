{
  "name": "std-app-layout",
  "version": "1.1.0",
  "description": "std-app-layout — dashboard-layout chrome (sidebar nav + top bar with optional search and notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data.",
  "orbitals": [
    {
      "name": "AppLayoutOrbital",
      "entity": {
        "name": "AppLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "AppLayout",
          "category": "interaction",
          "emits": [
            {
              "event": "SEARCH",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string"
                }
              ]
            },
            {
              "event": "NOTIFY_CLICK",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "NOTIFY_CLICK",
                "name": "Notify Click"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "searchEvent": "SEARCH",
                      "type": "dashboard-layout",
                      "children": [
                        {
                          "direction": "vertical",
                          "className": "max-w-5xl mx-auto w-full",
                          "children": [
                            "@config.contentTrait"
                          ],
                          "type": "stack",
                          "gap": "lg"
                        }
                      ],
                      "notifications": [],
                      "appName": "App",
                      "notificationClickEvent": "NOTIFY_CLICK",
                      "navItems": []
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "SEARCH"
              },
              {
                "from": "composing",
                "to": "composing",
                "event": "NOTIFY_CLICK"
              }
            ]
          },
          "config": {
            "navItems": {
              "type": "[object]",
              "default": []
            },
            "notifications": {
              "type": "[object]",
              "default": []
            },
            "notificationClickEvent": {
              "type": "string",
              "default": "NOTIFY_CLICK"
            },
            "appName": {
              "type": "string",
              "default": "App"
            },
            "contentTrait": {
              "type": "trait"
            },
            "searchEvent": {
              "type": "string",
              "default": "SEARCH"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AppLayoutPage",
          "path": "/app-layout",
          "traits": [
            {
              "ref": "AppLayout"
            }
          ]
        }
      ]
    }
  ]
}
