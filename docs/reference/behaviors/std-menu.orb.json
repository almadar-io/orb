                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "failure": "MenuItemLoadFailed",
                        "success": "MenuItemLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "MenuItemDeleted",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "success": "MenuItemLoaded",
                        "failure": "MenuItemLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MenuItemWriteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "MenuItem",
                    {
                      "emit": {
                        "success": "MenuItemLoaded",
                        "failure": "MenuItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Menu"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MenuItemManagePage",
          "path": "/menu/manage",
          "traits": [
            {
              "ref": "MenuItemManage"
            }
          ]
        }
      ]
    }
  ]
}
