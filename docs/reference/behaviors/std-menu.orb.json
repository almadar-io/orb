{
  "name": "std-menu",
  "version": "1.0.0",
  "description": "std-menu — restaurant POS menu items grouped by category with availability windows. Owns a MenuItem entity (price, category, available, prep time, modifier groups) and a single manage trait that loads items, browses them in a data-grid with Create / Update / Toggle-Available / Delete actions, and persists each verdict back to the row.",
  "orbitals": [
    {
      "name": "MenuOrbital",
      "entity": {
        "name": "MenuItem",
        "collection": "menuitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "category",
            "type": "string",
            "required": true
          },
          {
            "name": "imageUrl",
            "type": "string"
          },
          {
            "name": "available",
            "type": "boolean",
            "default": true
          },
          {
            "name": "availableFrom",
            "type": "string"
          },
          {
            "name": "availableUntil",
            "type": "string"
          },
          {
            "name": "tags",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "modifierGroupIds",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "prepTimeMinutes",
            "type": "number",
            "default": 10
          },
          {
            "name": "order",
            "type": "number",
            "default": 0
          }
        ]
      },
