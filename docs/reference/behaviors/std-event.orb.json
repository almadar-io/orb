                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Events"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "EventManagePage",
          "path": "/events/manage",
          "traits": [
