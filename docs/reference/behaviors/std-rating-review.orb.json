{
  "name": "std-rating-review",
  "version": "1.0.0",
  "description": "std-rating-review — capture a 1..N star rating with optional comment + photos. Owns a RatingReview entity; SUBMIT persists @payload.data (rating, comment, photos, targetId) and emits RatingReviewSubmitted so cross-trait listeners can react (e.g. recompute aggregate).",
  "orbitals": [
    {
      "name": "RatingReviewOrbital",
      "entity": {
        "name": "RatingReview",
        "collection": "ratingreviews",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "rating",
            "type": "number",
            "required": true
          },
          {
            "name": "comment",
            "type": "string"
          },
          {
            "name": "photos",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "name": "authorId",
            "type": "string"
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RatingReviewSubmit",
          "category": "interaction",
          "linkedEntity": "RatingReview",
          "emits": [
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "RATE",
              "payloadSchema": [
                {
                  "name": "rating",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_COMMENT",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RatingReviewLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RatingReview]"
                }
              ]
            },
            {
              "event": "RatingReviewLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RatingReviewSubmitted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.rating",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.comment",
                  "type": "string"
                },
                {
                  "name": "row.photos",
                  "type": "[string]"
                },
                {
                  "name": "row.authorId",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RatingReviewSubmitFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "submitting"
              },
              {
                "name": "submitted"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RATE",
                "name": "Rate",
                "payloadSchema": [
                  {
                    "name": "rating",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_COMMENT",
                "name": "Edit Comment",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RatingReviewLoaded",
                "name": "RatingReview loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RatingReview]"
                  }
                ]
              },
              {
                "key": "RatingReviewLoadFailed",
                "name": "RatingReview load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "RatingReviewSubmitted",
                "name": "RatingReview submitted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "RatingReview"
                  }
                ]
              },
              {
                "key": "RatingReviewSubmitFailed",
                "name": "RatingReview submit failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RatingReview",
                    {
                      "emit": {
                        "success": "RatingReviewLoaded",
                        "failure": "RatingReviewLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "variant": "h3",
                          "content": "Rate this",
                          "type": "typography"
                        },
                        {
                          "value": "@entity.rating",
                          "type": "star-rating",
                          "max": 5,
                          "action": "RATE"
                        },
                        {
                          "action": "EDIT_COMMENT",
                          "type": "textarea",
                          "placeholder": "Tell us more (optional)"
                        },
                        {
                          "action": "SUBMIT",
                          "type": "button",
                          "label": "Submit",
                          "variant": "primary",
                          "icon": "send"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RATE",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    "@payload.rating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "content": "Rate this",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "value": "@entity.rating",
                          "max": 5,
                          "action": "RATE",
                          "type": "star-rating"
                        },
                        {
                          "type": "textarea",
                          "action": "EDIT_COMMENT",
                          "placeholder": "Tell us more (optional)"
                        },
                        {
                          "icon": "send",
                          "action": "SUBMIT",
                          "label": "Submit",
                          "variant": "primary",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_COMMENT",
                "effects": [
                  [
                    "set",
                    "@entity.comment",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RatingReviewLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "variant": "h3",
                          "content": "Rate this",
                          "type": "typography"
                        },
                        {
                          "type": "star-rating",
                          "value": "@entity.rating",
                          "action": "RATE",
                          "max": 5
                        },
                        {
                          "placeholder": "Tell us more (optional)",
                          "action": "EDIT_COMMENT",
                          "type": "textarea"
                        },
                        {
                          "variant": "primary",
                          "action": "SUBMIT",
                          "type": "button",
                          "label": "Submit",
                          "icon": "send"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RatingReviewLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "persist",
                    "create",
                    "RatingReview",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "RatingReviewSubmitFailed",
                        "success": "RatingReviewSubmitted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Submitting your review…"
                        }
                      ],
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "submitted",
                "event": "RatingReviewSubmitted",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle",
                          "color": "success"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Thanks for your review!"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "idle",
                "event": "RatingReviewSubmitFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    0
                  ],
                  [
                    "set",
                    "@entity.comment",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "content": "Rate this",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "action": "RATE",
                          "value": "@entity.rating",
                          "type": "star-rating",
                          "max": 5
                        },
                        {
                          "type": "textarea",
                          "action": "EDIT_COMMENT",
                          "placeholder": "Tell us more (optional)"
                        },
                        {
                          "icon": "send",
                          "type": "button",
                          "label": "Submit",
                          "action": "SUBMIT",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "allowComment": {
              "type": "boolean",
              "default": true
            },
            "allowPhotos": {
              "type": "boolean",
              "default": false
            },
            "title": {
              "type": "string",
              "default": "Rate this"
            },
            "maxStars": {
              "type": "number",
              "default": 5
            },
            "submitEvent": {
              "type": "string",
              "default": "SUBMIT_REVIEW"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "RatingReviewSubmitPage",
          "path": "/ratingreviews/submit",
          "traits": [
            {
              "ref": "RatingReviewSubmit"
            }
          ]
        }
      ]
    }
  ]
}
