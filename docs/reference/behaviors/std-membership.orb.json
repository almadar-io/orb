{
  "name": "std-membership",
  "version": "1.0.0",
  "description": "std-membership — recurring gym/fitness/club membership with tier, renewal, freeze, and member-self-managed cancel. Distinct from std-recurring-charge (Stripe SaaS) — memberships support tier upgrades, freezes, and self-managed cancellation.",
  "orbitals": [
    {
      "name": "MembershipOrbital",
      "entity": {
        "name": "Membership",
        "collection": "memberships",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "memberId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberName",
            "type": "string",
            "default": ""
          },
          {
            "name": "tier",
            "type": "string",
            "default": "basic",
            "values": [
              "basic",
              "standard",
              "premium",
              "vip"
            ]
          },
          {
            "name": "monthlyDues",
            "type": "number",
            "default": 0
          },
          {
            "name": "startDate",
            "type": "string",
            "required": true
          },
          {
            "name": "renewalDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "frozen",
              "cancelled",
              "expired"
            ]
          },
          {
            "name": "accessLevel",
            "type": "string",
            "default": ""
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "MembershipDirectory",
          "category": "interaction",
          "linkedEntity": "Membership",
          "emits": [
            {
              "event": "UPGRADE_TIER",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FREEZE_MEMBERSHIP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CANCEL_MEMBERSHIP",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MembershipLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Membership]"
                }
              ]
            },
            {
              "event": "MembershipLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "MembershipLoaded",
                "name": "Membership loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Membership]"
                  }
                ]
              },
              {
                "key": "MembershipLoadFailed",
                "name": "Membership load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "UPGRADE_TIER",
                "name": "Upgrade Tier",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FREEZE_MEMBERSHIP",
                "name": "Freeze Membership",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_MEMBERSHIP",
                "name": "Cancel Membership",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "success": "MembershipLoaded",
                        "failure": "MembershipLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading memberships…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "MembershipLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "id-card"
                            },
                            {
                              "level": 2,
                              "type": "heading",
                              "content": "Memberships"
                            },
                            {
                              "variant": "buff",
                              "label": "Member tier",
                              "icon": "shield",
                              "type": "status-effect"
                            }
                          ],
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "speed": 40,
                          "text": "Welcome back, member.",
                          "type": "typewriter-text"
                        },
                        {
                          "items": [
                            {
                              "id": "active",
                              "label": "Active"
                            },
                            {
                              "id": "frozen",
                              "label": "Paused"
                            },
                            {
                              "id": "cancelled",
                              "label": "Cancelled"
                            }
                          ],
                          "activeTab": "active",
                          "type": "tabs"
                        },
                        {
                          "children": [
                            {
                              "duration": 1200,
                              "value": 128,
                              "suffix": " members",
                              "type": "animated-counter"
                            },
                            {
                              "current": 720,
                              "type": "xp-bar",
                              "level": 7,
                              "showLabel": true,
                              "max": 1000
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "data": {
                            "description": "Guest passes, towel service, locker reserve",
                            "title": "Premium Perks",
                            "icon": "star"
                          },
                          "type": "module-card"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "event": "UPGRADE_TIER",
                              "label": "Upgrade",
                              "variant": "primary"
                            },
                            {
                              "label": "Freeze",
                              "event": "FREEZE_MEMBERSHIP",
                              "variant": "ghost"
                            },
                            {
                              "label": "Cancel",
                              "event": "CANCEL_MEMBERSHIP",
                              "variant": "danger"
                            }
                          ],
                          "fields": [
                            {
                              "name": "memberName",
                              "variant": "caption",
                              "label": "Member"
                            },
                            {
                              "label": "Tier",
                              "variant": "badge",
                              "name": "tier"
                            },
                            {
                              "name": "monthlyDues",
                              "label": "Monthly Dues",
                              "variant": "caption"
                            },
                            {
                              "name": "renewalDate",
                              "variant": "caption",
                              "label": "Renews"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "cols": 1,
                          "gap": "sm",
                          "entity": "@payload.data"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "MembershipLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "UPGRADE_TIER",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Tier upgraded",
                      "variant": "success",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "FREEZE_MEMBERSHIP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "info",
                      "message": "Membership frozen"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL_MEMBERSHIP",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Membership cancelled"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Membership",
                    {
                      "emit": {
                        "failure": "MembershipLoadFailed",
                        "success": "MembershipLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Memberships"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "MembershipPage",
          "path": "/memberships",
          "traits": [
            {
              "ref": "MembershipDirectory"
            }
          ]
        }
      ]
    }
  ]
}
