{
  "name": "ReviewOrbital",
  "orbitals": [
    {
      "name": "ReviewOrbital",
      "entity": {
        "name": "Review",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "rating",
            "type": "number"
          },
          {
            "name": "comment",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ReviewRating",
          "category": "interaction",
          "linkedEntity": "Review",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "rated"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "RATE"
              },
              {
                "key": "RESET"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Review"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "star",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Rating",
                              "variant": "h2"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "How would you rate this?",
                          "variant": "body",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "rating"
                          ],
                          "max": 5.0,
                          "event": "RATE",
                          "size": "lg",
                          "type": "star-rating"
                        },
                        {
                          "label": "Submit Rating",
                          "icon": "star",
                          "type": "button",
                          "event": "RATE",
                          "variant": "primary"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "rated",
                "event": "RATE",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    "@payload.rating"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle",
                              "size": "lg"
                            },
                            {
                              "variant": "h2",
                              "content": "Thank You!",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "size": "lg",
                          "type": "star-rating",
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "rating"
                          ],
                          "readOnly": true,
                          "max": 5.0
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Your rating has been recorded."
                        },
                        {
                          "label": "Rate Again",
                          "variant": "ghost",
                          "type": "button",
                          "event": "RESET",
                          "icon": "rotate-ccw"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "rated",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.rating",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "star"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Rating"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "How would you rate this?",
                          "color": "muted"
                        },
                        {
                          "event": "RATE",
                          "max": 5.0,
                          "size": "lg",
                          "type": "star-rating",
                          "value": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "rating"
                          ]
                        },
                        {
                          "type": "button",
                          "event": "RATE",
                          "variant": "primary",
                          "icon": "star",
                          "label": "Submit Rating"
                        }
                      ],
                      "type": "stack",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ReviewsRating",
          "path": "/reviews/rating",
          "traits": [
            {
              "ref": "ReviewRating"
            }
          ]
        }
      ]
    }
  ]
}
