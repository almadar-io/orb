{
  "name": "std-flag",
  "version": "1.0.0",
  "description": "std-flag — user-initiated content flagging. Owns a Flag entity; SUBMIT persists @payload.data (targetId, targetType, reason, notes) and emits FlagSubmitted so cross-trait listeners (e.g. std-mod-queue) can react.",
  "orbitals": [
    {
      "name": "FlagOrbital",
      "entity": {
        "name": "Flag",
        "collection": "flags",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "reportedBy",
            "type": "string"
          },
          {
            "name": "reason",
            "type": "string",
            "default": "spam",
            "values": [
              "spam",
              "abuse",
              "off-topic",
              "misinformation",
              "nsfw",
              "other"
            ]
          },
          {
            "name": "notes",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FlagReport",
          "category": "interaction",
          "linkedEntity": "Flag",
          "emits": [
            {
              "event": "SUBMIT",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "SELECT_REASON",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EDIT_NOTES",
              "payloadSchema": [
                {
                  "name": "value",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "FlagLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Flag]"
                }
              ]
            },
            {
              "event": "FlagLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FlagSubmitted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.reportedBy",
                  "type": "string"
                },
                {
                  "name": "row.reason",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FlagSubmitFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "submitting"
              },
              {
                "name": "submitted"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SELECT_REASON",
                "name": "Select Reason",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EDIT_NOTES",
                "name": "Edit Notes",
                "payloadSchema": [
                  {
                    "name": "value",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FlagLoaded",
                "name": "Flag loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Flag]"
                  }
                ]
              },
              {
                "key": "FlagLoadFailed",
                "name": "Flag load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SUBMIT",
                "name": "Submit",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "FlagSubmitted",
                "name": "Flag submitted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Flag"
                  }
                ]
              },
              {
                "key": "FlagSubmitFailed",
                "name": "Flag submit failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Flag",
                    {
                      "emit": {
                        "failure": "FlagLoadFailed",
                        "success": "FlagLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Report content",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "action": "SELECT_REASON",
                          "placeholder": "Select a reason",
                          "options": [
                            {
                              "value": "spam",
                              "label": "Spam"
                            },
                            {
                              "value": "abuse",
                              "label": "Abuse"
                            },
                            {
                              "label": "Off-topic",
                              "value": "off-topic"
                            },
                            {
                              "label": "Misinformation",
                              "value": "misinformation"
                            },
                            {
                              "label": "NSFW",
                              "value": "nsfw"
                            },
                            {
                              "value": "other",
                              "label": "Other"
                            }
                          ],
                          "type": "select"
                        },
                        {
                          "action": "EDIT_NOTES",
                          "placeholder": "Add details (optional)",
                          "type": "textarea"
                        },
                        {
                          "type": "button",
                          "action": "SUBMIT",
                          "icon": "flag",
                          "variant": "primary",
                          "label": "Submit report"
                        }
                      ],
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "SELECT_REASON",
                "effects": [
                  [
                    "set",
                    "@entity.reason",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "EDIT_NOTES",
                "effects": [
                  [
                    "set",
                    "@entity.notes",
                    "@payload.value"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FlagLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "content": "Report content",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "options": [
                            {
                              "value": "spam",
                              "label": "Spam"
                            },
                            {
                              "value": "abuse",
                              "label": "Abuse"
                            },
                            {
                              "label": "Off-topic",
                              "value": "off-topic"
                            },
                            {
                              "label": "Misinformation",
                              "value": "misinformation"
                            },
                            {
                              "label": "NSFW",
                              "value": "nsfw"
                            },
                            {
                              "label": "Other",
                              "value": "other"
                            }
                          ],
                          "action": "SELECT_REASON",
                          "type": "select",
                          "placeholder": "Select a reason"
                        },
                        {
                          "placeholder": "Add details (optional)",
                          "action": "EDIT_NOTES",
                          "type": "textarea"
                        },
                        {
                          "variant": "primary",
                          "type": "button",
                          "label": "Submit report",
                          "action": "SUBMIT",
                          "icon": "flag"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "FlagLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Flag",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "FlagSubmitted",
                        "failure": "FlagSubmitFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Submitting your report…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "submitted",
                "event": "FlagSubmitted",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle",
                          "color": "success"
                        },
                        {
                          "content": "Thanks. Our team will review this report.",
                          "type": "typography",
                          "variant": "h3"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "submitting",
                "to": "error",
                "event": "FlagSubmitFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "submitted",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.reason",
                    "spam"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Report content"
                        },
                        {
                          "type": "select",
                          "placeholder": "Select a reason",
                          "action": "SELECT_REASON",
                          "options": [
                            {
                              "value": "spam",
                              "label": "Spam"
                            },
                            {
                              "label": "Abuse",
                              "value": "abuse"
                            },
                            {
                              "label": "Off-topic",
                              "value": "off-topic"
                            },
                            {
                              "label": "Misinformation",
                              "value": "misinformation"
                            },
                            {
                              "value": "nsfw",
                              "label": "NSFW"
                            },
                            {
                              "label": "Other",
                              "value": "other"
                            }
                          ]
                        },
                        {
                          "placeholder": "Add details (optional)",
                          "action": "EDIT_NOTES",
                          "type": "textarea"
                        },
                        {
                          "type": "button",
                          "action": "SUBMIT",
                          "variant": "primary",
                          "icon": "flag",
                          "label": "Submit report"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "variant": "h3",
                          "content": "Report content",
                          "type": "typography"
                        },
                        {
                          "placeholder": "Select a reason",
                          "type": "select",
                          "action": "SELECT_REASON",
                          "options": [
                            {
                              "label": "Spam",
                              "value": "spam"
                            },
                            {
                              "label": "Abuse",
                              "value": "abuse"
                            },
                            {
                              "label": "Off-topic",
                              "value": "off-topic"
                            },
                            {
                              "value": "misinformation",
                              "label": "Misinformation"
                            },
                            {
                              "value": "nsfw",
                              "label": "NSFW"
                            },
                            {
                              "value": "other",
                              "label": "Other"
                            }
                          ]
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Add details (optional)",
                          "action": "EDIT_NOTES"
                        },
                        {
                          "type": "button",
                          "action": "SUBMIT",
                          "label": "Submit report",
                          "variant": "primary",
                          "icon": "flag"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "reasons": {
              "type": "[string]",
              "default": [
                "spam",
                "abuse",
                "off-topic",
                "misinformation",
                "nsfw",
                "other"
              ]
            },
            "title": {
              "type": "string",
              "default": "Report content"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "FlagReportPage",
          "path": "/flags/report",
          "traits": [
            {
              "ref": "FlagReport"
            }
          ]
        }
      ]
    }
  ]
}
