    {
      "name": "WorkOrderOrbital",
      "entity": {
        "name": "WorkOrder",
        "collection": "workorders",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerName",
            "type": "string",
            "required": true
          },
          {
            "name": "serviceType",
            "type": "string",
            "required": true
          },
          {
            "name": "address",
            "type": "string",
            "required": true
          },
          {
            "name": "priority",
            "type": "string",
            "default": "normal",
            "values": [
              "low",
              "normal",
              "high",
              "urgent"
            ]
          },
          {
            "name": "status",
            "type": "string",
            "default": "created",
            "values": [
              "created",
              "assigned",
              "en-route",
              "on-site",
              "completed",
              "cancelled"
            ]
          },
          {
            "name": "assignedTo",
            "type": "string"
          },
          {
            "name": "scheduledAt",
            "type": "string"
          },
          {
            "name": "etaMinutes",
