                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading work orders…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WorkOrderLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clipboard-list"
                            },
                            {
                              "type": "typography",
                              "content": "Work Orders",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Assign",
                              "icon": "user-plus",
                              "event": "ASSIGN",
                              "variant": "primary"
                            },
                            {
                              "event": "START_TRAVEL",
                              "icon": "navigation",
                              "variant": "secondary",
                              "label": "Start Travel"
                            },
                            {
                              "variant": "secondary",
                              "label": "Arrive",
                              "event": "ARRIVE",
                              "icon": "map-pin"
                            },
                            {
                              "icon": "check",
                              "label": "Complete",
                              "variant": "primary",
                              "event": "COMPLETE"
                            },
                            {
                              "icon": "x",
                              "event": "CANCEL",
                              "variant": "danger",
                              "label": "Cancel"
                            }
                          ],
                          "fields": [
                            {
                              "label": "Customer",
                              "name": "customerName",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "serviceType",
                              "label": "Service"
                            },
                            {
                              "name": "address",
                              "label": "Address",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "name": "priority",
                              "label": "Priority"
                            },
                            {
                              "variant": "badge",
                              "name": "status",
                              "label": "Status"
                            },
                            {
                              "label": "Assigned",
                              "variant": "caption",
                              "name": "assignedTo"
                            },
                            {
                              "label": "ETA (min)",
                              "variant": "caption",
                              "name": "etaMinutes"
                            }
                          ],
                          "cols": 1,
                          "gap": "sm",
                          "entity": "@payload.data"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WorkOrderLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ASSIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.assignedTo",
                    "@payload.assignedTo"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "assigned"
                  ],
                  [
                    "persist",
                    "update",
                    "WorkOrder",
                    "@entity",
                    {
                      "emit": {
                        "failure": "WorkOrderUpdateFailed",
                        "success": "WorkOrderUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "START_TRAVEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.etaMinutes",
                    "@payload.etaMinutes"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "en-route"
                  ],
                  [
                    "persist",
                    "update",
                    "WorkOrder",
                    "@entity",
                    {
                      "emit": {
                        "failure": "WorkOrderUpdateFailed",
                        "success": "WorkOrderUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ARRIVE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "on-site"
                  ],
                  [
                    "persist",
                    "update",
                    "WorkOrder",
                    "@entity",
                    {
                      "emit": {
                        "success": "WorkOrderUpdated",
                        "failure": "WorkOrderUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.notes"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "completed"
                  ],
                  [
                    "persist",
                    "update",
                    "WorkOrder",
                    "@entity",
                    {
                      "emit": {
                        "success": "WorkOrderUpdated",
                        "failure": "WorkOrderUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.notes"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "persist",
                    "update",
                    "WorkOrder",
                    "@entity",
                    {
                      "emit": {
                        "success": "WorkOrderUpdated",
                        "failure": "WorkOrderUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WorkOrderUpdated",
                "effects": [
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "success": "WorkOrderLoaded",
                        "failure": "WorkOrderLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "WorkOrderUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorkOrder",
                    {
                      "emit": {
                        "failure": "WorkOrderLoadFailed",
                        "success": "WorkOrderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Work Orders"
            }
          },
