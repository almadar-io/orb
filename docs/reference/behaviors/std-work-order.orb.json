              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WorkOrderLoaded",
                "name": "WorkOrder loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[WorkOrder]"
                  }
                ]
              },
              {
                "key": "WorkOrderLoadFailed",
                "name": "WorkOrder load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ASSIGN",
                "name": "Assign",
                "payloadSchema": [
