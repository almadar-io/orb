{
  "name": "std-checkin",
  "version": "1.0.0",
  "description": "std-checkin — unified arrival check-in atom. Config picks the verification mode (qr or geo); SCAN persists the captured location/code against a target (work-order, ticket, or appointment) and emits CheckinRecorded for cross-trait listeners.",
  "orbitals": [
    {
      "name": "CheckinOrbital",
      "entity": {
        "name": "Checkin",
        "collection": "checkins",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "mode",
            "type": "string",
            "default": "geo",
            "values": [
              "geo",
              "qr"
            ]
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "userId",
            "type": "string"
          },
          {
            "name": "lat",
            "type": "number"
          },
          {
            "name": "lng",
            "type": "number"
          },
          {
            "name": "qrCode",
            "type": "string"
          },
          {
            "name": "verified",
            "type": "boolean",
            "default": false
          },
          {
            "name": "checkedInAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "CheckinScan",
          "category": "interaction",
          "linkedEntity": "Checkin",
          "emits": [
            {
              "event": "SCAN",
              "payloadSchema": [
                {
                  "name": "qrCode",
                  "type": "string"
                },
                {
                  "name": "lat",
                  "type": "number"
                },
                {
                  "name": "lng",
                  "type": "number"
                },
                {
                  "name": "latitude",
                  "type": "number"
                },
                {
                  "name": "longitude",
                  "type": "number"
                },
                {
                  "name": "result",
                  "type": "object"
                },
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CheckinLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Checkin]"
                }
              ]
            },
            {
              "event": "CheckinLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CheckinRecorded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.mode",
                  "type": "string"
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string"
                },
                {
                  "name": "row.lat",
                  "type": "number"
                },
                {
                  "name": "row.lng",
                  "type": "number"
                },
                {
                  "name": "row.qrCode",
                  "type": "string"
                },
                {
                  "name": "row.verified",
                  "type": "boolean"
                },
                {
                  "name": "row.checkedInAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CheckinFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "checking-in"
              },
              {
                "name": "checked-in"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CheckinLoaded",
                "name": "Checkin loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Checkin]"
                  }
                ]
              },
              {
                "key": "CheckinLoadFailed",
                "name": "Checkin load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SCAN",
                "name": "Scan",
                "payloadSchema": [
                  {
                    "name": "qrCode",
                    "type": "string"
                  },
                  {
                    "name": "lat",
                    "type": "number"
                  },
                  {
                    "name": "lng",
                    "type": "number"
                  },
                  {
                    "name": "latitude",
                    "type": "number"
                  },
                  {
                    "name": "longitude",
                    "type": "number"
                  },
                  {
                    "name": "result",
                    "type": "object"
                  },
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "CheckinRecorded",
                "name": "Checkin recorded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Checkin"
                  }
                ]
              },
              {
                "key": "CheckinFailed",
                "name": "Checkin failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading check-in…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "CheckinLoaded",
                "guard": [
                  "=",
                  "geo",
                  "qr"
                ],
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "variant": "h3",
                          "content": "Check in",
                          "type": "typography"
                        },
                        {
                          "showCameraControls": true,
                          "type": "qr-scanner",
                          "onScan": "SCAN",
                          "showOverlay": true,
                          "facingMode": "environment"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "CheckinLoaded",
                "guard": [
                  "=",
                  "geo",
                  "geo"
                ],
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "type": "typography",
                          "content": "Check in",
                          "variant": "h3"
                        },
                        {
                          "showClickedPin": true,
                          "markers": [],
                          "zoom": 14,
                          "type": "map-view",
                          "centerLng": "@entity.lng",
                          "mapClickEvent": "SCAN",
                          "centerLat": "@entity.lat",
                          "height": "320px"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CheckinLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "checking-in",
                "event": "SCAN",
                "guard": [
                  "=",
                  "geo",
                  "qr"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.mode",
                    "qr"
                  ],
                  [
                    "set",
                    "@entity.verified",
                    true
                  ],
                  [
                    "persist",
                    "create",
                    "Checkin",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "CheckinFailed",
                        "success": "CheckinRecorded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Recording check-in…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "checking-in",
                "event": "SCAN",
                "guard": [
                  "=",
                  "geo",
                  "geo"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.mode",
                    "geo"
                  ],
                  [
                    "set",
                    "@entity.lat",
                    "@payload.latitude"
                  ],
                  [
                    "set",
                    "@entity.lng",
                    "@payload.longitude"
                  ],
                  [
                    "set",
                    "@entity.verified",
                    true
                  ],
                  [
                    "persist",
                    "create",
                    "Checkin",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "CheckinFailed",
                        "success": "CheckinRecorded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Recording check-in…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "checking-in",
                "to": "checked-in",
                "event": "CheckinRecorded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "color": "success",
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Checked in"
                        }
                      ],
                      "align": "center",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "checking-in",
                "to": "error",
                "event": "CheckinFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "checked-in",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "success": "CheckinLoaded",
                        "failure": "CheckinLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted",
                          "content": "Loading check-in…"
                        }
                      ],
                      "direction": "vertical",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Checkin",
                    {
                      "emit": {
                        "failure": "CheckinLoadFailed",
                        "success": "CheckinLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading check-in…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "mode": {
              "type": "string",
              "default": "geo"
            },
            "title": {
              "type": "string",
              "default": "Check in"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CheckinScanPage",
          "path": "/checkins/scan",
          "traits": [
            {
              "ref": "CheckinScan"
            }
          ]
        }
      ]
    }
  ]
}
