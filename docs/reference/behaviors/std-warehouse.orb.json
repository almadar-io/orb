{
  "name": "std-warehouse",
  "version": "1.0.0",
  "description": "std-warehouse — physical or logical storage location where stock lives. Used by inventory and retail to scope stock counts.",
  "orbitals": [
    {
      "name": "WarehouseOrbital",
      "entity": {
        "name": "Warehouse",
        "collection": "warehouses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "default": ""
          },
          {
            "name": "address",
            "type": "string",
            "default": ""
          },
          {
            "name": "type",
            "type": "string",
            "default": "warehouse",
            "values": [
              "warehouse",
              "store",
              "transit"
            ]
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "totalSkus",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "WarehouseDirectory",
          "category": "interaction",
          "linkedEntity": "Warehouse",
          "emits": [
            {
              "event": "OPEN_WAREHOUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WarehouseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Warehouse]"
                }
              ]
            },
            {
              "event": "WarehouseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WarehouseLoaded",
                "name": "Warehouse loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Warehouse]"
                  }
                ]
              },
              {
                "key": "WarehouseLoadFailed",
                "name": "Warehouse load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_WAREHOUSE",
                "name": "Open Warehouse",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "success": "WarehouseLoaded",
                        "failure": "WarehouseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading locations…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WarehouseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "warehouse"
                            },
                            {
                              "type": "typography",
                              "content": "Locations",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Open",
                              "icon": "arrow-right",
                              "variant": "primary",
                              "event": "OPEN_WAREHOUSE"
                            }
                          ],
                          "type": "data-grid",
                          "cols": 1,
                          "gap": "sm",
                          "fields": [
                            {
                              "label": "Code",
                              "variant": "caption",
                              "name": "code"
                            },
                            {
                              "label": "Name",
                              "name": "name",
                              "variant": "caption"
                            },
                            {
                              "name": "type",
                              "label": "Type",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "totalSkus",
                              "label": "SKUs"
                            },
                            {
                              "variant": "badge",
                              "name": "isActive",
                              "label": "Active"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WarehouseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "OPEN_WAREHOUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Opened location"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "success": "WarehouseLoaded",
                        "failure": "WarehouseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Locations"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WarehousePage",
          "path": "/warehouses",
          "traits": [
            {
              "ref": "WarehouseDirectory"
            }
          ]
        }
      ]
    }
  ]
}
