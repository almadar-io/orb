{
  "name": "std-warehouse",
  "version": "1.0.0",
  "description": "std-warehouse — physical or logical storage location where stock lives. Used by inventory and retail to scope stock counts.",
  "orbitals": [
    {
      "name": "WarehouseOrbital",
      "entity": {
        "name": "Warehouse",
        "collection": "warehouses",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "code",
            "type": "string",
            "default": ""
          },
          {
            "name": "address",
            "type": "string",
            "default": ""
          },
          {
            "name": "type",
            "type": "string",
            "default": "warehouse",
            "values": [
              "warehouse",
              "store",
              "transit"
            ]
          },
          {
            "name": "isActive",
            "type": "boolean",
            "default": true
          },
          {
            "name": "totalSkus",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "WarehouseDirectory",
          "category": "interaction",
          "linkedEntity": "Warehouse",
          "emits": [
            {
              "event": "OPEN_WAREHOUSE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "WarehouseLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Warehouse]"
                }
              ]
            },
            {
              "event": "WarehouseLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WarehouseLoaded",
                "name": "Warehouse loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Warehouse]"
                  }
                ]
              },
              {
                "key": "WarehouseLoadFailed",
                "name": "Warehouse load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "OPEN_WAREHOUSE",
                "name": "Open Warehouse",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "success": "WarehouseLoaded",
                        "failure": "WarehouseLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading locations…",
                          "type": "typography",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WarehouseLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "warehouse"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Locations"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "tabs",
                          "items": [
                            {
                              "label": "Warehouses",
                              "id": "warehouses"
                            },
                            {
                              "id": "bins",
                              "label": "Bins"
                            },
                            {
                              "label": "Zones",
                              "id": "zones"
                            }
                          ],
                          "activeTab": "warehouses"
                        },
                        {
                          "type": "dashboard-grid",
                          "cells": [
                            {
                              "content": {
                                "icon": "package",
                                "value": 0,
                                "max": 10000,
                                "color": "text-emerald-400",
                                "type": "resource-counter",
                                "label": "Total SKUs",
                                "size": "md"
                              }
                            },
                            {
                              "content": {
                                "max": 500,
                                "color": "text-blue-400",
                                "label": "Pallets",
                                "type": "resource-counter",
                                "size": "md",
                                "value": 320,
                                "icon": "boxes"
                              }
                            },
                            {
                              "content": {
                                "effects": [
                                  {
                                    "label": "Below reorder",
                                    "icon": "alert-triangle"
                                  }
                                ],
                                "health": 4,
                                "maxHealth": 100,
                                "type": "enemy-plate",
                                "level": 1,
                                "name": "Low-stock alert: SKU-4421"
                              }
                            }
                          ]
                        },
                        {
                          "children": [
                            {
                              "selected": false,
                              "rarity": "common",
                              "quantity": 12,
                              "label": "Bin A-01",
                              "size": "md",
                              "icon": "package",
                              "type": "item-slot",
                              "empty": false
                            },
                            {
                              "label": "Bin A-02",
                              "type": "item-slot",
                              "rarity": "uncommon",
                              "size": "md",
                              "empty": false,
                              "selected": false,
                              "quantity": 8,
                              "icon": "package"
                            },
                            {
                              "type": "item-slot",
                              "icon": "package",
                              "rarity": "common",
                              "selected": false,
                              "size": "md",
                              "label": "Bin A-03",
                              "quantity": 0,
                              "empty": true
                            },
                            {
                              "icon": "package",
                              "label": "Bin A-04",
                              "size": "md",
                              "quantity": 3,
                              "rarity": "rare",
                              "empty": false,
                              "type": "item-slot",
                              "selected": true
                            }
                          ],
                          "type": "grid",
                          "cols": 4,
                          "gap": "sm"
                        },
                        {
                          "active": [
                            {
                              "label": "Fast Pick",
                              "id": "fastpick",
                              "icon": "zap"
                            },
                            {
                              "icon": "scan",
                              "id": "scan",
                              "label": "Auto Scan"
                            }
                          ],
                          "type": "powerup-slots",
                          "maxSlots": 4
                        },
                        {
                          "output": {
                            "id": "kit-01",
                            "label": "Kit 01",
                            "icon": "box",
                            "quantity": 1
                          },
                          "type": "crafting-recipe",
                          "inputs": [
                            {
                              "id": "sku-100",
                              "icon": "package",
                              "quantity": 2,
                              "label": "Part A"
                            },
                            {
                              "icon": "package",
                              "label": "Part B",
                              "id": "sku-200",
                              "quantity": 1
                            }
                          ],
                          "canCraft": true
                        },
                        {
                          "indent": 16,
                          "tree": [
                            {
                              "type": "folder",
                              "name": "Warehouse 01",
                              "children": [
                                {
                                  "type": "folder",
                                  "name": "Aisle A",
                                  "children": [
                                    {
                                      "path": "/wh01/a/01",
                                      "type": "file",
                                      "name": "Bin A-01"
                                    },
                                    {
                                      "path": "/wh01/a/02",
                                      "name": "Bin A-02",
                                      "type": "file"
                                    }
                                  ],
                                  "path": "/wh01/a"
                                },
                                {
                                  "type": "folder",
                                  "children": [
                                    {
                                      "name": "Bin B-01",
                                      "path": "/wh01/b/01",
                                      "type": "file"
                                    }
                                  ],
                                  "path": "/wh01/b",
                                  "name": "Aisle B"
                                }
                              ],
                              "path": "/wh01"
                            }
                          ],
                          "type": "file-tree"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "name": "code",
                              "label": "Code",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "name",
                              "label": "Name"
                            },
                            {
                              "label": "Type",
                              "name": "type",
                              "variant": "badge"
                            },
                            {
                              "label": "SKUs",
                              "name": "totalSkus",
                              "variant": "caption"
                            },
                            {
                              "name": "isActive",
                              "label": "Active",
                              "variant": "badge"
                            }
                          ],
                          "cols": 1,
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Open",
                              "variant": "primary",
                              "event": "OPEN_WAREHOUSE",
                              "icon": "arrow-right"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WarehouseLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "OPEN_WAREHOUSE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Opened location"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Warehouse",
                    {
                      "emit": {
                        "failure": "WarehouseLoadFailed",
                        "success": "WarehouseLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Locations"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WarehousePage",
          "path": "/warehouses",
          "traits": [
            {
              "ref": "WarehouseDirectory"
            }
          ]
        }
      ]
    }
  ]
}
