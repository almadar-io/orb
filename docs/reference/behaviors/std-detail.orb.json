{
  "name": "DetailRecordOrbital",
  "orbitals": [
    {
      "name": "DetailRecordOrbital",
      "entity": {
        "name": "DetailRecord",
        "collection": "detailrecords",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "DetailRecordBrowse",
          "category": "interaction",
          "linkedEntity": "DetailRecord",
          "listens": [
            {
              "event": "*.SAVE",
              "triggers": "SAVE"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "SAVE"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "max-w-5xl mx-auto w-full",
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "file-text",
                                  "size": "lg"
                                },
                                {
                                  "content": "DetailRecords",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack"
                            },
                            {
                              "children": [
                                {
                                  "event": "CREATE",
                                  "icon": "plus",
                                  "type": "button",
                                  "label": "Create DetailRecord",
                                  "variant": "primary"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack"
                            }
                          ],
                          "justify": "space-between",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "entity": "DetailRecord",
                          "emptyDescription": "Create your first detailrecord to get started.",
                          "emptyTitle": "No detailrecords yet",
                          "columns": [
                            {
                              "name": "name",
                              "icon": "file-text",
                              "variant": "h4",
                              "label": "Name"
                            },
                            {
                              "label": "Description",
                              "name": "description",
                              "variant": "badge",
                              "colorMap": {
                                "pending": "warning",
                                "disabled": "neutral",
                                "error": "destructive",
                                "cancelled": "destructive",
                                "active": "success",
                                "failed": "destructive",
                                "done": "success",
                                "inactive": "neutral",
                                "completed": "success",
                                "archived": "neutral",
                                "scheduled": "warning",
                                "draft": "warning"
                              }
                            },
                            {
                              "variant": "caption",
                              "label": "Status",
                              "name": "status"
                            }
                          ],
                          "itemActions": [
                            {
                              "size": "sm",
                              "event": "VIEW",
                              "label": "View",
                              "variant": "ghost"
                            }
                          ],
                          "emptyIcon": "inbox"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "DetailRecordCreate",
          "category": "interaction",
          "linkedEntity": "DetailRecord",
          "emits": [
            {
              "event": "SAVE"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "CREATE"
              },
              {
                "key": "CLOSE"
              },
              {
                "key": "SAVE"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle",
                              "size": "md"
                            },
                            {
                              "variant": "h3",
                              "content": "New DetailRecord",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "DetailRecord",
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE",
                          "fields": [
                            "name",
                            "description",
                            "status"
                          ],
                          "type": "form-section"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "DetailRecord",
                    "@payload.data"
                  ],
                  [
                    "fetch",
                    "DetailRecord"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "SAVE"
                  ],
                  [
                    "notify",
                    "DetailRecord created successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "DetailRecordView",
          "category": "interaction",
          "linkedEntity": "DetailRecord",
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "VIEW"
              },
              {
                "key": "CLOSE"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "VIEW",
                "effects": [
                  [
                    "fetch",
                    "DetailRecord",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "eye",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "@entity.name"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "content": "Name",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "content": "@entity.name",
                              "variant": "body"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "content": "Description",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.description"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md",
                          "children": [
                            {
                              "content": "Status",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@entity.status"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "caption",
                              "content": "Created At"
                            },
                            {
                              "variant": "body",
                              "content": "@entity.createdAt",
                              "type": "typography"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "justify": "end",
                          "children": [
                            {
                              "variant": "ghost",
                              "type": "button",
                              "event": "CLOSE",
                              "label": "Close"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Detailrecords",
          "path": "/detailrecords",
          "traits": [
            {
              "ref": "DetailRecordBrowse"
            },
            {
              "ref": "DetailRecordCreate"
            },
            {
              "ref": "DetailRecordView"
            }
          ]
        }
      ]
    }
  ]
}
