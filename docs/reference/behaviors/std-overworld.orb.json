{
  "name": "std-overworld",
  "version": "1.0.0",
  "description": "std-overworld as a Function",
  "orbitals": [
    {
      "name": "WorldRegionOrbital",
      "entity": {
        "name": "WorldRegion",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WorldRegionNavigation",
          "category": "interaction",
          "linkedEntity": "WorldRegion",
          "emits": [
            {
              "event": "WorldRegionLoaded",
              "description": "Fired when WorldRegion finishes loading; payload.data holds the regions",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[WorldRegion]"
                }
              ]
            },
            {
              "event": "WorldRegionLoadFailed",
              "description": "Fired when WorldRegion fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "exploring"
              },
              {
                "name": "transitioning"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WorldRegionLoaded",
                "name": "WorldRegion loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[WorldRegion]"
                  }
                ]
              },
              {
                "key": "WorldRegionLoadFailed",
                "name": "WorldRegion load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "TRAVEL",
                "name": "Travel",
                "payloadSchema": [
                  {
                    "name": "zoneId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARRIVE",
                "name": "Arrive",
                "payloadSchema": [
                  {
                    "name": "zoneId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorldRegion",
                    {
                      "emit": {
                        "failure": "WorldRegionLoadFailed",
                        "success": "WorldRegionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading map…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "exploring",
                "event": "WorldRegionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "justify": "between",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "name": "map",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "type": "typography",
                                  "content": "World Map"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md"
                            },
                            {
                              "status": "online",
                              "type": "status-dot",
                              "pulse": false,
                              "label": "Exploring"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "map-view",
                          "height": "200px",
                          "zoom": 10,
                          "markers": []
                        },
                        {
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "direction": "vertical",
                              "children": [
                                {
                                  "justify": "between",
                                  "type": "stack",
                                  "align": "center",
                                  "direction": "horizontal",
                                  "children": [
                                    {
                                      "align": "center",
                                      "direction": "horizontal",
                                      "gap": "sm",
                                      "type": "stack",
                                      "children": [
                                        {
                                          "name": "map-pin",
                                          "type": "icon"
                                        },
                                        {
                                          "variant": "h4",
                                          "content": "@item.name",
                                          "type": "typography"
                                        }
                                      ]
                                    },
                                    {
                                      "label": "@item.description",
                                      "type": "badge"
                                    }
                                  ]
                                },
                                {
                                  "content": "@item.status",
                                  "type": "typography",
                                  "variant": "caption"
                                }
                              ],
                              "gap": "sm"
                            }
                          ],
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "TRAVEL",
                              "label": "Travel"
                            }
                          ],
                          "fields": []
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WorldRegionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "content": "Failed to load map",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "content": "@payload.error",
                          "variant": "body",
                          "type": "typography",
                          "color": "muted"
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "action": "INIT",
                          "label": "Retry",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "exploring",
                "to": "transitioning",
                "event": "TRAVEL",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "name": "loader",
                              "type": "icon"
                            },
                            {
                              "content": "Traveling...",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": "Traveling to the destination region."
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "transitioning",
                "to": "loading",
                "event": "ARRIVE",
                "effects": [
                  [
                    "fetch",
                    "WorldRegion",
                    {
                      "emit": {
                        "success": "WorldRegionLoaded",
                        "failure": "WorldRegionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WorldRegion",
                    {
                      "emit": {
                        "failure": "WorldRegionLoadFailed",
                        "success": "WorldRegionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WorldRegionPage",
          "path": "/worldregions",
          "traits": [
            {
              "ref": "WorldRegionNavigation"
            }
          ]
        }
      ]
    }
  ]
}
