{
  "name": "std-list",
  "version": "1.0.0",
  "description": "std-list as a Function",
  "orbitals": [
    {
      "name": "ListItemOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        }
      ],
      "entity": {
        "name": "ListItem",
        "collection": "listitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "ListItemBrowse",
          "category": "interaction",
          "linkedEntity": "ListItem",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "EDIT",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.name",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.createdAt",
                  "type": "string"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ListItemLoaded",
              "description": "Fired when the ListItem collection finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ListItem]"
                }
              ]
            },
            {
              "event": "ListItemLoadFailed",
              "description": "Fired when the ListItem collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "ITEM_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemPersistor"
              }
            },
            {
              "event": "ITEM_UPDATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemPersistor"
              }
            },
            {
              "event": "ITEM_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ListItemLoaded",
                "name": "ListItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ListItem]"
                  }
                ]
              },
              {
                "key": "ListItemLoadFailed",
                "name": "ListItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "EDIT",
                "name": "Edit"
              },
              {
                "key": "DELETE",
                "name": "Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "failure": "ListItemLoadFailed",
                        "success": "ListItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading list…"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "ListItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "max-w-5xl mx-auto w-full",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "list"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "ListItems"
                                }
                              ],
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "md"
                            },
                            {
                              "action": "CREATE",
                              "icon": "plus",
                              "variant": "primary",
                              "label": "Create",
                              "type": "button"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "label": "Edit",
                              "variant": "ghost",
                              "event": "EDIT"
                            },
                            {
                              "label": "Delete",
                              "variant": "danger",
                              "event": "DELETE"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "icon": "list",
                              "label": "Name",
                              "name": "name",
                              "variant": "h4"
                            },
                            {
                              "name": "description",
                              "variant": "caption",
                              "label": "Description"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ListItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "content": "Failed to load list",
                          "type": "typography",
                          "variant": "h3"
                        },
                        {
                          "variant": "body",
                          "content": "@payload.error",
                          "color": "muted",
                          "type": "typography"
                        },
                        {
                          "variant": "primary",
                          "label": "Retry",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "action": "INIT"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "success": "ListItemLoaded",
                        "failure": "ListItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "failure": "ListItemLoadFailed",
                        "success": "ListItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "ListItemCreate",
          "category": "interaction",
          "linkedEntity": "ListItem",
          "emits": [
            {
              "event": "LIST_ITEM_CREATED",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE"
            },
            {
              "event": "ModalRecordLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModalRecordLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ModalRecord]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListItemBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "ModalRecord"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "LIST_ITEM_CREATED",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ModalRecordLoadFailed",
                "name": "ModalRecord load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ModalRecordLoaded",
                "name": "ModalRecord loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ModalRecord]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "failure": "ModalRecordLoadFailed",
                        "success": "ModalRecordLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "guard": [
                  "or",
                  [
                    "=",
                    "create",
                    "create"
                  ],
                  "@payload.row"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle"
                            },
                            {
                              "variant": "h3",
                              "content": "Create ListItem",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "type": "form-section",
                          "entity": "@payload.row",
                          "submitEvent": "LIST_ITEM_CREATED",
                          "fields": [
                            "name",
                            "description",
                            "status"
                          ],
                          "cancelEvent": "CLOSE"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "LIST_ITEM_CREATED",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "icon": {
              "type": "string",
              "default": "layout-panel-top"
            },
            "mode": {
              "type": "string",
              "default": "create"
            },
            "fields": {
              "type": "[string]",
              "default": []
            },
            "title": {
              "type": "string",
              "default": "Details"
            }
          },
          "scope": "instance"
        },
        {
          "name": "ListItemEdit",
          "category": "interaction",
          "linkedEntity": "ListItem",
          "emits": [
            {
              "event": "LIST_ITEM_UPDATED",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE"
            },
            {
              "event": "ModalRecordLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModalRecordLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ModalRecord]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "EDIT",
              "triggers": "EDIT",
              "source": {
                "kind": "trait",
                "trait": "ListItemBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EDIT",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "ModalRecord"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "LIST_ITEM_UPDATED",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ModalRecordLoadFailed",
                "name": "ModalRecord load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ModalRecordLoaded",
                "name": "ModalRecord loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ModalRecord]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "failure": "ModalRecordLoadFailed",
                        "success": "ModalRecordLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "EDIT",
                "guard": [
                  "or",
                  [
                    "=",
                    "edit",
                    "create"
                  ],
                  "@payload.row"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "edit"
                            },
                            {
                              "variant": "h3",
                              "content": "Edit ListItem",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "edit",
                          "type": "form-section",
                          "entity": "@payload.row",
                          "submitEvent": "LIST_ITEM_UPDATED",
                          "fields": [
                            "name",
                            "description",
                            "status"
                          ],
                          "cancelEvent": "CLOSE"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "LIST_ITEM_UPDATED",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "icon": {
              "type": "string",
              "default": "layout-panel-top"
            },
            "mode": {
              "type": "string",
              "default": "create"
            },
            "fields": {
              "type": "[string]",
              "default": []
            },
            "title": {
              "type": "string",
              "default": "Details"
            }
          },
          "scope": "instance"
        },
        {
          "name": "ListItemDelete",
          "category": "interaction",
          "linkedEntity": "ListItem",
          "emits": [
            {
              "event": "CONFIRM_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL"
            },
            {
              "event": "ConfirmActionLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConfirmActionLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ConfirmAction]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListItemBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ConfirmAction"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ConfirmActionLoadFailed",
                "name": "ConfirmAction load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConfirmActionLoaded",
                "name": "ConfirmAction loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ConfirmAction]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ListItem",
                    {
                      "emit": {
                        "failure": "ConfirmActionLoadFailed",
                        "success": "ConfirmActionLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "guard": "@payload.row",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "content": "Delete ListItem",
                              "type": "typography",
                              "variant": "h3"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "This action cannot be undone.",
                          "variant": "error",
                          "type": "alert"
                        },
                        {
                          "variant": "h4",
                          "content": "@entity.name",
                          "type": "typography"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "color": "muted",
                          "content": "@entity.pendingId"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "end",
                          "children": [
                            {
                              "action": "CANCEL",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Cancel"
                            },
                            {
                              "type": "button",
                              "variant": "danger",
                              "label": "Delete",
                              "icon": "check",
                              "actionPayload": {
                                "id": "@payload.id"
                              },
                              "action": "CONFIRM_DELETE"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "icon": {
              "type": "string",
              "default": "alert-triangle"
            },
            "title": {
              "type": "string",
              "default": "Confirm Action"
            },
            "confirmLabel": {
              "type": "string",
              "default": "Confirm"
            },
            "alertMessage": {
              "type": "string",
              "default": "Are you sure?"
            }
          },
          "scope": "instance"
        },
        {
          "name": "ListItemPersistor",
          "category": "lifecycle",
          "linkedEntity": "ListItem",
          "emits": [
            {
              "event": "ITEM_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ITEM_UPDATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ITEM_DELETED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "LIST_ITEM_CREATED",
              "triggers": "DO_CREATE",
              "source": {
                "kind": "trait",
                "trait": "ListItemCreate"
              }
            },
            {
              "event": "LIST_ITEM_UPDATED",
              "triggers": "DO_UPDATE",
              "source": {
                "kind": "trait",
                "trait": "ListItemEdit"
              }
            },
            {
              "event": "CONFIRM_DELETE",
              "triggers": "DO_DELETE",
              "source": {
                "kind": "trait",
                "trait": "ListItemDelete"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_CREATE",
                "name": "Do Create",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "ListItem",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_UPDATE",
                "name": "Do Update",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "ListItem",
                    "required": true
                  }
                ]
              },
              {
                "key": "DO_DELETE",
                "name": "Do Delete",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEM_CREATED",
                "name": "Item Created"
              },
              {
                "key": "ITEM_UPDATED",
                "name": "Item Updated"
              },
              {
                "key": "ITEM_DELETED",
                "name": "Item Deleted"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_CREATE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "ListItem",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ITEM_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_UPDATE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "ListItem",
                    "@payload.data",
                    {
                      "emit": {
                        "success": "ITEM_UPDATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "DO_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "ListItem",
                    "@payload.id",
                    {
                      "emit": {
                        "success": "ITEM_DELETED"
                      }
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ListItemPage",
          "path": "/listitems",
          "traits": [
            {
              "ref": "ListItemBrowse"
            },
            {
              "ref": "ListItemCreate"
            },
            {
              "ref": "ListItemEdit"
            },
            {
              "ref": "ListItemDelete"
            },
            {
              "ref": "ListItemPersistor"
            }
          ]
        }
      ]
    }
  ]
}
