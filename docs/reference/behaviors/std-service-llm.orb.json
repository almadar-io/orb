{
  "name": "std-service-llm",
  "version": "2.0.0",
  "description": "std-service-llm — LLM completion service. Bind via `uses Llm from \"std/behaviors/std-service-llm\"` and configure `provider` / `model` / `prompt` / `temperature` / `maxTokens` at the call site. Pass `uiTrait: \"@trait.YourLlmForm\"` to inject your own prompt form; leave unset to render the atom's default form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceLlmOrbital",
      "entity": {
        "name": "ServiceLlm",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "provider",
            "type": "string",
            "default": "openai"
          },
          {
            "name": "model",
            "type": "string",
            "default": "gpt-4"
          },
          {
            "name": "prompt",
            "type": "string",
            "default": ""
          },
          {
            "name": "temperature",
            "type": "number",
            "default": 0.7
          },
          {
            "name": "maxTokens",
            "type": "number",
            "default": 2048
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "llmStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceLlmDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "COMPLETE",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "stretch",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "brain"
                            },
                            {
                              "type": "typography",
                              "content": "LLM Completion",
                              "variant": "h2"
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "options": [
                                {
                                  "value": "openai",
                                  "label": "OpenAI"
                                },
                                {
                                  "value": "anthropic",
                                  "label": "Anthropic"
                                },
                                {
                                  "label": "Google",
                                  "value": "google"
                                }
                              ],
                              "type": "select"
                            },
                            {
                              "options": [
                                {
                                  "label": "GPT-4",
                                  "value": "gpt-4"
                                },
                                {
                                  "label": "GPT-4 Turbo",
                                  "value": "gpt-4-turbo"
                                },
                                {
                                  "value": "claude-3-5-sonnet",
                                  "label": "Claude 3.5 Sonnet"
                                },
                                {
                                  "label": "Gemini Pro",
                                  "value": "gemini-pro"
                                }
                              ],
                              "type": "select"
                            },
                            {
                              "placeholder": "Enter your prompt...",
                              "type": "textarea"
                            },
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "placeholder": "Temperature (0.0 - 2.0)",
                                  "type": "input",
                                  "inputType": "number"
                                },
                                {
                                  "placeholder": "Max tokens",
                                  "type": "input",
                                  "inputType": "number"
                                }
                              ]
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "label": "Complete",
                          "type": "button",
                          "action": "COMPLETE",
                          "variant": "primary",
                          "icon": "sparkles"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceLlmLlm",
          "category": "interaction",
          "linkedEntity": "ServiceLlm",
          "emits": [
            {
              "event": "ServiceLlmLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceLlmLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "LlmCompleted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "content",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceLlmLlmFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "COMPLETE",
              "triggers": "COMPLETE",
              "source": {
                "kind": "trait",
                "trait": "ServiceLlmDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "processing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete"
              },
              {
                "key": "ServiceLlmLoaded",
                "name": "ServiceLlm loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceLlmLoadFailed",
                "name": "ServiceLlm load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LlmCompleted",
                "name": "Llm completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "content",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceLlmLlmFailed",
                "name": "ServiceLlm llm failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.provider",
                    "openai"
                  ],
                  [
                    "set",
                    "@entity.model",
                    "gpt-4"
                  ],
                  [
                    "set",
                    "@entity.prompt",
                    ""
                  ],
                  [
                    "set",
                    "@entity.temperature",
                    0.7
                  ],
                  [
                    "set",
                    "@entity.maxTokens",
                    2048
                  ],
                  [
                    "fetch",
                    "ServiceLlm",
                    {
                      "emit": {
                        "failure": "ServiceLlmLoadFailed",
                        "success": "ServiceLlmLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        "@trait.ServiceLlmDefaultForm"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "COMPLETE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Generating...",
                      "message": "Calling LLM provider.",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "generate",
                    {
                      "temperature": 0.7,
                      "model": "gpt-4",
                      "userPrompt": "",
                      "maxTokens": 2048
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "LlmCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceLlmLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceLlmLoadFailed"
              },
              {
                "from": "processing",
                "to": "complete",
                "event": "LlmCompleted",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "type": "alert",
                          "variant": "success",
                          "message": "LLM completion ready"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "@entity.result"
                        },
                        {
                          "label": "Start Over",
                          "type": "button",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "action": "RESET"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "error"
                  ],
                  [
                    "emit",
                    "ServiceLlmLlmFailed",
                    {
                      "error": "@entity.error",
                      "code": "llm_complete_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "message": "@entity.error",
                      "title": "LLM Failed",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        "@trait.ServiceLlmDefaultForm"
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "complete",
                "event": "LlmCompleted"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceLlmLlmFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceLlmDefaultForm"
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        "@trait.ServiceLlmDefaultForm"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "maxTokens": {
              "type": "number",
              "default": 2048
            },
            "temperature": {
              "type": "number",
              "default": 0.7
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceLlmDefaultForm"
            },
            "model": {
              "type": "string",
              "default": "gpt-4"
            },
            "provider": {
              "type": "string",
              "default": "openai"
            },
            "prompt": {
              "type": "string",
              "default": ""
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceLlmPage",
          "path": "/servicellms",
          "traits": [
            {
              "ref": "ServiceLlmLlm"
            }
          ]
        }
      ]
    }
  ]
}
