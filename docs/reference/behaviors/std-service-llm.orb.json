{
  "name": "std-service-llm",
  "version": "1.0.0",
  "description": "std-service-llm as a Function",
  "orbitals": [
    {
      "name": "ServiceLlmOrbital",
      "entity": {
        "name": "ServiceLlm",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "inputText",
            "type": "string",
            "default": ""
          },
          {
            "name": "action",
            "type": "string",
            "default": "generate"
          },
          {
            "name": "result",
            "type": "string",
            "default": ""
          },
          {
            "name": "llmStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceLlmLlm",
          "category": "interaction",
          "linkedEntity": "ServiceLlm",
          "emits": [
            {
              "event": "ServiceLlmLoaded",
              "description": "Fired when ServiceLlm finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "inputText",
                  "type": "string"
                },
                {
                  "name": "action",
                  "type": "string"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "llmStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceLlmLoadFailed",
              "description": "Fired when ServiceLlm fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceLlmLlmCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceLlmLlmFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "processing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GENERATE",
                "name": "Generate"
              },
              {
                "key": "CLASSIFY",
                "name": "Classify"
              },
              {
                "key": "SUMMARIZE",
                "name": "Summarize"
              },
              {
                "key": "COMPLETE",
                "name": "Complete",
                "payloadSchema": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "RETRY",
                "name": "Retry"
              },
              {
                "key": "ServiceLlmLoaded",
                "name": "ServiceLlm loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "inputText",
                    "type": "string"
                  },
                  {
                    "name": "action",
                    "type": "string"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "llmStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceLlmLoadFailed",
                "name": "ServiceLlm load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceLlmLlmCompleted",
                "name": "ServiceLlm llm completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceLlmLlmFailed",
                "name": "ServiceLlm llm failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.inputText",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceLlm",
                    {
                      "emit": {
                        "success": "ServiceLlmLoaded",
                        "failure": "ServiceLlmLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "brain"
                            },
                            {
                              "type": "typography",
                              "content": "ServiceLlm LLM",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Enter text for LLM processing..."
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "variant": "primary",
                              "action": "GENERATE",
                              "label": "Generate",
                              "icon": "sparkles",
                              "type": "button"
                            },
                            {
                              "label": "Classify",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "tag",
                              "action": "CLASSIFY"
                            },
                            {
                              "action": "SUMMARIZE",
                              "label": "Summarize",
                              "type": "button",
                              "variant": "secondary",
                              "icon": "align-left"
                            }
                          ],
                          "justify": "center",
                          "direction": "horizontal"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "align": "stretch"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "GENERATE",
                "effects": [
                  [
                    "set",
                    "@entity.action",
                    "generate"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Running servicellm LLM task...",
                      "title": "Processing..."
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "generate",
                    {
                      "userPrompt": "@entity.inputText"
                    },
                    {
                      "emit": {
                        "success": "ServiceLlmLlmCompleted",
                        "failure": "ServiceLlmLlmFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "CLASSIFY",
                "effects": [
                  [
                    "set",
                    "@entity.action",
                    "classify"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Processing...",
                      "message": "Running servicellm LLM task..."
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "classify",
                    {
                      "text": "@entity.inputText",
                      "categories": [
                        "positive",
                        "negative",
                        "neutral"
                      ]
                    },
                    {
                      "emit": {
                        "success": "ServiceLlmLlmCompleted",
                        "failure": "ServiceLlmLlmFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "processing",
                "event": "SUMMARIZE",
                "effects": [
                  [
                    "set",
                    "@entity.action",
                    "summarize"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Processing...",
                      "message": "Running servicellm LLM task..."
                    }
                  ],
                  [
                    "call-service",
                    "llm",
                    "summarize",
                    {
                      "text": "@entity.inputText"
                    },
                    {
                      "emit": {
                        "failure": "ServiceLlmLlmFailed",
                        "success": "ServiceLlmLlmCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.content"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "message": "LLM task complete",
                          "variant": "success",
                          "type": "alert"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.result",
                          "variant": "body"
                        },
                        {
                          "variant": "ghost",
                          "action": "RESET",
                          "label": "Start Over",
                          "icon": "rotate-ccw",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.llmStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "error-state",
                          "onRetry": "RETRY",
                          "message": "@entity.error",
                          "title": "LLM Failed"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "RETRY",
                              "type": "button",
                              "variant": "primary",
                              "label": "Retry",
                              "icon": "refresh-cw"
                            },
                            {
                              "action": "RESET",
                              "type": "button",
                              "icon": "rotate-ccw",
                              "label": "Reset",
                              "variant": "ghost"
                            }
                          ],
                          "gap": "sm",
                          "justify": "center"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "brain",
                              "type": "icon"
                            },
                            {
                              "content": "ServiceLlm LLM",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Enter text for LLM processing..."
                        },
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "children": [
                            {
                              "variant": "primary",
                              "type": "button",
                              "label": "Generate",
                              "action": "GENERATE",
                              "icon": "sparkles"
                            },
                            {
                              "icon": "tag",
                              "type": "button",
                              "action": "CLASSIFY",
                              "label": "Classify",
                              "variant": "secondary"
                            },
                            {
                              "icon": "align-left",
                              "variant": "secondary",
                              "type": "button",
                              "label": "Summarize",
                              "action": "SUMMARIZE"
                            }
                          ],
                          "justify": "center"
                        }
                      ],
                      "align": "stretch",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "stretch",
                      "children": [
                        {
                          "gap": "md",
                          "children": [
                            {
                              "type": "icon",
                              "name": "brain"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "ServiceLlm LLM"
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Enter text for LLM processing..."
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "GENERATE",
                              "label": "Generate",
                              "type": "button",
                              "variant": "primary",
                              "icon": "sparkles"
                            },
                            {
                              "type": "button",
                              "label": "Classify",
                              "variant": "secondary",
                              "action": "CLASSIFY",
                              "icon": "tag"
                            },
                            {
                              "variant": "secondary",
                              "type": "button",
                              "label": "Summarize",
                              "action": "SUMMARIZE",
                              "icon": "align-left"
                            }
                          ],
                          "justify": "center"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.llmStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "align": "stretch",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "brain",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "ServiceLlm LLM"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "textarea",
                          "placeholder": "Enter text for LLM processing..."
                        },
                        {
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "Generate",
                              "action": "GENERATE",
                              "variant": "primary",
                              "type": "button",
                              "icon": "sparkles"
                            },
                            {
                              "type": "button",
                              "variant": "secondary",
                              "icon": "tag",
                              "label": "Classify",
                              "action": "CLASSIFY"
                            },
                            {
                              "variant": "secondary",
                              "icon": "align-left",
                              "type": "button",
                              "action": "SUMMARIZE",
                              "label": "Summarize"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceLlmPage",
          "path": "/servicellms",
          "traits": [
            {
              "ref": "ServiceLlmLlm"
            }
          ]
        }
      ]
    }
  ]
}
