{
  "name": "std-ledger-entry",
  "version": "1.0.0",
  "description": "std-ledger-entry — general-ledger journal entry atom. Owns a LedgerEntry entity (double-entry debit/credit) and a single trait that loads journal entries into a data-grid with reconcile and reverse row actions.",
  "orbitals": [
    {
      "name": "LedgerEntryOrbital",
      "entity": {
        "name": "LedgerEntry",
        "collection": "ledgerentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "accountId",
            "type": "string",
            "required": true
          },
          {
            "name": "accountName",
            "type": "string",
            "default": ""
          },
          {
            "name": "entryDate",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "debit",
            "type": "number",
            "default": 0
          },
          {
            "name": "credit",
            "type": "number",
            "default": 0
          },
          {
            "name": "referenceType",
            "type": "string",
            "default": "manual",
            "values": [
              "manual",
              "invoice",
              "bill",
              "payment",
              "adjustment"
            ]
          },
          {
            "name": "referenceId",
            "type": "string",
            "default": ""
          },
          {
            "name": "isReconciled",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "LedgerEntryJournal",
          "category": "interaction",
          "linkedEntity": "LedgerEntry",
          "emits": [
            {
              "event": "RECONCILE_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REVERSE_ENTRY",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "LedgerEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[LedgerEntry]"
                }
              ]
            },
            {
              "event": "LedgerEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "LedgerEntryLoaded",
                "name": "LedgerEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[LedgerEntry]"
                  }
                ]
              },
              {
                "key": "LedgerEntryLoadFailed",
                "name": "LedgerEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RECONCILE_ENTRY",
                "name": "Reconcile Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REVERSE_ENTRY",
                "name": "Reverse Entry",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "success": "LedgerEntryLoaded",
                        "failure": "LedgerEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading journal entries…",
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "LedgerEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "book-open"
                            },
                            {
                              "type": "typography",
                              "content": "Journal Entries",
                              "variant": "h3"
                            },
                            {
                              "position": "right",
                              "content": "Running ledger balance computed from posted debits minus credits.",
                              "children": [
                                {
                                  "name": "info",
                                  "type": "icon"
                                }
                              ],
                              "type": "tooltip"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "tabs",
                          "activeTab": "journal",
                          "items": [
                            {
                              "label": "Journal",
                              "id": "journal"
                            },
                            {
                              "id": "ledger",
                              "label": "Ledger"
                            },
                            {
                              "label": "Reports",
                              "id": "reports"
                            }
                          ]
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "animated": true,
                              "value": 12480,
                              "label": "Net Balance",
                              "type": "score-display",
                              "size": "lg"
                            },
                            {
                              "type": "svg-grid",
                              "cols": 8,
                              "x": 0,
                              "spacing": 24,
                              "y": 0,
                              "opacity": 0.35,
                              "color": "muted",
                              "nodeRadius": 2,
                              "rows": 4
                            },
                            {
                              "strokeWidth": 2,
                              "type": "svg-flow",
                              "color": "primary",
                              "animated": true,
                              "points": [
                                {
                                  "x": 10,
                                  "y": 30
                                },
                                {
                                  "y": 30,
                                  "x": 80
                                },
                                {
                                  "x": 160,
                                  "y": 30
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "entity-cards",
                          "fields": [
                            {
                              "name": "entryDate",
                              "label": "Date",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "accountName",
                              "label": "Account"
                            },
                            {
                              "variant": "caption",
                              "label": "Debit",
                              "name": "debit"
                            },
                            {
                              "label": "Credit",
                              "name": "credit",
                              "variant": "caption"
                            }
                          ],
                          "entity": "@payload.data",
                          "minCardWidth": 240,
                          "maxCols": 3,
                          "gap": "md"
                        },
                        {
                          "type": "entity-list",
                          "entity": "@payload.data",
                          "variant": "card",
                          "fields": [
                            {
                              "name": "entryDate",
                              "label": "Date"
                            },
                            {
                              "name": "accountName",
                              "label": "Account"
                            },
                            {
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "name": "debit",
                              "label": "Debit"
                            },
                            {
                              "label": "Credit",
                              "name": "credit"
                            }
                          ],
                          "showDividers": true
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "event": "RECONCILE_ENTRY",
                              "variant": "primary",
                              "label": "Reconcile"
                            },
                            {
                              "event": "REVERSE_ENTRY",
                              "variant": "danger",
                              "label": "Reverse"
                            }
                          ],
                          "type": "data-grid",
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "entryDate",
                              "label": "Date"
                            },
                            {
                              "variant": "caption",
                              "label": "Account",
                              "name": "accountName"
                            },
                            {
                              "variant": "caption",
                              "name": "description",
                              "label": "Description"
                            },
                            {
                              "variant": "caption",
                              "label": "Debit",
                              "name": "debit"
                            },
                            {
                              "label": "Credit",
                              "name": "credit",
                              "variant": "caption"
                            },
                            {
                              "name": "isReconciled",
                              "variant": "badge",
                              "label": "Reconciled"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "LedgerEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "type": "alert",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "RECONCILE_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Entry reconciled",
                    "success"
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REVERSE_ENTRY",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "notify",
                    "Entry reversed",
                    "info"
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "LedgerEntry",
                    {
                      "emit": {
                        "success": "LedgerEntryLoaded",
                        "failure": "LedgerEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Journal Entries"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "LedgerEntryPage",
          "path": "/journal",
          "traits": [
            {
              "ref": "LedgerEntryJournal"
            }
          ]
        }
      ]
    }
  ]
}
