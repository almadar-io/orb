                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "menuItems": [
                            {
                              "event": "START",
                              "label": "Start Game",
                              "variant": "primary"
                            }
                          ],
                          "type": "game-menu",
                          "title": "Arcade",
                          "subtitle": "Main Menu"
                        }
                      ],
                      "type": "game-shell",
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              }
            ]
          }
        }
