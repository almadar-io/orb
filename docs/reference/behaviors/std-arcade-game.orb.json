                              "label": "Score",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ]
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ],
                              "label": "Level"
                            }
                          ],
                          "menuItems": [
                            {
                              "variant": "primary",
                              "event": "RESTART",
                              "label": "Play Again"
                            },
                            {
                              "label": "Main Menu",
                              "variant": "secondary",
                              "event": "RESTART"
                            }
                          ],
                          "type": "game-over-screen"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "paused",
                "event": "NAVIGATE"
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "RESUME",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "stats": [
                            {
                              "label": "Score",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ]
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ],
                              "label": "Level"
                            }
                          ],
                          "type": "game-hud"
                        }
                      ],
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "playing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "game-hud",
                          "stats": [
                            {
                              "label": "Score",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ]
                            },
                            {
                              "label": "Level",
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ]
                            }
                          ]
                        }
                      ],
                      "type": "game-shell",
                      "showTopBar": true,
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              },
              {
                "from": "paused",
                "to": "menu",
