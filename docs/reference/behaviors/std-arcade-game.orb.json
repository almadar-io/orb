                                  "array/first",
                                  "@entity"
                                ],
                                "score"
                              ]
                            },
                            {
                              "value": [
                                "object/get",
                                [
                                  "array/first",
                                  "@entity"
                                ],
                                "level"
                              ],
                              "label": "Level"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "menu",
                "to": "menu",
                "event": "NAVIGATE"
              },
              {
                "from": "playing",
                "to": "paused",
                "event": "PAUSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "game-menu",
                      "menuItems": [
                        {
                          "label": "Resume",
