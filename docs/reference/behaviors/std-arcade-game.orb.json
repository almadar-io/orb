    {
      "name": "ArcadeScoreOrbital",
      "entity": {
        "name": "ArcadeScore",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "playerName",
            "type": "string",
            "required": true
          },
          {
            "name": "score",
            "type": "number",
            "required": true
          },
          {
            "name": "level",
            "type": "number"
          },
          {
            "name": "completedAt",
            "type": "string"
          },
          {
            "name": "highScore",
            "type": "number"
          },
          {
            "name": "combo",
            "type": "number"
          },
          {
            "name": "multiplier",
            "type": "number"
          }
        ]
      },
      "traits": [
        {
          "name": "ArcadeScoreScoreBoard",
          "category": "interaction",
          "linkedEntity": "ArcadeScore",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "ADD_SCORE"
              },
              {
                "key": "COMBO"
              },
              {
                "key": "RESET"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ArcadeScore"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "combo": "@entity.combo",
                          "multiplier": "@entity.multiplier",
                          "score": "@entity.score",
                          "highScore": "@entity.highScore",
                          "level": "@entity.level",
                          "type": "score-board"
                        }
                      ],
                      "type": "game-shell"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ADD_SCORE",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    [
                      "+",
                      "@entity.score",
                      "@payload.points"
                    ]
                  ],
                  [
                    "set",
                    "@entity.combo",
                    [
                      "+",
                      "@entity.combo",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "appName": "Arcade Game",
                      "showTopBar": true,
                      "type": "game-shell",
                      "children": [
                        {
                          "combo": "@entity.combo",
                          "multiplier": "@entity.multiplier",
                          "level": "@entity.level",
                          "type": "score-board",
                          "score": "@entity.score",
                          "highScore": "@entity.highScore"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "COMBO",
                "effects": [
                  [
                    "set",
                    "@entity.multiplier",
                    "@payload.multiplier"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "showTopBar": true,
                      "children": [
                        {
                          "highScore": "@entity.highScore",
                          "score": "@entity.score",
                          "type": "score-board",
                          "multiplier": "@entity.multiplier",
                          "combo": "@entity.combo",
                          "level": "@entity.level"
                        }
                      ],
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.score",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.combo",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.multiplier",
                    1.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showTopBar": true,
                      "children": [
                        {
                          "level": "@entity.level",
                          "multiplier": "@entity.multiplier",
                          "combo": "@entity.combo",
                          "type": "score-board",
                          "score": "@entity.score",
                          "highScore": "@entity.highScore"
                        }
                      ],
                      "type": "game-shell",
                      "appName": "Arcade Game"
                    }
                  ]
                ]
              }
            ]
          }
        }
