                  [
                    "render-ui",
                    "main",
                    {
                      "type": "game-shell",
                      "appName": "Arcade Game",
                      "children": [
                        {
                          "title": "Arcade",
                          "type": "game-menu",
                          "menuItems": [
                            {
                              "variant": "primary",
                              "label": "Start Game",
                              "event": "START"
                            }
                          ],
                          "subtitle": "Main Menu"
