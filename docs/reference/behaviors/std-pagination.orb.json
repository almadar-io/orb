{
  "name": "std-pagination",
  "version": "1.0.0",
  "description": "std-pagination — single primitive: pagination control. PAGE accepts the Pagination component's `{page}` emit; ITEMS_LOADED accepts an upstream `{data:[object]}` payload and derives totalPages = ceil(len/pageSize). Molecules wire `BrowseItemLoaded -> ITEMS_LOADED` to keep it in lockstep with the data hub.",
  "orbitals": [
    {
      "name": "PagedItemOrbital",
      "entity": {
        "name": "PagedItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "currentPage",
            "type": "number",
            "default": 1
          },
          {
            "name": "totalPages",
            "type": "number",
            "default": 1
          }
        ]
      },
      "traits": [
        {
          "name": "PagedItemPagination",
          "category": "interaction",
          "linkedEntity": "PagedItem",
          "emits": [
            {
              "event": "PAGE",
              "payloadSchema": [
                {
                  "name": "page",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "PagedItemLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[PagedItem]"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PagedItemLoaded",
                "name": "PagedItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[PagedItem]"
                  }
                ]
              },
              {
                "key": "PAGE",
                "name": "Page",
                "payloadSchema": [
                  {
                    "name": "page",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "ITEMS_LOADED",
                "name": "Items Loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[object]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.currentPage",
                    1
                  ],
                  [
                    "set",
                    "@entity.totalPages",
                    1
                  ],
                  [
                    "fetch",
                    "PagedItem",
                    {
                      "emit": {
                        "success": "PagedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "totalPages": "@entity.totalPages",
                      "type": "pagination",
                      "showPageSize": false,
                      "currentPage": "@entity.currentPage",
                      "pageChangeEvent": "PAGE"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PagedItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pagination",
                      "currentPage": "@entity.currentPage",
                      "showPageSize": false,
                      "totalPages": "@entity.totalPages",
                      "pageChangeEvent": "PAGE"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "PAGE",
                "effects": [
                  [
                    "set",
                    "@entity.currentPage",
                    "@payload.page"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "showPageSize": false,
                      "currentPage": "@entity.currentPage",
                      "type": "pagination",
                      "pageChangeEvent": "PAGE",
                      "totalPages": "@entity.totalPages"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ITEMS_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.totalPages",
                    [
                      "math/ceil",
                      [
                        "/",
                        "@payload.totalCount",
                        10
                      ]
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "pagination",
                      "totalPages": "@entity.totalPages",
                      "showPageSize": false,
                      "pageChangeEvent": "PAGE",
                      "currentPage": "@entity.currentPage"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "event": {
              "type": "string",
              "default": "PAGE"
            },
            "pageSize": {
              "type": "number",
              "default": 10
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "PagedItemPaginationPage",
          "path": "/pageditems/paginated",
          "traits": [
            {
              "ref": "PagedItemPagination"
            }
          ]
        }
      ]
    }
  ]
}
