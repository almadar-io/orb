{
  "name": "std-dashboard-grid-layout",
  "version": "2.0.0",
  "description": "std-dashboard-grid-layout — dashboard-layout chrome with three trait config slots: statsTrait, graphsTrait, feedTrait.",
  "orbitals": [
    {
      "name": "DashboardGridLayoutOrbital",
      "entity": {
        "name": "DashboardGridLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "DashboardGridLayout",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "dashboard-layout",
                      "appName": "Dashboard",
                      "children": [
                        "@config.statsTrait",
                        "@config.graphsTrait",
                        {
                          "type": "typography",
                          "content": "Recent Activity",
                          "variant": "h4"
                        },
                        "@config.feedTrait"
                      ],
                      "navItems": [
                        {
                          "icon": "bar-chart-3",
                          "label": "Dashboard",
                          "href": "/dashboard"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "appName": {
              "type": "string",
              "default": "Dashboard"
            },
            "graphsTrait": {
              "type": "trait"
            },
            "navItems": {
              "type": "[object]",
              "default": [
                {
                  "icon": "bar-chart-3",
                  "label": "Dashboard",
                  "href": "/dashboard"
                }
              ]
            },
            "statsTrait": {
              "type": "trait"
            },
            "feedTrait": {
              "type": "trait"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "DashboardGridLayoutPage",
          "path": "/dashboard",
          "traits": [
            {
              "ref": "DashboardGridLayout"
            }
          ]
        }
      ]
    }
  ]
}
