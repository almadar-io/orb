{
  "name": "std-combat",
  "version": "1.0.0",
  "description": "std-combat as a Function",
  "orbitals": [
    {
      "name": "CombatantOrbital",
      "entity": {
        "name": "Combatant",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "hp",
            "type": "number",
            "default": 100
          },
          {
            "name": "attack",
            "type": "number",
            "default": 10
          },
          {
            "name": "defense",
            "type": "number",
            "default": 5
          }
        ]
      },
      "traits": [
        {
          "name": "CombatantCombat",
          "category": "interaction",
          "linkedEntity": "Combatant",
          "emits": [
            {
              "event": "CombatantLoaded",
              "description": "Fired when Combatant finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "hp",
                  "type": "number"
                },
                {
                  "name": "attack",
                  "type": "number"
                },
                {
                  "name": "defense",
                  "type": "number"
                }
              ]
            },
            {
              "event": "CombatantLoadFailed",
              "description": "Fired when Combatant fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              },
              {
                "name": "attacking"
              },
              {
                "name": "cooldown"
              },
              {
                "name": "defeated"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ATTACK",
                "name": "Attack",
                "payloadSchema": [
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "HIT",
                "name": "Hit",
                "payloadSchema": [
                  {
                    "name": "damage",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "DEFEAT",
                "name": "Defeat"
              },
              {
                "key": "COOLDOWN_END",
                "name": "Cooldown End"
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "CombatantLoaded",
                "name": "Combatant loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "hp",
                    "type": "number"
                  },
                  {
                    "name": "attack",
                    "type": "number"
                  },
                  {
                    "name": "defense",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "CombatantLoadFailed",
                "name": "Combatant load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Combatant",
                    {
                      "emit": {
                        "failure": "CombatantLoadFailed",
                        "success": "CombatantLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "position": "top",
                          "type": "game-hud",
                          "stats": [
                            {
                              "value": "@entity.hp",
                              "label": "HP"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "variant": "primary",
                          "label": "Attack",
                          "icon": "swords",
                          "action": "ATTACK"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "attacking",
                "event": "ATTACK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ],
                          "position": "top",
                          "type": "game-hud"
                        },
                        {
                          "type": "button",
                          "icon": "clock",
                          "action": "HIT",
                          "label": "Cooldown End",
                          "variant": "secondary"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "attacking",
                "to": "cooldown",
                "event": "HIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "position": "top",
                          "stats": [
                            {
                              "value": "@entity.hp",
                              "label": "HP"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "type": "badge",
                          "label": "Cooling down..."
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "attacking",
                "to": "defeated",
                "event": "DEFEAT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "game-over-screen",
                          "title": "Defeated",
                          "variant": "defeat"
                        },
                        {
                          "variant": "ghost",
                          "action": "RESET",
                          "label": "Reset",
                          "type": "button",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "cooldown",
                "to": "ready",
                "event": "COOLDOWN_END",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "position": "top",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "value": "@entity.attack",
                              "label": "Attack"
                            },
                            {
                              "label": "Defense",
                              "value": "@entity.defense"
                            }
                          ],
                          "type": "game-hud"
                        },
                        {
                          "label": "Attack",
                          "type": "button",
                          "icon": "swords",
                          "action": "ATTACK",
                          "variant": "primary"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "cooldown",
                "to": "defeated",
                "event": "DEFEAT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "title": "Defeated",
                          "type": "game-over-screen",
                          "variant": "defeat"
                        },
                        {
                          "label": "Reset",
                          "type": "button",
                          "icon": "rotate-ccw",
                          "variant": "ghost",
                          "action": "RESET"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "defeated",
                "to": "ready",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "position": "top",
                          "type": "game-hud",
                          "stats": [
                            {
                              "label": "HP",
                              "value": "@entity.hp"
                            },
                            {
                              "label": "Attack",
                              "value": "@entity.attack"
                            },
                            {
                              "value": "@entity.defense",
                              "label": "Defense"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "label": "Attack",
                          "variant": "primary",
                          "action": "ATTACK",
                          "icon": "swords"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "CombatantPage",
          "path": "/combatants",
          "traits": [
            {
              "ref": "CombatantCombat"
            }
          ]
        }
      ]
    }
  ]
}
