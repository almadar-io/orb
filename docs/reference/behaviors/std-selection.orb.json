{
  "name": "std-selection",
  "version": "1.0.0",
  "description": "std-selection as a Function",
  "orbitals": [
    {
      "name": "SelectableItemOrbital",
      "entity": {
        "name": "SelectableItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "SelectableItemSelection",
          "category": "interaction",
          "linkedEntity": "SelectableItem",
          "emits": [
            {
              "event": "SelectableItemLoaded",
              "description": "Fired when SelectableItem finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[SelectableItem]"
                }
              ]
            },
            {
              "event": "SelectableItemLoadFailed",
              "description": "Fired when SelectableItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "selecting"
              },
              {
                "name": "selected"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SelectableItemLoaded",
                "name": "SelectableItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[SelectableItem]"
                  }
                ]
              },
              {
                "key": "SelectableItemLoadFailed",
                "name": "SelectableItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SELECT",
                "name": "Select",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CONFIRM_SELECTION",
                "name": "Confirm Selection",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "success": "SelectableItemLoaded",
                        "failure": "SelectableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading…"
                        }
                      ],
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "SelectableItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "check-square",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "SelectableItems"
                            }
                          ],
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "Choose a selectableitem to continue.",
                          "variant": "caption"
                        },
                        {
                          "entity": "@payload.data",
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "gap": "sm",
                              "type": "stack",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "label": "@item.name",
                                  "type": "checkbox"
                                }
                              ]
                            }
                          ],
                          "type": "data-grid",
                          "className": "transition-shadow hover:shadow-md cursor-pointer",
                          "fields": [],
                          "itemActions": [
                            {
                              "event": "SELECT",
                              "icon": "check",
                              "label": "Select"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "SelectableItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to load"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "color": "muted",
                          "content": "@payload.error"
                        },
                        {
                          "label": "Retry",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "type": "button"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "selecting",
                "event": "SELECT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "gap": "md",
                              "type": "stack",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "check-square",
                                  "type": "icon"
                                },
                                {
                                  "variant": "h2",
                                  "content": "SelectableItems",
                                  "type": "typography"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "direction": "horizontal",
                              "gap": "sm",
                              "align": "center",
                              "type": "stack",
                              "children": [
                                {
                                  "label": "Selecting",
                                  "type": "badge"
                                },
                                {
                                  "action": "CLEAR",
                                  "icon": "x",
                                  "variant": "ghost",
                                  "label": "Clear",
                                  "type": "button"
                                }
                              ]
                            }
                          ],
                          "align": "center",
                          "type": "stack",
                          "gap": "md",
                          "justify": "between",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "message": "@payload.id",
                          "type": "alert",
                          "variant": "info"
                        },
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "icon": "check",
                              "actionPayload": {
                                "id": "@payload.id"
                              },
                              "action": "CONFIRM_SELECTION",
                              "label": "Confirm",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "selected",
                "event": "CONFIRM_SELECTION",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "check-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "Selection Confirmed",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "align": "center",
                              "type": "stack"
                            },
                            {
                              "type": "badge",
                              "label": "Confirmed"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Selection confirmed successfully."
                        },
                        {
                          "children": [
                            {
                              "content": "Selected ID:",
                              "variant": "caption",
                              "type": "typography"
                            },
                            {
                              "type": "typography",
                              "variant": "body",
                              "content": "@payload.id"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "action": "CLEAR",
                          "variant": "ghost",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Clear Selection"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "selecting",
                "to": "loading",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "selected",
                "to": "loading",
                "event": "CLEAR",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "success": "SelectableItemLoaded",
                        "failure": "SelectableItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "SelectableItem",
                    {
                      "emit": {
                        "failure": "SelectableItemLoadFailed",
                        "success": "SelectableItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "SelectableItemSelectionPage",
          "path": "/selectableitems/selection",
          "traits": [
            {
              "ref": "SelectableItemSelection"
            }
          ]
        }
      ]
    }
  ]
}
