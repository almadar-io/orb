{
  "name": "std-master-detail-layout",
  "version": "2.0.0",
  "description": "std-master-detail-layout — chrome with std-drawer side-panel + masterTrait config slot for the consumer's master list.",
  "orbitals": [
    {
      "name": "MasterDetailLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-drawer",
          "as": "Drawer"
        }
      ],
      "entity": {
        "name": "MasterDetailLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "auxiliaryEntities": [
        {
          "name": "DrawerContent",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            }
          ]
        }
      ],
      "traits": [
        {
          "name": "MasterDetailDrawer",
          "category": "interaction",
          "linkedEntity": "DrawerContent",
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "OPEN",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT"
              },
              {
                "from": "closed",
                "to": "open",
                "event": "OPEN",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "content": "@payload.name",
                          "variant": "h4",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "body",
                          "content": "@payload.description"
                        },
                        {
                          "children": [
                            {
                              "label": "Close",
                              "action": "CLOSE",
                              "type": "button",
                              "variant": "ghost"
                            }
                          ],
                          "justify": "end",
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "MasterDetailLayout",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "className": "max-w-6xl mx-auto w-full",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "list",
                              "type": "icon"
                            },
                            {
                              "content": "Master / Detail",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        "@config.masterTrait"
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "masterTrait": {
              "type": "trait"
            },
            "title": {
              "type": "string",
              "default": "Master / Detail"
            },
            "icon": {
              "type": "string",
              "default": "list"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "MasterDetailPage",
          "path": "/master-detail",
          "traits": [
            {
              "ref": "MasterDetailLayout"
            },
            {
              "ref": "MasterDetailDrawer"
            }
          ]
        }
      ]
    }
  ]
}
