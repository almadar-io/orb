{
  "name": "std-email-broadcast",
  "version": "1.0.0",
  "description": "std-email-broadcast — send an email blast to a segment of contacts using a chosen template; tracks send progress.",
  "orbitals": [
    {
      "name": "EmailBroadcastOrbital",
      "entity": {
        "name": "EmailBroadcast",
        "collection": "emailbroadcasts",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "subject",
            "type": "string",
            "default": ""
          },
          {
            "name": "segmentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "templateId",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "scheduled",
              "sending",
              "sent",
              "failed"
            ]
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "recipientCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "sentCount",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "EmailBroadcastBroadcast",
          "category": "interaction",
          "linkedEntity": "EmailBroadcast",
          "emits": [
            {
              "event": "SEND",
              "payloadSchema": [
                {
                  "name": "broadcastId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EmailBroadcastLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[EmailBroadcast]"
                }
              ]
            },
            {
              "event": "EmailBroadcastLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "BroadcastSent",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "sending"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EmailBroadcastLoaded",
                "name": "EmailBroadcast loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[EmailBroadcast]"
                  }
                ]
              },
              {
                "key": "EmailBroadcastLoadFailed",
                "name": "EmailBroadcast load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "broadcastId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "BroadcastSent",
                "name": "Broadcast sent",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "success": "EmailBroadcastLoaded",
                        "failure": "EmailBroadcastLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading broadcasts…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "EmailBroadcastLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "mail"
                            },
                            {
                              "content": "Email Broadcasts",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "cols": 1,
                          "entity": "@payload.data",
                          "gap": "sm",
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "name",
                              "variant": "caption",
                              "label": "Name"
                            },
                            {
                              "label": "Subject",
                              "variant": "caption",
                              "name": "subject"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            },
                            {
                              "label": "Recipients",
                              "name": "recipientCount",
                              "variant": "badge"
                            },
                            {
                              "label": "Sent",
                              "name": "sentCount",
                              "variant": "badge"
                            },
                            {
                              "name": "scheduledAt",
                              "label": "Scheduled",
                              "variant": "caption"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Send",
                              "event": "SEND",
                              "icon": "send"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "EmailBroadcastLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "sending",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.broadcastId"
                  ],
                  [
                    "emit",
                    "BroadcastSent",
                    {
                      "id": "@payload.broadcastId"
                    }
                  ]
                ]
              },
              {
                "from": "sending",
                "to": "browsing",
                "event": "BroadcastSent",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Broadcast sent"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "EmailBroadcast",
                    {
                      "emit": {
                        "failure": "EmailBroadcastLoadFailed",
                        "success": "EmailBroadcastLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Email Broadcasts"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "EmailBroadcastPage",
          "path": "/broadcasts",
          "traits": [
            {
              "ref": "EmailBroadcastBroadcast"
            }
          ]
        }
      ]
    }
  ]
}
