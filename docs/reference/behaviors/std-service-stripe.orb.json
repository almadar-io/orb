{
  "name": "std-service-stripe",
  "version": "2.0.0",
  "description": "std-service-stripe — Stripe payment service. Bind via `uses Stripe from \"std/behaviors/std-service-stripe\"` and configure `amount` / `currency` / `metadata` at the call site. Pass `uiTrait: \"@trait.YourPaymentForm\"` to inject your own Stripe Elements card form; leave unset to render the atom's default test form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceStripeOrbital",
      "entity": {
        "name": "ServiceStripe",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0
          },
          {
            "name": "currency",
            "type": "string",
            "default": "usd"
          },
          {
            "name": "paymentIntentId",
            "type": "string",
            "default": ""
          },
          {
            "name": "clientSecret",
            "type": "string",
            "default": ""
          },
          {
            "name": "paymentStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceStripeDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "CREATE_PAYMENT",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PAYMENT",
                "name": "Create Payment"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "Payment",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "0.00",
                              "inputType": "number"
                            },
                            {
                              "type": "select",
                              "options": [
                                {
                                  "label": "USD",
                                  "value": "usd"
                                },
                                {
                                  "value": "eur",
                                  "label": "EUR"
                                },
                                {
                                  "value": "gbp",
                                  "label": "GBP"
                                }
                              ]
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "action": "CREATE_PAYMENT",
                          "icon": "credit-card",
                          "variant": "primary",
                          "label": "Pay",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceStripeStripe",
          "category": "interaction",
          "linkedEntity": "ServiceStripe",
          "emits": [
            {
              "event": "ServiceStripeLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStripeLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceStripeStripeCompleted",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceStripeStripeFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "PAYMENT_CREATED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "clientSecret",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PAYMENT_CONFIRMED",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE_PAYMENT",
              "triggers": "CREATE_PAYMENT",
              "source": {
                "kind": "trait",
                "trait": "ServiceStripeDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "confirming"
              },
              {
                "name": "succeeded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE_PAYMENT",
                "name": "Create Payment"
              },
              {
                "key": "ServiceStripeLoaded",
                "name": "ServiceStripe loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceStripeLoadFailed",
                "name": "ServiceStripe load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "PAYMENT_CREATED",
                "name": "Payment Created",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "clientSecret",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PAYMENT_CONFIRMED",
                "name": "Payment Confirmed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceStripeStripeCompleted",
                "name": "ServiceStripe stripe completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceStripeStripeFailed",
                "name": "ServiceStripe stripe failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.amount",
                    0
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "usd"
                  ],
                  [
                    "fetch",
                    "ServiceStripe",
                    {
                      "emit": {
                        "failure": "ServiceStripeLoadFailed",
                        "success": "ServiceStripeLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceStripeDefaultForm"
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "creating",
                "event": "CREATE_PAYMENT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Creating payment...",
                      "type": "loading-state",
                      "message": "Setting up your payment intent."
                    }
                  ],
                  [
                    "call-service",
                    "stripe",
                    "createPaymentIntent",
                    {
                      "amount": "@entity.amount",
                      "currency": "@entity.currency",
                      "metadata": {}
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "PAYMENT_CREATED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceStripeLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceStripeLoadFailed"
              },
              {
                "from": "creating",
                "to": "confirming",
                "event": "PAYMENT_CREATED",
                "effects": [
                  [
                    "set",
                    "@entity.paymentIntentId",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.clientSecret",
                    "@payload.clientSecret"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Confirming payment...",
                      "type": "loading-state",
                      "message": "Processing your payment."
                    }
                  ],
                  [
                    "call-service",
                    "stripe",
                    "confirmPayment",
                    {
                      "paymentIntentId": "@entity.paymentIntentId"
                    },
                    {
                      "emit": {
                        "failure": "FAILED",
                        "success": "PAYMENT_CONFIRMED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceStripeStripeFailed",
                    {
                      "error": "@entity.error",
                      "code": "create_payment_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "title": "Payment Failed",
                      "message": "@entity.error",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "succeeded",
                "event": "PAYMENT_CONFIRMED",
                "effects": [
                  [
                    "set",
                    "@entity.paymentStatus",
                    "succeeded"
                  ],
                  [
                    "emit",
                    "ServiceStripeStripeCompleted",
                    {
                      "result": "@payload"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "type": "alert",
                          "message": "Payment successful!"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "content": "@entity.paymentIntentId",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "label": "New Payment",
                          "action": "RESET",
                          "variant": "ghost",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceStripeStripeFailed",
                    {
                      "error": "@entity.error",
                      "code": "confirm_payment_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "title": "Payment Failed",
                      "message": "@entity.error",
                      "type": "error-state"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Payment"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "inputType": "number",
                              "placeholder": "0.00",
                              "type": "input"
                            },
                            {
                              "options": [
                                {
                                  "label": "USD",
                                  "value": "usd"
                                },
                                {
                                  "value": "eur",
                                  "label": "EUR"
                                },
                                {
                                  "value": "gbp",
                                  "label": "GBP"
                                }
                              ],
                              "type": "select"
                            }
                          ],
                          "direction": "vertical",
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "variant": "primary",
                          "action": "CREATE_PAYMENT",
                          "type": "button",
                          "icon": "credit-card",
                          "label": "Pay"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "succeeded",
                "to": "succeeded",
                "event": "ServiceStripeStripeCompleted"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceStripeStripeFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "md",
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "credit-card",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "Payment",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "inputType": "number",
                              "type": "input",
                              "placeholder": "0.00"
                            },
                            {
                              "options": [
                                {
                                  "label": "USD",
                                  "value": "usd"
                                },
                                {
                                  "label": "EUR",
                                  "value": "eur"
                                },
                                {
                                  "value": "gbp",
                                  "label": "GBP"
                                }
                              ],
                              "type": "select"
                            }
                          ],
                          "gap": "md",
                          "direction": "vertical",
                          "type": "stack"
                        },
                        {
                          "label": "Pay",
                          "variant": "primary",
                          "action": "CREATE_PAYMENT",
                          "type": "button",
                          "icon": "credit-card"
                        }
                      ],
                      "align": "center",
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "credit-card"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Payment"
                            }
                          ],
                          "align": "center",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "inputType": "number",
                              "type": "input",
                              "placeholder": "0.00"
                            },
                            {
                              "options": [
                                {
                                  "value": "usd",
                                  "label": "USD"
                                },
                                {
                                  "value": "eur",
                                  "label": "EUR"
                                },
                                {
                                  "value": "gbp",
                                  "label": "GBP"
                                }
                              ],
                              "type": "select"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "label": "Pay",
                          "type": "button",
                          "action": "CREATE_PAYMENT",
                          "icon": "credit-card",
                          "variant": "primary"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "amount": {
              "type": "number",
              "default": 0
            },
            "currency": {
              "type": "string",
              "default": "usd"
            },
            "metadata": {
              "type": "object",
              "default": {}
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceStripeDefaultForm"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceStripePage",
          "path": "/servicestripes",
          "traits": [
            {
              "ref": "ServiceStripeStripe"
            }
          ]
        }
      ]
    }
  ]
}
