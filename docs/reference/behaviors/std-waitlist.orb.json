{
  "name": "std-waitlist",
  "version": "1.0.0",
  "description": "std-waitlist — sorted queue with auto-promote-on-cancel. Owns a WaitlistEntry entity (one row per (targetId, userId)); JOIN appends a waiting entry, PROMOTE flips status to promoted, CANCEL flips status to cancelled and emits WaitlistEntryCancelled so a parent molecule can promote the next waiting entry.",
  "orbitals": [
    {
      "name": "WaitlistOrbital",
      "entity": {
        "name": "WaitlistEntry",
        "collection": "waitlistentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "userId",
            "type": "string",
            "required": true
          },
          {
            "name": "position",
            "type": "number",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "waiting",
            "values": [
              "waiting",
              "promoted",
              "cancelled",
              "expired"
            ]
          },
          {
            "name": "joinedAt",
            "type": "string"
          },
          {
            "name": "promotedAt",
            "type": "string"
          },
          {
            "name": "notifiedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "WaitlistManage",
          "category": "interaction",
          "linkedEntity": "WaitlistEntry",
          "emits": [
            {
              "event": "JOIN",
              "payloadSchema": [
                {
                  "name": "targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "userId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "PROMOTE",
              "payloadSchema": [
                {
                  "name": "entryId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "entryId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WaitlistEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[WaitlistEntry]"
                }
              ]
            },
            {
              "event": "WaitlistEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WaitlistEntryJoined",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WaitlistEntryPromoted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WaitlistEntryCancelled",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.targetType",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.userId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.position",
                  "type": "number",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.joinedAt",
                  "type": "string"
                },
                {
                  "name": "row.promotedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "WaitlistEntryFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "WaitlistEntryLoaded",
                "name": "WaitlistEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[WaitlistEntry]"
                  }
                ]
              },
              {
                "key": "WaitlistEntryLoadFailed",
                "name": "WaitlistEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "JOIN",
                "name": "Join",
                "payloadSchema": [
                  {
                    "name": "targetId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "userId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "PROMOTE",
                "name": "Promote",
                "payloadSchema": [
                  {
                    "name": "entryId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "entryId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              },
              {
                "key": "WaitlistEntryJoined",
                "name": "WaitlistEntry joined",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              },
              {
                "key": "WaitlistEntryPromoted",
                "name": "WaitlistEntry promoted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              },
              {
                "key": "WaitlistEntryCancelled",
                "name": "WaitlistEntry cancelled",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "WaitlistEntry"
                  }
                ]
              },
              {
                "key": "WaitlistEntryFailed",
                "name": "WaitlistEntry failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "failure": "WaitlistEntryLoadFailed",
                        "success": "WaitlistEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Loading waitlist…",
                          "variant": "caption"
                        }
                      ],
                      "align": "center",
                      "gap": "md",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "WaitlistEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "users",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Waitlist"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "fields": [
                            {
                              "name": "position",
                              "variant": "badge",
                              "label": "#"
                            },
                            {
                              "label": "User",
                              "variant": "caption",
                              "name": "userId"
                            },
                            {
                              "variant": "badge",
                              "label": "Type",
                              "name": "targetType"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            },
                            {
                              "label": "Joined",
                              "name": "joinedAt",
                              "variant": "caption"
                            }
                          ],
                          "gap": "sm",
                          "cols": 1,
                          "entity": "@payload.data",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "event": "PROMOTE",
                              "variant": "primary",
                              "icon": "arrow-up",
                              "label": "Promote"
                            },
                            {
                              "label": "Cancel",
                              "event": "CANCEL",
                              "variant": "danger",
                              "icon": "x"
                            }
                          ]
                        },
                        {
                          "variant": "secondary",
                          "action": "JOIN",
                          "label": "Join Waitlist",
                          "icon": "user-plus",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "WaitlistEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "JOIN",
                "effects": [
                  [
                    "set",
                    "@entity.targetId",
                    "@payload.targetId"
                  ],
                  [
                    "set",
                    "@entity.userId",
                    "@payload.userId"
                  ],
                  [
                    "persist",
                    "create",
                    "WaitlistEntry",
                    "@entity",
                    {
                      "emit": {
                        "failure": "WaitlistEntryFailed",
                        "success": "WaitlistEntryJoined"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "PROMOTE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entryId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "promoted"
                  ],
                  [
                    "persist",
                    "update",
                    "WaitlistEntry",
                    "@entity",
                    {
                      "emit": {
                        "success": "WaitlistEntryPromoted",
                        "failure": "WaitlistEntryFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.entryId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "persist",
                    "update",
                    "WaitlistEntry",
                    "@entity",
                    {
                      "emit": {
                        "success": "WaitlistEntryCancelled",
                        "failure": "WaitlistEntryFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WaitlistEntryJoined",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "failure": "WaitlistEntryLoadFailed",
                        "success": "WaitlistEntryLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WaitlistEntryPromoted",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "failure": "WaitlistEntryLoadFailed",
                        "success": "WaitlistEntryLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "WaitlistEntryCancelled",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "success": "WaitlistEntryLoaded",
                        "failure": "WaitlistEntryLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "WaitlistEntryFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "WaitlistEntry",
                    {
                      "emit": {
                        "success": "WaitlistEntryLoaded",
                        "failure": "WaitlistEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Waitlist"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "WaitlistManagePage",
          "path": "/waitlistentries/manage",
          "traits": [
            {
              "ref": "WaitlistManage"
            }
          ]
        }
      ]
    }
  ]
}
