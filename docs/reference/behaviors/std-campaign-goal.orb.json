{
  "name": "std-campaign-goal",
  "version": "1.0.0",
  "description": "std-campaign-goal — nonprofit fundraising campaign primitive with a target dollar amount, running raised total, donor count, deadline, and status. Browses campaigns in a data-grid with Launch / End row actions.",
  "orbitals": [
    {
      "name": "CampaignGoalOrbital",
      "entity": {
        "name": "CampaignGoal",
        "collection": "campaigngoals",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "targetAmount",
            "type": "number",
            "default": 0
          },
          {
            "name": "raisedAmount",
            "type": "number",
            "default": 0
          },
          {
            "name": "donorCount",
            "type": "number",
            "default": 0
          },
          {
            "name": "startDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "endDate",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "active",
              "achieved",
              "ended"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "CampaignGoalTracker",
          "category": "interaction",
          "linkedEntity": "CampaignGoal",
          "emits": [
            {
              "event": "LAUNCH_CAMPAIGN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "END_CAMPAIGN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CampaignGoalLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CampaignGoal]"
                }
              ]
            },
            {
              "event": "CampaignGoalLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CampaignGoalLoaded",
                "name": "CampaignGoal loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CampaignGoal]"
                  }
                ]
              },
              {
                "key": "CampaignGoalLoadFailed",
                "name": "CampaignGoal load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "LAUNCH_CAMPAIGN",
                "name": "Launch Campaign",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "END_CAMPAIGN",
                "name": "End Campaign",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CampaignGoal",
                    {
                      "emit": {
                        "failure": "CampaignGoalLoadFailed",
                        "success": "CampaignGoalLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "align": "center",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading campaigns…",
                          "color": "muted"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CampaignGoalLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "secondaryAction": {
                            "label": "Learn More",
                            "variant": "ghost",
                            "action": "VIEW_STORY"
                          },
                          "type": "hero-section",
                          "titleAccent": "Campaigns",
                          "tag": "Campaign",
                          "primaryAction": {
                            "variant": "primary",
                            "label": "Donate Now",
                            "action": "LAUNCH_CAMPAIGN"
                          },
                          "title": "Help us reach our goal",
                          "subtitle": "Every gift moves the needle. Join thousands of donors making impact possible.",
                          "tagVariant": "primary"
                        },
                        {
                          "type": "stack",
                          "gap": "lg",
                          "justify": "around",
                          "children": [
                            {
                              "prefix": "$",
                              "suffix": " raised",
                              "duration": 1500,
                              "value": 482000,
                              "type": "animated-counter"
                            },
                            {
                              "suffix": " donors",
                              "duration": 1500,
                              "value": 1240,
                              "type": "animated-counter"
                            },
                            {
                              "duration": 1500,
                              "type": "animated-counter",
                              "value": 87,
                              "suffix": "% of goal"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "color": "primary",
                          "value": 87,
                          "max": 100,
                          "showPercentage": true,
                          "type": "progress-bar"
                        },
                        {
                          "trigger": "scroll",
                          "animation": "fade-up",
                          "type": "animated-reveal",
                          "children": [
                            {
                              "text": "Together, we change lives.",
                              "speed": 60,
                              "type": "typewriter-text"
                            }
                          ]
                        },
                        {
                          "type": "content-section",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Choose your donation tier"
                            },
                            {
                              "type": "pricing-grid",
                              "plans": [
                                {
                                  "price": "$25",
                                  "features": [
                                    "Tax receipt",
                                    "Thank-you email"
                                  ],
                                  "name": "Supporter",
                                  "action": {
                                    "label": "Give $25",
                                    "href": "#"
                                  },
                                  "description": "Provides one week of meals"
                                },
                                {
                                  "description": "Funds a child's school supplies for a year",
                                  "cta": {
                                    "action": "LAUNCH_CAMPAIGN",
                                    "label": "Give $100"
                                  },
                                  "name": "Advocate",
                                  "features": [
                                    "Tax receipt",
                                    "Personalized note",
                                    "Quarterly update"
                                  ],
                                  "price": "$100",
                                  "highlighted": true
                                },
                                {
                                  "cta": {
                                    "label": "Give $500",
                                    "action": "LAUNCH_CAMPAIGN"
                                  },
                                  "name": "Champion",
                                  "description": "Sponsors a community clean-water station",
                                  "price": "$500",
                                  "features": [
                                    "Tax receipt",
                                    "Recognition in newsletter",
                                    "Site-visit invite"
                                  ]
                                }
                              ]
                            }
                          ],
                          "padding": "lg",
                          "background": "alt"
                        },
                        {
                          "background": "default",
                          "padding": "md",
                          "type": "content-section",
                          "children": [
                            {
                              "content": "Impact in pictures",
                              "type": "typography",
                              "variant": "h3"
                            },
                            {
                              "data": [
                                {
                                  "name": "Clean water delivery",
                                  "id": "i1",
                                  "imageUrl": "https://picsum.photos/seed/campaign1/800/600"
                                },
                                {
                                  "id": "i2",
                                  "name": "School supplies handout",
                                  "imageUrl": "https://picsum.photos/seed/campaign2/800/600"
                                },
                                {
                                  "imageUrl": "https://picsum.photos/seed/campaign3/800/600",
                                  "name": "Community meal program",
                                  "id": "i3"
                                },
                                {
                                  "name": "Volunteer team",
                                  "id": "i4",
                                  "imageUrl": "https://picsum.photos/seed/campaign4/800/600"
                                }
                              ],
                              "type": "media-gallery"
                            }
                          ]
                        },
                        {
                          "type": "lightbox",
                          "isOpen": false,
                          "currentIndex": 0,
                          "showCounter": true,
                          "images": [
                            {
                              "src": "https://picsum.photos/seed/campaign1/1200/800",
                              "caption": "Clean water",
                              "alt": "Impact"
                            }
                          ]
                        },
                        {
                          "variant": "quotes",
                          "type": "social-proof",
                          "items": [
                            {
                              "role": "Beneficiary",
                              "quote": "This nonprofit changed my family's life.",
                              "author": "Maria S."
                            },
                            {
                              "author": "James W.",
                              "role": "Recurring donor",
                              "quote": "Every dollar I give I can see in the field."
                            },
                            {
                              "quote": "Transparent, honest, and effective.",
                              "author": "Lina P.",
                              "role": "Volunteer"
                            }
                          ]
                        },
                        {
                          "discord": {
                            "url": "https://discord.gg/example"
                          },
                          "github": {
                            "url": "https://github.com/example"
                          },
                          "twitter": {
                            "url": "https://twitter.com/example"
                          },
                          "type": "community-links",
                          "heading": "Stay connected"
                        },
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "target"
                            },
                            {
                              "type": "typography",
                              "content": "Campaigns",
                              "variant": "h3"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Launch",
                              "event": "LAUNCH_CAMPAIGN",
                              "variant": "primary"
                            },
                            {
                              "event": "END_CAMPAIGN",
                              "variant": "danger",
                              "label": "End"
                            }
                          ],
                          "cols": 1,
                          "fields": [
                            {
                              "variant": "caption",
                              "label": "Name",
                              "name": "name"
                            },
                            {
                              "label": "Target",
                              "name": "targetAmount",
                              "variant": "caption"
                            },
                            {
                              "label": "Raised",
                              "variant": "caption",
                              "name": "raisedAmount"
                            },
                            {
                              "label": "Donors",
                              "name": "donorCount",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "label": "Status",
                              "variant": "badge"
                            }
                          ],
                          "entity": "@payload.data",
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CampaignGoalLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "LAUNCH_CAMPAIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Campaign launched",
                      "variant": "success",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "END_CAMPAIGN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Campaign ended",
                      "type": "alert",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CampaignGoal",
                    {
                      "emit": {
                        "success": "CampaignGoalLoaded",
                        "failure": "CampaignGoalLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Campaigns"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CampaignGoalPage",
          "path": "/campaigns",
          "traits": [
            {
              "ref": "CampaignGoalTracker"
            }
          ]
        }
      ]
    }
  ]
}
