{
  "name": "std-tabs-layout",
  "version": "2.0.0",
  "description": "std-tabs-layout — chrome with std-tabs strip; consumer overrides config.tabs[].content with @trait.X references.",
  "orbitals": [
    {
      "name": "TabsLayoutOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-tabs",
          "as": "Tabs"
        }
      ],
      "entity": {
        "name": "TabsLayoutState",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          }
        ]
      },
      "auxiliaryEntities": [
        {
          "name": "TabsItem",
          "persistence": "runtime",
          "fields": [
            {
              "name": "id",
              "type": "string",
              "required": true
            },
            {
              "name": "activeTab",
              "type": "string",
              "default": ""
            },
            {
              "name": "items",
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "properties": {
                  "content": {
                    "name": "content",
                    "type": "trait"
                  },
                  "label": {
                    "name": "label",
                    "type": "string"
                  },
                  "icon": {
                    "name": "icon",
                    "type": "string"
                  },
                  "badge": {
                    "name": "badge",
                    "type": "string"
                  },
                  "id": {
                    "name": "id",
                    "type": "string"
                  }
                }
              }
            }
          ]
        }
      ],
      "traits": [
        {
          "name": "TabsLayoutTabs",
          "category": "interaction",
          "linkedEntity": "TabsItem",
          "emits": [
            {
              "event": "TAB_CHANGED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TAB_CHANGED",
                "name": "Tab Changed",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    [
                      {
                        "id": "overview",
                        "label": "Overview",
                        "icon": "info"
                      },
                      {
                        "label": "Details",
                        "icon": "list",
                        "id": "details"
                      },
                      {
                        "label": "Settings",
                        "icon": "settings",
                        "id": "settings"
                      }
                    ]
                  ],
                  [
                    "set",
                    "@entity.activeTab",
                    "overview"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "tabs",
                      "tabChangeEvent": "TAB_CHANGED",
                      "orientation": "horizontal",
                      "items": "@entity.items",
                      "variant": "default",
                      "activeTab": "@entity.activeTab"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TAB_CHANGED",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    [
                      {
                        "id": "overview",
                        "label": "Overview",
                        "icon": "info"
                      },
                      {
                        "label": "Details",
                        "icon": "list",
                        "id": "details"
                      },
                      {
                        "label": "Settings",
                        "icon": "settings",
                        "id": "settings"
                      }
                    ]
                  ],
                  [
                    "set",
                    "@entity.activeTab",
                    "@payload.tabId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "default",
                      "type": "tabs",
                      "tabChangeEvent": "TAB_CHANGED",
                      "orientation": "horizontal",
                      "items": "@entity.items",
                      "activeTab": "@entity.activeTab"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "defaultTab": {
              "type": "string",
              "default": "overview"
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "variant": {
              "type": "string",
              "default": "default",
              "values": [
                "default",
                "pills",
                "underline"
              ]
            },
            "tabs": {
              "type": "[object]",
              "default": [
                {
                  "id": "overview",
                  "label": "Overview",
                  "icon": "info"
                },
                {
                  "label": "Details",
                  "icon": "list",
                  "id": "details"
                },
                {
                  "label": "Settings",
                  "icon": "settings",
                  "id": "settings"
                }
              ]
            }
          },
          "scope": "instance"
        },
        {
          "name": "TabsLayout",
          "category": "interaction",
          "stateMachine": {
            "states": [
              {
                "name": "composing",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              }
            ],
            "transitions": [
              {
                "from": "composing",
                "to": "composing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "layout"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Tabbed View"
                            }
                          ],
                          "gap": "sm",
                          "direction": "horizontal",
                          "align": "center",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        "@trait.TabsLayoutTabs"
                      ],
                      "gap": "md",
                      "type": "stack",
                      "className": "max-w-6xl mx-auto w-full"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Tabbed View"
            },
            "icon": {
              "type": "string",
              "default": "layout"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TabsLayoutPage",
          "path": "/tabs-layout",
          "traits": [
            {
              "ref": "TabsLayout"
            },
            {
              "ref": "TabsLayoutTabs"
            }
          ]
        }
      ]
    }
  ]
}
