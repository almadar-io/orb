                    "update",
                    "AgentSession",
                    {
                      "id": "@payload.row.id",
                      "status": "ended"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
                    "ENDED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
