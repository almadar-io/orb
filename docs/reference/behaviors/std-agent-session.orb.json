                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.row",
                          "fields": [
                            "label"
                          ],
                          "cancelEvent": "CLOSE",
                          "submitEvent": "SAVE",
                          "type": "form-section",
                          "mode": "edit"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "box"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
