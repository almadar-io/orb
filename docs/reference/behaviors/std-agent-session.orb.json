                      "title": "Session",
                      "type": "empty-state",
                      "icon": "git-branch"
                    }
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "forked",
                "event": "FORK",
                "effects": [
                  [
                    "agent/fork"
                  ],
                  [
                    "persist",
                    "create",
                    "AgentSession",
                    {
                      "parentId": "@payload.row.id",
                      "status": "forked",
                      "createdAt": "@now"
                    },
                    {
                      "emit": {
                        "success": "AgentSessionSaved",
                        "failure": "AgentSessionSaveFailed"
                      }
                    }
                  ],
                  [
                    "emit",
                    "FORKED",
                    {
                      "sessionId": "@payload.row.id"
                    }
                  ]
                ]
              },
              {
                "from": "ended",
                "to": "ended",
                "event": "END",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentSession",
                    {
                      "id": "@payload.row.id",
                      "status": "ended"
                    },
                    {
                      "emit": {
                        "failure": "AgentSessionUpdateFailed",
                        "success": "AgentSessionUpdated"
                      }
                    }
                  ],
                  [
                    "emit",
