{
  "name": "std-class-roster",
  "version": "1.0.0",
  "description": "std-class-roster — list of members enrolled in a specific class session, with attendance tracking. Owns a RosterEntry entity and a single roster trait that loads entries, renders them in a data-grid, and surfaces Check In / No Show per row.",
  "orbitals": [
    {
      "name": "ClassRosterOrbital",
      "entity": {
        "name": "RosterEntry",
        "collection": "rosterentries",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "sessionId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberId",
            "type": "string",
            "required": true
          },
          {
            "name": "memberName",
            "type": "string",
            "default": ""
          },
          {
            "name": "enrolledAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "checkedInAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "enrolled",
            "values": [
              "enrolled",
              "checked_in",
              "no_show",
              "waitlist"
            ]
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "RosterEntryRoster",
          "category": "interaction",
          "linkedEntity": "RosterEntry",
          "emits": [
            {
              "event": "CHECK_IN",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_NO_SHOW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "RosterEntryLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RosterEntry]"
                }
              ]
            },
            {
              "event": "RosterEntryLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RosterEntryLoaded",
                "name": "RosterEntry loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RosterEntry]"
                  }
                ]
              },
              {
                "key": "RosterEntryLoadFailed",
                "name": "RosterEntry load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CHECK_IN",
                "name": "Check In",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_NO_SHOW",
                "name": "Mark No Show",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "success": "RosterEntryLoaded",
                        "failure": "RosterEntryLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading roster…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "RosterEntryLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "users"
                            },
                            {
                              "variant": "h3",
                              "content": "Class Roster",
                              "type": "typography"
                            },
                            {
                              "size": "sm",
                              "type": "avatar",
                              "alt": "Instructor",
                              "src": "https://picsum.photos/seed/instructor/64/64"
                            }
                          ]
                        },
                        {
                          "max": 100,
                          "variant": "primary",
                          "value": 65,
                          "label": "Attendance",
                          "type": "progress-bar",
                          "showLabel": true
                        },
                        {
                          "children": {
                            "variant": "caption",
                            "content": "Pull to refresh roster",
                            "color": "muted",
                            "type": "typography"
                          },
                          "refreshEvent": "INIT",
                          "type": "pull-to-refresh"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "sm",
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Check In",
                              "variant": "primary",
                              "event": "CHECK_IN"
                            },
                            {
                              "label": "No Show",
                              "variant": "ghost",
                              "event": "MARK_NO_SHOW"
                            }
                          ],
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Member",
                              "variant": "caption",
                              "name": "memberName"
                            },
                            {
                              "name": "sessionId",
                              "label": "Session",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "caption"
                            },
                            {
                              "name": "checkedInAt",
                              "variant": "caption",
                              "label": "Checked In"
                            }
                          ],
                          "cols": 1
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RosterEntryLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CHECK_IN",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "success",
                      "message": "Checked in",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_NO_SHOW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Marked no-show"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RosterEntry",
                    {
                      "emit": {
                        "failure": "RosterEntryLoadFailed",
                        "success": "RosterEntryLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Class Roster"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "RosterEntryPage",
          "path": "/roster",
          "traits": [
            {
              "ref": "RosterEntryRoster"
            }
          ]
        }
      ]
    }
  ]
}
