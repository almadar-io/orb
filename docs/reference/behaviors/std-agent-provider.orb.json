                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SWITCHED",
                "name": "Switched"
              },
              {
                "key": "AgentProviderLoaded",
                "name": "AgentProvider loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "currentProvider",
                    "type": "string"
                  },
                  {
                    "name": "currentModel",
                    "type": "string"
                  },
                  {
                    "name": "fallbackProvider",
                    "type": "string"
                  },
                  {
                    "name": "requestCount",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderUpdated",
                "name": "AgentProvider updated",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderUpdateFailed",
                "name": "AgentProvider update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.currentModel",
                    "claude-sonnet-4-20250514"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "anthropic"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "stack",
                          "justify": "between",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "repeat",
                                  "type": "icon"
                                },
                                {
                                  "content": "Switch Provider",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ],
                              "direction": "horizontal",
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "type": "button",
                              "action": "SWITCH",
                              "variant": "primary",
                              "label": "Open",
                              "icon": "repeat"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "description": "Click Open to view details in a modal overlay.",
                          "type": "empty-state",
                          "icon": "repeat",
                          "title": "Nothing open"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "loading",
                "event": "SWITCH",
                "effects": [
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderRowLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "open",
                "event": "AgentProviderRowLoaded",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "repeat",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Switch Provider"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "content": "Current:",
                              "type": "typography",
                              "variant": "caption"
                            },
                            {
                              "type": "badge",
                              "label": "@entity.currentProvider"
                            },
                            {
                              "label": "@entity.currentModel",
                              "type": "badge"
                            }
                          ]
                        },
                        {
                          "fields": [
                            "currentProvider",
                            "currentModel"
                          ],
                          "entity": "@payload.row",
                          "mode": "edit",
                          "type": "form-section",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE"
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "closed",
                "event": "AgentProviderLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Failed to load provider",
                    "error"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
