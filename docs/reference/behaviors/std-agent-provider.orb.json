                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "currentProvider",
                  "type": "string"
                },
                {
                  "name": "currentModel",
                  "type": "string"
                },
                {
                  "name": "fallbackProvider",
                  "type": "string"
                },
                {
                  "name": "requestCount",
                  "type": "number"
                },
                {
                  "name": "message",
                  "type": "string"
                },
                {
                  "name": "notificationType",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentProviderLoadFailed",
              "description": "Fired when AgentProvider fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SWITCHED",
              "triggers": "SWITCHED",
              "source": {
                "kind": "trait",
                "trait": "AgentProviderModal"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "active"
              },
              {
                "name": "switching"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DO_SWITCH",
                "name": "Do Switch",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "SWITCHED",
                "name": "Switched"
              },
              {
                "key": "SWITCH_AUTO",
                "name": "Switch Auto"
              },
              {
                "key": "SHOW",
                "name": "Show"
              },
              {
                "key": "AgentProviderLoaded",
                "name": "AgentProvider loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "currentProvider",
                    "type": "string"
                  },
                  {
                    "name": "currentModel",
                    "type": "string"
                  },
                  {
                    "name": "fallbackProvider",
                    "type": "string"
                  },
                  {
                    "name": "requestCount",
                    "type": "number"
                  },
                  {
                    "name": "message",
                    "type": "string"
                  },
                  {
                    "name": "notificationType",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentProviderLoadFailed",
                "name": "AgentProvider load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.fallbackProvider",
                    "openai"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "success": "AgentProviderLoaded",
                        "failure": "AgentProviderLoadFailed"
                      }
                    }
                  ],
                  [
                    "agent/provider"
                  ],
                  [
                    "agent/model"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "description": "Provider is ready",
                      "icon": "repeat",
                      "title": "Provider",
                      "type": "empty-state"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "switching",
                "event": "DO_SWITCH",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@payload.data.currentProvider",
                    "@payload.data.currentModel"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@payload.data.currentProvider"
                  ],
                  [
                    "set",
                    "@entity.currentModel",
                    "@payload.data.currentModel"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "switching",
                "event": "DO_SWITCH",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@payload.data.currentProvider",
                    "@payload.data.currentModel"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@payload.data.currentProvider"
                  ],
                  [
                    "set",
                    "@entity.currentModel",
                    "@payload.data.currentModel"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "switching",
                "event": "SWITCHED",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@entity.currentProvider",
                    "@entity.currentModel"
                  ]
                ]
              },
              {
                "from": "active",
                "to": "switching",
                "event": "SWITCH_AUTO",
                "effects": [
                  [
                    "agent/switch-provider",
                    "@entity.fallbackProvider"
                  ],
                  [
                    "set",
                    "@entity.currentProvider",
                    "@entity.fallbackProvider"
                  ]
                ]
              },
              {
                "from": "switching",
                "to": "active",
                "event": "INIT",
                "effects": [
                  [
                    "agent/provider"
                  ],
                  [
                    "agent/model"
                  ],
                  [
                    "set",
                    "@entity.requestCount",
                    [
                      "+",
                      "@entity.requestCount",
                      1
                    ]
                  ],
                  [
                    "emit",
                    "SHOW",
                    {
                      "notificationType": "info",
                      "message": "Provider switched"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "AgentProviderPage",
          "path": "/agentproviders",
          "traits": [
            {
              "ref": "AgentProviderModal"
            },
            {
              "ref": "AgentProviderNotification"
            },
            {
              "ref": "AgentProviderAgent"
            }
          ]
        }
      ]
    }
  ]
}
