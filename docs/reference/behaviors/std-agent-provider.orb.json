                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "justify": "between",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "empty-state",
                          "icon": "repeat",
                          "description": "Click Open to view details in a modal overlay.",
                          "title": "Nothing open"
                        }
                      ],
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        {
                          "gap": "md",
                          "justify": "between",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "name": "repeat",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Switch Provider"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "icon": "repeat",
                              "action": "SWITCH",
                              "variant": "primary",
                              "label": "Open",
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "empty-state",
                          "icon": "repeat",
                          "title": "Nothing open",
                          "description": "Click Open to view details in a modal overlay."
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "AgentProvider",
                    "@payload.data",
                    {
                      "emit": {
                        "failure": "AgentProviderUpdateFailed",
                        "success": "AgentProviderUpdated"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "SWITCHED"
                  ],
                  [
                    "fetch",
                    "AgentProvider",
                    {
                      "emit": {
                        "failure": "AgentProviderLoadFailed",
                        "success": "AgentProviderLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "justify": "between",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "md",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "repeat"
                                },
                                {
                                  "content": "Switch Provider",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "type": "button",
                              "variant": "primary",
                              "action": "SWITCH",
                              "icon": "repeat",
                              "label": "Open"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "icon": "repeat",
                          "type": "empty-state",
                          "title": "Nothing open",
                          "description": "Click Open to view details in a modal overlay."
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
