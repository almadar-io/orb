                              "type": "stack",
                              "children": [
                                {
                                  "name": "repeat",
                                  "type": "icon"
                                },
                                {
                                  "content": "Switch Provider",
                                  "variant": "h2",
                                  "type": "typography"
                                }
                              ]
                            },
                            {
                              "action": "SWITCH",
                              "type": "button",
                              "label": "Open",
                              "variant": "primary",
                              "icon": "repeat"
