{
  "name": "std-agent-chat-thread",
  "version": "1.0.0",
  "description": "std-agent-chat-thread as a Function",
  "orbitals": [
    {
      "name": "AgentChatThreadOrbital",
      "entity": {
        "name": "AgentChatThread",
        "collection": "agentchatthreads",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending",
              "sent"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "role",
            "type": "string",
            "default": "user",
            "values": [
              "user",
              "assistant",
              "system",
              "tool"
            ]
          },
          {
            "name": "content",
            "type": "string",
            "default": ""
          },
          {
            "name": "timestamp",
            "type": "string",
            "default": ""
          },
          {
            "name": "toolName",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "AgentChatThreadThread",
          "category": "interaction",
          "linkedEntity": "AgentChatThread",
          "emits": [
            {
              "event": "AgentChatThreadLoaded",
              "description": "Fired when the chat thread finishes loading; payload.data holds the messages",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentChatThread]"
                }
              ]
            },
            {
              "event": "AgentChatThreadLoadFailed",
              "description": "Fired when the chat thread fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadSaved",
              "description": "Fired when a new message is persisted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadSaveFailed",
              "description": "Fired when a message persist fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadDeleted",
              "description": "Fired when the chat thread is cleared",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "AgentChatThreadDeleteFailed",
              "description": "Fired when clearing the chat thread fails",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "idle"
              },
              {
                "name": "composing"
              },
              {
                "name": "persisting"
              },
              {
                "name": "deleting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentChatThreadLoaded",
                "name": "AgentChatThread loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentChatThread]"
                  }
                ]
              },
              {
                "key": "AgentChatThreadLoadFailed",
                "name": "AgentChatThread load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "COMPOSE",
                "name": "Compose"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "content",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "CANCEL_COMPOSE",
                "name": "Cancel Compose"
              },
              {
                "key": "AgentChatThreadSaved",
                "name": "AgentChatThread saved",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadSaveFailed",
                "name": "AgentChatThread save failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadDeleted",
                "name": "AgentChatThread deleted",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "AgentChatThreadDeleteFailed",
                "name": "AgentChatThread delete failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading conversation…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "idle",
                "event": "AgentChatThreadLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "gap": "sm",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "gap": "sm",
                              "align": "center",
                              "children": [
                                {
                                  "name": "message-circle",
                                  "type": "icon"
                                },
                                {
                                  "content": "Chat Thread",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal"
                            },
                            {
                              "label": "New Message",
                              "variant": "primary",
                              "action": "COMPOSE",
                              "type": "button",
                              "icon": "plus"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-list",
                          "entity": "@payload.data",
                          "fields": [],
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "type": "stack",
                              "gap": "xs",
                              "direction": "vertical",
                              "children": [
                                {
                                  "align": "center",
                                  "children": [
                                    {
                                      "type": "badge",
                                      "label": "@item.role"
                                    },
                                    {
                                      "variant": "secondary",
                                      "label": "@item.status",
                                      "type": "badge"
                                    },
                                    {
                                      "variant": "caption",
                                      "color": "muted",
                                      "type": "typography",
                                      "content": "@item.timestamp"
                                    }
                                  ],
                                  "gap": "sm",
                                  "direction": "horizontal",
                                  "type": "stack"
                                },
                                {
                                  "type": "typography",
                                  "variant": "body",
                                  "content": "@item.content"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentChatThreadLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "icon",
                          "color": "destructive",
                          "name": "alert-triangle"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load conversation"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "body",
                          "content": "@payload.error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "variant": "primary",
                          "type": "button",
                          "action": "INIT",
                          "label": "Retry"
                        }
                      ],
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "composing",
                "event": "COMPOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "align": "center",
                          "justify": "between",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "align": "center",
                              "direction": "horizontal",
                              "gap": "sm",
                              "type": "stack",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "message-circle"
                                },
                                {
                                  "variant": "h2",
                                  "content": "Chat Thread",
                                  "type": "typography"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "type": "form-section",
                          "cancelEvent": "CANCEL_COMPOSE",
                          "submitEvent": "SEND",
                          "fields": [
                            "content"
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "deleting",
                "event": "CLEAR",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "AgentChatThread",
                    {
                      "emit": {
                        "failure": "AgentChatThreadDeleteFailed",
                        "success": "AgentChatThreadDeleted"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Clearing conversation…",
                          "color": "muted",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "persisting",
                "event": "SEND",
                "effects": [
                  [
                    "persist",
                    "create",
                    "AgentChatThread",
                    {
                      "role": "user",
                      "content": "@payload.content",
                      "timestamp": "@now",
                      "status": "sent"
                    },
                    {
                      "emit": {
                        "failure": "AgentChatThreadSaveFailed",
                        "success": "AgentChatThreadSaved"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Sending…",
                          "variant": "caption",
                          "color": "muted",
                          "type": "typography"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "composing",
                "to": "loading",
                "event": "CANCEL_COMPOSE",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "loading",
                "event": "AgentChatThreadSaved",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "failure": "AgentChatThreadLoadFailed",
                        "success": "AgentChatThreadLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "persisting",
                "to": "error",
                "event": "AgentChatThreadSaveFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "color": "destructive",
                          "name": "alert-triangle",
                          "type": "icon"
                        },
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Failed to send message"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "@payload.error",
                          "variant": "body"
                        },
                        {
                          "label": "Retry",
                          "type": "button",
                          "variant": "primary",
                          "action": "INIT",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "className": "py-12"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "loading",
                "event": "AgentChatThreadDeleted",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "error",
                "event": "AgentChatThreadDeleteFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to clear conversation",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "color": "muted",
                          "variant": "body"
                        },
                        {
                          "variant": "primary",
                          "label": "Retry",
                          "icon": "rotate-ccw",
                          "action": "INIT",
                          "type": "button"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentChatThread",
                    {
                      "emit": {
                        "success": "AgentChatThreadLoaded",
                        "failure": "AgentChatThreadLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentChatThreadPage",
          "path": "/agentchatthreads",
          "traits": [
            {
              "ref": "AgentChatThreadThread"
            }
          ]
        }
      ]
    }
  ]
}
