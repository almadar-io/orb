{
  "name": "std-ledger-entry-form",
  "version": "1.0.0",
  "description": "Tracks balanced journal-entry pairs (debit + credit) before persisting LedgerEntry rows",
  "orbitals": [
    {
      "name": "JournalTransactionOrbital",
      "uses": [
        {
          "from": "std/behaviors/std-ledger-entry",
          "as": "LedgerEntry"
        },
        {
          "from": "std/behaviors/std-chart-of-accounts",
          "as": "Account"
        },
        {
          "from": "std/behaviors/std-modal",
          "as": "Modal"
        },
        {
          "from": "std/behaviors/std-confirmation",
          "as": "Confirmation"
        }
      ],
      "entity": {
        "name": "JournalTransaction",
        "collection": "journaltransactions",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "transactionDate",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "default": ""
          },
          {
            "name": "debitAccountId",
            "type": "string",
            "default": ""
          },
          {
            "name": "debitAccountName",
            "type": "string",
            "default": ""
          },
          {
            "name": "creditAccountId",
            "type": "string",
            "default": ""
          },
          {
            "name": "creditAccountName",
            "type": "string",
            "default": ""
          },
          {
            "name": "amount",
            "type": "number",
            "default": 0
          },
          {
            "name": "referenceType",
            "type": "string",
            "default": "manual",
            "values": [
              "manual",
              "invoice",
              "bill",
              "payment"
            ]
          },
          {
            "name": "referenceId",
            "type": "string",
            "default": ""
          },
          {
            "name": "isPosted",
            "type": "boolean",
            "default": false
          },
          {
            "name": "pendingId",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "JournalTransactionBrowse",
          "category": "interaction",
          "linkedEntity": "JournalTransaction",
          "emits": [
            {
              "event": "CREATE"
            },
            {
              "event": "POST_TRANSACTION",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.transactionDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountId",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountName",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountId",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountName",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.referenceType",
                  "type": "string"
                },
                {
                  "name": "row.referenceId",
                  "type": "string"
                },
                {
                  "name": "row.isPosted",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "REQUEST_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.transactionDate",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.description",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountId",
                  "type": "string"
                },
                {
                  "name": "row.debitAccountName",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountId",
                  "type": "string"
                },
                {
                  "name": "row.creditAccountName",
                  "type": "string"
                },
                {
                  "name": "row.amount",
                  "type": "number"
                },
                {
                  "name": "row.referenceType",
                  "type": "string"
                },
                {
                  "name": "row.referenceId",
                  "type": "string"
                },
                {
                  "name": "row.isPosted",
                  "type": "boolean"
                },
                {
                  "name": "row.pendingId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "JournalTransactionLoaded",
              "description": "Fired when the journal-transaction collection finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[JournalTransaction]"
                }
              ]
            },
            {
              "event": "JournalTransactionLoadFailed",
              "description": "Fired when the journal-transaction collection fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "TRANSACTION_CREATED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionPersistor"
              }
            },
            {
              "event": "TRANSACTION_POSTED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionPersistor"
              }
            },
            {
              "event": "TRANSACTION_DELETED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionPersistor"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "JournalTransactionLoaded",
                "name": "JournalTransaction loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[JournalTransaction]"
                  }
                ]
              },
              {
                "key": "JournalTransactionLoadFailed",
                "name": "JournalTransaction load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "POST_TRANSACTION",
                "name": "Post Transaction"
              },
              {
                "key": "REQUEST_DELETE",
                "name": "Request Delete"
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "failure": "JournalTransactionLoadFailed",
                        "success": "JournalTransactionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading transactions…"
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "JournalTransactionLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "between",
                          "type": "stack",
                          "children": [
                            {
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "book-open"
                                },
                                {
                                  "content": "Journal Transactions",
                                  "type": "typography",
                                  "variant": "h2"
                                }
                              ],
                              "type": "stack",
                              "gap": "md",
                              "direction": "horizontal"
                            },
                            {
                              "type": "button",
                              "action": "CREATE",
                              "variant": "primary",
                              "label": "New Transaction",
                              "icon": "plus"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Date",
                              "variant": "caption",
                              "name": "transactionDate"
                            },
                            {
                              "label": "Description",
                              "variant": "body",
                              "name": "description"
                            },
                            {
                              "label": "Debit",
                              "variant": "caption",
                              "name": "debitAccountName"
                            },
                            {
                              "label": "Credit",
                              "name": "creditAccountName",
                              "variant": "caption"
                            },
                            {
                              "variant": "badge",
                              "label": "Amount",
                              "name": "amount"
                            },
                            {
                              "label": "Posted",
                              "variant": "badge",
                              "name": "isPosted"
                            }
                          ],
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Post",
                              "event": "POST_TRANSACTION"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "event": "REQUEST_DELETE"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "JournalTransactionLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "icon",
                          "name": "alert-triangle",
                          "color": "destructive"
                        },
                        {
                          "content": "Failed to load transactions",
                          "variant": "h3",
                          "type": "typography"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "type": "typography",
                          "content": "@payload.error"
                        },
                        {
                          "icon": "rotate-ccw",
                          "type": "button",
                          "label": "Retry",
                          "variant": "primary",
                          "action": "INIT"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "failure": "JournalTransactionLoadFailed",
                        "success": "JournalTransactionLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "JournalTransactionLoaded",
                        "failure": "JournalTransactionLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "JournalTransactionCreate",
          "category": "interaction",
          "linkedEntity": "JournalTransaction",
          "emits": [
            {
              "event": "SAVE",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "object",
                  "required": true
                }
              ]
            },
            {
              "event": "CLOSE"
            },
            {
              "event": "ModalRecordLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ModalRecordLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ModalRecord]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "CREATE",
              "triggers": "CREATE",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Open",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "row",
                    "type": "ModalRecord"
                  }
                ]
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "SAVE",
                "name": "Save",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "object",
                    "required": true
                  }
                ]
              },
              {
                "key": "ModalRecordLoadFailed",
                "name": "ModalRecord load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ModalRecordLoaded",
                "name": "ModalRecord loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ModalRecord]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "ModalRecordLoaded",
                        "failure": "ModalRecordLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "CREATE",
                "guard": [
                  "or",
                  [
                    "=",
                    "create",
                    "create"
                  ],
                  "@payload.row"
                ],
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "plus-circle",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "New Transaction"
                            }
                          ],
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.row",
                          "fields": [
                            "transactionDate",
                            "description",
                            "debitAccountId",
                            "creditAccountId",
                            "amount",
                            "referenceType",
                            "referenceId"
                          ],
                          "type": "form-section",
                          "mode": "create",
                          "submitEvent": "SAVE",
                          "cancelEvent": "CLOSE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "fields": {
              "type": "[string]",
              "default": []
            },
            "mode": {
              "type": "string",
              "default": "create"
            },
            "icon": {
              "type": "string",
              "default": "layout-panel-top"
            },
            "title": {
              "type": "string",
              "default": "Details"
            }
          },
          "scope": "instance"
        },
        {
          "name": "JournalTransactionDelete",
          "category": "interaction",
          "linkedEntity": "JournalTransaction",
          "emits": [
            {
              "event": "CONFIRM_DELETE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL"
            },
            {
              "event": "ConfirmActionLoadFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ConfirmActionLoaded",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[ConfirmAction]"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "REQUEST_DELETE",
              "triggers": "DELETE",
              "source": {
                "kind": "trait",
                "trait": "JournalTransactionBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "DELETE",
                "name": "Request",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "ConfirmAction"
                  }
                ]
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "ConfirmActionLoadFailed",
                "name": "ConfirmAction load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ConfirmActionLoaded",
                "name": "ConfirmAction loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ConfirmAction]"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "JournalTransaction",
                    {
                      "emit": {
                        "success": "ConfirmActionLoaded",
                        "failure": "ConfirmActionLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "DELETE",
                "guard": "@payload.row",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "set",
                    "@entity.name",
                    "@payload.row.name"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "type": "icon"
                            },
                            {
                              "content": "Delete Transaction",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "alert",
                          "message": "This action cannot be undone.",
                          "variant": "error"
                        },
                        {
                          "variant": "h4",
                          "content": "@entity.name",
                          "type": "typography"
                        },
                        {
                          "color": "muted",
                          "content": "@entity.pendingId",
                          "type": "typography",
                          "variant": "caption"
                        },
                        {
                          "direction": "horizontal",
                          "justify": "end",
                          "type": "stack",
                          "children": [
                            {
                              "action": "CANCEL",
                              "label": "Cancel",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "action": "CONFIRM_DELETE",
                              "variant": "danger",
                              "icon": "check",
                              "type": "button",
                              "actionPayload": {
                                "id": "@payload.id"
                              },
                              "label": "Delete"
                            }
                          ],
                          "gap": "sm"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Confirm Action"
            },
            "alertMessage": {
              "type": "string",
              "default": "Are you sure?"
            },
            "icon": {
              "type": "string",
              "default": "alert-triangle"
            },
            "confirmLabel": {
              "type": "string",
              "default": "Confirm"
            }
          },
          "scope": "instance"
        },
        {
          "name": "JournalTransactionPersistor",
          "category": "lifecycle",
          "linkedEntity": "JournalTransaction",
          "emits": [
            {
              "event": "TRANSACTION_CREATED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TRANSACTION_POSTED",
              "scope": "external",
              "payloadSchema": [
                {
