              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "ApprovalRequestLoaded",
                "name": "ApprovalRequest loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[ApprovalRequest]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "ApprovalRequestLoadFailed",
                "name": "ApprovalRequest load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh",
                "payloadSchema": [
