            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "ApprovalRequest",
                    {
                      "emit": {
                        "success": "ApprovalRequestLoaded",
                        "failure": "ApprovalRequestLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Loading approval requests…"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "ApprovalRequestLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "check-circle"
                            },
                            {
                              "type": "typography",
                              "variant": "h3",
                              "content": "Approval Requests"
                            },
                            {
                              "type": "button",
                              "action": "CREATE",
                              "variant": "primary",
                              "label": "New Approval Request"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "caption"
                            },
                            {
                              "label": "Target",
                              "name": "targetType",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "requestedBy",
                              "label": "Requested By"
                            },
                            {
                              "variant": "caption",
                              "label": "Approver",
                              "name": "assignedApprover"
                            },
                            {
                              "label": "Decision",
                              "variant": "badge",
                              "name": "approverDecision"
                            },
                            {
                              "label": "Status",
                              "name": "status",
                              "variant": "badge"
                            },
                            {
                              "variant": "caption",
                              "name": "decidedAt",
                              "label": "Decided"
                            }
                          ],
                          "cols": 1,
                          "gap": "sm",
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "variant": "secondary",
                              "label": "View"
                            },
                            {
                              "variant": "secondary",
                              "event": "EDIT",
                              "label": "Edit"
                            },
                            {
                              "label": "Approve",
                              "variant": "primary",
                              "event": "APPROVE"
                            },
                            {
                              "label": "Reject",
                              "variant": "danger",
                              "event": "REJECT"
                            },
                            {
                              "label": "Request Info",
                              "event": "REQUEST_INFO",
                              "variant": "ghost"
                            },
                            {
                              "variant": "ghost",
                              "label": "Withdraw",
                              "event": "WITHDRAW"
                            },
                            {
                              "label": "Delete",
                              "event": "REQUEST_DELETE",
                              "variant": "danger"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "ApprovalRequestLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "error",
                      "message": "@payload.message",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
