{
  "name": "std-related",
  "version": "1.0.0",
  "description": "std-related as a Function",
  "orbitals": [
    {
      "name": "RelatedItemOrbital",
      "entity": {
        "name": "RelatedItem",
        "collection": "relateditems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "RelatedItemList",
          "category": "interaction",
          "linkedEntity": "RelatedItem",
          "emits": [
            {
              "event": "RelatedItemLoaded",
              "description": "Fired when RelatedItem finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[RelatedItem]"
                }
              ]
            },
            {
              "event": "RelatedItemLoadFailed",
              "description": "Fired when RelatedItem fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "loaded"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "RelatedItemLoaded",
                "name": "RelatedItem loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[RelatedItem]"
                  }
                ]
              },
              {
                "key": "RelatedItemLoadFailed",
                "name": "RelatedItem load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "success": "RelatedItemLoaded",
                        "failure": "RelatedItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-8",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading related…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "sm",
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "loaded",
                "event": "RelatedItemLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "link",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Related"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "align": "center",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "renderItem": [
                            "fn",
                            "item",
                            {
                              "gap": "xs",
                              "type": "stack",
                              "children": [
                                {
                                  "variant": "body",
                                  "type": "typography",
                                  "content": "@item.name"
                                }
                              ],
                              "direction": "vertical"
                            }
                          ],
                          "fields": [],
                          "entity": "@payload.data",
                          "type": "data-list"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "RelatedItemLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "name": "alert-triangle",
                          "type": "icon",
                          "color": "destructive"
                        },
                        {
                          "type": "typography",
                          "content": "Failed to load related",
                          "variant": "body"
                        },
                        {
                          "type": "typography",
                          "content": "@payload.error",
                          "variant": "caption",
                          "color": "muted"
                        },
                        {
                          "variant": "ghost",
                          "type": "button",
                          "action": "INIT",
                          "icon": "rotate-ccw",
                          "label": "Retry"
                        }
                      ],
                      "align": "center",
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "sm",
                      "className": "py-8"
                    }
                  ]
                ]
              },
              {
                "from": "loaded",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "failure": "RelatedItemLoadFailed",
                        "success": "RelatedItemLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "RelatedItem",
                    {
                      "emit": {
                        "success": "RelatedItemLoaded",
                        "failure": "RelatedItemLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "Related",
          "path": "/related",
          "traits": [
            {
              "ref": "RelatedItemList"
            }
          ]
        }
      ]
    }
  ]
}
