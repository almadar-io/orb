{
  "name": "UploadFileOrbital",
  "orbitals": [
    {
      "name": "UploadFileOrbital",
      "entity": {
        "name": "UploadFile",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "fileName",
            "type": "string"
          },
          {
            "name": "fileSize",
            "type": "number"
          },
          {
            "name": "uploadStatus",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "UploadFileUpload",
          "category": "interaction",
          "linkedEntity": "UploadFile",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "uploading"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "UPLOAD"
              },
              {
                "key": "COMPLETE"
              },
              {
                "key": "FAILED"
              },
              {
                "key": "RESET"
              },
              {
                "key": "RETRY"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "upload",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Upload",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "align": "center",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "upload-drop-zone",
                          "event": "UPLOAD",
                          "multiple": false,
                          "accept": "*/*",
                          "maxSize": 10485760.0
                        }
                      ],
                      "type": "stack",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "uploading",
                "event": "UPLOAD",
                "effects": [
                  [
                    "set",
                    "@entity.fileName",
                    "@payload.fileName"
                  ],
                  [
                    "set",
                    "@entity.uploadStatus",
                    "uploading"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "type": "stack",
                          "align": "center",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "upload",
                              "size": "lg"
                            },
                            {
                              "variant": "h2",
                              "content": "Uploading...",
                              "type": "typography"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "variant": "body",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "fileName"
                          ]
                        },
                        {
                          "type": "progress-bar",
                          "value": 50.0,
                          "showPercentage": true
                        },
                        {
                          "type": "spinner",
                          "size": "md"
                        }
                      ],
                      "align": "center",
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "complete",
                "event": "COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "check-circle",
                              "size": "lg",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Upload Complete"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "success",
                          "message": "File uploaded successfully.",
                          "type": "alert"
                        },
                        {
                          "type": "typography",
                          "variant": "caption",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "fileName"
                          ],
                          "color": "muted"
                        },
                        {
                          "event": "RESET",
                          "variant": "primary",
                          "type": "button",
                          "icon": "upload",
                          "label": "Upload Another"
                        }
                      ],
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "uploading",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "error-state",
                          "message": "Something went wrong. Please try again.",
                          "onRetry": "UPLOAD",
                          "title": "Upload Failed"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "center",
                          "children": [
                            {
                              "type": "button",
                              "event": "RETRY",
                              "icon": "rotate-ccw",
                              "variant": "primary",
                              "label": "Retry"
                            },
                            {
                              "label": "Cancel",
                              "type": "button",
                              "variant": "ghost",
                              "event": "RESET"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "gap": "lg",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "children": [
                            {
                              "size": "lg",
                              "name": "upload",
                              "type": "icon"
                            },
                            {
                              "content": "Upload",
                              "variant": "h2",
                              "type": "typography"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "multiple": false,
                          "accept": "*/*",
                          "event": "UPLOAD",
                          "maxSize": 10485760.0,
                          "type": "upload-drop-zone"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "uploading",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "uploading"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "upload",
                              "type": "icon",
                              "size": "lg"
                            },
                            {
                              "type": "typography",
                              "content": "Uploading...",
                              "variant": "h2"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "sm",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "content": [
                            "object/get",
                            [
                              "array/first",
                              "@entity"
                            ],
                            "fileName"
                          ],
                          "type": "typography"
                        },
                        {
                          "showPercentage": true,
                          "type": "progress-bar",
                          "value": 50.0
                        },
                        {
                          "type": "spinner",
                          "size": "md"
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.uploadStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "lg",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "size": "lg",
                              "type": "icon",
                              "name": "upload"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Upload"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "accept": "*/*",
                          "multiple": false,
                          "event": "UPLOAD",
                          "maxSize": 10485760.0,
                          "type": "upload-drop-zone"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "UploadfilesUpload",
          "path": "/uploadfiles/upload",
          "traits": [
            {
              "ref": "UploadFileUpload"
            }
          ]
        }
      ]
    }
  ]
}
