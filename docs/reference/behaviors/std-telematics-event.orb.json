{
  "name": "std-telematics-event",
  "version": "1.0.0",
  "description": "std-telematics-event — read-only per-vehicle telemetry stream from GPS/OBD-II devices with acknowledge and severity/type filtering.",
  "orbitals": [
    {
      "name": "TelematicsEventOrbital",
      "entity": {
        "name": "TelematicsEvent",
        "collection": "telematicsevents",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "vehicleId",
            "type": "string",
            "required": true
          },
          {
            "name": "eventType",
            "type": "string",
            "default": "speeding",
            "values": [
              "hard-brake",
              "speeding",
              "idle",
              "harsh-acceleration",
              "geofence-violation",
              "engine-fault",
              "low-fuel"
            ]
          },
          {
            "name": "severity",
            "type": "string",
            "default": "info",
            "values": [
              "info",
              "warning",
              "critical"
            ]
          },
          {
            "name": "speed",
            "type": "number",
            "default": 0
          },
          {
            "name": "locationLat",
            "type": "number",
            "default": 0
          },
          {
            "name": "locationLng",
            "type": "number",
            "default": 0
          },
          {
            "name": "occurredAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "acknowledged",
            "type": "boolean",
            "default": false
          },
          {
            "name": "acknowledgedBy",
            "type": "string",
            "default": ""
          },
          {
            "name": "acknowledgedAt",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "TelematicsEventStream",
          "category": "interaction",
          "linkedEntity": "TelematicsEvent",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vehicleId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventType",
                  "type": "string"
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.speed",
                  "type": "number"
                },
                {
                  "name": "row.locationLat",
                  "type": "number"
                },
                {
                  "name": "row.locationLng",
                  "type": "number"
                },
                {
                  "name": "row.occurredAt",
                  "type": "string"
                },
                {
                  "name": "row.acknowledged",
                  "type": "boolean"
                },
                {
                  "name": "row.acknowledgedBy",
                  "type": "string"
                },
                {
                  "name": "row.acknowledgedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ACKNOWLEDGE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.vehicleId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.eventType",
                  "type": "string"
                },
                {
                  "name": "row.severity",
                  "type": "string"
                },
                {
                  "name": "row.speed",
                  "type": "number"
                },
                {
                  "name": "row.locationLat",
                  "type": "number"
                },
                {
                  "name": "row.locationLng",
                  "type": "number"
                },
                {
                  "name": "row.occurredAt",
                  "type": "string"
                },
                {
                  "name": "row.acknowledged",
                  "type": "boolean"
                },
                {
                  "name": "row.acknowledgedBy",
                  "type": "string"
                },
                {
                  "name": "row.acknowledgedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TelematicsEventLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[TelematicsEvent]"
                },
                {
                  "name": "totalCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "TelematicsEventLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TelematicsEventLoaded",
                "name": "TelematicsEvent loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[TelematicsEvent]"
                  },
                  {
                    "name": "totalCount",
                    "type": "number"
                  }
                ]
              },
              {
                "key": "TelematicsEventLoadFailed",
                "name": "TelematicsEvent load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ACKNOWLEDGE",
                "name": "Acknowledge",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFRESH",
                "name": "Refresh"
              },
              {
                "key": "FILTER_SEVERITY",
                "name": "Filter Severity",
                "payloadSchema": [
                  {
                    "name": "severity",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FILTER_TYPE",
                "name": "Filter Type",
                "payloadSchema": [
                  {
                    "name": "eventType",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "variant": "caption",
                          "content": "Loading telematics events…",
                          "type": "typography",
                          "color": "muted"
                        }
                      ],
                      "align": "center",
                      "className": "py-12",
                      "direction": "vertical",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "viewing",
                "event": "TelematicsEventLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "activity",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "Telematics Events",
                              "type": "typography"
                            }
                          ],
                          "gap": "sm"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "align": "center",
                          "children": [
                            {
                              "label": "Engine Health",
                              "thresholds": [
                                {
                                  "value": 30,
                                  "color": "danger"
                                },
                                {
                                  "value": 70,
                                  "color": "warning"
                                }
                              ],
                              "max": 100,
                              "unit": "%",
                              "variant": "radial",
                              "min": 0,
                              "type": "meter",
                              "value": 72
                            },
                            {
                              "step": 5,
                              "action": "FILTER_SEVERITY",
                              "min": 0,
                              "type": "range-slider",
                              "max": 200,
                              "showTooltip": true,
                              "value": 80
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal"
                        },
                        {
                          "cy": 60,
                          "rings": 3,
                          "maxRadius": 40,
                          "animated": true,
                          "type": "svg-pulse",
                          "color": "warning",
                          "cx": 60
                        },
                        {
                          "from": {
                            "x": 40,
                            "y": 80
                          },
                          "to": {
                            "y": 80,
                            "x": 220
                          },
                          "guardHint": "severity >= warning",
                          "isActive": true,
                          "eventLabel": "hard-brake",
                          "type": "transition-arrow"
                        },
                        {
                          "entity": "@payload.data",
                          "type": "timeline",
                          "fields": [
                            "eventType",
                            "occurredAt",
                            "severity"
                          ]
                        },
                        {
                          "entries": [],
                          "type": "event-log",
                          "label": "Live Event Stream",
                          "maxHeight": 240
                        },
                        {
                          "type": "data-grid",
                          "itemActions": [
                            {
                              "label": "Acknowledge",
                              "event": "ACKNOWLEDGE",
                              "variant": "primary"
                            },
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "secondary"
                            }
                          ],
                          "entity": "@payload.data",
                          "gap": "sm",
                          "cols": 1,
                          "fields": [
                            {
                              "variant": "caption",
                              "name": "vehicleId",
                              "label": "Vehicle"
                            },
                            {
                              "name": "eventType",
                              "label": "Type",
                              "variant": "badge"
                            },
                            {
                              "label": "Severity",
                              "variant": "badge",
                              "name": "severity"
                            },
                            {
                              "name": "speed",
                              "variant": "caption",
                              "label": "Speed"
                            },
                            {
                              "label": "Occurred",
                              "variant": "caption",
                              "name": "occurredAt"
                            },
                            {
                              "label": "Ack",
                              "name": "acknowledged",
                              "variant": "badge"
                            }
                          ]
                        }
                      ],
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TelematicsEventLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "message": "@payload.error",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "ACKNOWLEDGE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Event acknowledged",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Viewing event"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "REFRESH",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_SEVERITY",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "success": "TelematicsEventLoaded",
                        "failure": "TelematicsEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "FILTER_TYPE",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "success": "TelematicsEventLoaded",
                        "failure": "TelematicsEventLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "TelematicsEvent",
                    {
                      "emit": {
                        "failure": "TelematicsEventLoadFailed",
                        "success": "TelematicsEventLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Telematics Events"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TelematicsEventPage",
          "path": "/telematics-events",
          "traits": [
            {
              "ref": "TelematicsEventStream"
            }
          ]
        }
      ]
    }
  ]
}
