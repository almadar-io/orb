{
  "name": "std-service-redis",
  "version": "1.0.0",
  "description": "std-service-redis as a Function",
  "orbitals": [
    {
      "name": "ServiceRedisOrbital",
      "entity": {
        "name": "ServiceRedis",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "key",
            "type": "string"
          },
          {
            "name": "value",
            "type": "string"
          },
          {
            "name": "ttl",
            "type": "number",
            "default": 3600
          },
          {
            "name": "result",
            "type": "string"
          },
          {
            "name": "redisStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceRedisRedis",
          "category": "interaction",
          "linkedEntity": "ServiceRedis",
          "emits": [
            {
              "event": "ServiceRedisLoaded",
              "description": "Fired when ServiceRedis finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                },
                {
                  "name": "key",
                  "type": "string"
                },
                {
                  "name": "value",
                  "type": "string"
                },
                {
                  "name": "ttl",
                  "type": "number"
                },
                {
                  "name": "result",
                  "type": "string"
                },
                {
                  "name": "redisStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceRedisLoadFailed",
              "description": "Fired when ServiceRedis fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceRedisRedisCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceRedisRedisFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "executing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "GET_KEY",
                "name": "Get Key"
              },
              {
                "key": "SET_KEY",
                "name": "Set Key"
              },
              {
                "key": "DELETE_KEY",
                "name": "Delete Key"
              },
              {
                "key": "EXECUTED",
                "name": "Executed",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceRedisLoaded",
                "name": "ServiceRedis loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  },
                  {
                    "name": "key",
                    "type": "string"
                  },
                  {
                    "name": "value",
                    "type": "string"
                  },
                  {
                    "name": "ttl",
                    "type": "number"
                  },
                  {
                    "name": "result",
                    "type": "string"
                  },
                  {
                    "name": "redisStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceRedisLoadFailed",
                "name": "ServiceRedis load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceRedisRedisCompleted",
                "name": "ServiceRedis redis completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceRedisRedisFailed",
                "name": "ServiceRedis redis failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.key",
                    ""
                  ],
                  [
                    "set",
                    "@entity.ttl",
                    3600
                  ],
                  [
                    "set",
                    "@entity.value",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceRedis",
                    {
                      "emit": {
                        "failure": "ServiceRedisLoadFailed",
                        "success": "ServiceRedisLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "align": "center",
                          "children": [
                            {
                              "name": "database",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Redis Cache"
                            }
                          ],
                          "gap": "md",
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "placeholder": "cache-key",
                              "type": "input"
                            },
                            {
                              "placeholder": "cache-value",
                              "type": "input"
                            },
                            {
                              "placeholder": "3600",
                              "type": "input",
                              "inputType": "number"
                            }
                          ],
                          "direction": "vertical"
                        },
                        {
                          "justify": "center",
                          "children": [
                            {
                              "label": "Get",
                              "icon": "download",
                              "action": "GET_KEY",
                              "variant": "primary",
                              "type": "button"
                            },
                            {
                              "icon": "upload",
                              "label": "Set",
                              "action": "SET_KEY",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "action": "DELETE_KEY",
                              "variant": "danger",
                              "icon": "trash-2",
                              "type": "button",
                              "label": "Delete"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "sm",
                          "type": "stack"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "GET_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Running redis operation...",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "get",
                    {
                      "key": "@entity.key"
                    },
                    {
                      "emit": {
                        "failure": "ServiceRedisRedisFailed",
                        "success": "ServiceRedisRedisCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "SET_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Running redis operation...",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "set",
                    {
                      "value": "@entity.value",
                      "ttl": "@entity.ttl",
                      "key": "@entity.key"
                    },
                    {
                      "emit": {
                        "success": "ServiceRedisRedisCompleted",
                        "failure": "ServiceRedisRedisFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "DELETE_KEY",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "title": "Executing...",
                      "message": "Running redis operation...",
                      "type": "loading-state"
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "delete",
                    {
                      "key": "@entity.key"
                    },
                    {
                      "emit": {
                        "success": "ServiceRedisRedisCompleted",
                        "failure": "ServiceRedisRedisFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "complete",
                "event": "EXECUTED",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "variant": "success",
                          "message": "Operation complete",
                          "type": "alert"
                        },
                        {
                          "variant": "body",
                          "color": "muted",
                          "content": "@entity.result",
                          "type": "typography"
                        },
                        {
                          "label": "Reset",
                          "icon": "rotate-ccw",
                          "type": "button",
                          "variant": "ghost",
                          "action": "RESET"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.error",
                      "type": "error-state",
                      "title": "Redis Error",
                      "onRetry": "RESET"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "align": "center",
                          "gap": "md",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "database"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "Redis Cache"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "placeholder": "cache-key",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "placeholder": "cache-value"
                            },
                            {
                              "placeholder": "3600",
                              "type": "input",
                              "inputType": "number"
                            }
                          ],
                          "direction": "vertical",
                          "gap": "md"
                        },
                        {
                          "gap": "sm",
                          "type": "stack",
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "GET_KEY",
                              "type": "button",
                              "label": "Get",
                              "variant": "primary",
                              "icon": "download"
                            },
                            {
                              "icon": "upload",
                              "variant": "primary",
                              "type": "button",
                              "action": "SET_KEY",
                              "label": "Set"
                            },
                            {
                              "action": "DELETE_KEY",
                              "variant": "danger",
                              "type": "button",
                              "label": "Delete",
                              "icon": "trash-2"
                            }
                          ]
                        }
                      ],
                      "gap": "lg",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "align": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "icon",
                              "name": "database"
                            },
                            {
                              "variant": "h2",
                              "content": "Redis Cache",
                              "type": "typography"
                            }
                          ],
                          "gap": "md",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "type": "input",
                              "placeholder": "cache-key"
                            },
                            {
                              "type": "input",
                              "placeholder": "cache-value"
                            },
                            {
                              "placeholder": "3600",
                              "type": "input",
                              "inputType": "number"
                            }
                          ]
                        },
                        {
                          "justify": "center",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "action": "GET_KEY",
                              "icon": "download",
                              "label": "Get",
                              "variant": "primary",
                              "type": "button"
                            },
                            {
                              "label": "Set",
                              "type": "button",
                              "icon": "upload",
                              "action": "SET_KEY",
                              "variant": "primary"
                            },
                            {
                              "variant": "danger",
                              "label": "Delete",
                              "type": "button",
                              "icon": "trash-2",
                              "action": "DELETE_KEY"
                            }
                          ],
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceRedisPage",
          "path": "/servicerediss",
          "traits": [
            {
              "ref": "ServiceRedisRedis"
            }
          ]
        }
      ]
    }
  ]
}
