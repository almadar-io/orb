{
  "name": "std-service-redis",
  "version": "2.0.0",
  "description": "std-service-redis — Redis cache service. Bind via `uses Redis from \"std/behaviors/std-service-redis\"` and configure `op` / `key` / `value` / `ttl` at the call site. Pass `uiTrait: \"@trait.YourRedisForm\"` to inject your own form; leave unset to render the atom's default form (standalone surface).",
  "orbitals": [
    {
      "name": "ServiceRedisOrbital",
      "entity": {
        "name": "ServiceRedis",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "key",
            "type": "string",
            "default": ""
          },
          {
            "name": "value",
            "type": "string",
            "default": ""
          },
          {
            "name": "ttl",
            "type": "number",
            "default": 0
          },
          {
            "name": "op",
            "type": "string",
            "default": "get",
            "values": [
              "get",
              "set",
              "del"
            ]
          },
          {
            "name": "result",
            "type": "object",
            "default": {}
          },
          {
            "name": "redisStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceRedisDefaultForm",
          "category": "interaction",
          "emits": [
            {
              "event": "EXEC",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXEC",
                "name": "Exec"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "type": "stack",
                          "children": [
                            {
                              "name": "database",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Redis Cache",
                              "variant": "h2"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "vertical",
                          "children": [
                            {
                              "type": "select",
                              "options": [
                                {
                                  "value": "get",
                                  "label": "Get"
                                },
                                {
                                  "label": "Set",
                                  "value": "set"
                                },
                                {
                                  "label": "Delete",
                                  "value": "del"
                                }
                              ]
                            },
                            {
                              "placeholder": "cache-key",
                              "type": "input"
                            },
                            {
                              "placeholder": "cache-value",
                              "type": "input"
                            },
                            {
                              "type": "input",
                              "inputType": "number",
                              "placeholder": "ttl seconds"
                            }
                          ]
                        },
                        {
                          "variant": "primary",
                          "icon": "play",
                          "type": "button",
                          "label": "Execute",
                          "action": "EXEC"
                        }
                      ],
                      "align": "center"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceRedisRedis",
          "category": "interaction",
          "linkedEntity": "ServiceRedis",
          "emits": [
            {
              "event": "ServiceRedisLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceRedisLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "RedisDone",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceRedisRedisFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "EXEC",
              "triggers": "EXEC",
              "source": {
                "kind": "trait",
                "trait": "ServiceRedisDefaultForm"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "executing"
              },
              {
                "name": "complete"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "EXEC",
                "name": "Exec"
              },
              {
                "key": "ServiceRedisLoaded",
                "name": "ServiceRedis loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceRedisLoadFailed",
                "name": "ServiceRedis load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RedisDone",
                "name": "Redis done",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "ServiceRedisRedisFailed",
                "name": "ServiceRedis redis failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.key",
                    ""
                  ],
                  [
                    "set",
                    "@entity.value",
                    ""
                  ],
                  [
                    "set",
                    "@entity.ttl",
                    0
                  ],
                  [
                    "set",
                    "@entity.op",
                    "get"
                  ],
                  [
                    "fetch",
                    "ServiceRedis",
                    {
                      "emit": {
                        "failure": "ServiceRedisLoadFailed",
                        "success": "ServiceRedisLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "children": [
                        "@trait.ServiceRedisDefaultForm"
                      ],
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "executing",
                "event": "EXEC",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Running redis operation...",
                      "title": "Executing..."
                    }
                  ],
                  [
                    "call-service",
                    "redis",
                    "get",
                    {
                      "key": "",
                      "value": "",
                      "ttl": 0
                    },
                    {
                      "emit": {
                        "success": "RedisDone",
                        "failure": "FAILED"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceRedisLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceRedisLoadFailed"
              },
              {
                "from": "executing",
                "to": "complete",
                "event": "RedisDone",
                "effects": [
                  [
                    "set",
                    "@entity.result",
                    "@payload.result"
                  ],
                  [
                    "set",
                    "@entity.redisStatus",
                    "succeeded"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "name": "check-circle",
                          "type": "icon"
                        },
                        {
                          "type": "alert",
                          "message": "Operation complete",
                          "variant": "success"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "content": "@entity.result",
                          "variant": "body"
                        },
                        {
                          "type": "button",
                          "label": "Reset",
                          "action": "RESET",
                          "icon": "rotate-ccw",
                          "variant": "ghost"
                        }
                      ],
                      "direction": "vertical",
                      "type": "stack",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "executing",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceRedisRedisFailed",
                    {
                      "code": "redis_op_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@entity.error",
                      "title": "Redis Error",
                      "type": "error-state",
                      "onRetry": "RESET"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        "@trait.ServiceRedisDefaultForm"
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "complete",
                "to": "complete",
                "event": "RedisDone"
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceRedisRedisFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceRedisDefaultForm"
                      ],
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "ttl": {
              "type": "number",
              "default": 0
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceRedisDefaultForm"
            },
            "key": {
              "type": "string",
              "default": ""
            },
            "value": {
              "type": "string",
              "default": ""
            },
            "op": {
              "type": "string",
              "default": "get",
              "values": [
                "get",
                "set",
                "del"
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceRedisPage",
          "path": "/servicerediss",
          "traits": [
            {
              "ref": "ServiceRedisRedis"
            }
          ]
        }
      ]
    }
  ]
}
