{
  "name": "std-file-store",
  "version": "1.0.0",
  "description": "std-file-store — generic file + folder + metadata primitive consumed by document-mgmt, legal-case, and any organism that needs a file store. Fetches StoredFile rows on INIT and renders them in a data-grid with per-row Download/Archive actions.",
  "orbitals": [
    {
      "name": "StoredFileOrbital",
      "entity": {
        "name": "StoredFile",
        "collection": "storedfiles",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "path",
            "type": "string",
            "default": ""
          },
          {
            "name": "mimeType",
            "type": "string",
            "default": ""
          },
          {
            "name": "sizeBytes",
            "type": "number",
            "default": 0
          },
          {
            "name": "uploaderId",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploaderName",
            "type": "string",
            "default": ""
          },
          {
            "name": "folder",
            "type": "string",
            "default": ""
          },
          {
            "name": "uploadedAt",
            "type": "string",
            "default": ""
          },
          {
            "name": "isArchived",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "StoredFileStore",
          "category": "interaction",
          "linkedEntity": "StoredFile",
          "emits": [
            {
              "event": "DOWNLOAD_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "ARCHIVE_FILE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "StoredFileLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[StoredFile]"
                }
              ]
            },
            {
              "event": "StoredFileLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "StoredFileLoaded",
                "name": "StoredFile loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[StoredFile]"
                  }
                ]
              },
              {
                "key": "StoredFileLoadFailed",
                "name": "StoredFile load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DOWNLOAD_FILE",
                "name": "Download File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ARCHIVE_FILE",
                "name": "Archive File",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "failure": "StoredFileLoadFailed",
                        "success": "StoredFileLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "type": "stack",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "caption",
                          "content": "Loading files…"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "StoredFileLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "variant": "h3",
                          "type": "typography",
                          "content": "Files"
                        },
                        {
                          "type": "doc-breadcrumb",
                          "items": [
                            {
                              "label": "Workspace",
                              "href": "/"
                            },
                            {
                              "label": "Files",
                              "href": "/files"
                            },
                            {
                              "label": "All Documents"
                            }
                          ]
                        },
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack",
                          "children": [
                            {
                              "tree": [
                                {
                                  "path": "Contracts",
                                  "name": "Contracts",
                                  "children": [
                                    {
                                      "path": "Active.pdf",
                                      "type": "file",
                                      "name": "Active.pdf"
                                    },
                                    {
                                      "name": "Archived.pdf",
                                      "type": "file",
                                      "path": "Archived.pdf"
                                    }
                                  ],
                                  "type": "dir"
                                },
                                {
                                  "children": [
                                    {
                                      "name": "HR.docx"
                                    },
                                    {
                                      "name": "Security.md"
                                    }
                                  ],
                                  "name": "Policies"
                                },
                                {
                                  "name": "Templates",
                                  "children": [
                                    {
                                      "name": "Invoice.docx"
                                    },
                                    {
                                      "name": "NDA.pdf"
                                    }
                                  ]
                                }
                              ],
                              "type": "file-tree"
                            },
                            {
                              "gap": "sm",
                              "direction": "vertical",
                              "children": [
                                {
                                  "type": "upload-drop-zone",
                                  "maxFiles": 5,
                                  "description": "or click to browse",
                                  "accept": "*/*",
                                  "label": "Drop files here",
                                  "maxSize": 10485760,
                                  "icon": "upload"
                                },
                                {
                                  "items": [
                                    {
                                      "id": "recent",
                                      "content": "Files uploaded in the last 7 days.",
                                      "title": "Recent Uploads"
                                    },
                                    {
                                      "title": "Shared With Me",
                                      "content": "Files shared by collaborators.",
                                      "id": "shared"
                                    },
                                    {
                                      "content": "Files you have flagged for quick access.",
                                      "title": "Starred",
                                      "id": "starred"
                                    }
                                  ],
                                  "type": "accordion"
                                }
                              ],
                              "type": "stack"
                            }
                          ]
                        },
                        {
                          "type": "tag-cloud",
                          "variant": "primary",
                          "tags": [
                            {
                              "label": "Contracts"
                            },
                            {
                              "label": "Policies"
                            },
                            {
                              "label": "Templates"
                            },
                            {
                              "label": "Archive"
                            },
                            {
                              "label": "Drafts"
                            },
                            {
                              "label": "Public"
                            }
                          ]
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Download",
                              "event": "DOWNLOAD_FILE",
                              "variant": "primary"
                            },
                            {
                              "event": "ARCHIVE_FILE",
                              "variant": "danger",
                              "label": "Archive"
                            }
                          ],
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "label": "Name",
                              "name": "name"
                            },
                            {
                              "name": "folder",
                              "label": "Folder"
                            },
                            {
                              "label": "Type",
                              "name": "mimeType"
                            },
                            {
                              "name": "sizeBytes",
                              "label": "Size"
                            },
                            {
                              "label": "Uploaded",
                              "name": "uploadedAt"
                            }
                          ],
                          "type": "data-grid"
                        },
                        {
                          "totalPages": 8,
                          "type": "pagination",
                          "currentPage": 1,
                          "showTotal": true,
                          "showPageSize": false,
                          "totalItems": 80
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "StoredFileLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DOWNLOAD_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Download requested"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "ARCHIVE_FILE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "variant": "info",
                      "type": "alert",
                      "message": "Archive requested"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "StoredFile",
                    {
                      "emit": {
                        "success": "StoredFileLoaded",
                        "failure": "StoredFileLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "content": "Loading files…",
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ]
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Files"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "StoredFilePage",
          "path": "/files",
          "traits": [
            {
              "ref": "StoredFileStore"
            }
          ]
        }
      ]
    }
  ]
}
