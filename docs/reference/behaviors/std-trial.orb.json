{
  "name": "std-trial",
  "version": "1.0.0",
  "description": "std-trial — subscription trial countdown with auto-convert at expiry. Owns a Trial entity; CONVERT flips status to converted and stamps convertedAt, EXPIRE flips to expired, CANCEL flips to cancelled. Persists results back to the row and emits TrialUpdated / TrialConverted for downstream listeners.",
  "orbitals": [
    {
      "name": "TrialOrbital",
      "entity": {
        "name": "Trial",
        "collection": "trials",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "planId",
            "type": "string",
            "required": true
          },
          {
            "name": "startedAt",
            "type": "string"
          },
          {
            "name": "expiresAt",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "converted",
              "expired",
              "cancelled"
            ]
          },
          {
            "name": "convertedAt",
            "type": "string"
          },
          {
            "name": "notifiedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TrialManage",
          "category": "interaction",
          "linkedEntity": "Trial",
          "emits": [
            {
              "event": "CONVERT",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "convertedAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EXPIRE",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Trial]"
                }
              ]
            },
            {
              "event": "TrialLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialConverted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "converting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TrialLoaded",
                "name": "Trial loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Trial]"
                  }
                ]
              },
              {
                "key": "TrialLoadFailed",
                "name": "Trial load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONVERT",
                "name": "Convert",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "convertedAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "EXPIRE",
                "name": "Expire",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "TrialUpdated",
                "name": "Trial updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "TrialConverted",
                "name": "Trial converted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical",
                      "gap": "md",
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "variant": "caption",
                          "type": "typography",
                          "content": "Loading trials…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TrialLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "content": "Trials",
                              "variant": "h3",
                              "type": "typography"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": {
                            "title": "Free trial",
                            "body": "Try every feature for fourteen days. No credit card needed."
                          },
                          "type": "about-page-template"
                        },
                        {
                          "color": "primary",
                          "max": 14,
                          "label": "Trial day nine of fourteen",
                          "value": 9,
                          "type": "progress-bar",
                          "showPercentage": false
                        },
                        {
                          "front": {
                            "gap": "sm",
                            "direction": "vertical",
                            "children": [
                              {
                                "type": "icon",
                                "name": "sparkles"
                              },
                              {
                                "content": "Your trial",
                                "variant": "h4",
                                "type": "typography"
                              },
                              {
                                "content": "Hover or tap to see what's next",
                                "variant": "caption",
                                "type": "typography",
                                "color": "muted"
                              }
                            ],
                            "type": "stack",
                            "className": "p-6",
                            "align": "center"
                          },
                          "height": "h-48",
                          "back": {
                            "align": "center",
                            "gap": "sm",
                            "direction": "vertical",
                            "children": [
                              {
                                "content": "Upgrade soon",
                                "type": "typography",
                                "variant": "h4"
                              },
                              {
                                "variant": "caption",
                                "type": "typography",
                                "content": "Convert to keep your data and unlock unlimited usage."
                              }
                            ],
                            "className": "p-6",
                            "type": "stack"
                          },
                          "type": "flip-card"
                        },
                        {
                          "trigger": "scroll",
                          "type": "animated-reveal",
                          "duration": 600,
                          "animation": "fade-up",
                          "children": [
                            {
                              "message": "Convert your trial today to keep your current usage tier.",
                              "title": "Lock in your plan",
                              "variant": "info",
                              "type": "alert"
                            }
                          ]
                        },
                        {
                          "itemActions": [
                            {
                              "variant": "primary",
                              "label": "Convert",
                              "icon": "check",
                              "event": "CONVERT"
                            },
                            {
                              "label": "Expire",
                              "variant": "secondary",
                              "icon": "clock",
                              "event": "EXPIRE"
                            },
                            {
                              "icon": "x",
                              "variant": "danger",
                              "label": "Cancel",
                              "event": "CANCEL"
                            }
                          ],
                          "gap": "sm",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "customerId",
                              "variant": "caption",
                              "label": "Customer"
                            },
                            {
                              "label": "Plan",
                              "variant": "caption",
                              "name": "planId"
                            },
                            {
                              "variant": "badge",
                              "label": "Status",
                              "name": "status"
                            },
                            {
                              "label": "Started",
                              "variant": "caption",
                              "name": "startedAt"
                            },
                            {
                              "label": "Expires",
                              "variant": "caption",
                              "name": "expiresAt"
                            },
                            {
                              "label": "Converted",
                              "name": "convertedAt",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "notifiedAt",
                              "label": "Notified"
                            }
                          ],
                          "type": "data-grid",
                          "cols": 1
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TrialLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "converting",
                "event": "CONVERT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "converted"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialConverted",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "className": "py-12",
                      "align": "center",
                      "direction": "vertical",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "type": "typography",
                          "variant": "caption",
                          "content": "Converting trial…"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EXPIRE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "expired"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialUpdated",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TrialUpdated",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "converting",
                "to": "loading",
                "event": "TrialConverted",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Trials"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TrialManagePage",
          "path": "/trials/manage",
          "traits": [
            {
              "ref": "TrialManage"
            }
          ]
        }
      ]
    }
  ]
}
