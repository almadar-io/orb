{
  "name": "std-trial",
  "version": "1.0.0",
  "description": "std-trial — subscription trial countdown with auto-convert at expiry. Owns a Trial entity; CONVERT flips status to converted and stamps convertedAt, EXPIRE flips to expired, CANCEL flips to cancelled. Persists results back to the row and emits TrialUpdated / TrialConverted for downstream listeners.",
  "orbitals": [
    {
      "name": "TrialOrbital",
      "entity": {
        "name": "Trial",
        "collection": "trials",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "planId",
            "type": "string",
            "required": true
          },
          {
            "name": "startedAt",
            "type": "string"
          },
          {
            "name": "expiresAt",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "converted",
              "expired",
              "cancelled"
            ]
          },
          {
            "name": "convertedAt",
            "type": "string"
          },
          {
            "name": "notifiedAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "TrialManage",
          "category": "interaction",
          "linkedEntity": "Trial",
          "emits": [
            {
              "event": "CONVERT",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "convertedAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "EXPIRE",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "CANCEL",
              "payloadSchema": [
                {
                  "name": "trialId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[Trial]"
                }
              ]
            },
            {
              "event": "TrialLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "TrialConverted",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.planId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.startedAt",
                  "type": "string"
                },
                {
                  "name": "row.expiresAt",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.convertedAt",
                  "type": "string"
                },
                {
                  "name": "row.notifiedAt",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "converting"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TrialLoaded",
                "name": "Trial loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[Trial]"
                  }
                ]
              },
              {
                "key": "TrialLoadFailed",
                "name": "Trial load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CONVERT",
                "name": "Convert",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "convertedAt",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "EXPIRE",
                "name": "Expire",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel",
                "payloadSchema": [
                  {
                    "name": "trialId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "TrialUpdated",
                "name": "Trial updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              },
              {
                "key": "TrialConverted",
                "name": "Trial converted",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "Trial"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "gap": "md",
                      "direction": "vertical",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading trials…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "TrialLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "type": "stack",
                          "children": [
                            {
                              "type": "icon",
                              "name": "clock"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Trials"
                            }
                          ],
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "@payload.data",
                          "itemActions": [
                            {
                              "icon": "check",
                              "variant": "primary",
                              "event": "CONVERT",
                              "label": "Convert"
                            },
                            {
                              "label": "Expire",
                              "icon": "clock",
                              "event": "EXPIRE",
                              "variant": "secondary"
                            },
                            {
                              "event": "CANCEL",
                              "variant": "danger",
                              "icon": "x",
                              "label": "Cancel"
                            }
                          ],
                          "cols": 1,
                          "fields": [
                            {
                              "name": "customerId",
                              "label": "Customer",
                              "variant": "caption"
                            },
                            {
                              "label": "Plan",
                              "name": "planId",
                              "variant": "caption"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            },
                            {
                              "label": "Started",
                              "variant": "caption",
                              "name": "startedAt"
                            },
                            {
                              "label": "Expires",
                              "variant": "caption",
                              "name": "expiresAt"
                            },
                            {
                              "name": "convertedAt",
                              "variant": "caption",
                              "label": "Converted"
                            },
                            {
                              "label": "Notified",
                              "variant": "caption",
                              "name": "notifiedAt"
                            }
                          ],
                          "type": "data-grid",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "TrialLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "type": "alert",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "converting",
                "event": "CONVERT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "converted"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialConverted",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "content": "Converting trial…",
                          "variant": "caption"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EXPIRE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "expired"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialUpdated",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.trialId"
                  ],
                  [
                    "set",
                    "@entity.subscriptionId",
                    "@payload.row.subscriptionId"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.planId",
                    "@payload.row.planId"
                  ],
                  [
                    "set",
                    "@entity.startedAt",
                    "@payload.row.startedAt"
                  ],
                  [
                    "set",
                    "@entity.expiresAt",
                    "@payload.row.expiresAt"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "cancelled"
                  ],
                  [
                    "set",
                    "@entity.convertedAt",
                    "@payload.row.convertedAt"
                  ],
                  [
                    "set",
                    "@entity.notifiedAt",
                    "@payload.row.notifiedAt"
                  ],
                  [
                    "persist",
                    "update",
                    "Trial",
                    "@entity",
                    {
                      "emit": {
                        "success": "TrialUpdated",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "TrialUpdated",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "converting",
                "to": "loading",
                "event": "TrialConverted",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "success": "TrialLoaded",
                        "failure": "TrialLoadFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "Trial",
                    {
                      "emit": {
                        "failure": "TrialLoadFailed",
                        "success": "TrialLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "size": "sm",
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Trials"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "TrialManagePage",
          "path": "/trials/manage",
          "traits": [
            {
              "ref": "TrialManage"
            }
          ]
        }
      ]
    }
  ]
}
