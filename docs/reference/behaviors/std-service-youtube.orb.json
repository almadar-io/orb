{
  "name": "std-service-youtube",
  "version": "2.0.0",
  "description": "std-service-youtube. YouTube embed service. Bind via `uses Youtube from \"std/behaviors/std-service-youtube\"` and configure `videoId` / `autoplay` / `controls` / `start` at the call site. SPECIAL: the default render IS the embed itself, so passing `uiTrait: \"@trait.YourPlayerSkin\"` OVERRIDES the embed (e.g., a custom player skin) rather than supplements it. Leave `uiTrait` unset to render the atom's default embed.",
  "orbitals": [
    {
      "name": "ServiceYoutubeOrbital",
      "entity": {
        "name": "ServiceYoutube",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "videoId",
            "type": "string",
            "default": ""
          },
          {
            "name": "autoplay",
            "type": "boolean",
            "default": false
          },
          {
            "name": "controls",
            "type": "boolean",
            "default": true
          },
          {
            "name": "start",
            "type": "number",
            "default": 0
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceYoutubeDefaultPlayer",
          "category": "interaction",
          "emits": [
            {
              "event": "PLAY",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            },
            {
              "event": "READY",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "source",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "ready",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "PLAY",
                "name": "Play"
              },
              {
                "key": "READY",
                "name": "Ready"
              }
            ],
            "transitions": [
              {
                "from": "ready",
                "to": "ready",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "name": "video",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "variant": "h2",
                              "content": "YouTube Video"
                            },
                            {
                              "type": "typography",
                              "color": "muted",
                              "variant": "body",
                              "content": "@config.videoId"
                            },
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "children": [
                                {
                                  "action": "PLAY",
                                  "icon": "play",
                                  "label": "Play",
                                  "type": "button",
                                  "variant": "primary"
                                }
                              ],
                              "justify": "center"
                            }
                          ],
                          "align": "center",
                          "direction": "vertical",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "type": "card"
                    }
                  ]
                ]
              },
              {
                "from": "ready",
                "to": "ready",
                "event": "PLAY",
                "effects": [
                  [
                    "emit",
                    "PLAY",
                    {
                      "source": "default-player"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        },
        {
          "name": "ServiceYoutubeYoutube",
          "category": "interaction",
          "linkedEntity": "ServiceYoutube",
          "emits": [
            {
              "event": "ServiceYoutubeLoaded",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeLoadFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeYoutubeReady",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "videoId",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeYoutubeFailed",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "FAILED",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "READY",
              "triggers": "READY",
              "source": {
                "kind": "trait",
                "trait": "ServiceYoutubeDefaultPlayer"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "ready"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "READY",
                "name": "Ready"
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "ServiceYoutubeLoaded",
                "name": "ServiceYoutube loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeLoadFailed",
                "name": "ServiceYoutube load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeYoutubeReady",
                "name": "ServiceYoutube youtube ready",
                "payloadSchema": [
                  {
                    "name": "videoId",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeYoutubeFailed",
                "name": "ServiceYoutube youtube failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "RETRY",
                "name": "Retry"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.videoId",
                    ""
                  ],
                  [
                    "set",
                    "@entity.autoplay",
                    false
                  ],
                  [
                    "set",
                    "@entity.controls",
                    true
                  ],
                  [
                    "set",
                    "@entity.start",
                    0
                  ],
                  [
                    "fetch",
                    "ServiceYoutube",
                    {
                      "emit": {
                        "success": "ServiceYoutubeLoaded",
                        "failure": "ServiceYoutubeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceYoutubeDefaultPlayer"
                      ],
                      "type": "stack",
                      "gap": "md"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "ready",
                "event": "READY",
                "effects": [
                  [
                    "emit",
                    "ServiceYoutubeYoutubeReady",
                    {
                      "videoId": "@entity.videoId"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical",
                      "children": [
                        "@trait.ServiceYoutubeDefaultPlayer"
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceYoutubeYoutubeFailed",
                    {
                      "error": "@entity.error",
                      "code": "youtube_embed_failed"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "error-state",
                      "message": "@entity.error",
                      "title": "Video Failed",
                      "onRetry": "RETRY"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceYoutubeLoaded"
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "ServiceYoutubeLoadFailed"
              },
              {
                "from": "ready",
                "to": "ready",
                "event": "ServiceYoutubeYoutubeReady"
              },
              {
                "from": "ready",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "emit",
                    "ServiceYoutubeYoutubeFailed",
                    {
                      "code": "youtube_playback_failed",
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "onRetry": "RETRY",
                      "title": "Video Failed",
                      "type": "error-state",
                      "message": "@entity.error"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "error",
                "event": "ServiceYoutubeYoutubeFailed"
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RETRY",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "emit",
                    "FAILED",
                    {
                      "error": "@entity.error"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        "@trait.ServiceYoutubeDefaultPlayer"
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "controls": {
              "type": "boolean",
              "default": true
            },
            "start": {
              "type": "number",
              "default": 0
            },
            "autoplay": {
              "type": "boolean",
              "default": false
            },
            "videoId": {
              "type": "string",
              "default": ""
            },
            "uiTrait": {
              "type": "trait",
              "default": "@trait.ServiceYoutubeDefaultPlayer"
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceYoutubePage",
          "path": "/serviceyoutubes",
          "traits": [
            {
              "ref": "ServiceYoutubeYoutube"
            }
          ]
        }
      ]
    }
  ]
}
