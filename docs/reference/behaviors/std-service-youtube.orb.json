{
  "name": "std-service-youtube",
  "version": "1.0.0",
  "description": "std-service-youtube as a Function",
  "orbitals": [
    {
      "name": "ServiceYoutubeOrbital",
      "entity": {
        "name": "ServiceYoutube",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "selectedVideoId",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoTitle",
            "type": "string",
            "default": ""
          },
          {
            "name": "videoDescription",
            "type": "string",
            "default": ""
          },
          {
            "name": "searchStatus",
            "type": "string",
            "default": "idle"
          },
          {
            "name": "error",
            "type": "string",
            "default": ""
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ServiceYoutubeYoutube",
          "category": "interaction",
          "linkedEntity": "ServiceYoutube",
          "emits": [
            {
              "event": "ServiceYoutubeLoaded",
              "description": "Fired when ServiceYoutube finishes loading",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "query",
                  "type": "string"
                },
                {
                  "name": "selectedVideoId",
                  "type": "string"
                },
                {
                  "name": "videoTitle",
                  "type": "string"
                },
                {
                  "name": "videoDescription",
                  "type": "string"
                },
                {
                  "name": "searchStatus",
                  "type": "string"
                },
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "name",
                  "type": "string"
                },
                {
                  "name": "description",
                  "type": "string"
                },
                {
                  "name": "status",
                  "type": "string"
                },
                {
                  "name": "createdAt",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeLoadFailed",
              "description": "Fired when ServiceYoutube fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "message",
                  "type": "string"
                }
              ]
            },
            {
              "event": "ServiceYoutubeYoutubeCompleted",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "result",
                  "type": "object"
                }
              ]
            },
            {
              "event": "ServiceYoutubeYoutubeFailed",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              },
              {
                "name": "results"
              },
              {
                "name": "viewingDetail"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "SEARCH_COMPLETE",
                "name": "Search Complete",
                "payloadSchema": [
                  {
                    "name": "results",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "FAILED",
                "name": "Failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "SELECT_VIDEO",
                "name": "Select Video",
                "payloadSchema": [
                  {
                    "name": "videoId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "RESET",
                "name": "Reset"
              },
              {
                "key": "VIDEO_LOADED",
                "name": "Video Loaded",
                "payloadSchema": [
                  {
                    "name": "title",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "BACK",
                "name": "Back"
              },
              {
                "key": "ServiceYoutubeLoaded",
                "name": "ServiceYoutube loaded",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "query",
                    "type": "string"
                  },
                  {
                    "name": "selectedVideoId",
                    "type": "string"
                  },
                  {
                    "name": "videoTitle",
                    "type": "string"
                  },
                  {
                    "name": "videoDescription",
                    "type": "string"
                  },
                  {
                    "name": "searchStatus",
                    "type": "string"
                  },
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "description",
                    "type": "string"
                  },
                  {
                    "name": "status",
                    "type": "string"
                  },
                  {
                    "name": "createdAt",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeLoadFailed",
                "name": "ServiceYoutube load failed",
                "payloadSchema": [
                  {
                    "name": "message",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeYoutubeCompleted",
                "name": "ServiceYoutube youtube completed",
                "payloadSchema": [
                  {
                    "name": "result",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "ServiceYoutubeYoutubeFailed",
                "name": "ServiceYoutube youtube failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.query",
                    ""
                  ],
                  [
                    "fetch",
                    "ServiceYoutube",
                    {
                      "emit": {
                        "success": "ServiceYoutubeLoaded",
                        "failure": "ServiceYoutubeLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "type": "stack",
                      "children": [
                        {
                          "direction": "horizontal",
                          "align": "center",
                          "children": [
                            {
                              "type": "icon",
                              "name": "video"
                            },
                            {
                              "type": "typography",
                              "content": "YouTube Search",
                              "variant": "h2"
                            }
                          ],
                          "type": "stack",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "Search YouTube videos...",
                          "type": "input"
                        },
                        {
                          "label": "Search",
                          "action": "SEARCH",
                          "type": "button",
                          "variant": "primary",
                          "icon": "search"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "title": "Searching...",
                      "message": "Searching YouTube for videos..."
                    }
                  ],
                  [
                    "call-service",
                    "youtube",
                    "search",
                    {
                      "query": "@entity.query",
                      "maxResults": 10,
                      "type": "video"
                    },
                    {
                      "emit": {
                        "failure": "ServiceYoutubeYoutubeFailed",
                        "success": "ServiceYoutubeYoutubeCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "results",
                "event": "SEARCH_COMPLETE",
                "effects": [
                  [
                    "set",
                    "@entity.searchStatus",
                    "complete"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "gap": "md",
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "name": "video",
                              "type": "icon"
                            },
                            {
                              "content": "Search Results",
                              "type": "typography",
                              "variant": "h2"
                            }
                          ],
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "Select a video to view details.",
                          "variant": "body",
                          "type": "typography"
                        },
                        {
                          "type": "stack",
                          "gap": "sm",
                          "justify": "center",
                          "direction": "horizontal",
                          "children": [
                            {
                              "action": "RESET",
                              "icon": "rotate-ccw",
                              "label": "New Search",
                              "variant": "ghost",
                              "type": "button"
                            },
                            {
                              "icon": "search",
                              "action": "SEARCH",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Search Again"
                            }
                          ]
                        }
                      ],
                      "align": "stretch",
                      "gap": "lg",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "error",
                "event": "FAILED",
                "effects": [
                  [
                    "set",
                    "@entity.error",
                    "@payload.error"
                  ],
                  [
                    "set",
                    "@entity.searchStatus",
                    "error"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "message": "@entity.error",
                          "onRetry": "SEARCH",
                          "type": "error-state",
                          "title": "Search Failed"
                        },
                        {
                          "justify": "center",
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "label": "Retry",
                              "action": "SEARCH",
                              "icon": "refresh-cw",
                              "variant": "primary"
                            },
                            {
                              "type": "button",
                              "action": "RESET",
                              "label": "Reset",
                              "icon": "rotate-ccw",
                              "variant": "ghost"
                            }
                          ]
                        }
                      ],
                      "type": "stack",
                      "align": "center",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Searching YouTube for videos...",
                      "type": "loading-state",
                      "title": "Searching..."
                    }
                  ],
                  [
                    "call-service",
                    "youtube",
                    "search",
                    {
                      "type": "video",
                      "maxResults": 10,
                      "query": "@entity.query"
                    },
                    {
                      "emit": {
                        "success": "ServiceYoutubeYoutubeCompleted",
                        "failure": "ServiceYoutubeYoutubeFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "viewingDetail",
                "event": "SELECT_VIDEO",
                "effects": [
                  [
                    "set",
                    "@entity.selectedVideoId",
                    "@payload.videoId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "loading-state",
                      "message": "Fetching video details...",
                      "title": "Loading video..."
                    }
                  ],
                  [
                    "call-service",
                    "youtube",
                    "getVideo",
                    {
                      "videoId": "@payload.videoId"
                    },
                    {
                      "emit": {
                        "failure": "ServiceYoutubeYoutubeFailed",
                        "success": "ServiceYoutubeYoutubeCompleted"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.searchStatus",
                    "idle"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "align": "stretch",
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "name": "video",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "YouTube Search",
                              "variant": "h2"
                            }
                          ],
                          "type": "stack",
                          "align": "center"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "Search YouTube videos...",
                          "type": "input"
                        },
                        {
                          "icon": "search",
                          "action": "SEARCH",
                          "variant": "primary",
                          "label": "Search",
                          "type": "button"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "viewingDetail",
                "to": "viewingDetail",
                "event": "VIDEO_LOADED",
                "effects": [
                  [
                    "set",
                    "@entity.videoTitle",
                    "@payload.title"
                  ],
                  [
                    "set",
                    "@entity.videoDescription",
                    "@payload.description"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "align": "stretch",
                      "gap": "lg",
                      "type": "stack",
                      "children": [
                        {
                          "children": [
                            {
                              "name": "video",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "content": "@entity.videoTitle",
                              "type": "typography"
                            }
                          ],
                          "type": "stack",
                          "align": "center",
                          "direction": "horizontal",
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "content": "@entity.videoDescription",
                          "type": "typography",
                          "variant": "body"
                        },
                        {
                          "icon": "arrow-left",
                          "label": "Back to Results",
                          "action": "BACK",
                          "type": "button",
                          "variant": "ghost"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewingDetail",
                "to": "results",
                "event": "BACK",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "stretch",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "name": "video",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Search Results",
                              "variant": "h2"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "body",
                          "type": "typography",
                          "content": "Select a video to view details."
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "icon": "rotate-ccw",
                              "type": "button",
                              "variant": "ghost",
                              "label": "New Search",
                              "action": "RESET"
                            },
                            {
                              "label": "Search Again",
                              "type": "button",
                              "action": "SEARCH",
                              "variant": "ghost",
                              "icon": "search"
                            }
                          ],
                          "justify": "center",
                          "gap": "sm"
                        }
                      ],
                      "direction": "vertical",
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "idle",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.searchStatus",
                    "idle"
                  ],
                  [
                    "set",
                    "@entity.error",
                    ""
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "type": "stack",
                      "align": "stretch",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "align": "center",
                          "children": [
                            {
                              "name": "video",
                              "type": "icon"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "YouTube Search"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "placeholder": "Search YouTube videos...",
                          "type": "input"
                        },
                        {
                          "variant": "primary",
                          "label": "Search",
                          "type": "button",
                          "icon": "search",
                          "action": "SEARCH"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "ServiceYoutubePage",
          "path": "/serviceyoutubes",
          "traits": [
            {
              "ref": "ServiceYoutubeYoutube"
            }
          ]
        }
      ]
    }
  ]
}
