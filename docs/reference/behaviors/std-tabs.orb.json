{
  "name": "std-tabs",
  "version": "2.0.0",
  "description": "std-tabs — embeddable tab-navigation atom. Renders a tabs strip from @config.tabs ([{id, label, icon?, badge?, content?}]); clicking a tab updates @entity.activeTab so only the matching @trait.X content shows. Events remap at the call site for routing, persistence, analytics.",
  "orbitals": [
    {
      "name": "TabsItemOrbital",
      "entity": {
        "name": "TabsItem",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "activeTab",
            "type": "string",
            "default": ""
          },
          {
            "name": "items",
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "properties": {
                "badge": {
                  "name": "badge",
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "type": "string"
                },
                "content": {
                  "name": "content",
                  "type": "trait"
                },
                "id": {
                  "name": "id",
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "type": "string"
                }
              }
            }
          }
        ]
      },
      "traits": [
        {
          "name": "TabsItemTabs",
          "category": "interaction",
          "linkedEntity": "TabsItem",
          "emits": [
            {
              "event": "TAB_CHANGED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "tabId",
                  "type": "string",
                  "required": true
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "TAB_CHANGED",
                "name": "Tab Changed",
                "payloadSchema": [
                  {
                    "name": "tabId",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    [
                      {
                        "label": "Overview",
                        "id": "overview",
                        "icon": "info"
                      },
                      {
                        "id": "details",
                        "icon": "list",
                        "label": "Details"
                      },
                      {
                        "label": "Settings",
                        "icon": "settings",
                        "id": "settings"
                      }
                    ]
                  ],
                  [
                    "set",
                    "@entity.activeTab",
                    "overview"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "activeTab": "@entity.activeTab",
                      "orientation": "horizontal",
                      "tabChangeEvent": "TAB_CHANGED",
                      "items": "@entity.items",
                      "variant": "default",
                      "type": "tabs"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "idle",
                "event": "TAB_CHANGED",
                "effects": [
                  [
                    "set",
                    "@entity.items",
                    [
                      {
                        "label": "Overview",
                        "id": "overview",
                        "icon": "info"
                      },
                      {
                        "id": "details",
                        "icon": "list",
                        "label": "Details"
                      },
                      {
                        "label": "Settings",
                        "icon": "settings",
                        "id": "settings"
                      }
                    ]
                  ],
                  [
                    "set",
                    "@entity.activeTab",
                    "@payload.tabId"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "activeTab": "@entity.activeTab",
                      "type": "tabs",
                      "tabChangeEvent": "TAB_CHANGED",
                      "items": "@entity.items",
                      "variant": "default",
                      "orientation": "horizontal"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "variant": {
              "type": "string",
              "default": "default",
              "values": [
                "default",
                "pills",
                "underline"
              ]
            },
            "orientation": {
              "type": "string",
              "default": "horizontal",
              "values": [
                "horizontal",
                "vertical"
              ]
            },
            "defaultTab": {
              "type": "string",
              "default": "overview"
            },
            "tabs": {
              "type": "[object]",
              "default": [
                {
                  "label": "Overview",
                  "id": "overview",
                  "icon": "info"
                },
                {
                  "id": "details",
                  "icon": "list",
                  "label": "Details"
                },
                {
                  "label": "Settings",
                  "icon": "settings",
                  "id": "settings"
                }
              ]
            }
          },
          "scope": "instance"
        }
      ],
      "pages": [
        {
          "name": "TabsItemTabsPage",
          "path": "/tabsitems",
          "traits": [
            {
              "ref": "TabsItemTabs"
            }
          ]
        }
      ]
    }
  ]
}
