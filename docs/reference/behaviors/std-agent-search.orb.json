{
  "name": "std-agent-search",
  "version": "1.0.0",
  "description": "std-agent-search as a Function",
  "orbitals": [
    {
      "name": "AgentSearchOrbital",
      "entity": {
        "name": "AgentSearch",
        "collection": "agentsearchs",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "active",
            "values": [
              "active",
              "inactive",
              "pending"
            ]
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "query",
            "type": "string",
            "default": ""
          },
          {
            "name": "results",
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "type": "string",
            "default": ""
          },
          {
            "name": "resultCount",
            "type": "number",
            "default": 0
          }
        ]
      },
      "traits": [
        {
          "name": "AgentSearchBrowse",
          "category": "interaction",
          "linkedEntity": "AgentSearch",
          "emits": [
            {
              "event": "SEARCH"
            },
            {
              "event": "CLEAR"
            },
            {
              "event": "AgentSearchLoaded",
              "description": "Fired when AgentSearch finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSearch]"
                }
              ]
            },
            {
              "event": "AgentSearchLoadFailed",
              "description": "Fired when AgentSearch fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEARCHED",
              "triggers": "INIT",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchAgent"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "AgentSearchLoaded",
                "name": "AgentSearch loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSearch]"
                  }
                ]
              },
              {
                "key": "AgentSearchLoadFailed",
                "name": "AgentSearch load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "AgentSearch"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "success": "AgentSearchLoaded",
                        "failure": "AgentSearchLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "align": "center",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "color": "muted",
                          "content": "Loading searches…",
                          "variant": "caption",
                          "type": "typography"
                        }
                      ],
                      "gap": "md",
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "AgentSearchLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "className": "max-w-5xl mx-auto w-full",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "gap": "md",
                          "children": [
                            {
                              "type": "stack",
                              "gap": "sm",
                              "direction": "horizontal",
                              "align": "center",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "search"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "AgentSearch"
                                }
                              ]
                            },
                            {
                              "children": [
                                {
                                  "action": "SEARCH",
                                  "variant": "primary",
                                  "icon": "search",
                                  "label": "Search",
                                  "type": "button"
                                },
                                {
                                  "type": "button",
                                  "action": "CLEAR",
                                  "icon": "x",
                                  "label": "Clear",
                                  "variant": "ghost"
                                }
                              ],
                              "type": "stack",
                              "direction": "horizontal",
                              "gap": "sm"
                            }
                          ],
                          "type": "stack"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "data-grid",
                          "fields": [
                            {
                              "icon": "search",
                              "label": "Query",
                              "variant": "h4",
                              "name": "query"
                            },
                            {
                              "label": "Language",
                              "name": "language",
                              "colorMap": {
                                "failed": "destructive",
                                "draft": "warning",
                                "cancelled": "destructive",
                                "active": "success",
                                "pending": "warning",
                                "completed": "success",
                                "inactive": "neutral",
                                "scheduled": "warning",
                                "archived": "neutral",
                                "done": "success",
                                "disabled": "neutral",
                                "error": "destructive"
                              },
                              "variant": "badge"
                            },
                            {
                              "label": "Result Count",
                              "name": "resultCount",
                              "variant": "caption"
                            }
                          ],
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "label": "View",
                              "variant": "ghost"
                            }
                          ],
                          "entity": "@payload.data"
                        }
                      ],
                      "gap": "lg"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "AgentSearchLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "gap": "md",
                      "children": [
                        {
                          "name": "alert-triangle",
                          "color": "destructive",
                          "type": "icon"
                        },
                        {
                          "type": "typography",
                          "variant": "h3",
                          "content": "Failed to load searches"
                        },
                        {
                          "color": "muted",
                          "variant": "body",
                          "content": "@payload.error",
                          "type": "typography"
                        },
                        {
                          "type": "button",
                          "action": "INIT",
                          "variant": "primary",
                          "label": "Retry",
                          "icon": "rotate-ccw"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "success": "AgentSearchLoaded",
                        "failure": "AgentSearchLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "success": "AgentSearchLoaded",
                        "failure": "AgentSearchLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "scope": "collection"
        },
        {
          "name": "AgentSearchAgent",
          "category": "interaction",
          "linkedEntity": "AgentSearch",
          "emits": [
            {
              "event": "SEARCHED",
              "scope": "external",
              "payloadSchema": [
                {
                  "name": "query",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "resultCount",
                  "type": "number"
                }
              ]
            },
            {
              "event": "AgentSearchLoaded",
              "description": "Fired when AgentSearch finishes loading; payload.data holds the list",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[AgentSearch]"
                }
              ]
            },
            {
              "event": "AgentSearchLoadFailed",
              "description": "Fired when AgentSearch fails to load",
              "scope": "internal",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "listens": [
            {
              "event": "SEARCH",
              "triggers": "SEARCH",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchBrowse"
              }
            },
            {
              "event": "CLEAR",
              "triggers": "CLEAR",
              "source": {
                "kind": "trait",
                "trait": "AgentSearchBrowse"
              }
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "searching"
              },
              {
                "name": "results"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "SEARCH",
                "name": "Search",
                "payloadSchema": [
                  {
                    "name": "query",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "language",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "CLEAR",
                "name": "Clear"
              },
              {
                "key": "SEARCHED",
                "name": "Searched"
              },
              {
                "key": "AgentSearchLoaded",
                "name": "AgentSearch loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[AgentSearch]"
                  }
                ]
              },
              {
                "key": "AgentSearchLoadFailed",
                "name": "AgentSearch load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "success": "AgentSearchLoaded",
                        "failure": "AgentSearchLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "icon": "search",
                      "type": "empty-state",
                      "title": "Code Search",
                      "description": "Code Search is ready"
                    }
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "agent/search-code",
                    "@payload.query",
                    "@payload.language"
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "results",
                "event": "SEARCH",
                "effects": [
                  [
                    "fetch",
                    "AgentSearch",
                    {
                      "emit": {
                        "failure": "AgentSearchLoadFailed",
                        "success": "AgentSearchLoaded"
                      }
                    }
                  ],
                  [
                    "emit",
                    "SEARCHED",
                    {
                      "resultCount": 0,
                      "query": "@payload.query"
                    }
                  ]
                ]
              },
              {
                "from": "results",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "agent/search-code",
                    "@payload.query",
                    "@payload.language"
                  ]
                ]
              },
              {
                "from": "results",
                "to": "idle",
                "event": "CLEAR"
              }
            ]
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "AgentSearchPage",
          "path": "/agentsearchs",
          "traits": [
            {
              "ref": "AgentSearchBrowse"
            },
            {
              "ref": "AgentSearchAgent"
            }
          ]
        }
      ]
    }
  ]
}
