{
  "name": "std-invoice",
  "version": "1.0.0",
  "description": "std-invoice — invoice generation atom. Owns an Invoice entity (line-items + tax + total + refund tiers via config). Browses invoices in a data-grid with Send / Mark-Paid / Void / Refund actions; viewing state renders the canonical invoice pattern detail.",
  "orbitals": [
    {
      "name": "InvoiceOrbital",
      "entity": {
        "name": "InvoiceRecord",
        "collection": "invoices",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "invoiceNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string",
            "default": "draft",
            "values": [
              "draft",
              "sent",
              "paid",
              "overdue",
              "void"
            ]
          },
          {
            "name": "currency",
            "type": "string",
            "default": "USD"
          },
          {
            "name": "subtotal",
            "type": "number",
            "default": 0
          },
          {
            "name": "tax",
            "type": "number",
            "default": 0
          },
          {
            "name": "total",
            "type": "number",
            "default": 0
          },
          {
            "name": "issuedAt",
            "type": "string"
          },
          {
            "name": "dueAt",
            "type": "string"
          },
          {
            "name": "paidAt",
            "type": "string"
          },
          {
            "name": "lineItemsJson",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "InvoiceManage",
          "category": "interaction",
          "linkedEntity": "InvoiceRecord",
          "emits": [
            {
              "event": "VIEW",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "SEND",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "MARK_PAID",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "VOID",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "REFUND",
              "payloadSchema": [
                {
                  "name": "invoiceId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true
                }
              ]
            },
            {
              "event": "InvoiceLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[InvoiceRecord]"
                }
              ]
            },
            {
              "event": "InvoiceLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceUpdated",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceUpdateFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceRefunded",
              "payloadSchema": [
                {
                  "name": "row.id",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.invoiceNumber",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.customerId",
                  "type": "string",
                  "required": true
                },
                {
                  "name": "row.subscriptionId",
                  "type": "string"
                },
                {
                  "name": "row.status",
                  "type": "string"
                },
                {
                  "name": "row.currency",
                  "type": "string"
                },
                {
                  "name": "row.subtotal",
                  "type": "number"
                },
                {
                  "name": "row.tax",
                  "type": "number"
                },
                {
                  "name": "row.total",
                  "type": "number"
                },
                {
                  "name": "row.issuedAt",
                  "type": "string"
                },
                {
                  "name": "row.dueAt",
                  "type": "string"
                },
                {
                  "name": "row.paidAt",
                  "type": "string"
                },
                {
                  "name": "row.lineItemsJson",
                  "type": "string"
                },
                {
                  "name": "row.notes",
                  "type": "string"
                }
              ]
            },
            {
              "event": "InvoiceRefundFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "viewing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "InvoiceLoaded",
                "name": "Invoice loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[InvoiceRecord]"
                  }
                ]
              },
              {
                "key": "InvoiceLoadFailed",
                "name": "Invoice load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "VIEW",
                "name": "View",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "SEND",
                "name": "Send",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "MARK_PAID",
                "name": "Mark Paid",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "VOID",
                "name": "Void",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "REFUND",
                "name": "Refund",
                "payloadSchema": [
                  {
                    "name": "invoiceId",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "amount",
                    "type": "number",
                    "required": true
                  }
                ]
              },
              {
                "key": "InvoiceUpdated",
                "name": "Invoice updated",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "InvoiceUpdateFailed",
                "name": "Invoice update failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "InvoiceRefunded",
                "name": "Invoice refunded",
                "payloadSchema": [
                  {
                    "name": "row",
                    "type": "InvoiceRecord"
                  }
                ]
              },
              {
                "key": "InvoiceRefundFailed",
                "name": "Invoice refund failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "className": "py-12",
                      "children": [
                        {
                          "type": "spinner"
                        },
                        {
                          "type": "typography",
                          "content": "Loading invoices…",
                          "variant": "caption",
                          "color": "muted"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "md",
                      "align": "center"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "InvoiceLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "children": [
                            {
                              "type": "icon",
                              "name": "receipt"
                            },
                            {
                              "variant": "h3",
                              "type": "typography",
                              "content": "Invoices"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "itemActions": [
                            {
                              "event": "VIEW",
                              "variant": "secondary",
                              "label": "View",
                              "icon": "eye"
                            },
                            {
                              "icon": "send",
                              "variant": "primary",
                              "event": "SEND",
                              "label": "Send"
                            },
                            {
                              "event": "MARK_PAID",
                              "icon": "check",
                              "variant": "primary",
                              "label": "Mark Paid"
                            },
                            {
                              "event": "VOID",
                              "label": "Void",
                              "variant": "danger",
                              "icon": "x"
                            },
                            {
                              "icon": "rotate-ccw",
                              "label": "Refund",
                              "event": "REFUND",
                              "variant": "danger"
                            }
                          ],
                          "gap": "sm",
                          "cols": 1,
                          "type": "data-grid",
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "invoiceNumber",
                              "label": "Invoice #",
                              "variant": "caption"
                            },
                            {
                              "variant": "caption",
                              "name": "customerId",
                              "label": "Customer"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            },
                            {
                              "name": "total",
                              "variant": "caption",
                              "label": "Total"
                            },
                            {
                              "variant": "badge",
                              "name": "currency",
                              "label": "Currency"
                            },
                            {
                              "variant": "caption",
                              "label": "Due",
                              "name": "dueAt"
                            }
                          ]
                        }
                      ],
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "InvoiceLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.invoiceNumber",
                    "@payload.row.invoiceNumber"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "@payload.row.status"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "@payload.row.issuedAt"
                  ],
                  [
                    "set",
                    "@entity.dueAt",
                    "@payload.row.dueAt"
                  ],
                  [
                    "set",
                    "@entity.customerId",
                    "@payload.row.customerId"
                  ],
                  [
                    "set",
                    "@entity.currency",
                    "@payload.row.currency"
                  ],
                  [
                    "set",
                    "@entity.notes",
                    "@payload.row.notes"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "name": "receipt",
                              "type": "icon"
                            },
                            {
                              "variant": "h3",
                              "content": "@entity.invoiceNumber",
                              "type": "typography"
                            },
                            {
                              "variant": "secondary",
                              "type": "badge",
                              "label": "@entity.status"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "children": [
                            {
                              "gap": "xs",
                              "children": [
                                {
                                  "color": "muted",
                                  "variant": "caption",
                                  "content": "Issued",
                                  "type": "typography"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.issuedAt",
                                  "variant": "body2"
                                }
                              ],
                              "type": "stack",
                              "direction": "vertical"
                            },
                            {
                              "children": [
                                {
                                  "variant": "caption",
                                  "type": "typography",
                                  "content": "Due",
                                  "color": "muted"
                                },
                                {
                                  "variant": "body2",
                                  "content": "@entity.dueAt",
                                  "type": "typography"
                                }
                              ],
                              "gap": "xs",
                              "direction": "vertical",
                              "type": "stack"
                            },
                            {
                              "type": "stack",
                              "children": [
                                {
                                  "content": "Currency",
                                  "color": "muted",
                                  "type": "typography",
                                  "variant": "caption"
                                },
                                {
                                  "type": "typography",
                                  "content": "@entity.currency",
                                  "variant": "body2"
                                }
                              ],
                              "gap": "xs",
                              "direction": "vertical"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "lg"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "typography",
                          "color": "muted",
                          "variant": "body2",
                          "content": "@entity.notes"
                        },
                        {
                          "children": [
                            {
                              "action": "SEND",
                              "label": "Send",
                              "variant": "primary",
                              "type": "button",
                              "icon": "send"
                            },
                            {
                              "variant": "primary",
                              "icon": "check",
                              "type": "button",
                              "label": "Mark Paid",
                              "action": "MARK_PAID"
                            },
                            {
                              "type": "button",
                              "action": "VOID",
                              "icon": "x",
                              "label": "Void",
                              "variant": "danger"
                            },
                            {
                              "type": "button",
                              "variant": "danger",
                              "icon": "rotate-ccw",
                              "label": "Refund",
                              "action": "REFUND"
                            },
                            {
                              "action": "INIT",
                              "variant": "secondary",
                              "label": "Back",
                              "type": "button",
                              "icon": "arrow-left"
                            }
                          ],
                          "type": "stack",
                          "justify": "end",
                          "direction": "horizontal",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "SEND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "sent"
                  ],
                  [
                    "set",
                    "@entity.issuedAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ],
                  [
                    "call-service",
                    "email",
                    "send",
                    {
                      "invoiceId": "@payload.invoiceId"
                    },
                    {
                      "emit": {
                        "failure": "InvoiceUpdateFailed",
                        "success": "InvoiceUpdated"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_PAID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "paid"
                  ],
                  [
                    "set",
                    "@entity.paidAt",
                    "now"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "VOID",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "set",
                    "@entity.status",
                    "void"
                  ],
                  [
                    "persist",
                    "update",
                    "InvoiceRecord",
                    "@entity",
                    {
                      "emit": {
                        "success": "InvoiceUpdated",
                        "failure": "InvoiceUpdateFailed"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "REFUND",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.invoiceId"
                  ],
                  [
                    "call-service",
                    "stripe",
                    "refund",
                    {
                      "amount": "@payload.amount",
                      "invoiceId": "@payload.invoiceId"
                    },
                    {
                      "emit": {
                        "failure": "InvoiceRefundFailed",
                        "success": "InvoiceRefunded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "InvoiceUpdated",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "InvoiceUpdateFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "loading",
                "event": "InvoiceRefunded",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "InvoiceRefundFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "loading",
                "event": "InvoiceUpdated",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "InvoiceRecord",
                    {
                      "emit": {
                        "failure": "InvoiceLoadFailed",
                        "success": "InvoiceLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner",
                      "size": "sm"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "refundTiersJson": {
              "type": "string",
              "default": "[]"
            },
            "title": {
              "type": "string",
              "default": "Invoices"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "InvoiceManagePage",
          "path": "/invoices/manage",
          "traits": [
            {
              "ref": "InvoiceManage"
            }
          ]
        }
      ]
    }
  ]
}
