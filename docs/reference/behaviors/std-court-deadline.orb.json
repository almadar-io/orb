{
  "name": "std-court-deadline",
  "version": "1.0.0",
  "description": "std-court-deadline — statutory filing deadline tied to a legal matter. Browses deadlines in a data-grid with Complete / Extend row actions.",
  "orbitals": [
    {
      "name": "CourtDeadlineOrbital",
      "entity": {
        "name": "CourtDeadline",
        "collection": "courtdeadlines",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterId",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "deadlineType",
            "type": "string",
            "default": "filing",
            "values": [
              "filing",
              "response",
              "discovery",
              "hearing",
              "trial",
              "other"
            ]
          },
          {
            "name": "dueAt",
            "type": "string",
            "required": true
          },
          {
            "name": "jurisdiction",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "upcoming",
            "values": [
              "upcoming",
              "completed",
              "missed",
              "extended"
            ]
          },
          {
            "name": "reminderSent",
            "type": "boolean",
            "default": false
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CourtDeadlineDocket",
          "category": "interaction",
          "linkedEntity": "CourtDeadline",
          "emits": [
            {
              "event": "MARK_COMPLETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EXTEND_DEADLINE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CourtDeadlineLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CourtDeadline]"
                }
              ]
            },
            {
              "event": "CourtDeadlineLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CourtDeadlineLoaded",
                "name": "CourtDeadline loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CourtDeadline]"
                  }
                ]
              },
              {
                "key": "CourtDeadlineLoadFailed",
                "name": "CourtDeadline load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MARK_COMPLETED",
                "name": "Mark Completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EXTEND_DEADLINE",
                "name": "Extend Deadline",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CourtDeadlineLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "options": [
                            {
                              "label": "This Week",
                              "value": "this-week"
                            },
                            {
                              "value": "this-month",
                              "label": "This Month"
                            },
                            {
                              "label": "This Quarter",
                              "value": "this-quarter"
                            },
                            {
                              "value": "this-year",
                              "label": "This Year"
                            }
                          ],
                          "type": "date-range-selector",
                          "selected": "this-month"
                        },
                        {
                          "type": "timeline",
                          "fields": [
                            "title",
                            "date",
                            "status",
                            "description"
                          ],
                          "title": "Deadline Chronology",
                          "items": [
                            {
                              "title": "Filing",
                              "status": "completed",
                              "description": "Initial filing submitted",
                              "date": "2026-01-15",
                              "id": "filing"
                            },
                            {
                              "date": "2026-02-20",
                              "title": "Response",
                              "id": "response",
                              "status": "current",
                              "description": "Defendant response due"
                            },
                            {
                              "status": "upcoming",
                              "date": "2026-04-10",
                              "description": "Discovery cutoff",
                              "id": "discovery",
                              "title": "Discovery"
                            },
                            {
                              "id": "hearing",
                              "description": "Pretrial hearing",
                              "status": "upcoming",
                              "title": "Hearing",
                              "date": "2026-06-15"
                            },
                            {
                              "id": "trial",
                              "status": "upcoming",
                              "title": "Trial",
                              "date": "2026-09-01",
                              "description": "Trial date"
                            }
                          ]
                        },
                        {
                          "itemActions": [
                            {
                              "label": "Complete",
                              "variant": "primary",
                              "event": "MARK_COMPLETED"
                            },
                            {
                              "variant": "ghost",
                              "event": "EXTEND_DEADLINE",
                              "label": "Extend"
                            }
                          ],
                          "gap": "sm",
                          "cols": 1,
                          "entity": "@payload.data",
                          "fields": [
                            {
                              "name": "title",
                              "label": "Title",
                              "variant": "caption"
                            },
                            {
                              "name": "deadlineType",
                              "label": "Type",
                              "variant": "badge"
                            },
                            {
                              "label": "Due",
                              "variant": "caption",
                              "name": "dueAt"
                            },
                            {
                              "label": "Jurisdiction",
                              "variant": "caption",
                              "name": "jurisdiction"
                            },
                            {
                              "label": "Assigned",
                              "variant": "caption",
                              "name": "assignedTo"
                            },
                            {
                              "name": "status",
                              "variant": "badge",
                              "label": "Status"
                            }
                          ],
                          "type": "data-grid"
                        }
                      ],
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CourtDeadlineLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "@payload.error",
                      "variant": "error",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_COMPLETED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Deadline completed",
                      "type": "alert",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EXTEND_DEADLINE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Deadline extended",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Deadlines"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CourtDeadlinePage",
          "path": "/deadlines",
          "traits": [
            {
              "ref": "CourtDeadlineDocket"
            }
          ]
        }
      ]
    }
  ]
}
