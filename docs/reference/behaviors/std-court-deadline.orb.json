{
  "name": "std-court-deadline",
  "version": "1.0.0",
  "description": "std-court-deadline — statutory filing deadline tied to a legal matter. Browses deadlines in a data-grid with Complete / Extend row actions.",
  "orbitals": [
    {
      "name": "CourtDeadlineOrbital",
      "entity": {
        "name": "CourtDeadline",
        "collection": "courtdeadlines",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "matterId",
            "type": "string",
            "required": true
          },
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "deadlineType",
            "type": "string",
            "default": "filing",
            "values": [
              "filing",
              "response",
              "discovery",
              "hearing",
              "trial",
              "other"
            ]
          },
          {
            "name": "dueAt",
            "type": "string",
            "required": true
          },
          {
            "name": "jurisdiction",
            "type": "string",
            "default": ""
          },
          {
            "name": "assignedTo",
            "type": "string",
            "default": ""
          },
          {
            "name": "status",
            "type": "string",
            "default": "upcoming",
            "values": [
              "upcoming",
              "completed",
              "missed",
              "extended"
            ]
          },
          {
            "name": "reminderSent",
            "type": "boolean",
            "default": false
          },
          {
            "name": "notes",
            "type": "string",
            "default": ""
          }
        ]
      },
      "traits": [
        {
          "name": "CourtDeadlineDocket",
          "category": "interaction",
          "linkedEntity": "CourtDeadline",
          "emits": [
            {
              "event": "MARK_COMPLETED",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "EXTEND_DEADLINE",
              "payloadSchema": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true
                }
              ]
            },
            {
              "event": "CourtDeadlineLoaded",
              "payloadSchema": [
                {
                  "name": "data",
                  "type": "[CourtDeadline]"
                }
              ]
            },
            {
              "event": "CourtDeadlineLoadFailed",
              "payloadSchema": [
                {
                  "name": "error",
                  "type": "string"
                },
                {
                  "name": "code",
                  "type": "string"
                }
              ]
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "loading",
                "isInitial": true
              },
              {
                "name": "browsing"
              },
              {
                "name": "error"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CourtDeadlineLoaded",
                "name": "CourtDeadline loaded",
                "payloadSchema": [
                  {
                    "name": "data",
                    "type": "[CourtDeadline]"
                  }
                ]
              },
              {
                "key": "CourtDeadlineLoadFailed",
                "name": "CourtDeadline load failed",
                "payloadSchema": [
                  {
                    "name": "error",
                    "type": "string"
                  },
                  {
                    "name": "code",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "MARK_COMPLETED",
                "name": "Mark Completed",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              },
              {
                "key": "EXTEND_DEADLINE",
                "name": "Extend Deadline",
                "payloadSchema": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true
                  }
                ]
              }
            ],
            "transitions": [
              {
                "from": "loading",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "failure": "CourtDeadlineLoadFailed",
                        "success": "CourtDeadlineLoaded"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "browsing",
                "event": "CourtDeadlineLoaded",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "cols": 1,
                      "entity": "@payload.data",
                      "itemActions": [
                        {
                          "variant": "primary",
                          "event": "MARK_COMPLETED",
                          "label": "Complete"
                        },
                        {
                          "variant": "ghost",
                          "label": "Extend",
                          "event": "EXTEND_DEADLINE"
                        }
                      ],
                      "gap": "sm",
                      "type": "data-grid",
                      "fields": [
                        {
                          "name": "title",
                          "variant": "caption",
                          "label": "Title"
                        },
                        {
                          "label": "Type",
                          "variant": "badge",
                          "name": "deadlineType"
                        },
                        {
                          "variant": "caption",
                          "name": "dueAt",
                          "label": "Due"
                        },
                        {
                          "name": "jurisdiction",
                          "label": "Jurisdiction",
                          "variant": "caption"
                        },
                        {
                          "variant": "caption",
                          "label": "Assigned",
                          "name": "assignedTo"
                        },
                        {
                          "name": "status",
                          "variant": "badge",
                          "label": "Status"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "loading",
                "to": "error",
                "event": "CourtDeadlineLoadFailed",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "error",
                      "message": "@payload.error"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "MARK_COMPLETED",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "alert",
                      "variant": "success",
                      "message": "Deadline completed"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "EXTEND_DEADLINE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "message": "Deadline extended",
                      "variant": "info",
                      "type": "alert"
                    }
                  ]
                ]
              },
              {
                "from": "error",
                "to": "loading",
                "event": "INIT",
                "effects": [
                  [
                    "fetch",
                    "CourtDeadline",
                    {
                      "emit": {
                        "success": "CourtDeadlineLoaded",
                        "failure": "CourtDeadlineLoadFailed"
                      }
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "spinner"
                    }
                  ]
                ]
              }
            ]
          },
          "config": {
            "title": {
              "type": "string",
              "default": "Deadlines"
            }
          },
          "scope": "collection"
        }
      ],
      "pages": [
        {
          "name": "CourtDeadlinePage",
          "path": "/deadlines",
          "traits": [
            {
              "ref": "CourtDeadlineDocket"
            }
          ]
        }
      ]
    }
  ]
}
