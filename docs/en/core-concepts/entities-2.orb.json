{
  "name": "CounterApp",
  "version": "1.0.0",
  "description": "Counter — minimal entity with set-based state mutations and a guard",
  "orbitals": [
    {
      "name": "CounterUnit",
      "entity": {
        "name": "Counter",
        "persistence": "runtime",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "count",
            "type": "number",
            "default": 0.0
          },
          {
            "name": "label",
            "type": "string",
            "default": "Counter"
          }
        ]
      },
      "traits": [
        {
          "name": "CounterTrait",
          "category": "interaction",
          "linkedEntity": "Counter",
          "stateMachine": {
            "states": [
              {
                "name": "Counting",
                "isInitial": true
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "INCREMENT",
                "name": "Increment"
              },
              {
                "key": "DECREMENT",
                "name": "Decrement"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "Counting",
                "to": "Counting",
                "event": "INIT",
                "effects": [
                  [
                    "set",
                    "@entity.count",
                    0.0
                  ],
                  [
                    "set",
                    "@entity.label",
                    "Counter"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "@entity.label"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.count",
                          "variant": "h1"
                        },
                        {
                          "children": [
                            {
                              "label": "+1",
                              "variant": "primary",
                              "action": "INCREMENT",
                              "type": "button",
                              "icon": "plus"
                            },
                            {
                              "action": "DECREMENT",
                              "variant": "secondary",
                              "type": "button",
                              "icon": "minus",
                              "label": "-1"
                            },
                            {
                              "action": "RESET",
                              "type": "button",
                              "variant": "ghost",
                              "label": "Reset",
                              "icon": "rotate-ccw"
                            }
                          ],
                          "direction": "horizontal",
                          "type": "stack",
                          "gap": "md"
                        }
                      ],
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg",
                      "className": "py-12",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "Counting",
                "to": "Counting",
                "event": "INCREMENT",
                "effects": [
                  [
                    "set",
                    "@entity.count",
                    [
                      "+",
                      "@entity.count",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "type": "stack",
                      "className": "py-12",
                      "direction": "vertical",
                      "align": "center",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@entity.label",
                          "variant": "h2"
                        },
                        {
                          "variant": "h1",
                          "content": "@entity.count",
                          "type": "typography"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "children": [
                            {
                              "label": "+1",
                              "action": "INCREMENT",
                              "type": "button",
                              "icon": "plus",
                              "variant": "primary"
                            },
                            {
                              "action": "DECREMENT",
                              "type": "button",
                              "label": "-1",
                              "variant": "secondary",
                              "icon": "minus"
                            },
                            {
                              "action": "RESET",
                              "variant": "ghost",
                              "icon": "rotate-ccw",
                              "label": "Reset",
                              "type": "button"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "Counting",
                "to": "Counting",
                "event": "DECREMENT",
                "guard": [
                  ">",
                  "@entity.count",
                  0.0
                ],
                "effects": [
                  [
                    "set",
                    "@entity.count",
                    [
                      "-",
                      "@entity.count",
                      1.0
                    ]
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "direction": "vertical",
                      "align": "center",
                      "className": "py-12",
                      "type": "stack",
                      "children": [
                        {
                          "type": "typography",
                          "content": "@entity.label",
                          "variant": "h2"
                        },
                        {
                          "type": "typography",
                          "content": "@entity.count",
                          "variant": "h1"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "children": [
                            {
                              "label": "+1",
                              "icon": "plus",
                              "action": "INCREMENT",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "icon": "minus",
                              "action": "DECREMENT",
                              "type": "button",
                              "variant": "secondary",
                              "label": "-1"
                            },
                            {
                              "icon": "rotate-ccw",
                              "type": "button",
                              "label": "Reset",
                              "variant": "ghost",
                              "action": "RESET"
                            }
                          ],
                          "gap": "md"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "Counting",
                "to": "Counting",
                "event": "RESET",
                "effects": [
                  [
                    "set",
                    "@entity.count",
                    0.0
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "@entity.label"
                        },
                        {
                          "type": "typography",
                          "variant": "h1",
                          "content": "@entity.count"
                        },
                        {
                          "type": "stack",
                          "children": [
                            {
                              "icon": "plus",
                              "action": "INCREMENT",
                              "label": "+1",
                              "type": "button",
                              "variant": "primary"
                            },
                            {
                              "icon": "minus",
                              "type": "button",
                              "label": "-1",
                              "action": "DECREMENT",
                              "variant": "secondary"
                            },
                            {
                              "icon": "rotate-ccw",
                              "variant": "ghost",
                              "action": "RESET",
                              "label": "Reset",
                              "type": "button"
                            }
                          ],
                          "direction": "horizontal",
                          "gap": "md"
                        }
                      ],
                      "className": "py-12",
                      "align": "center",
                      "type": "stack"
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "CounterPage",
          "path": "/counter",
          "traits": [
            {
              "ref": "CounterTrait"
            }
          ]
        }
      ]
    }
  ]
}
