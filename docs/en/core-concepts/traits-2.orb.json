{
  "name": "CartItemOrbital",
  "orbitals": [
    {
      "name": "CartItemOrbital",
      "entity": {
        "name": "CartItem",
        "collection": "cartitems",
        "persistence": "persistent",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "string"
          },
          {
            "name": "pendingId",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "CartItemCartBrowse",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "checkout"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "PROCEED_CHECKOUT"
              },
              {
                "key": "BACK_TO_CART"
              },
              {
                "key": "CONFIRM_ORDER"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "CartItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "gap": "lg",
                      "children": [
                        {
                          "direction": "horizontal",
                          "justify": "space-between",
                          "type": "stack",
                          "children": [
                            {
                              "direction": "horizontal",
                              "children": [
                                {
                                  "name": "shopping-cart",
                                  "size": "lg",
                                  "type": "icon"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "content": "Shopping Cart"
                                }
                              ],
                              "gap": "md",
                              "type": "stack"
                            },
                            {
                              "event": "ADD_ITEM",
                              "label": "Add Item",
                              "icon": "plus",
                              "type": "button",
                              "variant": "primary"
                            }
                          ],
                          "gap": "md"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "type": "simple-grid",
                          "children": [
                            {
                              "label": "Items",
                              "type": "stat-display",
                              "value": [
                                "array/len",
                                "@entity"
                              ],
                              "icon": "package"
                            },
                            {
                              "value": [
                                "array/len",
                                "@entity"
                              ],
                              "icon": "dollar-sign",
                              "type": "stat-display",
                              "label": "Subtotal"
                            },
                            {
                              "type": "stat-display",
                              "value": [
                                "array/len",
                                "@entity"
                              ],
                              "icon": "receipt",
                              "label": "Total"
                            }
                          ],
                          "columns": 3.0
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "entity": "CartItem",
                          "emptyTitle": "Your cart is empty",
                          "columns": [
                            {
                              "icon": "shopping-cart",
                              "label": "Name",
                              "variant": "h4",
                              "name": "name"
                            },
                            {
                              "name": "description",
                              "label": "Description",
                              "format": "currency",
                              "variant": "caption"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "emptyDescription": "Add items to get started.",
                          "itemActions": [
                            {
                              "label": "Remove",
                              "variant": "danger",
                              "size": "sm",
                              "event": "REQUEST_REMOVE"
                            }
                          ]
                        },
                        {
                          "type": "button",
                          "event": "PROCEED_CHECKOUT",
                          "label": "Proceed to Checkout",
                          "variant": "primary",
                          "icon": "arrow-right"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "checkout",
                "event": "PROCEED_CHECKOUT",
                "effects": [
                  [
                    "ref",
                    "CartItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "size": "lg",
                              "name": "clipboard"
                            },
                            {
                              "variant": "h2",
                              "type": "typography",
                              "content": "Checkout"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "emptyIcon": "inbox",
                          "type": "data-grid",
                          "emptyTitle": "Your cart is empty",
                          "emptyDescription": "Add items to get started.",
                          "itemActions": [
                            {
                              "size": "sm",
                              "event": "REQUEST_REMOVE",
                              "variant": "danger",
                              "label": "Remove"
                            }
                          ],
                          "columns": [
                            {
                              "label": "Name",
                              "variant": "h4",
                              "name": "name",
                              "icon": "shopping-cart"
                            },
                            {
                              "label": "Description",
                              "format": "currency",
                              "variant": "caption",
                              "name": "description"
                            },
                            {
                              "label": "Status",
                              "variant": "badge",
                              "name": "status"
                            }
                          ],
                          "entity": "CartItem"
                        },
                        {
                          "direction": "horizontal",
                          "gap": "sm",
                          "justify": "end",
                          "type": "stack",
                          "children": [
                            {
                              "label": "Back to Cart",
                              "variant": "ghost",
                              "event": "BACK_TO_CART",
                              "type": "button",
                              "icon": "arrow-left"
                            },
                            {
                              "label": "Confirm Order",
                              "event": "CONFIRM_ORDER",
                              "type": "button",
                              "variant": "primary",
                              "icon": "check"
                            }
                          ]
                        }
                      ],
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "checkout",
                "to": "browsing",
                "event": "BACK_TO_CART",
                "effects": [
                  [
                    "ref",
                    "CartItem"
                  ]
                ]
              },
              {
                "from": "checkout",
                "to": "browsing",
                "event": "CONFIRM_ORDER",
                "effects": [
                  [
                    "ref",
                    "CartItem"
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "children": [
                        {
                          "size": "lg",
                          "type": "icon",
                          "name": "check-circle"
                        },
                        {
                          "variant": "h2",
                          "type": "typography",
                          "content": "Order Confirmed"
                        },
                        {
                          "type": "typography",
                          "content": "Your order has been placed successfully.",
                          "variant": "body"
                        },
                        {
                          "variant": "primary",
                          "label": "Continue Shopping",
                          "type": "button",
                          "event": "INIT"
                        }
                      ],
                      "type": "stack",
                      "direction": "vertical",
                      "align": "center",
                      "gap": "lg"
                    }
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "CartItemAddItem",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "stateMachine": {
            "states": [
              {
                "name": "closed",
                "isInitial": true
              },
              {
                "name": "open"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "ADD_ITEM"
              },
              {
                "key": "CLOSE"
              },
              {
                "key": "SAVE"
              }
            ],
            "transitions": [
              {
                "from": "closed",
                "to": "closed",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "CartItem"
                  ]
                ]
              },
              {
                "from": "closed",
                "to": "open",
                "event": "ADD_ITEM",
                "effects": [
                  [
                    "fetch",
                    "CartItem"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "direction": "vertical",
                      "gap": "md",
                      "type": "stack",
                      "children": [
                        {
                          "gap": "sm",
                          "children": [
                            {
                              "type": "icon",
                              "name": "plus-circle",
                              "size": "md"
                            },
                            {
                              "type": "typography",
                              "content": "Add Item",
                              "variant": "h3"
                            }
                          ],
                          "type": "stack",
                          "direction": "horizontal"
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "mode": "create",
                          "entity": "CartItem",
                          "cancelEvent": "CLOSE",
                          "type": "form-section",
                          "fields": [
                            "name",
                            "description",
                            "status"
                          ],
                          "submitEvent": "SAVE"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "Cancelled",
                    "info"
                  ]
                ]
              },
              {
                "from": "open",
                "to": "closed",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "CartItem",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "notify",
                    "CartItem created successfully"
                  ]
                ]
              }
            ]
          }
        },
        {
          "name": "CartItemRemoveConfirm",
          "category": "interaction",
          "linkedEntity": "CartItem",
          "stateMachine": {
            "states": [
              {
                "name": "idle",
                "isInitial": true
              },
              {
                "name": "confirming"
              }
            ],
            "events": [
              {
                "key": "INIT"
              },
              {
                "key": "REQUEST_REMOVE"
              },
              {
                "key": "CONFIRM_REMOVE"
              },
              {
                "key": "CANCEL"
              },
              {
                "key": "CLOSE"
              }
            ],
            "transitions": [
              {
                "from": "idle",
                "to": "idle",
                "event": "INIT",
                "effects": [
                  [
                    "ref",
                    "CartItem"
                  ]
                ]
              },
              {
                "from": "idle",
                "to": "confirming",
                "event": "REQUEST_REMOVE",
                "effects": [
                  [
                    "set",
                    "@entity.pendingId",
                    "@payload.id"
                  ],
                  [
                    "fetch",
                    "CartItem",
                    {
                      "id": "@payload.id"
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "children": [
                        {
                          "align": "center",
                          "gap": "sm",
                          "direction": "horizontal",
                          "type": "stack",
                          "children": [
                            {
                              "name": "alert-triangle",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "type": "typography",
                              "content": "Remove Item",
                              "variant": "h3"
                            }
                          ]
                        },
                        {
                          "type": "divider"
                        },
                        {
                          "variant": "danger",
                          "type": "alert",
                          "message": "Are you sure you want to remove this item from your cart?"
                        },
                        {
                          "direction": "horizontal",
                          "children": [
                            {
                              "type": "button",
                              "event": "CANCEL",
                              "label": "Cancel",
                              "variant": "ghost"
                            },
                            {
                              "variant": "danger",
                              "icon": "check",
                              "type": "button",
                              "event": "CONFIRM_REMOVE",
                              "label": "Remove"
                            }
                          ],
                          "type": "stack",
                          "justify": "end",
                          "gap": "sm"
                        }
                      ],
                      "gap": "md",
                      "direction": "vertical",
                      "type": "stack"
                    }
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CONFIRM_REMOVE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "CartItem",
                    "@entity.pendingId"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "CartItem"
                  ],
                  [
                    "notify",
                    "CartItem deleted successfully"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "CartItem"
                  ]
                ]
              },
              {
                "from": "confirming",
                "to": "idle",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "ref",
                    "CartItem"
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "Cart",
          "path": "/cart",
          "traits": [
            {
              "ref": "CartItemCartBrowse"
            },
            {
              "ref": "CartItemAddItem"
            },
            {
              "ref": "CartItemRemoveConfirm"
            }
          ]
        }
      ]
    }
  ]
}
